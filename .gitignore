# --- Large / externally-hosted data: lives on Zenodo, NOT in git ---
# (download_data.sh fetches these; see DATASET_LICENSES.md)

# WebQSP: RDF graph (5.7 GB) + PostgreSQL dump (5.2 GB) -> Zenodo
datasets/webqsp/graph/*.nt.gz
datasets/webqsp/graph/*.nt
datasets/webqsp/data/*.dump

# All bundled dataset data archives -> Zenodo (open ones) / source (restricted)
datasets/*/data.zip
datasets/*/data/            # unzipped data (created at load time)

# Materialized RDF output (regenerated by materialize_all.sh)
datasets/*/materialized/

# --- Runtime / scratch ---
setup/.ontop/
**/__pycache__/
*.pyc
