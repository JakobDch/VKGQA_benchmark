  rr:predicateObjectMap [ rr:predicate p:model ; rr:objectMap [ rr:column "model_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_agricultural_machinery_stores_brands_3_Stores_Machines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"store_id\", \"machine_id\" FROM \"Stores_Machines\"""" ] ;
