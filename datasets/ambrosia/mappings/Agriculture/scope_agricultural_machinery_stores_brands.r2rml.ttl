@prefix : <http://ambrosia.example.org/agriculture#> .
@prefix p: <http://ambrosia.example.org/agriculture/prop#> .
@prefix ex: <http://ambrosia.example.org/agriculture/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_agricultural_machinery_stores_brands_0_Brands_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"brand_name\" FROM \"Brands\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Brands/{id}" ; rr:class :Brands ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "brand_name" ] ] .

<#tm_scope_agricultural_machinery_stores_brands_1_Agricultural_Machinery_Stores_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"store_id\", \"store_name\", \"location\" FROM \"Agricultural_Machinery_Stores\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Agricultural_Machinery_Stores/{store_id}" ; rr:class :Agricultural_Machinery_Stores ] ;
  rr:predicateObjectMap [ rr:predicate p:store_id ; rr:objectMap [ rr:column "store_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "store_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_agricultural_machinery_stores_brands_2_Machines_base> a rr:TriplesMap ;
