<#tm_scope_agricultural_machinery_stores_brands_4_Stores_Machines_machine_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"machine_id\" FROM \"Stores_Machines\" WHERE \"machine_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Stores_Machines/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMachines ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Machines/{machine_id}" ; rr:termType rr:IRI ] ] .

