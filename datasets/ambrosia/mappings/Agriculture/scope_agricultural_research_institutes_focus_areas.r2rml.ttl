@prefix : <http://ambrosia.example.org/agriculture#> .
@prefix p: <http://ambrosia.example.org/agriculture/prop#> .
@prefix ex: <http://ambrosia.example.org/agriculture/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_agricultural_research_institutes_focus_areas_0_Agricultural_Research_Institutes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Agricultural_Research_Institutes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Agricultural_Research_Institutes/{id}" ; rr:class :Agricultural_Research_Institutes ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_agricultural_research_institutes_focus_areas_1_Focus_Areas_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"area_name\" FROM \"Focus_Areas\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Focus_Areas/{id}" ; rr:class :Focus_Areas ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "area_name" ] ] .

<#tm_scope_agricultural_research_institutes_focus_areas_2_Agricultural_Research_Institutes_Focus_Areas_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"institute_id\", \"focus_area_id\" FROM \"Agricultural_Research_Institutes_Focus_Areas\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Agricultural_Research_Institutes_Focus_Areas/{institute_id}/{focus_area_id}" ; rr:class :Agricultural_Research_Institutes_Focus_Areas ] ;
  rr:predicateObjectMap [ rr:predicate p:institute_id ; rr:objectMap [ rr:column "institute_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:focus_area_id ; rr:objectMap [ rr:column "focus_area_id" ] ] .

<#tm_scope_agricultural_research_institutes_focus_areas_3_Agricultural_Research_Institutes_Focus_Areas_focus_area_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"institute_id\", \"focus_area_id\" FROM \"Agricultural_Research_Institutes_Focus_Areas\" WHERE \"focus_area_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Agricultural_Research_Institutes_Focus_Areas/{institute_id}/{focus_area_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFocus_Areas ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Focus_Areas/{focus_area_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_agricultural_research_institutes_focus_areas_4_Agricultural_Research_Institutes_Focus_Areas_institute_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"institute_id\", \"focus_area_id\" FROM \"Agricultural_Research_Institutes_Focus_Areas\" WHERE \"institute_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Agricultural_Research_Institutes_Focus_Areas/{institute_id}/{focus_area_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAgricultural_Research_Institutes ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Agricultural_Research_Institutes/{institute_id}" ; rr:termType rr:IRI ] ] .

