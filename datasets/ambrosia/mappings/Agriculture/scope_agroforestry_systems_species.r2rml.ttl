  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\", \"email\" FROM \"Farmers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farmer/{id}" ; rr:class :Farmer ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_agroforestry_systems_species_4_Works_On_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"farmer_id\", \"farm_id\" FROM \"Works_On\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Works_On/{farmer_id}/{farm_id}" ; rr:class :Works_On ] ;
  rr:predicateObjectMap [ rr:predicate p:farmer_id ; rr:objectMap [ rr:column "farmer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:farm_id ; rr:objectMap [ rr:column "farm_id" ] ] .

<#tm_scope_agroforestry_systems_species_5_Works_On_farm_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"farmer_id\", \"farm_id\" FROM \"Works_On\" WHERE \"farm_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Works_On/{farmer_id}/{farm_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFarm ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farm/{farm_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_agroforestry_systems_species_6_Works_On_farmer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"farmer_id\", \"farm_id\" FROM \"Works_On\" WHERE \"farmer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Works_On/{farmer_id}/{farm_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFarmer ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farmer/{farmer_id}" ; rr:termType rr:IRI ] ] .

