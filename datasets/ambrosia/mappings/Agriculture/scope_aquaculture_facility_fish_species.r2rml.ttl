@prefix : <http://ambrosia.example.org/agriculture#> .
@prefix p: <http://ambrosia.example.org/agriculture/prop#> .
@prefix ex: <http://ambrosia.example.org/agriculture/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_aquaculture_facility_fish_species_0_Aquaculture_Facility_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Aquaculture_Facility\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Aquaculture_Facility/{id}" ; rr:class :Aquaculture_Facility ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_aquaculture_facility_fish_species_1_Fish_Species_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"species_name\" FROM \"Fish_Species\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Species/{id}" ; rr:class :Species ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "species_name" ] ] .

<#tm_scope_aquaculture_facility_fish_species_2_Aquaculture_Facility_Fish_Species_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"aquaculture_facility_id\", \"fish_species_id\" FROM \"Aquaculture_Facility_Fish_Species\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Aquaculture_Facility_Fish_Species/{aquaculture_facility_id}/{fish_species_id}" ; rr:class :Aquaculture_Facility_Fish_Species ] ;
  rr:predicateObjectMap [ rr:predicate p:aquaculture_facility_id ; rr:objectMap [ rr:column "aquaculture_facility_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fish_species_id ; rr:objectMap [ rr:column "fish_species_id" ] ] .

<#tm_scope_aquaculture_facility_fish_species_3_Aquaculture_Facility_Fish_Species_fish_species_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"aquaculture_facility_id\", \"fish_species_id\" FROM \"Aquaculture_Facility_Fish_Species\" WHERE \"fish_species_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Aquaculture_Facility_Fish_Species/{aquaculture_facility_id}/{fish_species_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSpecies ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Species/{fish_species_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_aquaculture_facility_fish_species_4_Aquaculture_Facility_Fish_Species_aquaculture_facility_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"aquaculture_facility_id\", \"fish_species_id\" FROM \"Aquaculture_Facility_Fish_Species\" WHERE \"aquaculture_facility_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Aquaculture_Facility_Fish_Species/{aquaculture_facility_id}/{fish_species_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAquaculture_Facility ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Aquaculture_Facility/{aquaculture_facility_id}" ; rr:termType rr:IRI ] ] .

