@prefix : <http://ambrosia.example.org/agriculture#> .
@prefix p: <http://ambrosia.example.org/agriculture/prop#> .
@prefix ex: <http://ambrosia.example.org/agriculture/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_coffee_plantations_processing_techniques_0_Coffee_Plantations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"plantation_id\", \"name\", \"location\" FROM \"Coffee_Plantations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Coffee_Plantations/{plantation_id}" ; rr:class :Coffee_Plantations ] ;
  rr:predicateObjectMap [ rr:predicate p:plantation_id ; rr:objectMap [ rr:column "plantation_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_coffee_plantations_processing_techniques_1_Processing_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"technique_id\", \"technique_name\" FROM \"Processing_Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Processing_Techniques/{technique_id}" ; rr:class :Processing_Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_id ; rr:objectMap [ rr:column "technique_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "technique_name" ] ] .

<#tm_scope_coffee_plantations_processing_techniques_2_Coffee_Plantations_Processing_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"coffee_plantation_id\", \"processing_technique_id\" FROM \"Coffee_Plantations_Processing_Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Coffee_Plantations_Processing_Techniques/{id}" ; rr:class :Coffee_Plantations_Processing_Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:coffee_plantation_id ; rr:objectMap [ rr:column "coffee_plantation_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:processing_technique_id ; rr:objectMap [ rr:column "processing_technique_id" ] ] .

<#tm_scope_coffee_plantations_processing_techniques_3_Coffee_Plantations_Processing_Techniques_processing_technique_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"processing_technique_id\" FROM \"Coffee_Plantations_Processing_Techniques\" WHERE \"processing_technique_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Coffee_Plantations_Processing_Techniques/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProcessing_Techniques ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Processing_Techniques/{processing_technique_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_coffee_plantations_processing_techniques_4_Coffee_Plantations_Processing_Techniques_coffee_plantation_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"coffee_plantation_id\" FROM \"Coffee_Plantations_Processing_Techniques\" WHERE \"coffee_plantation_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Coffee_Plantations_Processing_Techniques/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCoffee_Plantations ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Coffee_Plantations/{coffee_plantation_id}" ; rr:termType rr:IRI ] ] .

