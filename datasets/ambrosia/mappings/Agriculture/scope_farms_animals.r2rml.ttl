  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:harvestDate ; rr:objectMap [ rr:column "HarvestDate" ] ] .

<#tm_scope_farms_animals_3_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EquipID\", \"Model\", \"PurchaseDate\" FROM \"Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Equipment/{EquipID}" ; rr:class :Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:EquipID ; rr:objectMap [ rr:column "EquipID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:model ; rr:objectMap [ rr:column "Model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PurchaseDate ; rr:objectMap [ rr:column "PurchaseDate" ] ] .

<#tm_scope_farms_animals_4_Farms_Animals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FarmID\", \"AnimalID\" FROM \"Farms_Animals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farms_Animals/{FarmID}/{AnimalID}" ; rr:class :Farms_Animals ] ;
  rr:predicateObjectMap [ rr:predicate p:FarmID ; rr:objectMap [ rr:column "FarmID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AnimalID ; rr:objectMap [ rr:column "AnimalID" ] ] .

<#tm_scope_farms_animals_5_Farms_Animals_AnimalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FarmID\", \"AnimalID\" FROM \"Farms_Animals\" WHERE \"AnimalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farms_Animals/{FarmID}/{AnimalID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAnimals ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Animals/{AnimalID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_farms_animals_6_Farms_Animals_FarmID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FarmID\", \"AnimalID\" FROM \"Farms_Animals\" WHERE \"FarmID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farms_Animals/{FarmID}/{AnimalID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFarm ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farm/{FarmID}" ; rr:termType rr:IRI ] ] .

