@prefix : <http://ambrosia.example.org/agriculture#> .
@prefix p: <http://ambrosia.example.org/agriculture/prop#> .
@prefix ex: <http://ambrosia.example.org/agriculture/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_farms_animals_0_Farms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FarmID\", \"Name\", \"Location\" FROM \"Farms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farm/{FarmID}" ; rr:class :Farm ] ;
  rr:predicateObjectMap [ rr:predicate p:FarmID ; rr:objectMap [ rr:column "FarmID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_scope_farms_animals_1_Animals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AnimalID\", \"Type\", \"Quantity\" FROM \"Animals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Animals/{AnimalID}" ; rr:class :Animals ] ;
  rr:predicateObjectMap [ rr:predicate p:AnimalID ; rr:objectMap [ rr:column "AnimalID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "Quantity" ] ] .

