@prefix : <http://ambrosia.example.org/agriculture#> .
@prefix p: <http://ambrosia.example.org/agriculture/prop#> .
@prefix ex: <http://ambrosia.example.org/agriculture/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_fertilizers_components_0_Fertilizers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"quantity\" FROM \"Fertilizers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Fertilizers/{id}" ; rr:class :Fertilizers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "quantity" ] ] .

<#tm_scope_fertilizers_components_1_Components_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"componentName\" FROM \"Components\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Components/{id}" ; rr:class :Components ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "componentName" ] ] .

<#tm_scope_fertilizers_components_2_FarmerInfo_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"farmerName\", \"farmLocation\" FROM \"FarmerInfo\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farmer/{id}" ; rr:class :Farmer ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "farmerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "farmLocation" ] ] .

<#tm_scope_fertilizers_components_3_Crops_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"cropName\", \"yield\" FROM \"Crops\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Crop/{id}" ; rr:class :Crop ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "cropName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:yieldPerAcre ; rr:objectMap [ rr:column "yield" ] ] .

<#tm_scope_fertilizers_components_4_Farmers_Crops_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"farmerId\", \"cropId\" FROM \"Farmers_Crops\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farmers_Crops/{_amb_rowid}" ; rr:class :Farmers_Crops ] ;
  rr:predicateObjectMap [ rr:predicate p:farmerId ; rr:objectMap [ rr:column "farmerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cropId ; rr:objectMap [ rr:column "cropId" ] ] .

<#tm_scope_fertilizers_components_5_Farmers_Crops_cropId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"cropId\" FROM \"Farmers_Crops\" WHERE \"cropId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farmers_Crops/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCrop ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Crop/{cropId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_fertilizers_components_6_Farmers_Crops_farmerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"farmerId\" FROM \"Farmers_Crops\" WHERE \"farmerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farmers_Crops/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFarmer ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Farmer/{farmerId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_fertilizers_components_7_Fertilizers_Components_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"fertilizerId\", \"componentId\" FROM \"Fertilizers_Components\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Fertilizers_Components/{_amb_rowid}" ; rr:class :Fertilizers_Components ] ;
  rr:predicateObjectMap [ rr:predicate p:fertilizerId ; rr:objectMap [ rr:column "fertilizerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:componentId ; rr:objectMap [ rr:column "componentId" ] ] .

<#tm_scope_fertilizers_components_8_Fertilizers_Components_componentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"componentId\" FROM \"Fertilizers_Components\" WHERE \"componentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Fertilizers_Components/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasComponents ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Components/{componentId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_fertilizers_components_9_Fertilizers_Components_fertilizerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"fertilizerId\" FROM \"Fertilizers_Components\" WHERE \"fertilizerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Fertilizers_Components/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFertilizers ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Fertilizers/{fertilizerId}" ; rr:termType rr:IRI ] ] .

