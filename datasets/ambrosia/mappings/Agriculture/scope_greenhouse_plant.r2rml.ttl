@prefix : <http://ambrosia.example.org/agriculture#> .
@prefix p: <http://ambrosia.example.org/agriculture/prop#> .
@prefix ex: <http://ambrosia.example.org/agriculture/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_greenhouse_plant_0_Greenhouse_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Greenhouse\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Greenhouse/{id}" ; rr:class :Greenhouse ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_greenhouse_plant_1_Plant_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"type\" FROM \"Plant\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Plant/{id}" ; rr:class :Plant ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_scope_greenhouse_plant_2_Greenhouse_Plant_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"greenhouse_id\", \"plant_id\", \"quantity\" FROM \"Greenhouse_Plant\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Greenhouse_Plant/{greenhouse_id}/{plant_id}" ; rr:class :Greenhouse_Plant ] ;
  rr:predicateObjectMap [ rr:predicate p:greenhouse_id ; rr:objectMap [ rr:column "greenhouse_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:plant_id ; rr:objectMap [ rr:column "plant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "quantity" ] ] .

<#tm_scope_greenhouse_plant_3_Greenhouse_Plant_plant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"greenhouse_id\", \"plant_id\" FROM \"Greenhouse_Plant\" WHERE \"plant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Greenhouse_Plant/{greenhouse_id}/{plant_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPlant ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Plant/{plant_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_greenhouse_plant_4_Greenhouse_Plant_greenhouse_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"greenhouse_id\", \"plant_id\" FROM \"Greenhouse_Plant\" WHERE \"greenhouse_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Greenhouse_Plant/{greenhouse_id}/{plant_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGreenhouse ; rr:objectMap [ rr:template "http://ambrosia.example.org/agriculture/id/Greenhouse/{greenhouse_id}" ; rr:termType rr:IRI ] ] .

