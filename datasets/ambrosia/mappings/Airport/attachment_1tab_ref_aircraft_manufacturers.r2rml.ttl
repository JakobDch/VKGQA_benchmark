@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_aircraft_manufacturers_0_airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_aircraft_manufacturers_1_flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"from_airport_id\", \"to_airport_id\" FROM \"flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:from_airport_id ; rr:objectMap [ rr:column "from_airport_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:to_airport_id ; rr:objectMap [ rr:column "to_airport_id" ] ] .

<#tm_attachment_1tab_ref_aircraft_manufacturers_2_flights_to_airport_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"to_airport_id\" FROM \"flights\" WHERE \"to_airport_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_to_airport_id ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{to_airport_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_aircraft_manufacturers_3_flights_from_airport_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"from_airport_id\" FROM \"flights\" WHERE \"from_airport_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_from_airport_id ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{from_airport_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_aircraft_manufacturers_4_manufacturers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"manufacturers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/manufacturers/{id}" ; rr:class :manufacturers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_aircraft_manufacturers_5_plane_details_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"plane_id\", \"manufacturer_id\" FROM \"plane_details\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/plane_details/{_amb_rowid}" ; rr:class :plane_details ] ;
  rr:predicateObjectMap [ rr:predicate p:plane_id ; rr:objectMap [ rr:column "plane_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:manufacturer_id ; rr:objectMap [ rr:column "manufacturer_id" ] ] .

<#tm_attachment_1tab_ref_aircraft_manufacturers_6_plane_details_manufacturer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"manufacturer_id\" FROM \"plane_details\" WHERE \"manufacturer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/plane_details/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasmanufacturers ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/manufacturers/{manufacturer_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_aircraft_manufacturers_7_plane_details_plane_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"plane_id\" FROM \"plane_details\" WHERE \"plane_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/plane_details/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPlanes ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{plane_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_aircraft_manufacturers_8_planes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"model\", \"number_of_seats\" FROM \"planes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{id}" ; rr:class :Planes ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:model ; rr:objectMap [ rr:column "model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number_of_seats ; rr:objectMap [ rr:column "number_of_seats" ] ] .

