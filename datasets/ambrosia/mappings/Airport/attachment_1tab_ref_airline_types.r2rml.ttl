<#tm_attachment_1tab_ref_airline_types_9_Assignments_pilot_license_number_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignment_id\", \"pilot_license_number\" FROM \"Assignments\" WHERE \"pilot_license_number\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Assignments/{assignment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPilots ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Pilots/{pilot_license_number}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_airline_types_10_Assignments_flight_number_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignment_id\", \"flight_number\" FROM \"Assignments\" WHERE \"flight_number\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Assignments/{assignment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flight_number}" ; rr:termType rr:IRI ] ] .

