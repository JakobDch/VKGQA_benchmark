@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_airline_types_0_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"city\", \"country\", \"latitude\", \"longitude\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:latitude ; rr:objectMap [ rr:column "latitude" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:longitude ; rr:objectMap [ rr:column "longitude" ] ] .

<#tm_attachment_1tab_ref_airline_types_1_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airline_name\", \"type_of_alliance\", \"home_airport_id\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airline_name ; rr:objectMap [ rr:column "airline_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type_of_alliance ; rr:objectMap [ rr:column "type_of_alliance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:home_airport_id ; rr:objectMap [ rr:column "home_airport_id" ] ] .

<#tm_attachment_1tab_ref_airline_types_2_Airlines_home_airport_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"home_airport_id\" FROM \"Airlines\" WHERE \"home_airport_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{home_airport_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_airline_types_3_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flight_number\", \"departure_time\", \"arrival_time\", \"airline_id\", \"aircraft_model\", \"source_airport_id\", \"destination_airport_id\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flight_number}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:flight_number ; rr:objectMap [ rr:column "flight_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departure_time ; rr:objectMap [ rr:column "departure_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrival_time ; rr:objectMap [ rr:column "arrival_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airline_id ; rr:objectMap [ rr:column "airline_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:aircraft_model ; rr:objectMap [ rr:column "aircraft_model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:source_airport_id ; rr:objectMap [ rr:column "source_airport_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destination_airport_id ; rr:objectMap [ rr:column "destination_airport_id" ] ] .

<#tm_attachment_1tab_ref_airline_types_4_Flights_destination_airport_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flight_number\", \"destination_airport_id\" FROM \"Flights\" WHERE \"destination_airport_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flight_number}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_destination_airport_id ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{destination_airport_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_airline_types_5_Flights_source_airport_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flight_number\", \"source_airport_id\" FROM \"Flights\" WHERE \"source_airport_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flight_number}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_source_airport_id ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{source_airport_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_airline_types_6_Flights_airline_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flight_number\", \"airline_id\" FROM \"Flights\" WHERE \"airline_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flight_number}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{airline_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_airline_types_7_Pilots_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"pilot_license_number\", \"first_name\", \"last_name\", \"date_of_birth\", \"rating_level\" FROM \"Pilots\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Pilots/{pilot_license_number}" ; rr:class :Pilots ] ;
  rr:predicateObjectMap [ rr:predicate p:pilot_license_number ; rr:objectMap [ rr:column "pilot_license_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date_of_birth ; rr:objectMap [ rr:column "date_of_birth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rating_level ; rr:objectMap [ rr:column "rating_level" ] ] .

<#tm_attachment_1tab_ref_airline_types_8_Assignments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignment_id\", \"flight_number\", \"pilot_license_number\" FROM \"Assignments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Assignments/{assignment_id}" ; rr:class :Assignments ] ;
  rr:predicateObjectMap [ rr:predicate p:assignment_id ; rr:objectMap [ rr:column "assignment_id" ] ] ;
