@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_airport_staff_0_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"city\", \"country\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_attachment_1tab_ref_airport_staff_1_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightNumber\", \"departureTime\", \"arrivalTime\", \"destinationId\", \"airlineId\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightNumber}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:flightNumber ; rr:objectMap [ rr:column "flightNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departureTime ; rr:objectMap [ rr:column "departureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrivalTime ; rr:objectMap [ rr:column "arrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destinationId ; rr:objectMap [ rr:column "destinationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airlineId ; rr:objectMap [ rr:column "airlineId" ] ] .

<#tm_attachment_1tab_ref_airport_staff_2_Flight_airlineId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightNumber\", \"airlineId\" FROM \"Flight\" WHERE \"airlineId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightNumber}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{airlineId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_airport_staff_3_Flight_destinationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightNumber\", \"destinationId\" FROM \"Flight\" WHERE \"destinationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightNumber}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{destinationId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_airport_staff_4_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"headquarterCity\", \"website\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ; rr:class :Airlines ] ;
