@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_boarding_types_0_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"Origin\", \"Destination\", \"DepartureTime\", \"ArrivalTime\", \"AirlineID\", \"PlaneID\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Origin ; rr:objectMap [ rr:column "Origin" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlineID ; rr:objectMap [ rr:column "AirlineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PlaneID ; rr:objectMap [ rr:column "PlaneID" ] ] .

<#tm_attachment_1tab_ref_boarding_types_1_Flights_PlaneID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"PlaneID\" FROM \"Flights\" WHERE \"PlaneID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPlanes ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{PlaneID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_boarding_types_2_Flights_AirlineID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"AirlineID\" FROM \"Flights\" WHERE \"AirlineID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{AirlineID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_boarding_types_3_Passengers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PassengerID\", \"Name\", \"Age\", \"BoardingType\", \"FlightID\" FROM \"Passengers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BoardingType ; rr:objectMap [ rr:column "BoardingType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] .

<#tm_attachment_1tab_ref_boarding_types_4_Passengers_FlightID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PassengerID\", \"FlightID\" FROM \"Passengers\" WHERE \"FlightID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_boarding_types_5_Planes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PlaneID\", \"Model\", \"Capacity\" FROM \"Planes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{PlaneID}" ; rr:class :Planes ] ;
  rr:predicateObjectMap [ rr:predicate p:PlaneID ; rr:objectMap [ rr:column "PlaneID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Model ; rr:objectMap [ rr:column "Model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] .

<#tm_attachment_1tab_ref_boarding_types_6_Planes_PlaneID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PlaneID\" FROM \"Planes\" WHERE \"PlaneID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{PlaneID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{PlaneID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_boarding_types_7_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirlineID\", \"Name\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{AirlineID}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlineID ; rr:objectMap [ rr:column "AirlineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

