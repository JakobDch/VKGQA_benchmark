  rr:predicateObjectMap [ rr:predicate p:typeName ; rr:objectMap [ rr:column "typeName" ] ] .

<#tm_attachment_1tab_ref_exclusive_areas_4_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightNumber\", \"aircraftTypeId\", \"departureTime\", \"arrivalTime\", \"originTerminalId\", \"destinationTerminalId\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightNumber}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:flightNumber ; rr:objectMap [ rr:column "flightNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:aircraftTypeId ; rr:objectMap [ rr:column "aircraftTypeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departureTime ; rr:objectMap [ rr:column "departureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrivalTime ; rr:objectMap [ rr:column "arrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:originTerminalId ; rr:objectMap [ rr:column "originTerminalId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destinationTerminalId ; rr:objectMap [ rr:column "destinationTerminalId" ] ] .

