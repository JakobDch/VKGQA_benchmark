  rr:logicalTable [ rr:sqlQuery """SELECT \"areaId\", \"terminalId\", \"exclusiveAreaValue\" FROM \"ExclusiveArea\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/ExclusiveArea/{areaId}" ; rr:class :ExclusiveArea ] ;
  rr:predicateObjectMap [ rr:predicate p:areaId ; rr:objectMap [ rr:column "areaId" ] ] ;
