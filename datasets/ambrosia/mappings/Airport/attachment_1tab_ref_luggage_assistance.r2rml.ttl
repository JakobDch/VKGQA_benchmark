@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_luggage_assistance_0_Passengers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PassengerID\", \"Name\", \"FlightID\" FROM \"Passengers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] .

<#tm_attachment_1tab_ref_luggage_assistance_1_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"DepartureTime\", \"Destination\", \"AvailableSeats\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AvailableSeats ; rr:objectMap [ rr:column "AvailableSeats" ] ] .

<#tm_attachment_1tab_ref_luggage_assistance_2_LuggageRequests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RequestID\", \"PassengerID\", \"AssistanceType\", \"Location\", \"RequestDate\" FROM \"LuggageRequests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/LuggageRequests/{RequestID}" ; rr:class :LuggageRequests ] ;
  rr:predicateObjectMap [ rr:predicate p:RequestID ; rr:objectMap [ rr:column "RequestID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AssistanceType ; rr:objectMap [ rr:column "AssistanceType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RequestDate ; rr:objectMap [ rr:column "RequestDate" ] ] .

<#tm_attachment_1tab_ref_luggage_assistance_3_LuggageRequests_PassengerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RequestID\", \"PassengerID\" FROM \"LuggageRequests\" WHERE \"PassengerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/LuggageRequests/{RequestID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPassengers ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_luggage_assistance_4_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LocationID\", \"LocationName\" FROM \"Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Locations/{LocationID}" ; rr:class :Locations ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationID ; rr:objectMap [ rr:column "LocationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationName ; rr:objectMap [ rr:column "LocationName" ] ] .

<#tm_attachment_1tab_ref_luggage_assistance_5_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"LuggageRequestID\", \"LocationID\", \"SlotStart\", \"SlotEnd\", \"BookingStatus\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Bookings/{BookingID}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:BookingID ; rr:objectMap [ rr:column "BookingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LuggageRequestID ; rr:objectMap [ rr:column "LuggageRequestID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationID ; rr:objectMap [ rr:column "LocationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SlotStart ; rr:objectMap [ rr:column "SlotStart" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SlotEnd ; rr:objectMap [ rr:column "SlotEnd" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BookingStatus ; rr:objectMap [ rr:column "BookingStatus" ] ] .

<#tm_attachment_1tab_ref_luggage_assistance_6_Bookings_LocationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"LocationID\" FROM \"Bookings\" WHERE \"LocationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocations ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Locations/{LocationID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_luggage_assistance_7_Bookings_LuggageRequestID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"LuggageRequestID\" FROM \"Bookings\" WHERE \"LuggageRequestID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLuggageRequests ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/LuggageRequests/{LuggageRequestID}" ; rr:termType rr:IRI ] ] .

