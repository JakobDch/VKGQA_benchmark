<#tm_attachment_1tab_ref_special_care_passengers_7_PassengerAssistanceRequests_AssistantID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RequestID\", \"AssistantID\" FROM \"PassengerAssistanceRequests\" WHERE \"AssistantID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/PassengerAssistanceRequests/{RequestID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAssistant ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Assistant/{AssistantID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_special_care_passengers_8_PassengerAssistanceRequests_PassengerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RequestID\", \"PassengerID\" FROM \"PassengerAssistanceRequests\" WHERE \"PassengerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/PassengerAssistanceRequests/{RequestID}" ] ;
