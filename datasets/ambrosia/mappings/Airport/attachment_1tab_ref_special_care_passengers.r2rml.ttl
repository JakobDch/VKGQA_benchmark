@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_special_care_passengers_0_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"DepartureTime\", \"ArrivalTime\", \"Origin\", \"Destination\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Origin ; rr:objectMap [ rr:column "Origin" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] .

<#tm_attachment_1tab_ref_special_care_passengers_1_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirportID\", \"Name\", \"City\", \"Country\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{AirportID}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:AirportID ; rr:objectMap [ rr:column "AirportID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_ref_special_care_passengers_2_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirlineID\", \"Name\", \"HeadquartersCity\", \"HomeAirportId\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{AirlineID}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlineID ; rr:objectMap [ rr:column "AirlineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HeadquartersCity ; rr:objectMap [ rr:column "HeadquartersCity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HomeAirportId ; rr:objectMap [ rr:column "HomeAirportId" ] ] .

<#tm_attachment_1tab_ref_special_care_passengers_3_Airlines_HomeAirportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirlineID\", \"HomeAirportId\" FROM \"Airlines\" WHERE \"HomeAirportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{AirlineID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{HomeAirportId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_special_care_passengers_4_Passengers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PassengerID\", \"DateOfBirth\", \"FullName\" FROM \"Passengers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

