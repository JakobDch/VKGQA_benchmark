<#tm_attachment_1tab_ref_special_care_passengers_6_PassengerAssistanceRequests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RequestID\", \"PassengerID\", \"AssistantID\", \"Type\" FROM \"PassengerAssistanceRequests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/PassengerAssistanceRequests/{RequestID}" ; rr:class :PassengerAssistanceRequests ] ;
  rr:predicateObjectMap [ rr:predicate p:RequestID ; rr:objectMap [ rr:column "RequestID" ] ] ;
