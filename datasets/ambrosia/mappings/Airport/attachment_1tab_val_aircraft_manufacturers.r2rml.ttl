@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_aircraft_manufacturers_0_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"city\", \"country\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_attachment_1tab_val_aircraft_manufacturers_1_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airlineName\", \"headquarteredIn\", \"homeAirportId\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airlineName ; rr:objectMap [ rr:column "airlineName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:headquarteredIn ; rr:objectMap [ rr:column "headquarteredIn" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:homeAirportId ; rr:objectMap [ rr:column "homeAirportId" ] ] .

<#tm_attachment_1tab_val_aircraft_manufacturers_2_Airlines_homeAirportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"homeAirportId\" FROM \"Airlines\" WHERE \"homeAirportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{homeAirportId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_aircraft_manufacturers_3_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"flightNo\", \"departureTime\", \"arrivalTime\", \"originAirportId\", \"destinationAirportId\", \"aircraftId\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:flightNo ; rr:objectMap [ rr:column "flightNo" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departureTime ; rr:objectMap [ rr:column "departureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrivalTime ; rr:objectMap [ rr:column "arrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:originAirportId ; rr:objectMap [ rr:column "originAirportId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destinationAirportId ; rr:objectMap [ rr:column "destinationAirportId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:aircraftId ; rr:objectMap [ rr:column "aircraftId" ] ] .

<#tm_attachment_1tab_val_aircraft_manufacturers_4_Flights_aircraftId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"aircraftId\" FROM \"Flights\" WHERE \"aircraftId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasManufactures ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Manufactures/{aircraftId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_aircraft_manufacturers_5_Flights_destinationAirportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"destinationAirportId\" FROM \"Flights\" WHERE \"destinationAirportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_destinationAirportId ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{destinationAirportId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_aircraft_manufacturers_6_Flights_originAirportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"originAirportId\" FROM \"Flights\" WHERE \"originAirportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_originAirportId ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{originAirportId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_aircraft_manufacturers_7_Manufactures_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"aircraftModel\", \"manufacturers\", \"numberOfSeats\" FROM \"Manufactures\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Manufactures/{id}" ; rr:class :Manufactures ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:aircraftModel ; rr:objectMap [ rr:column "aircraftModel" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:manufacturers ; rr:objectMap [ rr:column "manufacturers" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:numberOfSeats ; rr:objectMap [ rr:column "numberOfSeats" ] ] .

