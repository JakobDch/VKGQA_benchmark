@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_airport_accommodations_0_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"DepartureTime\", \"ArrivalTime\", \"Origin\", \"Destination\", \"AircraftType\", \"SeatsAvailable\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Origin ; rr:objectMap [ rr:column "Origin" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AircraftType ; rr:objectMap [ rr:column "AircraftType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SeatsAvailable ; rr:objectMap [ rr:column "SeatsAvailable" ] ] .

<#tm_attachment_1tab_val_airport_accommodations_1_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirlineID\", \"Name\", \"Headquarters\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{AirlineID}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlineID ; rr:objectMap [ rr:column "AirlineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Headquarters ; rr:objectMap [ rr:column "Headquarters" ] ] .

<#tm_attachment_1tab_val_airport_accommodations_2_Pilots_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PilotID\", \"FirstName\", \"LastName\", \"LicenseNumber\", \"DateOfBirth\" FROM \"Pilots\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Pilots/{PilotID}" ; rr:class :Pilots ] ;
  rr:predicateObjectMap [ rr:predicate p:PilotID ; rr:objectMap [ rr:column "PilotID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LicenseNumber ; rr:objectMap [ rr:column "LicenseNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] .

<#tm_attachment_1tab_val_airport_accommodations_3_AssignPilotToFlight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"PilotID\" FROM \"AssignPilotToFlight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/AssignsPilotToFlight/{FlightID}/{PilotID}" ; rr:class :AssignsPilotToFlight ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PilotID ; rr:objectMap [ rr:column "PilotID" ] ] .

<#tm_attachment_1tab_val_airport_accommodations_4_AssignPilotToFlight_PilotID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"PilotID\" FROM \"AssignPilotToFlight\" WHERE \"PilotID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/AssignsPilotToFlight/{FlightID}/{PilotID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPilots ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Pilots/{PilotID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_airport_accommodations_5_AssignPilotToFlight_FlightID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"PilotID\" FROM \"AssignPilotToFlight\" WHERE \"FlightID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/AssignsPilotToFlight/{FlightID}/{PilotID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_airport_accommodations_6_Hotels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"HotelID\", \"Name\", \"Location\", \"Price\", \"AccomodationType\" FROM \"Hotels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Hotels/{HotelID}" ; rr:class :Hotels ] ;
  rr:predicateObjectMap [ rr:predicate p:HotelID ; rr:objectMap [ rr:column "HotelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccomodationType ; rr:objectMap [ rr:column "AccomodationType" ] ] .

