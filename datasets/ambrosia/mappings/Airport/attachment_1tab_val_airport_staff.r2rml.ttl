@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_airport_staff_0_Languages_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LanguageID\", \"Name\" FROM \"Languages\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Languages/{LanguageID}" ; rr:class :Languages ] ;
  rr:predicateObjectMap [ rr:predicate p:LanguageID ; rr:objectMap [ rr:column "LanguageID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_val_airport_staff_1_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirportID\", \"Name\", \"City\", \"Country\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{AirportID}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:AirportID ; rr:objectMap [ rr:column "AirportID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_val_airport_staff_2_Staff_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StaffID\", \"Position\", \"AirportID\", \"LanguageID\", \"FullName\" FROM \"Staff\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Staff/{StaffID}" ; rr:class :Staff ] ;
  rr:predicateObjectMap [ rr:predicate p:StaffID ; rr:objectMap [ rr:column "StaffID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Position ; rr:objectMap [ rr:column "Position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AirportID ; rr:objectMap [ rr:column "AirportID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LanguageID ; rr:objectMap [ rr:column "LanguageID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_val_airport_staff_3_Staff_LanguageID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StaffID\", \"LanguageID\" FROM \"Staff\" WHERE \"LanguageID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Staff/{StaffID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLanguages ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Languages/{LanguageID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_airport_staff_4_Staff_AirportID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StaffID\", \"AirportID\" FROM \"Staff\" WHERE \"AirportID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Staff/{StaffID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{AirportID}" ; rr:termType rr:IRI ] ] .

