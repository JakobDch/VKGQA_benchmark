  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_DestinationAirportID ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{DestinationAirportID}" ; rr:termType rr:IRI ] ] .

