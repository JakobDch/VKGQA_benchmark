<#tm_attachment_1tab_val_arrival_facilities_7_Flights_DepartureAirportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"DepartureAirportId\" FROM \"Flights\" WHERE \"DepartureAirportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_DepartureAirportId ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{DepartureAirportId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_arrival_facilities_8_Passengers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"FlightId\" FROM \"Passengers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{id}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
