@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_arrival_facilities_0_TerminalFacility_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Arrival_Facilities\", \"Maximum_Capacity\", \"OpeningHours\" FROM \"TerminalFacility\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/TerminalFacility/{id}" ; rr:class :TerminalFacility ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Arrival_Facilities ; rr:objectMap [ rr:column "Arrival_Facilities" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Maximum_Capacity ; rr:objectMap [ rr:column "Maximum_Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OpeningHours ; rr:objectMap [ rr:column "OpeningHours" ] ] .

<#tm_attachment_1tab_val_arrival_facilities_1_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Location\", \"NumberOfTerminals\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfTerminals ; rr:objectMap [ rr:column "NumberOfTerminals" ] ] .

<#tm_attachment_1tab_val_arrival_facilities_2_Airports_NumberOfTerminals_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"NumberOfTerminals\" FROM \"Airports\" WHERE \"NumberOfTerminals\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminalFacility ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/TerminalFacility/{NumberOfTerminals}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_arrival_facilities_3_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Headquarters\", \"IATA_Code\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Headquarters ; rr:objectMap [ rr:column "Headquarters" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:IATA_Code ; rr:objectMap [ rr:column "IATA_Code" ] ] .

<#tm_attachment_1tab_val_arrival_facilities_4_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"FlightNo\", \"DepartureAirportId\", \"DestinationAirportId\", \"AirlineId\", \"Departs\", \"Arrives\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightNo ; rr:objectMap [ rr:column "FlightNo" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureAirportId ; rr:objectMap [ rr:column "DepartureAirportId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DestinationAirportId ; rr:objectMap [ rr:column "DestinationAirportId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlineId ; rr:objectMap [ rr:column "AirlineId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Departs ; rr:objectMap [ rr:column "Departs" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Arrives ; rr:objectMap [ rr:column "Arrives" ] ] .

<#tm_attachment_1tab_val_arrival_facilities_5_Flights_AirlineId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"AirlineId\" FROM \"Flights\" WHERE \"AirlineId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{AirlineId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_arrival_facilities_6_Flights_DestinationAirportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"DestinationAirportId\" FROM \"Flights\" WHERE \"DestinationAirportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
