[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Development_Projects_base
target		ex:Development_Projects/{ID} a :Development_Projects ; p:ID {ID} ; p:ProjectName {ProjectName} ; p:Increased_Capacity {Increased_Capacity} ; p:StartDate {StartDate} ; p:EndDate {EndDate} ; p:Cost {Cost} .
source		SELECT `ID`, `ProjectName`, `Increased_Capacity`, `StartDate`, `EndDate`, `Cost` FROM `Development_Projects`

mappingId	Aircraft_base
target		ex:Aircraft/{ID} a :Aircraft ; p:ID {ID} ; p:Model {Model} ; p:Capacity {Capacity} ; p:Manufacturer {Manufacturer} ; p:Year {Year} .
source		SELECT `ID`, `Model`, `Capacity`, `Manufacturer`, `Year` FROM `Aircraft`

mappingId	Flight_base
target		ex:Flights/{ID} a :Flights ; p:ID {ID} ; p:DepartureTime {DepartureTime} ; p:ArrivalTime {ArrivalTime} ; p:Origin {Origin} ; p:Destination {Destination} ; p:AircraftID {AircraftID} .
source		SELECT `ID`, `DepartureTime`, `ArrivalTime`, `Origin`, `Destination`, `AircraftID` FROM `Flight`

mappingId	Flight_AircraftID_fk
target		ex:Flights/{ID} p:hasAircraft ex:Aircraft/{AircraftID} .
source		SELECT `ID`, `AircraftID` FROM `Flight` WHERE `AircraftID` IS NOT NULL

mappingId	Staff_base
target		ex:Staff/{ID} a :Staff ; p:ID {ID} ; p:name {Name} ; p:Position {Position} ; p:Salary {Salary} ; p:HireDate {HireDate} .
source		SELECT `ID`, `Name`, `Position`, `Salary`, `HireDate` FROM `Staff`

]]
