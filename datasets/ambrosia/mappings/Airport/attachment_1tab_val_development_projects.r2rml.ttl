@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_development_projects_0_Development_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"ProjectName\", \"Increased_Capacity\", \"StartDate\", \"EndDate\", \"Cost\" FROM \"Development_Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Development_Projects/{ID}" ; rr:class :Development_Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProjectName ; rr:objectMap [ rr:column "ProjectName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Increased_Capacity ; rr:objectMap [ rr:column "Increased_Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Cost ; rr:objectMap [ rr:column "Cost" ] ] .

<#tm_attachment_1tab_val_development_projects_1_Aircraft_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Model\", \"Capacity\", \"Manufacturer\", \"Year\" FROM \"Aircraft\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{ID}" ; rr:class :Aircraft ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Model ; rr:objectMap [ rr:column "Model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Manufacturer ; rr:objectMap [ rr:column "Manufacturer" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] .

<#tm_attachment_1tab_val_development_projects_2_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"DepartureTime\", \"ArrivalTime\", \"Origin\", \"Destination\", \"AircraftID\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{ID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Origin ; rr:objectMap [ rr:column "Origin" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AircraftID ; rr:objectMap [ rr:column "AircraftID" ] ] .

<#tm_attachment_1tab_val_development_projects_3_Flight_AircraftID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"AircraftID\" FROM \"Flight\" WHERE \"AircraftID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAircraft ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{AircraftID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_development_projects_4_Staff_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Position\", \"Salary\", \"HireDate\" FROM \"Staff\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Staff/{ID}" ; rr:class :Staff ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Position ; rr:objectMap [ rr:column "Position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HireDate ; rr:objectMap [ rr:column "HireDate" ] ] .

