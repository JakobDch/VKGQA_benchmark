  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{passengerID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLounge ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Lounge/{loungeID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_exclusive_areas_5_Passenger_flightID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"passengerID\", \"flightID\" FROM \"Passenger\" WHERE \"flightID\" IS NOT NULL""" ] ;
