  rr:logicalTable [ rr:sqlQuery """SELECT \"loungeID\", \"name\", \"exclusiveArea\", \"amenities\", \"capacity\", \"terminalID\" FROM \"Lounge\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Lounge/{loungeID}" ; rr:class :Lounge ] ;
