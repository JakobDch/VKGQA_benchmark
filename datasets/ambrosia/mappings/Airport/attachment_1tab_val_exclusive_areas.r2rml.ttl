@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_exclusive_areas_0_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"departureTime\", \"arrivalTime\", \"aircraftID\", \"terminalID\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:flightID ; rr:objectMap [ rr:column "flightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departureTime ; rr:objectMap [ rr:column "departureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrivalTime ; rr:objectMap [ rr:column "arrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:aircraftID ; rr:objectMap [ rr:column "aircraftID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:terminalID ; rr:objectMap [ rr:column "terminalID" ] ] .

<#tm_attachment_1tab_val_exclusive_areas_1_Flight_terminalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"terminalID\" FROM \"Flight\" WHERE \"terminalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{terminalID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_exclusive_areas_2_Flight_aircraftID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"aircraftID\" FROM \"Flight\" WHERE \"aircraftID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAircraft ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{aircraftID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_exclusive_areas_3_Passenger_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"passengerID\", \"firstName\", \"lastName\", \"flightID\", \"loungeID\" FROM \"Passenger\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{passengerID}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:passengerID ; rr:objectMap [ rr:column "passengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:flightID ; rr:objectMap [ rr:column "flightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:loungeID ; rr:objectMap [ rr:column "loungeID" ] ] .

