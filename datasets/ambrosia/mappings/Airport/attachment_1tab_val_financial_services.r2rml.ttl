@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_financial_services_0_Financial_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Type\", \"Location_Within_Terminal\", \"Operating_Hours\" FROM \"Financial_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Financial_Services/{id}" ; rr:class :Financial_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Location_Within_Terminal ; rr:objectMap [ rr:column "Location_Within_Terminal" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Operating_Hours ; rr:objectMap [ rr:column "Operating_Hours" ] ] .

<#tm_attachment_1tab_val_financial_services_1_Terminals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Terminals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{id}" ; rr:class :Terminals ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_attachment_1tab_val_financial_services_2_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airline_name\", \"terminal_id\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airline_name ; rr:objectMap [ rr:column "airline_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:terminal_id ; rr:objectMap [ rr:column "terminal_id" ] ] .

<#tm_attachment_1tab_val_financial_services_3_Airlines_terminal_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"terminal_id\" FROM \"Airlines\" WHERE \"terminal_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{terminal_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_financial_services_4_Flight_Details_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"flight_number\", \"departure_time\", \"arrival_time\", \"origin_airport\", \"destination_airport\", \"airline_id\" FROM \"Flight_Details\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flight_Details/{_amb_rowid}" ; rr:class :Flight_Details ] ;
  rr:predicateObjectMap [ rr:predicate p:flight_number ; rr:objectMap [ rr:column "flight_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departure_time ; rr:objectMap [ rr:column "departure_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrival_time ; rr:objectMap [ rr:column "arrival_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:origin_airport ; rr:objectMap [ rr:column "origin_airport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destination_airport ; rr:objectMap [ rr:column "destination_airport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airline_id ; rr:objectMap [ rr:column "airline_id" ] ] .

<#tm_attachment_1tab_val_financial_services_5_Flight_Details_airline_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"airline_id\" FROM \"Flight_Details\" WHERE \"airline_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flight_Details/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{airline_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_financial_services_6_Baggage_Claims_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"claim_number\", \"carousel_location\", \"airport_code\" FROM \"Baggage_Claims\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/BaggageClaims/{_amb_rowid}" ; rr:class :BaggageClaims ] ;
  rr:predicateObjectMap [ rr:predicate p:claim_number ; rr:objectMap [ rr:column "claim_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:carousel_location ; rr:objectMap [ rr:column "carousel_location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airport_code ; rr:objectMap [ rr:column "airport_code" ] ] .

<#tm_attachment_1tab_val_financial_services_7_Baggage_Claims_airport_code_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"airport_code\" FROM \"Baggage_Claims\" WHERE \"airport_code\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/BaggageClaims/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{airport_code}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_financial_services_8_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"code\", \"name\", \"city\", \"country\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{code}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:code ; rr:objectMap [ rr:column "code" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

