@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_luggage_0_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"Origin\", \"Destination\", \"DepartureTime\", \"ArrivalTime\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Origin ; rr:objectMap [ rr:column "Origin" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] .

<#tm_attachment_1tab_val_luggage_1_Passengers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PassengerID\", \"DateOfBirth\", \"Nationality\", \"FullName\" FROM \"Passengers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Nationality ; rr:objectMap [ rr:column "Nationality" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_val_luggage_2_Luggage_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ItemID\", \"PassengerID\", \"Description\", \"Fees\" FROM \"Luggage\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Luggage/{ItemID}" ; rr:class :Luggage ] ;
  rr:predicateObjectMap [ rr:predicate p:ItemID ; rr:objectMap [ rr:column "ItemID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Fees ; rr:objectMap [ rr:column "Fees" ] ] .

<#tm_attachment_1tab_val_luggage_3_Luggage_PassengerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ItemID\", \"PassengerID\" FROM \"Luggage\" WHERE \"PassengerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Luggage/{ItemID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPassengers ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_luggage_4_Aircrafts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AircraftID\", \"Model\", \"Capacity\", \"RegistrationNumber\" FROM \"Aircrafts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{AircraftID}" ; rr:class :Aircraft ] ;
  rr:predicateObjectMap [ rr:predicate p:AircraftID ; rr:objectMap [ rr:column "AircraftID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Model ; rr:objectMap [ rr:column "Model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RegistrationNumber ; rr:objectMap [ rr:column "RegistrationNumber" ] ] .

