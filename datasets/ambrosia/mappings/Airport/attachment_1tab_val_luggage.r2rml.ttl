  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AircraftID ; rr:objectMap [ rr:column "AircraftID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AssignedDate ; rr:objectMap [ rr:column "AssignedDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReturnedDate ; rr:objectMap [ rr:column "ReturnedDate" ] ] .

<#tm_attachment_1tab_val_luggage_6_Assignments_AircraftID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AssignmentID\", \"AircraftID\" FROM \"Assignments\" WHERE \"AircraftID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Assignments/{AssignmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAircraft ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{AircraftID}" ; rr:termType rr:IRI ] ] .

