[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Flight_base
target		ex:Flights/{flightID} a :Flights ; p:flightID {flightID} ; p:departureTime {departureTime} ; p:destination {destination} ; p:duration {duration} .
source		SELECT `flightID`, `departureTime`, `destination`, `duration` FROM `Flight`

mappingId	Gate_base
target		ex:Gates/{gateID} a :Gates ; p:gateID {gateID} ; p:gateNumber {gateNumber} ; p:terminal {terminal} ; p:capacity {capacity} .
source		SELECT `gateID`, `gateNumber`, `terminal`, `capacity` FROM `Gate`

mappingId	Passenger_base
target		ex:Passengers/{passengerID} a :Passengers ; p:passengerID {passengerID} ; p:mobilityAids {mobilityAids} ; p:pickUpDropOffLocation {pickUpDropOffLocation} ; p:name {FullName} .
source		SELECT `passengerID`, `mobilityAids`, `pickUpDropOffLocation`, `FullName` FROM `Passenger`

mappingId	ServiceRequest_base
target		ex:ServiceRequest/{requestID} a :ServiceRequest ; p:requestID {requestID} ; p:flightID {flightID} ; p:passengerID {passengerID} ; p:serviceType {serviceType} .
source		SELECT `requestID`, `flightID`, `passengerID`, `serviceType` FROM `ServiceRequest`

mappingId	ServiceRequest_passengerID_fk
target		ex:ServiceRequest/{requestID} p:hasPassengers ex:Passengers/{passengerID} .
source		SELECT `requestID`, `passengerID` FROM `ServiceRequest` WHERE `passengerID` IS NOT NULL

mappingId	ServiceRequest_flightID_fk
target		ex:ServiceRequest/{requestID} p:hasFlights ex:Flights/{flightID} .
source		SELECT `requestID`, `flightID` FROM `ServiceRequest` WHERE `flightID` IS NOT NULL

]]
