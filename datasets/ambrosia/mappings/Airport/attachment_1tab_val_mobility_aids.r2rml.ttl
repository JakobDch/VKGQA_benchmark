@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_mobility_aids_0_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"departureTime\", \"destination\", \"duration\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:flightID ; rr:objectMap [ rr:column "flightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departureTime ; rr:objectMap [ rr:column "departureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destination ; rr:objectMap [ rr:column "destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration ; rr:objectMap [ rr:column "duration" ] ] .

<#tm_attachment_1tab_val_mobility_aids_1_Gate_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"gateID\", \"gateNumber\", \"terminal\", \"capacity\" FROM \"Gate\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Gates/{gateID}" ; rr:class :Gates ] ;
  rr:predicateObjectMap [ rr:predicate p:gateID ; rr:objectMap [ rr:column "gateID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:gateNumber ; rr:objectMap [ rr:column "gateNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:terminal ; rr:objectMap [ rr:column "terminal" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

<#tm_attachment_1tab_val_mobility_aids_2_Passenger_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"passengerID\", \"mobilityAids\", \"pickUpDropOffLocation\", \"FullName\" FROM \"Passenger\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{passengerID}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:passengerID ; rr:objectMap [ rr:column "passengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:mobilityAids ; rr:objectMap [ rr:column "mobilityAids" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:pickUpDropOffLocation ; rr:objectMap [ rr:column "pickUpDropOffLocation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_val_mobility_aids_3_ServiceRequest_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"requestID\", \"flightID\", \"passengerID\", \"serviceType\" FROM \"ServiceRequest\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/ServiceRequest/{requestID}" ; rr:class :ServiceRequest ] ;
  rr:predicateObjectMap [ rr:predicate p:requestID ; rr:objectMap [ rr:column "requestID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:flightID ; rr:objectMap [ rr:column "flightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:passengerID ; rr:objectMap [ rr:column "passengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:serviceType ; rr:objectMap [ rr:column "serviceType" ] ] .

<#tm_attachment_1tab_val_mobility_aids_4_ServiceRequest_passengerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"requestID\", \"passengerID\" FROM \"ServiceRequest\" WHERE \"passengerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/ServiceRequest/{requestID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPassengers ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{passengerID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_mobility_aids_5_ServiceRequest_flightID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"requestID\", \"flightID\" FROM \"ServiceRequest\" WHERE \"flightID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/ServiceRequest/{requestID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ; rr:termType rr:IRI ] ] .

