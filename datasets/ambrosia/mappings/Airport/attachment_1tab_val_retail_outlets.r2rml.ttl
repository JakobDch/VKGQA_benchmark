<#tm_attachment_1tab_val_retail_outlets_5_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"departureGateId\", \"arrivalGateId\", \"departureTime\", \"arrivalTime\", \"departureAirportId\", \"arrivalAirportId\" FROM \"Flights\"""" ] ;
