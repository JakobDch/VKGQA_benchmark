@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_special_care_passengers_0_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"city\", \"country\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_attachment_1tab_val_special_care_passengers_1_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightNumber\", \"departureAirportId\", \"arrivalAirportId\", \"departureTime\", \"arrivalTime\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightNumber}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:flightNumber ; rr:objectMap [ rr:column "flightNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departureAirportId ; rr:objectMap [ rr:column "departureAirportId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrivalAirportId ; rr:objectMap [ rr:column "arrivalAirportId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departureTime ; rr:objectMap [ rr:column "departureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrivalTime ; rr:objectMap [ rr:column "arrivalTime" ] ] .

<#tm_attachment_1tab_val_special_care_passengers_2_Flights_arrivalAirportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightNumber\", \"arrivalAirportId\" FROM \"Flights\" WHERE \"arrivalAirportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightNumber}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_arrivalAirportId ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{arrivalAirportId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_special_care_passengers_3_Flights_departureAirportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightNumber\", \"departureAirportId\" FROM \"Flights\" WHERE \"departureAirportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightNumber}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_departureAirportId ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{departureAirportId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_special_care_passengers_4_Passengers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"passengerId\", \"dateOfBirth\", \"isMinor\", \"FullName\" FROM \"Passengers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{passengerId}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:passengerId ; rr:objectMap [ rr:column "passengerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dateOfBirth ; rr:objectMap [ rr:column "dateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:isMinor ; rr:objectMap [ rr:column "isMinor" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_val_special_care_passengers_5_Requirements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"requirementId\", \"passengerId\", \"description\", \"assistant\" FROM \"Requirements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Requirements/{requirementId}" ; rr:class :Requirements ] ;
  rr:predicateObjectMap [ rr:predicate p:requirementId ; rr:objectMap [ rr:column "requirementId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:passengerId ; rr:objectMap [ rr:column "passengerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:assistant ; rr:objectMap [ rr:column "assistant" ] ] .

<#tm_attachment_1tab_val_special_care_passengers_6_Requirements_passengerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"requirementId\", \"passengerId\" FROM \"Requirements\" WHERE \"passengerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Requirements/{requirementId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPassengers ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{passengerId}" ; rr:termType rr:IRI ] ] .

