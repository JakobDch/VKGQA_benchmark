@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_airport_services_0_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CustomerID\", \"FirstName\", \"LastName\", \"EmailAddress\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Customers/{CustomerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] .

<#tm_attachment_2tab_ref_airport_services_1_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightNumber\", \"DepartureAirport\", \"ArrivalAirport\", \"DepartureTime\", \"EstimatedArrivalTime\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightNumber}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightNumber ; rr:objectMap [ rr:column "FlightNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureAirport ; rr:objectMap [ rr:column "DepartureAirport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalAirport ; rr:objectMap [ rr:column "ArrivalAirport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EstimatedArrivalTime ; rr:objectMap [ rr:column "EstimatedArrivalTime" ] ] .

<#tm_attachment_2tab_ref_airport_services_2_LostProperties_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PropertyID\", \"ItemDescription\", \"DateOfLoss\", \"Found\" FROM \"LostProperties\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/LostProperties/{PropertyID}" ; rr:class :LostProperties ] ;
  rr:predicateObjectMap [ rr:predicate p:PropertyID ; rr:objectMap [ rr:column "PropertyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ItemDescription ; rr:objectMap [ rr:column "ItemDescription" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfLoss ; rr:objectMap [ rr:column "DateOfLoss" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Found ; rr:objectMap [ rr:column "Found" ] ] .

<#tm_attachment_2tab_ref_airport_services_3_LostProperties_DateOfLoss_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PropertyID\", \"DateOfLoss\" FROM \"LostProperties\" WHERE \"DateOfLoss\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/LostProperties/{PropertyID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCalendar ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Calendar/{DateOfLoss}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_airport_services_4_Complaints_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ComplaintID\", \"Description\", \"Severity\", \"Resolved\", \"SubmissionDate\", \"CustomerId\", \"FlightNumber\" FROM \"Complaints\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Complaints/{ComplaintID}" ; rr:class :Complaints ] ;
  rr:predicateObjectMap [ rr:predicate p:ComplaintID ; rr:objectMap [ rr:column "ComplaintID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Severity ; rr:objectMap [ rr:column "Severity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Resolved ; rr:objectMap [ rr:column "Resolved" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SubmissionDate ; rr:objectMap [ rr:column "SubmissionDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerId ; rr:objectMap [ rr:column "CustomerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightNumber ; rr:objectMap [ rr:column "FlightNumber" ] ] .

<#tm_attachment_2tab_ref_airport_services_5_Complaints_FlightNumber_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ComplaintID\", \"FlightNumber\" FROM \"Complaints\" WHERE \"FlightNumber\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Complaints/{ComplaintID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightNumber}" ; rr:termType rr:IRI ] ] .

