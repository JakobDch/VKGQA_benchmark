  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Complaints/{ComplaintID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Customers/{CustomerId}" ; rr:termType rr:IRI ] ] .

