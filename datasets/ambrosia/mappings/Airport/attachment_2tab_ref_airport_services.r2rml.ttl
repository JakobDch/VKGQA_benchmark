<#tm_attachment_2tab_ref_airport_services_8_Calendar_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CalendarID\", \"Year\", \"Month\", \"Day\", \"Date\" FROM \"Calendar\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Calendar/{CalendarID}" ; rr:class :Calendar ] ;
