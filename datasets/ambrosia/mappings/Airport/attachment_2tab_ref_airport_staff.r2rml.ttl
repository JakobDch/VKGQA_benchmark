@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_airport_staff_0_Languages_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"language\" FROM \"Languages\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Languages/{id}" ; rr:class :Languages ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:language ; rr:objectMap [ rr:column "language" ] ] .

<#tm_attachment_2tab_ref_airport_staff_1_Pilots_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"licenseNumber\", \"speaksId\" FROM \"Pilots\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Pilots/{id}" ; rr:class :Pilots ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:licenseNumber ; rr:objectMap [ rr:column "licenseNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:speaksId ; rr:objectMap [ rr:column "speaksId" ] ] .

<#tm_attachment_2tab_ref_airport_staff_2_Pilots_speaksId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"speaksId\" FROM \"Pilots\" WHERE \"speaksId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Pilots/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLanguages ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Languages/{speaksId}" ; rr:termType rr:IRI ] ] .

