@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_boarding_equipment_0_Terminals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Name\" FROM \"Terminals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{Id}" ; rr:class :Terminals ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_ref_boarding_equipment_1_Aircraft_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Type\", \"Seats\" FROM \"Aircraft\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{Id}" ; rr:class :Aircraft ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Seats ; rr:objectMap [ rr:column "Seats" ] ] .

<#tm_attachment_2tab_ref_boarding_equipment_2_Jet_bridge_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Length\", \"Capacity\", \"Terminal_id\" FROM \"Jet_bridge\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Jet_Bridges/{Id}" ; rr:class :Jet_Bridges ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Length ; rr:objectMap [ rr:column "Length" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Terminal_id ; rr:objectMap [ rr:column "Terminal_id" ] ] .

<#tm_attachment_2tab_ref_boarding_equipment_3_Jet_bridge_Terminal_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Terminal_id\" FROM \"Jet_bridge\" WHERE \"Terminal_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Jet_Bridges/{Id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{Terminal_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_boarding_equipment_4_Staircar_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Number_of_Cars\", \"Capacity\", \"Terminal_id\" FROM \"Staircar\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Staircars/{Id}" ; rr:class :Staircars ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_Cars ; rr:objectMap [ rr:column "Number_of_Cars" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Terminal_id ; rr:objectMap [ rr:column "Terminal_id" ] ] .

<#tm_attachment_2tab_ref_boarding_equipment_5_Staircar_Terminal_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Terminal_id\" FROM \"Staircar\" WHERE \"Terminal_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Staircars/{Id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{Terminal_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_boarding_equipment_6_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Aircraft_id\", \"Terminal_id\", \"Departure_time\", \"Arrival_time\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{Id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Aircraft_id ; rr:objectMap [ rr:column "Aircraft_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Terminal_id ; rr:objectMap [ rr:column "Terminal_id" ] ] ;
