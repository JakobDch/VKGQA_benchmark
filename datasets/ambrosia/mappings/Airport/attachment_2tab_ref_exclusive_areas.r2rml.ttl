@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_exclusive_areas_0_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"airportID\", \"name\", \"city\", \"country\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{airportID}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:airportID ; rr:objectMap [ rr:column "airportID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_attachment_2tab_ref_exclusive_areas_1_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"airlineID\", \"name\", \"headquarters\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{airlineID}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:airlineID ; rr:objectMap [ rr:column "airlineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:headquarters ; rr:objectMap [ rr:column "headquarters" ] ] .

<#tm_attachment_2tab_ref_exclusive_areas_2_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"originAirport\", \"destinationAirport\", \"departureTime\", \"arrivalTime\", \"airlineID\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:flightID ; rr:objectMap [ rr:column "flightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:originAirport ; rr:objectMap [ rr:column "originAirport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destinationAirport ; rr:objectMap [ rr:column "destinationAirport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departureTime ; rr:objectMap [ rr:column "departureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrivalTime ; rr:objectMap [ rr:column "arrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airlineID ; rr:objectMap [ rr:column "airlineID" ] ] .

<#tm_attachment_2tab_ref_exclusive_areas_3_Flights_airlineID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"airlineID\" FROM \"Flights\" WHERE \"airlineID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{airlineID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_exclusive_areas_4_Flights_destinationAirport_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"destinationAirport\" FROM \"Flights\" WHERE \"destinationAirport\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_destinationAirport ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{destinationAirport}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_exclusive_areas_5_Flights_originAirport_fk> a rr:TriplesMap ;
