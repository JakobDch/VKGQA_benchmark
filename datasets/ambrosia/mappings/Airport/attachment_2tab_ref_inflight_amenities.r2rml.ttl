@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_inflight_amenities_0_Aircraft_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\" FROM \"Aircraft\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{id}" ; rr:class :Aircraft ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_ref_inflight_amenities_1_Onboard_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Service_name\", \"Aircraft_id\" FROM \"Onboard_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/OnboardServices/{id}" ; rr:class :OnboardServices ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Service_name ; rr:objectMap [ rr:column "Service_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Aircraft_id ; rr:objectMap [ rr:column "Aircraft_id" ] ] .

<#tm_attachment_2tab_ref_inflight_amenities_2_Onboard_Services_Aircraft_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Aircraft_id\" FROM \"Onboard_Services\" WHERE \"Aircraft_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/OnboardServices/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAircraft ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{Aircraft_id}" ; rr:termType rr:IRI ] ] .

