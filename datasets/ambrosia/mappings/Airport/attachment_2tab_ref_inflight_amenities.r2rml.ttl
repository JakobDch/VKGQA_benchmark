<#tm_attachment_2tab_ref_inflight_amenities_6_Passengers_Flight_number_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Flight_number\" FROM \"Passengers\" WHERE \"Flight_number\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{Flight_number}" ; rr:termType rr:IRI ] ] .

