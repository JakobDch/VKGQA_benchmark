  rr:predicateObjectMap [ rr:predicate p:Entertainment_name ; rr:objectMap [ rr:column "Entertainment_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Aircraft_id ; rr:objectMap [ rr:column "Aircraft_id" ] ] .

