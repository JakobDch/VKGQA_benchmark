  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAvailable_locations_destinationLocation ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Available_locations/{destinationLocation}" ; rr:termType rr:IRI ] ] .

