@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_luggage_assistance_0_Available_locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"location\" FROM \"Available_locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Available_locations/{id}" ; rr:class :Available_locations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_attachment_2tab_ref_luggage_assistance_1_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airlineName\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airlineName ; rr:objectMap [ rr:column "airlineName" ] ] .

<#tm_attachment_2tab_ref_luggage_assistance_2_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"originLocation\", \"destinationLocation\", \"airlineId\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:flightID ; rr:objectMap [ rr:column "flightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:originLocation ; rr:objectMap [ rr:column "originLocation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destinationLocation ; rr:objectMap [ rr:column "destinationLocation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airlineId ; rr:objectMap [ rr:column "airlineId" ] ] .

<#tm_attachment_2tab_ref_luggage_assistance_3_Flights_airlineId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"airlineId\" FROM \"Flights\" WHERE \"airlineId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{airlineId}" ; rr:termType rr:IRI ] ] .

