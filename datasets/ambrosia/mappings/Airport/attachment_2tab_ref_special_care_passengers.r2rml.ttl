@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_special_care_passengers_0_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"Origin\", \"Destination\", \"DepartureTime\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Origin ; rr:objectMap [ rr:column "Origin" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] .

<#tm_attachment_2tab_ref_special_care_passengers_1_Passenger_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PassengerID\", \"Email\", \"PhoneNumber\", \"FullName\" FROM \"Passenger\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_2tab_ref_special_care_passengers_2_Assistant_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AssistantID\", \"Name\", \"ContactInfo\" FROM \"Assistant\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Assistant/{AssistantID}" ; rr:class :Assistant ] ;
  rr:predicateObjectMap [ rr:predicate p:AssistantID ; rr:objectMap [ rr:column "AssistantID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ContactInfo ; rr:objectMap [ rr:column "ContactInfo" ] ] .

<#tm_attachment_2tab_ref_special_care_passengers_3_UnaccompaniedMinor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"UMID\", \"PassengerID\", \"AssistantID\" FROM \"UnaccompaniedMinor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/UnaccompaniedMinor/{UMID}" ; rr:class :UnaccompaniedMinor ] ;
  rr:predicateObjectMap [ rr:predicate p:UMID ; rr:objectMap [ rr:column "UMID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AssistantID ; rr:objectMap [ rr:column "AssistantID" ] ] .

<#tm_attachment_2tab_ref_special_care_passengers_4_UnaccompaniedMinor_AssistantID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"UMID\", \"AssistantID\" FROM \"UnaccompaniedMinor\" WHERE \"AssistantID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/UnaccompaniedMinor/{UMID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAssistant ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Assistant/{AssistantID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_special_care_passengers_5_UnaccompaniedMinor_PassengerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"UMID\", \"PassengerID\" FROM \"UnaccompaniedMinor\" WHERE \"PassengerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/UnaccompaniedMinor/{UMID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPassengers ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:termType rr:IRI ] ] .

