  rr:predicateObjectMap [ rr:predicate p:hasDisabledPassenger ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/DisabledPassenger/{SNPID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_special_care_passengers_11_Booking_UMID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"UMID\" FROM \"Booking\" WHERE \"UMID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUnaccompaniedMinor ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/UnaccompaniedMinor/{UMID}" ; rr:termType rr:IRI ] ] .

