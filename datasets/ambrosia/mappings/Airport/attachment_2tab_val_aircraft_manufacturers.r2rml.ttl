@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_aircraft_manufacturers_0_Boeing_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Model\", \"Number_of_seats\", \"Manufacture_year\", \"LastMaintenanceDate\" FROM \"Boeing\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Boeing/{id}" ; rr:class :Boeing ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Model ; rr:objectMap [ rr:column "Model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_seats ; rr:objectMap [ rr:column "Number_of_seats" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Manufacture_year ; rr:objectMap [ rr:column "Manufacture_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastMaintenanceDate ; rr:objectMap [ rr:column "LastMaintenanceDate" ] ] .

<#tm_attachment_2tab_val_aircraft_manufacturers_1_Airbus_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Model\", \"Number_of_seats\", \"Manufacture_year\", \"LastMaintenanceDate\" FROM \"Airbus\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airbus/{id}" ; rr:class :Airbus ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Model ; rr:objectMap [ rr:column "Model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_seats ; rr:objectMap [ rr:column "Number_of_seats" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Manufacture_year ; rr:objectMap [ rr:column "Manufacture_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastMaintenanceDate ; rr:objectMap [ rr:column "LastMaintenanceDate" ] ] .

<#tm_attachment_2tab_val_aircraft_manufacturers_2_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airplaneId\", \"departureTime\", \"arrivalTime\", \"destination\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airplaneId ; rr:objectMap [ rr:column "airplaneId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departureTime ; rr:objectMap [ rr:column "departureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrivalTime ; rr:objectMap [ rr:column "arrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destination ; rr:objectMap [ rr:column "destination" ] ] .

<#tm_attachment_2tab_val_aircraft_manufacturers_3_Flight_airplaneId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airplaneId\" FROM \"Flight\" WHERE \"airplaneId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBoeing ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Boeing/{airplaneId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_aircraft_manufacturers_4_Flight_airplaneId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airplaneId\" FROM \"Flight\" WHERE \"airplaneId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirbus ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airbus/{airplaneId}" ; rr:termType rr:IRI ] ] .

