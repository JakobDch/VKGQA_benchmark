[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Airport_base
target		ex:Airports/{ID} a :Airports ; p:ID {ID} ; p:name {Name} ; p:location {Location} ; p:RunwayLength {RunwayLength} .
source		SELECT `ID`, `Name`, `Location`, `RunwayLength` FROM `Airport`

mappingId	Hotel_base
target		ex:Hotels/{ID} a :Hotels ; p:ID {ID} ; p:AirportID {AirportID} ; p:Airport_Name {Airport_Name} ; p:Airport_Hotel {Airport_Hotel} ; p:Price {Price} .
source		SELECT `ID`, `AirportID`, `Airport_Name`, `Airport_Hotel`, `Price` FROM `Hotel`

mappingId	Hotel_AirportID_fk
target		ex:Hotels/{ID} p:hasAirports ex:Airports/{AirportID} .
source		SELECT `ID`, `AirportID` FROM `Hotel` WHERE `AirportID` IS NOT NULL

mappingId	SleepPod_base
target		ex:SleepPod/{ID} a :SleepPod ; p:ID {ID} ; p:AirportID {AirportID} ; p:Airport_Name {Airport_Name} ; p:Sleep_Pod {Sleep_Pod} ; p:Price {Price} .
source		SELECT `ID`, `AirportID`, `Airport_Name`, `Sleep_Pod`, `Price` FROM `SleepPod`

mappingId	SleepPod_AirportID_fk
target		ex:SleepPod/{ID} p:hasAirports ex:Airports/{AirportID} .
source		SELECT `ID`, `AirportID` FROM `SleepPod` WHERE `AirportID` IS NOT NULL

mappingId	Restaurant_base
target		ex:Restaurant/{ID} a :Restaurant ; p:ID {ID} ; p:AirportID {AirportID} ; p:Airport_Name {Airport_Name} ; p:name {Name} ; p:Cuisine {Cuisine} .
source		SELECT `ID`, `AirportID`, `Airport_Name`, `Name`, `Cuisine` FROM `Restaurant`

mappingId	Restaurant_AirportID_fk
target		ex:Restaurant/{ID} p:hasAirports ex:Airports/{AirportID} .
source		SELECT `ID`, `AirportID` FROM `Restaurant` WHERE `AirportID` IS NOT NULL

mappingId	CarRental_base
target		ex:CarRental/{ID} a :CarRental ; p:ID {ID} ; p:AirportID {AirportID} ; p:Airport_Name {Airport_Name} ; p:Company {Company} ; p:Rates {Rates} ; p:ContactInfo {ContactInfo} .
source		SELECT `ID`, `AirportID`, `Airport_Name`, `Company`, `Rates`, `ContactInfo` FROM `CarRental`

mappingId	CarRental_AirportID_fk
target		ex:CarRental/{ID} p:hasAirports ex:Airports/{AirportID} .
source		SELECT `ID`, `AirportID` FROM `CarRental` WHERE `AirportID` IS NOT NULL

mappingId	ParkingLot_base
target		ex:ParkingLot/{ID} a :ParkingLot ; p:ID {ID} ; p:AirportID {AirportID} ; p:Airport_Name {Airport_Name} ; p:Type {Type} ; p:Spaces {Spaces} ; p:Rate {Rate} .
source		SELECT `ID`, `AirportID`, `Airport_Name`, `Type`, `Spaces`, `Rate` FROM `ParkingLot`

mappingId	ParkingLot_AirportID_fk
target		ex:ParkingLot/{ID} p:hasAirports ex:Airports/{AirportID} .
source		SELECT `ID`, `AirportID` FROM `ParkingLot` WHERE `AirportID` IS NOT NULL

]]
