[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Flight_base
target		ex:Flights/{flightID} a :Flights ; p:flightID {flightID} ; p:airline {airline} ; p:departureAirport {departureAirport} ; p:arrivalAirport {arrivalAirport} ; p:date {date} ; p:duration {duration} .
source		SELECT `flightID`, `airline`, `departureAirport`, `arrivalAirport`, `date`, `duration` FROM `Flight`

mappingId	Employee_base
target		ex:Employees/{employeeID} a :Employees ; p:employeeID {employeeID} ; p:name {name} ; p:position {position} ; p:hireDate {hireDate} ; p:salary {salary} .
source		SELECT `employeeID`, `name`, `position`, `hireDate`, `salary` FROM `Employee`

mappingId	Passenger_base
target		ex:Passengers/{passengerID} a :Passengers ; p:passengerID {passengerID} ; p:firstName {firstName} ; p:lastName {lastName} ; p:birthdate {birthdate} ; p:nationality {nationality} .
source		SELECT `passengerID`, `firstName`, `lastName`, `birthdate`, `nationality` FROM `Passenger`

mappingId	Restaurant_base
target		ex:Restaurant/{restaurantID} a :Restaurant ; p:restaurantID {restaurantID} ; p:airportID {airportID} ; p:name {name} ; p:location {location} ; p:type {type} ; p:openingHours {openingHours} .
source		SELECT `restaurantID`, `airportID`, `name`, `location`, `type`, `openingHours` FROM `Restaurant`

mappingId	Bar_base
target		ex:Bar/{barID} a :Bar ; p:barID {barID} ; p:airportID {airportID} ; p:name {name} ; p:location {location} ; p:capacity {capacity} ; p:openingHours {openingHours} .
source		SELECT `barID`, `airportID`, `name`, `location`, `capacity`, `openingHours` FROM `Bar`

]]
