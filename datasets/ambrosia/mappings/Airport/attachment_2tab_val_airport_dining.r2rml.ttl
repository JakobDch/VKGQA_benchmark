  rr:logicalTable [ rr:sqlQuery """SELECT \"restaurantID\", \"airportID\", \"name\", \"location\", \"type\", \"openingHours\" FROM \"Restaurant\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Restaurant/{restaurantID}" ; rr:class :Restaurant ] ;
