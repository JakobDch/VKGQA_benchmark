@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_airport_dining_0_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flightID\", \"airline\", \"departureAirport\", \"arrivalAirport\", \"date\", \"duration\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:flightID ; rr:objectMap [ rr:column "flightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airline ; rr:objectMap [ rr:column "airline" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departureAirport ; rr:objectMap [ rr:column "departureAirport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrivalAirport ; rr:objectMap [ rr:column "arrivalAirport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration ; rr:objectMap [ rr:column "duration" ] ] .

