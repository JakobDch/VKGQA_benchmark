@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_airport_facilities_0_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"Airline\", \"Destination\", \"DepartureTime\", \"ArrivalTime\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Airline ; rr:objectMap [ rr:column "Airline" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] .

<#tm_attachment_2tab_val_airport_facilities_1_Passengers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PassengerID\", \"Name\", \"Age\", \"Nationality\" FROM \"Passengers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Nationality ; rr:objectMap [ rr:column "Nationality" ] ] .

<#tm_attachment_2tab_val_airport_facilities_2_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"PassengerID\", \"FlightID\", \"Class\", \"Price\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Bookings/{BookingID}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:BookingID ; rr:objectMap [ rr:column "BookingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Class ; rr:objectMap [ rr:column "Class" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_attachment_2tab_val_airport_facilities_3_Bookings_FlightID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"FlightID\" FROM \"Bookings\" WHERE \"FlightID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_airport_facilities_4_Bookings_PassengerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"PassengerID\" FROM \"Bookings\" WHERE \"PassengerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPassengers ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:termType rr:IRI ] ] .

