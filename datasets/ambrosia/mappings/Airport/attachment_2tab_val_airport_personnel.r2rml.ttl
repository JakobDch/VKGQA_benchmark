@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_airport_personnel_0_Air_traffic_controller_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Experience\", \"Salary\", \"Training_Center\" FROM \"Air_traffic_controller\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Air_traffic_controller/{id}" ; rr:class :Air_traffic_controller ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience ; rr:objectMap [ rr:column "Experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Training_Center ; rr:objectMap [ rr:column "Training_Center" ] ] .

<#tm_attachment_2tab_val_airport_personnel_1_Ground_staff_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Experience\", \"Salary\", \"Role\" FROM \"Ground_staff\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Ground_staff/{id}" ; rr:class :Ground_staff ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience ; rr:objectMap [ rr:column "Experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Role ; rr:objectMap [ rr:column "Role" ] ] .

<#tm_attachment_2tab_val_airport_personnel_2_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Date\", \"Time\", \"Destination\", \"Pilot_id\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Time ; rr:objectMap [ rr:column "Time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Pilot_id ; rr:objectMap [ rr:column "Pilot_id" ] ] .

<#tm_attachment_2tab_val_airport_personnel_3_Flight_Pilot_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Pilot_id\" FROM \"Flight\" WHERE \"Pilot_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPilots ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Pilots/{Pilot_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_airport_personnel_4_Pilots_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"License_Number\", \"Total_Flights\" FROM \"Pilots\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Pilots/{id}" ; rr:class :Pilots ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:License_Number ; rr:objectMap [ rr:column "License_Number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Total_Flights ; rr:objectMap [ rr:column "Total_Flights" ] ] .

<#tm_attachment_2tab_val_airport_personnel_5_Runway_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Length\", \"Width\", \"Location\" FROM \"Runway\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Runways/{id}" ; rr:class :Runways ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Length ; rr:objectMap [ rr:column "Length" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Width ; rr:objectMap [ rr:column "Width" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_attachment_2tab_val_airport_personnel_6_Planes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Model\", \"Registration_number\", \"Capacity\", \"Current_Location\" FROM \"Planes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{id}" ; rr:class :Planes ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Model ; rr:objectMap [ rr:column "Model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Registration_number ; rr:objectMap [ rr:column "Registration_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Current_Location ; rr:objectMap [ rr:column "Current_Location" ] ] .

<#tm_attachment_2tab_val_airport_personnel_7_Planes_Current_Location_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Current_Location\" FROM \"Planes\" WHERE \"Current_Location\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRunways ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Runways/{Current_Location}" ; rr:termType rr:IRI ] ] .

