[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Lost_Property_base
target		ex:LostProperties/{ID} a :LostProperties ; p:ID {ID} ; p:Item {Item} ; p:FoundAt {FoundAt} ; p:Description {Description} ; p:Date {Date} ; p:Owner {Owner} .
source		SELECT `ID`, `Item`, `FoundAt`, `Description`, `Date`, `Owner` FROM `Lost_Property`

mappingId	Customer_Complaints_base
target		ex:Complaints/{ComplaintID} a :Complaints ; p:ComplaintID {ComplaintID} ; p:CustomerName {CustomerName} ; p:FlightNumber {FlightNumber} ; p:Issue {Issue} ; p:Resolution {Resolution} ; p:Date {Date} .
source		SELECT `ComplaintID`, `CustomerName`, `FlightNumber`, `Issue`, `Resolution`, `Date` FROM `Customer_Complaints`

mappingId	Flights_base
target		ex:Flights/{FlightNumber} a :Flights ; p:FlightNumber {FlightNumber} ; p:Airline {Airline} ; p:DepartureTime {DepartureTime} ; p:ArrivalTime {ArrivalTime} ; p:OriginAirport {OriginAirport} ; p:DestinationAirport {DestinationAirport} .
source		SELECT `FlightNumber`, `Airline`, `DepartureTime`, `ArrivalTime`, `OriginAirport`, `DestinationAirport` FROM `Flights`

mappingId	Aircraft_base
target		ex:Aircraft/{Registration} a :Aircraft ; p:Registration {Registration} ; p:Model {Model} ; p:Manufacturer {Manufacturer} ; p:YearOfManufacture {YearOfManufacture} ; p:SeatCapacity {SeatCapacity} .
source		SELECT `Registration`, `Model`, `Manufacturer`, `YearOfManufacture`, `SeatCapacity` FROM `Aircraft`

mappingId	Employees_base
target		ex:Employees/{EmployeeID} a :Employees ; p:EmployeeID {EmployeeID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:JobTitle {JobTitle} ; p:HireDate {HireDate} .
source		SELECT `EmployeeID`, `FirstName`, `LastName`, `JobTitle`, `HireDate` FROM `Employees`

]]
