  rr:predicateObjectMap [ rr:predicate p:YearOfManufacture ; rr:objectMap [ rr:column "YearOfManufacture" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SeatCapacity ; rr:objectMap [ rr:column "SeatCapacity" ] ] .

<#tm_attachment_2tab_val_airport_services_4_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EmployeeID\", \"FirstName\", \"LastName\", \"JobTitle\", \"HireDate\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Employees/{EmployeeID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:EmployeeID ; rr:objectMap [ rr:column "EmployeeID" ] ] ;
