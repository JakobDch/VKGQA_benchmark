@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_airport_services_0_Lost_Property_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Item\", \"FoundAt\", \"Description\", \"Date\", \"Owner\" FROM \"Lost_Property\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/LostProperties/{ID}" ; rr:class :LostProperties ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Item ; rr:objectMap [ rr:column "Item" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FoundAt ; rr:objectMap [ rr:column "FoundAt" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Owner ; rr:objectMap [ rr:column "Owner" ] ] .

<#tm_attachment_2tab_val_airport_services_1_Customer_Complaints_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ComplaintID\", \"CustomerName\", \"FlightNumber\", \"Issue\", \"Resolution\", \"Date\" FROM \"Customer_Complaints\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Complaints/{ComplaintID}" ; rr:class :Complaints ] ;
  rr:predicateObjectMap [ rr:predicate p:ComplaintID ; rr:objectMap [ rr:column "ComplaintID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerName ; rr:objectMap [ rr:column "CustomerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightNumber ; rr:objectMap [ rr:column "FlightNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Issue ; rr:objectMap [ rr:column "Issue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Resolution ; rr:objectMap [ rr:column "Resolution" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] .

<#tm_attachment_2tab_val_airport_services_2_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightNumber\", \"Airline\", \"DepartureTime\", \"ArrivalTime\", \"OriginAirport\", \"DestinationAirport\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightNumber}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightNumber ; rr:objectMap [ rr:column "FlightNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Airline ; rr:objectMap [ rr:column "Airline" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OriginAirport ; rr:objectMap [ rr:column "OriginAirport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DestinationAirport ; rr:objectMap [ rr:column "DestinationAirport" ] ] .

<#tm_attachment_2tab_val_airport_services_3_Aircraft_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Registration\", \"Model\", \"Manufacturer\", \"YearOfManufacture\", \"SeatCapacity\" FROM \"Aircraft\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{Registration}" ; rr:class :Aircraft ] ;
  rr:predicateObjectMap [ rr:predicate p:Registration ; rr:objectMap [ rr:column "Registration" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Model ; rr:objectMap [ rr:column "Model" ] ] ;
