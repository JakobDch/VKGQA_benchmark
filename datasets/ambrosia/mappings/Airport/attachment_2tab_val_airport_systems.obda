[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Navigation_Systems_base
target		ex:Navigation_Systems/{SystemID} a :Navigation_Systems ; p:SystemID {SystemID} ; p:Airport {Airport} ; p:TypeOfSystem {TypeOfSystem} ; p:YearInstalled {YearInstalled} ; p:MaintenanceFrequency {MaintenanceFrequency} .
source		SELECT `SystemID`, `Airport`, `TypeOfSystem`, `YearInstalled`, `MaintenanceFrequency` FROM `Navigation_Systems`

mappingId	Communication_Systems_base
target		ex:Communication_Systems/{SystemID} a :Communication_Systems ; p:SystemID {SystemID} ; p:Airport {Airport} ; p:TypeOfSystem {TypeOfSystem} ; p:FrequencyInUse {FrequencyInUse} ; p:LastUpgradeYear {LastUpgradeYear} .
source		SELECT `SystemID`, `Airport`, `TypeOfSystem`, `FrequencyInUse`, `LastUpgradeYear` FROM `Communication_Systems`

mappingId	Runways_base
target		ex:Runways/{ID} a :Runways ; p:ID {ID} ; p:Airport {Airport} ; p:Length {Length} ; p:Width {Width} ; p:SurfaceType {SurfaceType} .
source		SELECT `ID`, `Airport`, `Length`, `Width`, `SurfaceType` FROM `Runways`

mappingId	Terminals_base
target		ex:Terminals/{ID} a :Terminals ; p:ID {ID} ; p:Airport {Airport} ; p:name {Name} ; p:NumberOfGates {NumberOfGates} ; p:ServicesOffered {ServicesOffered} .
source		SELECT `ID`, `Airport`, `Name`, `NumberOfGates`, `ServicesOffered` FROM `Terminals`

]]
