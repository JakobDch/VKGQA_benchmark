@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_airport_systems_0_Navigation_Systems_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SystemID\", \"Airport\", \"TypeOfSystem\", \"YearInstalled\", \"MaintenanceFrequency\" FROM \"Navigation_Systems\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Navigation_Systems/{SystemID}" ; rr:class :Navigation_Systems ] ;
  rr:predicateObjectMap [ rr:predicate p:SystemID ; rr:objectMap [ rr:column "SystemID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Airport ; rr:objectMap [ rr:column "Airport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeOfSystem ; rr:objectMap [ rr:column "TypeOfSystem" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearInstalled ; rr:objectMap [ rr:column "YearInstalled" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MaintenanceFrequency ; rr:objectMap [ rr:column "MaintenanceFrequency" ] ] .

<#tm_attachment_2tab_val_airport_systems_1_Communication_Systems_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SystemID\", \"Airport\", \"TypeOfSystem\", \"FrequencyInUse\", \"LastUpgradeYear\" FROM \"Communication_Systems\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Communication_Systems/{SystemID}" ; rr:class :Communication_Systems ] ;
  rr:predicateObjectMap [ rr:predicate p:SystemID ; rr:objectMap [ rr:column "SystemID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Airport ; rr:objectMap [ rr:column "Airport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeOfSystem ; rr:objectMap [ rr:column "TypeOfSystem" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FrequencyInUse ; rr:objectMap [ rr:column "FrequencyInUse" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastUpgradeYear ; rr:objectMap [ rr:column "LastUpgradeYear" ] ] .

<#tm_attachment_2tab_val_airport_systems_2_Runways_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Airport\", \"Length\", \"Width\", \"SurfaceType\" FROM \"Runways\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Runways/{ID}" ; rr:class :Runways ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Airport ; rr:objectMap [ rr:column "Airport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Length ; rr:objectMap [ rr:column "Length" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Width ; rr:objectMap [ rr:column "Width" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SurfaceType ; rr:objectMap [ rr:column "SurfaceType" ] ] .

<#tm_attachment_2tab_val_airport_systems_3_Terminals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Airport\", \"Name\", \"NumberOfGates\", \"ServicesOffered\" FROM \"Terminals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{ID}" ; rr:class :Terminals ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Airport ; rr:objectMap [ rr:column "Airport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfGates ; rr:objectMap [ rr:column "NumberOfGates" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ServicesOffered ; rr:objectMap [ rr:column "ServicesOffered" ] ] .

