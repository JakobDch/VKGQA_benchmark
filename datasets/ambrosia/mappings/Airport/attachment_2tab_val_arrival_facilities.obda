[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	terminal_base
target		ex:Terminals/{id} a :Terminals ; p:id {id} ; p:name {name} ; p:location {location} .
source		SELECT `id`, `name`, `location` FROM `terminal`

mappingId	arrival_hall_base
target		ex:arrival_hall/{id} a :arrival_hall ; p:id {id} ; p:terminal_id {terminal_id} ; p:Arrival_Hall {Arrival_Hall} ; p:Maximum_Capacity {Maximum_Capacity} ; p:number_of_gates {number_of_gates} .
source		SELECT `id`, `terminal_id`, `Arrival_Hall`, `Maximum_Capacity`, `number_of_gates` FROM `arrival_hall`

mappingId	arrival_hall_terminal_id_fk
target		ex:arrival_hall/{id} p:hasTerminals ex:Terminals/{terminal_id} .
source		SELECT `id`, `terminal_id` FROM `arrival_hall` WHERE `terminal_id` IS NOT NULL

mappingId	baggage_reclaim_base
target		ex:baggage_reclaim/{id} a :baggage_reclaim ; p:id {id} ; p:terminal_id {terminal_id} ; p:Baggage_Reclaim {Baggage_Reclaim} ; p:Maximum_Capacity {Maximum_Capacity} ; p:number_of_carousels {number_of_carousels} .
source		SELECT `id`, `terminal_id`, `Baggage_Reclaim`, `Maximum_Capacity`, `number_of_carousels` FROM `baggage_reclaim`

mappingId	baggage_reclaim_terminal_id_fk
target		ex:baggage_reclaim/{id} p:hasTerminals ex:Terminals/{terminal_id} .
source		SELECT `id`, `terminal_id` FROM `baggage_reclaim` WHERE `terminal_id` IS NOT NULL

mappingId	flight_base
target		ex:Flights/{id} a :Flights ; p:id {id} ; p:terminal_id {terminal_id} .
source		SELECT `id`, `terminal_id` FROM `flight`

mappingId	flight_terminal_id_fk
target		ex:Flights/{id} p:hasTerminals ex:Terminals/{terminal_id} .
source		SELECT `id`, `terminal_id` FROM `flight` WHERE `terminal_id` IS NOT NULL

]]
