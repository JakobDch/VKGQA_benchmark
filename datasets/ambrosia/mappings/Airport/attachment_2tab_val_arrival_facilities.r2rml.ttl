@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_arrival_facilities_0_terminal_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"terminal\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{id}" ; rr:class :Terminals ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_attachment_2tab_val_arrival_facilities_1_arrival_hall_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"terminal_id\", \"Arrival_Hall\", \"Maximum_Capacity\", \"number_of_gates\" FROM \"arrival_hall\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/arrival_hall/{id}" ; rr:class :arrival_hall ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:terminal_id ; rr:objectMap [ rr:column "terminal_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Arrival_Hall ; rr:objectMap [ rr:column "Arrival_Hall" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Maximum_Capacity ; rr:objectMap [ rr:column "Maximum_Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number_of_gates ; rr:objectMap [ rr:column "number_of_gates" ] ] .

<#tm_attachment_2tab_val_arrival_facilities_2_arrival_hall_terminal_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"terminal_id\" FROM \"arrival_hall\" WHERE \"terminal_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/arrival_hall/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{terminal_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_arrival_facilities_3_baggage_reclaim_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"terminal_id\", \"Baggage_Reclaim\", \"Maximum_Capacity\", \"number_of_carousels\" FROM \"baggage_reclaim\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/baggage_reclaim/{id}" ; rr:class :baggage_reclaim ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:terminal_id ; rr:objectMap [ rr:column "terminal_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Baggage_Reclaim ; rr:objectMap [ rr:column "Baggage_Reclaim" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Maximum_Capacity ; rr:objectMap [ rr:column "Maximum_Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number_of_carousels ; rr:objectMap [ rr:column "number_of_carousels" ] ] .

<#tm_attachment_2tab_val_arrival_facilities_4_baggage_reclaim_terminal_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"terminal_id\" FROM \"baggage_reclaim\" WHERE \"terminal_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/baggage_reclaim/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{terminal_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_arrival_facilities_5_flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"terminal_id\" FROM \"flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:terminal_id ; rr:objectMap [ rr:column "terminal_id" ] ] .

<#tm_attachment_2tab_val_arrival_facilities_6_flight_terminal_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"terminal_id\" FROM \"flight\" WHERE \"terminal_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{terminal_id}" ; rr:termType rr:IRI ] ] .

