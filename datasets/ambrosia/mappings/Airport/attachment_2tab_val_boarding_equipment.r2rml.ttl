@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_boarding_equipment_0_Terminals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\" FROM \"Terminals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{ID}" ; rr:class :Terminals ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_val_boarding_equipment_1_Jet_Bridges_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"BridgeName\", \"TerminalID\" FROM \"Jet_Bridges\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Jet_Bridges/{ID}" ; rr:class :Jet_Bridges ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BridgeName ; rr:objectMap [ rr:column "BridgeName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TerminalID ; rr:objectMap [ rr:column "TerminalID" ] ] .

<#tm_attachment_2tab_val_boarding_equipment_2_Jet_Bridges_TerminalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"TerminalID\" FROM \"Jet_Bridges\" WHERE \"TerminalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Jet_Bridges/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{TerminalID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_boarding_equipment_3_Staircars_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"CarName\", \"TerminalID\" FROM \"Staircars\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Staircars/{ID}" ; rr:class :Staircars ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CarName ; rr:objectMap [ rr:column "CarName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TerminalID ; rr:objectMap [ rr:column "TerminalID" ] ] .

<#tm_attachment_2tab_val_boarding_equipment_4_Staircars_TerminalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"TerminalID\" FROM \"Staircars\" WHERE \"TerminalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Staircars/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{TerminalID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_boarding_equipment_5_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirlineID\", \"CompanyName\", \"HomeTerminalID\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{AirlineID}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlineID ; rr:objectMap [ rr:column "AirlineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyName ; rr:objectMap [ rr:column "CompanyName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HomeTerminalID ; rr:objectMap [ rr:column "HomeTerminalID" ] ] .

<#tm_attachment_2tab_val_boarding_equipment_6_Airlines_HomeTerminalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirlineID\", \"HomeTerminalID\" FROM \"Airlines\" WHERE \"HomeTerminalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{AirlineID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{HomeTerminalID}" ; rr:termType rr:IRI ] ] .

