[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Customs_base
target		ex:Customs/{id} a :Customs ; p:id {id} ; p:Airport {Airport} ; p:CustomOfficerName {CustomOfficerName} ; p:CustomOfficePhoneNumber {CustomOfficePhoneNumber} ; p:OpeningHours {OpeningHours} .
source		SELECT `id`, `Airport`, `CustomOfficerName`, `CustomOfficePhoneNumber`, `OpeningHours` FROM `Customs`

mappingId	Immigration_base
target		ex:Immigration/{id} a :Immigration ; p:id {id} ; p:Airport {Airport} ; p:ImmigrationOfficerName {ImmigrationOfficerName} ; p:ImmigrationOfficePhoneNumber {ImmigrationOfficePhoneNumber} ; p:OpeningHours {OpeningHours} .
source		SELECT `id`, `Airport`, `ImmigrationOfficerName`, `ImmigrationOfficePhoneNumber`, `OpeningHours` FROM `Immigration`

mappingId	Runway_base
target		ex:Runways/{id} a :Runways ; p:id {id} ; p:Airport {Airport} ; p:Length {Length} ; p:Width {Width} ; p:SurfaceType {SurfaceType} .
source		SELECT `id`, `Airport`, `Length`, `Width`, `SurfaceType` FROM `Runway`

mappingId	Terminal_base
target		ex:Terminals/{id} a :Terminals ; p:id {id} ; p:Airport {Airport} ; p:name {Name} ; p:NumberOfDoors {NumberOfDoors} ; p:Facilities {Facilities} .
source		SELECT `id`, `Airport`, `Name`, `NumberOfDoors`, `Facilities` FROM `Terminal`

mappingId	Flight_base
target		ex:Flights/{id} a :Flights ; p:id {id} ; p:DepartureTime {DepartureTime} ; p:ArrivalTime {ArrivalTime} ; p:DestinationAirport {DestinationAirport} ; p:PlaneId {PlaneId} .
source		SELECT `id`, `DepartureTime`, `ArrivalTime`, `DestinationAirport`, `PlaneId` FROM `Flight`

mappingId	Flight_PlaneId_fk
target		ex:Flights/{id} p:hasAircraft ex:Aircraft/{PlaneId} .
source		SELECT `id`, `PlaneId` FROM `Flight` WHERE `PlaneId` IS NOT NULL

mappingId	Aircraft_base
target		ex:Aircraft/{id} a :Aircraft ; p:id {id} ; p:Model {Model} ; p:Capacity {Capacity} ; p:RegistrationNumber {RegistrationNumber} ; p:Manufacturer {Manufacturer} .
source		SELECT `id`, `Model`, `Capacity`, `RegistrationNumber`, `Manufacturer` FROM `Aircraft`

]]
