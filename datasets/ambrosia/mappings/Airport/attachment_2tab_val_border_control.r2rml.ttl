<#tm_attachment_2tab_val_border_control_4_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"DepartureTime\", \"ArrivalTime\", \"DestinationAirport\", \"PlaneId\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DestinationAirport ; rr:objectMap [ rr:column "DestinationAirport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PlaneId ; rr:objectMap [ rr:column "PlaneId" ] ] .

<#tm_attachment_2tab_val_border_control_5_Flight_PlaneId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"PlaneId\" FROM \"Flight\" WHERE \"PlaneId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAircraft ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{PlaneId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_border_control_6_Aircraft_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Model\", \"Capacity\", \"RegistrationNumber\", \"Manufacturer\" FROM \"Aircraft\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{id}" ; rr:class :Aircraft ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Model ; rr:objectMap [ rr:column "Model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RegistrationNumber ; rr:objectMap [ rr:column "RegistrationNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Manufacturer ; rr:objectMap [ rr:column "Manufacturer" ] ] .

