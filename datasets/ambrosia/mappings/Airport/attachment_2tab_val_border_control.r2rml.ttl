@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_border_control_0_Customs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Airport\", \"CustomOfficerName\", \"CustomOfficePhoneNumber\", \"OpeningHours\" FROM \"Customs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Customs/{id}" ; rr:class :Customs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Airport ; rr:objectMap [ rr:column "Airport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomOfficerName ; rr:objectMap [ rr:column "CustomOfficerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomOfficePhoneNumber ; rr:objectMap [ rr:column "CustomOfficePhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OpeningHours ; rr:objectMap [ rr:column "OpeningHours" ] ] .

