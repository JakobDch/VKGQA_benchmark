@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_development_projects_0_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Location\", \"YearEstablished\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearEstablished ; rr:objectMap [ rr:column "YearEstablished" ] ] .

<#tm_attachment_2tab_val_development_projects_1_Expansions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"AirportID\", \"Airport_Expansion\", \"Increased_Capacity\" FROM \"Expansions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Expansions/{id}" ; rr:class :Expansions ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AirportID ; rr:objectMap [ rr:column "AirportID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Airport_Expansion ; rr:objectMap [ rr:column "Airport_Expansion" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Increased_Capacity ; rr:objectMap [ rr:column "Increased_Capacity" ] ] .

<#tm_attachment_2tab_val_development_projects_2_Expansions_AirportID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"AirportID\" FROM \"Expansions\" WHERE \"AirportID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Expansions/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{AirportID}" ; rr:termType rr:IRI ] ] .

