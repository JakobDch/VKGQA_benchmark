  rr:predicateObjectMap [ rr:predicate p:LoungeID ; rr:objectMap [ rr:column "LoungeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Amenities ; rr:objectMap [ rr:column "Amenities" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] .

<#tm_attachment_2tab_val_exclusive_areas_8_VIP_Lounges_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LoungeID\", \"Name\", \"Location\", \"Amenities\", \"AccessLevel\" FROM \"VIP_Lounges\"""" ] ;
