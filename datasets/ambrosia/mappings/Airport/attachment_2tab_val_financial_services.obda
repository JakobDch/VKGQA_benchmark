[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Currency_Exchange_Service_base
target		ex:Currency_Exchange_Service/{id} a :Currency_Exchange_Service ; p:id {id} ; p:name {Name} ; p:Location_Within_Terminal {Location_Within_Terminal} ; p:Hours_of_Operation {Hours_of_Operation} ; p:Phone_Number {Phone_Number} ; p:email {Email} .
source		SELECT `id`, `Name`, `Location_Within_Terminal`, `Hours_of_Operation`, `Phone_Number`, `Email` FROM `Currency_Exchange_Service`

mappingId	ATM_Machine_base
target		ex:ATM_Machine/{id} a :ATM_Machine ; p:id {id} ; p:name {Name} ; p:Location_Within_Terminal {Location_Within_Terminal} ; p:Operating_Company {Operating_Company} ; p:Fees {Fees} ; p:Language_Options {Language_Options} .
source		SELECT `id`, `Name`, `Location_Within_Terminal`, `Operating_Company`, `Fees`, `Language_Options` FROM `ATM_Machine`

mappingId	Food_and_Beverage_base
target		ex:Food_and_Beverage/{id} a :Food_and_Beverage ; p:id {id} ; p:name {Name} ; p:Type {Type} ; p:Location_Within_Terminal {Location_Within_Terminal} ; p:Menu {Menu} ; p:Contact_Information {Contact_Information} .
source		SELECT `id`, `Name`, `Type`, `Location_Within_Terminal`, `Menu`, `Contact_Information` FROM `Food_and_Beverage`

mappingId	Shops_base
target		ex:Shops/{id} a :Shops ; p:id {id} ; p:name {Name} ; p:Category {Category} ; p:Location_Within_Terminal {Location_Within_Terminal} ; p:Product_Offerings {Product_Offerings} ; p:Business_Hours {Business_Hours} .
source		SELECT `id`, `Name`, `Category`, `Location_Within_Terminal`, `Product_Offerings`, `Business_Hours` FROM `Shops`

mappingId	Baggage_Claim_base
target		ex:BaggageClaims/{id} a :BaggageClaims ; p:id {id} ; p:Terminal {Terminal} ; p:Carousel_Numbers {Carousel_Numbers} ; p:Flight_Info {Flight_Info} ; p:Lost_And_Found {Lost_And_Found} .
source		SELECT `id`, `Terminal`, `Carousel_Numbers`, `Flight_Info`, `Lost_And_Found` FROM `Baggage_Claim`

mappingId	Parking_base
target		ex:Parking/{id} a :Parking ; p:id {id} ; p:Lot_Name {Lot_Name} ; p:location {Location} ; p:Daily_Rate {Daily_Rate} ; p:Weekly_Rate {Weekly_Rate} ; p:Monthly_Rate {Monthly_Rate} .
source		SELECT `id`, `Lot_Name`, `Location`, `Daily_Rate`, `Weekly_Rate`, `Monthly_Rate` FROM `Parking`

]]
