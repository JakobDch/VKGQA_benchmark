@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_financial_services_0_Currency_Exchange_Service_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Location_Within_Terminal\", \"Hours_of_Operation\", \"Phone_Number\", \"Email\" FROM \"Currency_Exchange_Service\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Currency_Exchange_Service/{id}" ; rr:class :Currency_Exchange_Service ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Location_Within_Terminal ; rr:objectMap [ rr:column "Location_Within_Terminal" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Hours_of_Operation ; rr:objectMap [ rr:column "Hours_of_Operation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Phone_Number ; rr:objectMap [ rr:column "Phone_Number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

