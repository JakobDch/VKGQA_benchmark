@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_inflight_amenities_0_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"country\", \"city\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] .

<#tm_attachment_2tab_val_inflight_amenities_1_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"headquartered_at\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:headquartered_at ; rr:objectMap [ rr:column "headquartered_at" ] ] .

<#tm_attachment_2tab_val_inflight_amenities_2_Airlines_headquartered_at_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"headquartered_at\" FROM \"Airlines\" WHERE \"headquartered_at\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{headquartered_at}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_inflight_amenities_3_Aircrafts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"model\", \"max_passengers\", \"max_range\", \"airline_id\" FROM \"Aircrafts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{id}" ; rr:class :Aircraft ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:model ; rr:objectMap [ rr:column "model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:max_passengers ; rr:objectMap [ rr:column "max_passengers" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:max_range ; rr:objectMap [ rr:column "max_range" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airline_id ; rr:objectMap [ rr:column "airline_id" ] ] .

<#tm_attachment_2tab_val_inflight_amenities_4_Aircrafts_airline_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airline_id\" FROM \"Aircrafts\" WHERE \"airline_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{airline_id}" ; rr:termType rr:IRI ] ] .

