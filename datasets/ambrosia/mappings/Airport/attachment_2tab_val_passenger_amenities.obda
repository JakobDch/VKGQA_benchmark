[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Lounge_base
target		ex:Lounge/{id} a :Lounge ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Capacity {Capacity} ; p:Accessibility {Accessibility} .
source		SELECT `id`, `Name`, `Location`, `Capacity`, `Accessibility` FROM `Lounge`

mappingId	ObservationDeck_base
target		ex:ObservationDeck/{id} a :ObservationDeck ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:ViewType {ViewType} ; p:Accessibility {Accessibility} .
source		SELECT `id`, `Name`, `Location`, `ViewType`, `Accessibility` FROM `ObservationDeck`

mappingId	Flight_base
target		ex:Flights/{id} a :Flights ; p:id {id} ; p:FlightNumber {FlightNumber} ; p:DepartureTime {DepartureTime} ; p:Destination {Destination} ; p:AircraftModel {AircraftModel} .
source		SELECT `id`, `FlightNumber`, `DepartureTime`, `Destination`, `AircraftModel` FROM `Flight`

mappingId	Gate_base
target		ex:Gates/{id} a :Gates ; p:id {id} ; p:GateNumber {GateNumber} ; p:TerminalName {TerminalName} ; p:AirlinesCode {AirlinesCode} .
source		SELECT `id`, `GateNumber`, `TerminalName`, `AirlinesCode` FROM `Gate`

mappingId	SecurityCheckpoint_base
target		ex:SecurityCheckpoints/{id} a :SecurityCheckpoints ; p:id {id} ; p:CheckpointLocation {CheckpointLocation} ; p:Accessibility {Accessibility} ; p:OperatingHours {OperatingHours} .
source		SELECT `id`, `CheckpointLocation`, `Accessibility`, `OperatingHours` FROM `SecurityCheckpoint`

]]
