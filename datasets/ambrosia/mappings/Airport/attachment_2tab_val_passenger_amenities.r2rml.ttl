@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_passenger_amenities_0_Lounge_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Location\", \"Capacity\", \"Accessibility\" FROM \"Lounge\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Lounge/{id}" ; rr:class :Lounge ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Accessibility ; rr:objectMap [ rr:column "Accessibility" ] ] .

