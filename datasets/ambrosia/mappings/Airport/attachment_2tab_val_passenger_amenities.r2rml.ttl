  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Location\", \"ViewType\", \"Accessibility\" FROM \"ObservationDeck\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/ObservationDeck/{id}" ; rr:class :ObservationDeck ] ;
