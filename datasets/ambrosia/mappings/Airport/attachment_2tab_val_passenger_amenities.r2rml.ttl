  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightNumber ; rr:objectMap [ rr:column "FlightNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AircraftModel ; rr:objectMap [ rr:column "AircraftModel" ] ] .

<#tm_attachment_2tab_val_passenger_amenities_3_Gate_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"GateNumber\", \"TerminalName\", \"AirlinesCode\" FROM \"Gate\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Gates/{id}" ; rr:class :Gates ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GateNumber ; rr:objectMap [ rr:column "GateNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TerminalName ; rr:objectMap [ rr:column "TerminalName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlinesCode ; rr:objectMap [ rr:column "AirlinesCode" ] ] .

<#tm_attachment_2tab_val_passenger_amenities_4_SecurityCheckpoint_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"CheckpointLocation\", \"Accessibility\", \"OperatingHours\" FROM \"SecurityCheckpoint\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/SecurityCheckpoints/{id}" ; rr:class :SecurityCheckpoints ] ;
