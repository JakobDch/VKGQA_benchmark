[PrefixDeclaration]
:	http://ambrosia.example.org/airport#
p:	http://ambrosia.example.org/airport/prop#
ex:	http://ambrosia.example.org/airport/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	DutyFreeShops_base
target		ex:Duty_Free_Shops/{ShopID} a :Duty_Free_Shops ; p:ShopID {ShopID} ; p:name {Name} ; p:location {Location} ; p:Size {Size} ; p:AnnualRevenue {AnnualRevenue} .
source		SELECT `ShopID`, `Name`, `Location`, `Size`, `AnnualRevenue` FROM `DutyFreeShops`

mappingId	SouvenirStores_base
target		ex:SouvenirStores/{StoreID} a :SouvenirStores ; p:StoreID {StoreID} ; p:name {Name} ; p:location {Location} ; p:InventoryCount {InventoryCount} ; p:AveragePurchaseAmount {AveragePurchaseAmount} .
source		SELECT `StoreID`, `Name`, `Location`, `InventoryCount`, `AveragePurchaseAmount` FROM `SouvenirStores`

mappingId	Flights_base
target		ex:Flights/{FlightID} a :Flights ; p:FlightID {FlightID} ; p:AirlineName {AirlineName} ; p:DepartureTime {DepartureTime} ; p:ArrivalTime {ArrivalTime} ; p:OriginAirportCode {OriginAirportCode} ; p:DestinationAirportCode {DestinationAirportCode} .
source		SELECT `FlightID`, `AirlineName`, `DepartureTime`, `ArrivalTime`, `OriginAirportCode`, `DestinationAirportCode` FROM `Flights`

mappingId	PassengerCheckIns_base
target		ex:PassengerCheckIns/{CheckInID} a :PassengerCheckIns ; p:CheckInID {CheckInID} ; p:FlightID {FlightID} ; p:PassengerName {PassengerName} ; p:BoardingPassNumber {BoardingPassNumber} ; p:CheckInTime {CheckInTime} .
source		SELECT `CheckInID`, `FlightID`, `PassengerName`, `BoardingPassNumber`, `CheckInTime` FROM `PassengerCheckIns`

mappingId	PassengerCheckIns_FlightID_fk
target		ex:PassengerCheckIns/{CheckInID} p:hasFlights ex:Flights/{FlightID} .
source		SELECT `CheckInID`, `FlightID` FROM `PassengerCheckIns` WHERE `FlightID` IS NOT NULL

]]
