@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_retail_outlets_0_DutyFreeShops_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ShopID\", \"Name\", \"Location\", \"Size\", \"AnnualRevenue\" FROM \"DutyFreeShops\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Duty_Free_Shops/{ShopID}" ; rr:class :Duty_Free_Shops ] ;
  rr:predicateObjectMap [ rr:predicate p:ShopID ; rr:objectMap [ rr:column "ShopID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Size ; rr:objectMap [ rr:column "Size" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AnnualRevenue ; rr:objectMap [ rr:column "AnnualRevenue" ] ] .

<#tm_attachment_2tab_val_retail_outlets_1_SouvenirStores_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StoreID\", \"Name\", \"Location\", \"InventoryCount\", \"AveragePurchaseAmount\" FROM \"SouvenirStores\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/SouvenirStores/{StoreID}" ; rr:class :SouvenirStores ] ;
  rr:predicateObjectMap [ rr:predicate p:StoreID ; rr:objectMap [ rr:column "StoreID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:InventoryCount ; rr:objectMap [ rr:column "InventoryCount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AveragePurchaseAmount ; rr:objectMap [ rr:column "AveragePurchaseAmount" ] ] .

<#tm_attachment_2tab_val_retail_outlets_2_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"AirlineName\", \"DepartureTime\", \"ArrivalTime\", \"OriginAirportCode\", \"DestinationAirportCode\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlineName ; rr:objectMap [ rr:column "AirlineName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OriginAirportCode ; rr:objectMap [ rr:column "OriginAirportCode" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DestinationAirportCode ; rr:objectMap [ rr:column "DestinationAirportCode" ] ] .

<#tm_attachment_2tab_val_retail_outlets_3_PassengerCheckIns_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CheckInID\", \"FlightID\", \"PassengerName\", \"BoardingPassNumber\", \"CheckInTime\" FROM \"PassengerCheckIns\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/PassengerCheckIns/{CheckInID}" ; rr:class :PassengerCheckIns ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckInID ; rr:objectMap [ rr:column "CheckInID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerName ; rr:objectMap [ rr:column "PassengerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BoardingPassNumber ; rr:objectMap [ rr:column "BoardingPassNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckInTime ; rr:objectMap [ rr:column "CheckInTime" ] ] .

<#tm_attachment_2tab_val_retail_outlets_4_PassengerCheckIns_FlightID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CheckInID\", \"FlightID\" FROM \"PassengerCheckIns\" WHERE \"FlightID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/PassengerCheckIns/{CheckInID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:termType rr:IRI ] ] .

