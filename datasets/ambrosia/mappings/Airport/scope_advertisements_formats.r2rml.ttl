@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_advertisements_formats_0_Advertisements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\" FROM \"Advertisements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Advertisements/{id}" ; rr:class :Advertisements ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_advertisements_formats_1_Formats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"format_name\" FROM \"Formats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Formats/{id}" ; rr:class :Formats ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:format_name ; rr:objectMap [ rr:column "format_name" ] ] .

<#tm_scope_advertisements_formats_2_Advertisements_Formats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"advertisement_id\", \"format_id\" FROM \"Advertisements_Formats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Advertisements_Formats/{advertisement_id}/{format_id}" ; rr:class :Advertisements_Formats ] ;
  rr:predicateObjectMap [ rr:predicate p:advertisement_id ; rr:objectMap [ rr:column "advertisement_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:format_id ; rr:objectMap [ rr:column "format_id" ] ] .

<#tm_scope_advertisements_formats_3_Advertisements_Formats_format_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"advertisement_id\", \"format_id\" FROM \"Advertisements_Formats\" WHERE \"format_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Advertisements_Formats/{advertisement_id}/{format_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFormats ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Formats/{format_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_advertisements_formats_4_Advertisements_Formats_advertisement_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"advertisement_id\", \"format_id\" FROM \"Advertisements_Formats\" WHERE \"advertisement_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Advertisements_Formats/{advertisement_id}/{format_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAdvertisements ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Advertisements/{advertisement_id}" ; rr:termType rr:IRI ] ] .

