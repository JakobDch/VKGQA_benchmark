@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_airlines_fleets_0_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"country\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{id}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_scope_airlines_fleets_1_Fleets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"fleetName\", \"capacity\" FROM \"Fleets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Fleets/{id}" ; rr:class :Fleets ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fleetName ; rr:objectMap [ rr:column "fleetName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

<#tm_scope_airlines_fleets_2_Airlines_Fleets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"airlineId\", \"fleetId\" FROM \"Airlines_Fleets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines_Fleets/{airlineId}/{fleetId}" ; rr:class :Airlines_Fleets ] ;
  rr:predicateObjectMap [ rr:predicate p:airlineId ; rr:objectMap [ rr:column "airlineId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fleetId ; rr:objectMap [ rr:column "fleetId" ] ] .

<#tm_scope_airlines_fleets_3_Airlines_Fleets_fleetId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"airlineId\", \"fleetId\" FROM \"Airlines_Fleets\" WHERE \"fleetId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines_Fleets/{airlineId}/{fleetId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFleets ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Fleets/{fleetId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_airlines_fleets_4_Airlines_Fleets_airlineId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"airlineId\", \"fleetId\" FROM \"Airlines_Fleets\" WHERE \"airlineId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines_Fleets/{airlineId}/{fleetId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{airlineId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_airlines_fleets_5_Airlines_Fleets_fleetId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"airlineId\", \"fleetId\" FROM \"Airlines_Fleets\" WHERE \"fleetId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines_Fleets/{airlineId}/{fleetId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFleets ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Fleets/{fleetId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_airlines_fleets_6_Airlines_Fleets_airlineId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"airlineId\", \"fleetId\" FROM \"Airlines_Fleets\" WHERE \"airlineId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines_Fleets/{airlineId}/{fleetId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{airlineId}" ; rr:termType rr:IRI ] ] .

