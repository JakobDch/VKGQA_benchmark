  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Boarding_Areas/{areaId}" ; rr:class :Boarding_Areas ] ;
  rr:predicateObjectMap [ rr:predicate p:areaId ; rr:objectMap [ rr:column "areaId" ] ] ;
