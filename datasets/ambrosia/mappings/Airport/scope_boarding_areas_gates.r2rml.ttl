  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

<#tm_scope_boarding_areas_gates_9_Gates_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"gateId\", \"gateName\" FROM \"Gates\"""" ] ;
