@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_duty_free_shops_products_0_Duty_Free_Shops_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"shop_id\", \"name\", \"location\" FROM \"Duty_Free_Shops\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Duty_Free_Shops/{shop_id}" ; rr:class :Duty_Free_Shops ] ;
  rr:predicateObjectMap [ rr:predicate p:shop_id ; rr:objectMap [ rr:column "shop_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_duty_free_shops_products_1_Products_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"product_id\", \"category\", \"price\" FROM \"Products\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Products/{product_id}" ; rr:class :Products ] ;
  rr:predicateObjectMap [ rr:predicate p:product_id ; rr:objectMap [ rr:column "product_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:category ; rr:objectMap [ rr:column "category" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_duty_free_shops_products_2_Duty_Free_Shops_Products_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"shop_id\", \"product_id\", \"quantity\" FROM \"Duty_Free_Shops_Products\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Duty_Free_Shops_Products/{shop_id}/{product_id}" ; rr:class :Duty_Free_Shops_Products ] ;
  rr:predicateObjectMap [ rr:predicate p:shop_id ; rr:objectMap [ rr:column "shop_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:product_id ; rr:objectMap [ rr:column "product_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "quantity" ] ] .

<#tm_scope_duty_free_shops_products_3_Duty_Free_Shops_Products_product_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"shop_id\", \"product_id\" FROM \"Duty_Free_Shops_Products\" WHERE \"product_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Duty_Free_Shops_Products/{shop_id}/{product_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProducts ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Products/{product_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_duty_free_shops_products_4_Duty_Free_Shops_Products_shop_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"shop_id\", \"product_id\" FROM \"Duty_Free_Shops_Products\" WHERE \"shop_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Duty_Free_Shops_Products/{shop_id}/{product_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDuty_Free_Shops ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Duty_Free_Shops/{shop_id}" ; rr:termType rr:IRI ] ] .

