@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_frequent_flyer_program_benefits_0_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"City\", \"Country\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{ID}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_scope_frequent_flyer_program_benefits_1_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Code\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{ID}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Code ; rr:objectMap [ rr:column "Code" ] ] .

<#tm_scope_frequent_flyer_program_benefits_2_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"DepartureTime\", \"ArrivalTime\", \"AirlineId\", \"FromAirportId\", \"ToAirportId\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlineId ; rr:objectMap [ rr:column "AirlineId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FromAirportId ; rr:objectMap [ rr:column "FromAirportId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ToAirportId ; rr:objectMap [ rr:column "ToAirportId" ] ] .

<#tm_scope_frequent_flyer_program_benefits_3_Flights_ToAirportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"ToAirportId\" FROM \"Flights\" WHERE \"ToAirportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_ToAirportId ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{ToAirportId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_frequent_flyer_program_benefits_4_Flights_FromAirportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"FromAirportId\" FROM \"Flights\" WHERE \"FromAirportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ] ;
