@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_gate_facility_0_Gate_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"gate_id\", \"airport_code\", \"terminal_number\" FROM \"Gate\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Gates/{gate_id}" ; rr:class :Gates ] ;
  rr:predicateObjectMap [ rr:predicate p:gate_id ; rr:objectMap [ rr:column "gate_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airport_code ; rr:objectMap [ rr:column "airport_code" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:terminal_number ; rr:objectMap [ rr:column "terminal_number" ] ] .

<#tm_scope_gate_facility_1_Facility_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"facility_id\", \"name\", \"description\" FROM \"Facility\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Facility/{facility_id}" ; rr:class :Facility ] ;
  rr:predicateObjectMap [ rr:predicate p:facility_id ; rr:objectMap [ rr:column "facility_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_gate_facility_2_Gate_Facility_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"gate_facility_id\", \"gate_id\", \"facility_id\" FROM \"Gate_Facility\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Gate_Facility/{gate_facility_id}" ; rr:class :Gate_Facility ] ;
  rr:predicateObjectMap [ rr:predicate p:gate_facility_id ; rr:objectMap [ rr:column "gate_facility_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:gate_id ; rr:objectMap [ rr:column "gate_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:facility_id ; rr:objectMap [ rr:column "facility_id" ] ] .

<#tm_scope_gate_facility_3_Gate_Facility_facility_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"gate_facility_id\", \"facility_id\" FROM \"Gate_Facility\" WHERE \"facility_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Gate_Facility/{gate_facility_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFacility ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Facility/{facility_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_gate_facility_4_Gate_Facility_gate_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"gate_facility_id\", \"gate_id\" FROM \"Gate_Facility\" WHERE \"gate_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Gate_Facility/{gate_facility_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGates ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Gates/{gate_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_gate_facility_5_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flight_id\", \"airline_name\", \"departure_time\", \"arrival_time\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flight_id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:flight_id ; rr:objectMap [ rr:column "flight_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airline_name ; rr:objectMap [ rr:column "airline_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departure_time ; rr:objectMap [ rr:column "departure_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrival_time ; rr:objectMap [ rr:column "arrival_time" ] ] .

<#tm_scope_gate_facility_6_Aircraft_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"aircraft_id\", \"model\", \"capacity\" FROM \"Aircraft\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Aircraft/{aircraft_id}" ; rr:class :Aircraft ] ;
  rr:predicateObjectMap [ rr:predicate p:aircraft_id ; rr:objectMap [ rr:column "aircraft_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:model ; rr:objectMap [ rr:column "model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

