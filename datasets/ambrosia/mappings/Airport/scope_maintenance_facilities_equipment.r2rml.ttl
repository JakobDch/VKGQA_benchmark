@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_maintenance_facilities_equipment_0_Maintenance_Facilities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Maintenance_Facilities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Maintenance_Facilities/{id}" ; rr:class :Maintenance_Facilities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_maintenance_facilities_equipment_1_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"equipmentId\", \"type\" FROM \"Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Equipment/{equipmentId}" ; rr:class :Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:equipmentId ; rr:objectMap [ rr:column "equipmentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_scope_maintenance_facilities_equipment_2_Maintenance_Facilities_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"maintenanceId\", \"equipmentTypeId\" FROM \"Maintenance_Facilities_Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Maintenance_Facilities_Equipment/{_amb_rowid}" ; rr:class :Maintenance_Facilities_Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:maintenanceId ; rr:objectMap [ rr:column "maintenanceId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:equipmentTypeId ; rr:objectMap [ rr:column "equipmentTypeId" ] ] .

<#tm_scope_maintenance_facilities_equipment_3_Maintenance_Facilities_Equipment_equipmentTypeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"equipmentTypeId\" FROM \"Maintenance_Facilities_Equipment\" WHERE \"equipmentTypeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Maintenance_Facilities_Equipment/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEquipment ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Equipment/{equipmentTypeId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_maintenance_facilities_equipment_4_Maintenance_Facilities_Equipment_maintenanceId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"maintenanceId\" FROM \"Maintenance_Facilities_Equipment\" WHERE \"maintenanceId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Maintenance_Facilities_Equipment/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMaintenance_Facilities ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Maintenance_Facilities/{maintenanceId}" ; rr:termType rr:IRI ] ] .

