@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_meteorological_offices_data_sources_0_Meteorological_Offices_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Meteorological_Offices\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Meteorological_Offices/{id}" ; rr:class :Meteorological_Offices ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_meteorological_offices_data_sources_1_Data_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"source_type\", \"description\" FROM \"Data_Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Data_Sources/{id}" ; rr:class :Data_Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:source_type ; rr:objectMap [ rr:column "source_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_meteorological_offices_data_sources_2_Meteorological_Offices_Data_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"meteo_office_id\", \"data_source_id\" FROM \"Meteorological_Offices_Data_Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Meteorological_Offices_Data_Sources/{_amb_rowid}" ; rr:class :Meteorological_Offices_Data_Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:meteo_office_id ; rr:objectMap [ rr:column "meteo_office_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:data_source_id ; rr:objectMap [ rr:column "data_source_id" ] ] .

<#tm_scope_meteorological_offices_data_sources_3_Meteorological_Offices_Data_Sources_data_source_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"data_source_id\" FROM \"Meteorological_Offices_Data_Sources\" WHERE \"data_source_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Meteorological_Offices_Data_Sources/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasData_Sources ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Data_Sources/{data_source_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_meteorological_offices_data_sources_4_Meteorological_Offices_Data_Sources_meteo_office_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"meteo_office_id\" FROM \"Meteorological_Offices_Data_Sources\" WHERE \"meteo_office_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Meteorological_Offices_Data_Sources/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMeteorological_Offices ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Meteorological_Offices/{meteo_office_id}" ; rr:termType rr:IRI ] ] .

