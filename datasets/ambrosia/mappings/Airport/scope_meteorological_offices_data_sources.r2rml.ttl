<#tm_scope_meteorological_offices_data_sources_7_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"flight_number\", \"departure_time\", \"arrival_time\", \"destination_airport\", \"airline_company\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{flight_number}" ; rr:class :Flights ] ;
