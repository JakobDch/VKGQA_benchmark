@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_onboard_entertainment_system_features_0_Onboard_Entertainment_System_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airline\", \"aircraft_model\" FROM \"Onboard_Entertainment_System\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Onboard_Entertainment_System/{id}" ; rr:class :Onboard_Entertainment_System ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airline ; rr:objectMap [ rr:column "airline" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:aircraft_model ; rr:objectMap [ rr:column "aircraft_model" ] ] .

<#tm_scope_onboard_entertainment_system_features_1_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"feature_id\", \"feature_name\" FROM \"Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Features/{feature_id}" ; rr:class :Features ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_id ; rr:objectMap [ rr:column "feature_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_name ; rr:objectMap [ rr:column "feature_name" ] ] .

<#tm_scope_onboard_entertainment_system_features_2_Onboard_Entertainment_System_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"onboard_entertainment_system_id\", \"features_feature_id\" FROM \"Onboard_Entertainment_System_Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Onboard_Entertainment_System_Features/{_amb_rowid}" ; rr:class :Onboard_Entertainment_System_Features ] ;
  rr:predicateObjectMap [ rr:predicate p:onboard_entertainment_system_id ; rr:objectMap [ rr:column "onboard_entertainment_system_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:features_feature_id ; rr:objectMap [ rr:column "features_feature_id" ] ] .

<#tm_scope_onboard_entertainment_system_features_3_Onboard_Entertainment_System_Features_features_feature_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"features_feature_id\" FROM \"Onboard_Entertainment_System_Features\" WHERE \"features_feature_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Onboard_Entertainment_System_Features/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFeatures ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Features/{features_feature_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_onboard_entertainment_system_features_4_Onboard_Entertainment_System_Features_onboard_entertainment_system_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"onboard_entertainment_system_id\" FROM \"Onboard_Entertainment_System_Features\" WHERE \"onboard_entertainment_system_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Onboard_Entertainment_System_Features/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOnboard_Entertainment_System ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Onboard_Entertainment_System/{onboard_entertainment_system_id}" ; rr:termType rr:IRI ] ] .

