@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_travel_agency_service_0_Travel_Agency_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AgencyID\", \"Name\", \"Location\" FROM \"Travel_Agency\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Travel_Agency/{AgencyID}" ; rr:class :Travel_Agency ] ;
  rr:predicateObjectMap [ rr:predicate p:AgencyID ; rr:objectMap [ rr:column "AgencyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_scope_travel_agency_service_1_Service_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ServiceID\", \"Description\", \"Price\" FROM \"Service\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Service/{ServiceID}" ; rr:class :Service ] ;
  rr:predicateObjectMap [ rr:predicate p:ServiceID ; rr:objectMap [ rr:column "ServiceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_scope_travel_agency_service_2_Travel_Agency_Service_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"AgencyID\", \"ServiceID\" FROM \"Travel_Agency_Service\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Travel_Agency_Service/{_amb_rowid}" ; rr:class :Travel_Agency_Service ] ;
  rr:predicateObjectMap [ rr:predicate p:AgencyID ; rr:objectMap [ rr:column "AgencyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ServiceID ; rr:objectMap [ rr:column "ServiceID" ] ] .

<#tm_scope_travel_agency_service_3_Travel_Agency_Service_ServiceID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ServiceID\" FROM \"Travel_Agency_Service\" WHERE \"ServiceID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Travel_Agency_Service/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasService ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Service/{ServiceID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_travel_agency_service_4_Travel_Agency_Service_AgencyID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"AgencyID\" FROM \"Travel_Agency_Service\" WHERE \"AgencyID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Travel_Agency_Service/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTravel_Agency ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Travel_Agency/{AgencyID}" ; rr:termType rr:IRI ] ] .

