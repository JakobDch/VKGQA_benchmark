@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_weather_model_parameters_0_Weather_Model_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"modelID\", \"modelName\", \"manufacturer\" FROM \"Weather_Model\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Weather_Model/{modelID}" ; rr:class :Weather_Model ] ;
  rr:predicateObjectMap [ rr:predicate p:modelID ; rr:objectMap [ rr:column "modelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:modelName ; rr:objectMap [ rr:column "modelName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:manufacturer ; rr:objectMap [ rr:column "manufacturer" ] ] .

<#tm_scope_weather_model_parameters_1_Parameters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"parameterID\", \"parameterName\", \"unit\" FROM \"Parameters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Parameters/{parameterID}" ; rr:class :Parameters ] ;
  rr:predicateObjectMap [ rr:predicate p:parameterID ; rr:objectMap [ rr:column "parameterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:parameterName ; rr:objectMap [ rr:column "parameterName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:unit ; rr:objectMap [ rr:column "unit" ] ] .

<#tm_scope_weather_model_parameters_2_Weather_Model_Parameters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"weatherModelId\", \"parameterId\", \"value\" FROM \"Weather_Model_Parameters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Weather_Model_Parameters/{_amb_rowid}" ; rr:class :Weather_Model_Parameters ] ;
  rr:predicateObjectMap [ rr:predicate p:weatherModelId ; rr:objectMap [ rr:column "weatherModelId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:parameterId ; rr:objectMap [ rr:column "parameterId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:value ; rr:objectMap [ rr:column "value" ] ] .

<#tm_scope_weather_model_parameters_3_Weather_Model_Parameters_parameterId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"parameterId\" FROM \"Weather_Model_Parameters\" WHERE \"parameterId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Weather_Model_Parameters/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasParameters ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Parameters/{parameterId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_weather_model_parameters_4_Weather_Model_Parameters_weatherModelId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"weatherModelId\" FROM \"Weather_Model_Parameters\" WHERE \"weatherModelId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Weather_Model_Parameters/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWeather_Model ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Weather_Model/{weatherModelId}" ; rr:termType rr:IRI ] ] .

