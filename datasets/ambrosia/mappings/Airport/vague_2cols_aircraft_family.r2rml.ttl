  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"source_airport_id\", \"destination_airport_id\", \"airline_id\", \"departure_time\", \"arrival_time\" FROM \"Routes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Routes/{id}" ; rr:class :Routes ] ;
