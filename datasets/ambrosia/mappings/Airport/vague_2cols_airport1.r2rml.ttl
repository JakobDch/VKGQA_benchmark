<#tm_vague_2cols_airport1_6_Pilots_Airline_Code_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Pilot_ID\", \"Airline_Code\" FROM \"Pilots\" WHERE \"Airline_Code\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Pilots/{Pilot_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{Airline_Code}" ; rr:termType rr:IRI ] ] .

