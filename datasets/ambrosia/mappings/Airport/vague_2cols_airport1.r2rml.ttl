  rr:logicalTable [ rr:sqlQuery """SELECT \"Record_ID\", \"Plane_ID\", \"Work_Order_Description\", \"Start_DateTime\", \"End_DateTime\", \"Total_Hours_Worked\", \"Cost\" FROM \"Maintenance_Records\"""" ] ;
