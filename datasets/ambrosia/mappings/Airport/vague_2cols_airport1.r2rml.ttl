@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_airport1_0_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Flight_ID\", \"Departure_Time\", \"Arrival_Time\", \"Aircraft_Type\", \"Origin_Airport_Code\", \"Destination_Airport_Code\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{Flight_ID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:Flight_ID ; rr:objectMap [ rr:column "Flight_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Departure_Time ; rr:objectMap [ rr:column "Departure_Time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Arrival_Time ; rr:objectMap [ rr:column "Arrival_Time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Aircraft_Type ; rr:objectMap [ rr:column "Aircraft_Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Origin_Airport_Code ; rr:objectMap [ rr:column "Origin_Airport_Code" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination_Airport_Code ; rr:objectMap [ rr:column "Destination_Airport_Code" ] ] .

<#tm_vague_2cols_airport1_1_Flights_Destination_Airport_Code_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Flight_ID\", \"Destination_Airport_Code\" FROM \"Flights\" WHERE \"Destination_Airport_Code\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{Flight_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_Destination_Airport_Code ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{Destination_Airport_Code}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_airport1_2_Flights_Origin_Airport_Code_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Flight_ID\", \"Origin_Airport_Code\" FROM \"Flights\" WHERE \"Origin_Airport_Code\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{Flight_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_Origin_Airport_Code ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{Origin_Airport_Code}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_airport1_3_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Airport_Code\", \"Airport_Name\", \"Country\", \"City\", \"Elevation\", \"Timezone\", \"IATA_Code\", \"Latitude\", \"Longitude\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{Airport_Code}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:Airport_Code ; rr:objectMap [ rr:column "Airport_Code" ] ] ;
