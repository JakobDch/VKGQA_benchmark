  rr:logicalTable [ rr:sqlQuery """SELECT \"Pilot_ID\", \"First_Name\", \"Last_Name\", \"Date_Of_Birth\", \"License_Number\", \"License_Issue_Date\", \"Rating\", \"Airline_Code\" FROM \"Pilots\"""" ] ;
