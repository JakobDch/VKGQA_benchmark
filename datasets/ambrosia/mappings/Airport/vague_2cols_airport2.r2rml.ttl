@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_airport2_0_Cities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Name\", \"Country\" FROM \"Cities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Cities/{Id}" ; rr:class :Cities ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_vague_2cols_airport2_1_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"CityId\", \"Code\", \"RunwayCount\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{Id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CityId ; rr:objectMap [ rr:column "CityId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Code ; rr:objectMap [ rr:column "Code" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RunwayCount ; rr:objectMap [ rr:column "RunwayCount" ] ] .

<#tm_vague_2cols_airport2_2_Airports_CityId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"CityId\" FROM \"Airports\" WHERE \"CityId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{Id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCities ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Cities/{CityId}" ; rr:termType rr:IRI ] ] .

