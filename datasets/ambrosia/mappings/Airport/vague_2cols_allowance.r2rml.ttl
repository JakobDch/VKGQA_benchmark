@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_allowance_0_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirlineID\", \"Name\", \"Headquarters\", \"Founded\", \"Website\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{AirlineID}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlineID ; rr:objectMap [ rr:column "AirlineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Headquarters ; rr:objectMap [ rr:column "Headquarters" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Founded ; rr:objectMap [ rr:column "Founded" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Website ; rr:objectMap [ rr:column "Website" ] ] .

