@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_building_design_0_Architects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Architects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Architects/{id}" ; rr:class :Architects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_vague_2cols_building_design_1_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_vague_2cols_building_design_2_Terminals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airport_id\", \"terminal_name\", \"capacity\" FROM \"Terminals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{id}" ; rr:class :Terminals ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airport_id ; rr:objectMap [ rr:column "airport_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:terminal_name ; rr:objectMap [ rr:column "terminal_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

<#tm_vague_2cols_building_design_3_Terminals_airport_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airport_id\" FROM \"Terminals\" WHERE \"airport_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{airport_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_building_design_4_Buildings_base> a rr:TriplesMap ;
