  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Buildings/{id}" ; rr:class :Buildings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:architecture_firm ; rr:objectMap [ rr:column "architecture_firm" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:architect ; rr:objectMap [ rr:column "architect" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airport_terminal ; rr:objectMap [ rr:column "airport_terminal" ] ] .

