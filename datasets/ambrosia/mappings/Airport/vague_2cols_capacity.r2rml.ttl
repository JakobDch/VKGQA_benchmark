<#tm_vague_2cols_capacity_7_AirportDetails_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"AirportID\", \"Passenger_Throughput\", \"Number_Of_Aircrafts\", \"Latitude\", \"Longitude\" FROM \"AirportDetails\"""" ] ;
