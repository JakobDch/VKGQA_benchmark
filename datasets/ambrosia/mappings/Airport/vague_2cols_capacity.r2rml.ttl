@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_capacity_0_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FlightID\", \"DepartureTime\", \"Destination\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightID ; rr:objectMap [ rr:column "FlightID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination ; rr:objectMap [ rr:column "Destination" ] ] .

<#tm_vague_2cols_capacity_1_Airline_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CompanyName\", \"Headquarters\", \"NumberofEmployees\" FROM \"Airline\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{CompanyName}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyName ; rr:objectMap [ rr:column "CompanyName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Headquarters ; rr:objectMap [ rr:column "Headquarters" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberofEmployees ; rr:objectMap [ rr:column "NumberofEmployees" ] ] .

<#tm_vague_2cols_capacity_2_Passengers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PassengerID\", \"Name\", \"Age\" FROM \"Passengers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Passengers/{PassengerID}" ; rr:class :Passengers ] ;
  rr:predicateObjectMap [ rr:predicate p:PassengerID ; rr:objectMap [ rr:column "PassengerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] .

<#tm_vague_2cols_capacity_3_AirlinesAndFlights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirlinesID\", \"FlightsID\" FROM \"AirlinesAndFlights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/AirlinesAndFlights/{AirlinesID}/{FlightsID}" ; rr:class :AirlinesAndFlights ] ;
  rr:predicateObjectMap [ rr:predicate p:AirlinesID ; rr:objectMap [ rr:column "AirlinesID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightsID ; rr:objectMap [ rr:column "FlightsID" ] ] .

<#tm_vague_2cols_capacity_4_AirlinesAndFlights_FlightsID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirlinesID\", \"FlightsID\" FROM \"AirlinesAndFlights\" WHERE \"FlightsID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/AirlinesAndFlights/{AirlinesID}/{FlightsID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{FlightsID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_capacity_5_AirlinesAndFlights_AirlinesID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AirlinesID\", \"FlightsID\" FROM \"AirlinesAndFlights\" WHERE \"AirlinesID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/AirlinesAndFlights/{AirlinesID}/{FlightsID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{AirlinesID}" ; rr:termType rr:IRI ] ] .

