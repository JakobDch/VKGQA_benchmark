<#tm_vague_2cols_location1_4_Baggage_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Bag_Id\", \"Flight_Id\", \"Owner_FirstName\", \"Owner_LastName\", \"Size_Inches\", \"Weight_Kgs\", \"Description\", \"Status\" FROM \"Baggage\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Baggage/{Bag_Id}" ; rr:class :Baggage ] ;
  rr:predicateObjectMap [ rr:predicate p:Bag_Id ; rr:objectMap [ rr:column "Bag_Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Flight_Id ; rr:objectMap [ rr:column "Flight_Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Owner_FirstName ; rr:objectMap [ rr:column "Owner_FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Owner_LastName ; rr:objectMap [ rr:column "Owner_LastName" ] ] ;
