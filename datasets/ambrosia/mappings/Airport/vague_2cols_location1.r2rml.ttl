@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_location1_0_Airports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"IATA_Code\", \"ICAA_Code\", \"Latitude\", \"Longitude\", \"Elevation\", \"Timezone\", \"Direction_Indicator\", \"Surface_Area\", \"Movement_Area\", \"Runway_Length\", \"City\", \"State\", \"Phone_Number\", \"Website\", \"Email\", \"Year_Established\" FROM \"Airports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:IATA_Code ; rr:objectMap [ rr:column "IATA_Code" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ICAA_Code ; rr:objectMap [ rr:column "ICAA_Code" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Latitude ; rr:objectMap [ rr:column "Latitude" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Longitude ; rr:objectMap [ rr:column "Longitude" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Elevation ; rr:objectMap [ rr:column "Elevation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Timezone ; rr:objectMap [ rr:column "Timezone" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Direction_Indicator ; rr:objectMap [ rr:column "Direction_Indicator" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Surface_Area ; rr:objectMap [ rr:column "Surface_Area" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Movement_Area ; rr:objectMap [ rr:column "Movement_Area" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Runway_Length ; rr:objectMap [ rr:column "Runway_Length" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:State ; rr:objectMap [ rr:column "State" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Phone_Number ; rr:objectMap [ rr:column "Phone_Number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Website ; rr:objectMap [ rr:column "Website" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year_Established ; rr:objectMap [ rr:column "Year_Established" ] ] .

<#tm_vague_2cols_location1_1_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Flight_ID\", \"Origin_Airport\", \"Destination_Airport\", \"Departure_Time\", \"Arrival_Time\", \"Carrier_Airlines\", \"Aircraft_Type\", \"Number_of_Passengers\", \"Flight_Status\", \"Gate_Number\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{Flight_ID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:Flight_ID ; rr:objectMap [ rr:column "Flight_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Origin_Airport ; rr:objectMap [ rr:column "Origin_Airport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Destination_Airport ; rr:objectMap [ rr:column "Destination_Airport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Departure_Time ; rr:objectMap [ rr:column "Departure_Time" ] ] ;
