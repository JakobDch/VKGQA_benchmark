<#tm_vague_2cols_location1_5_Baggage_Flight_Id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Bag_Id\", \"Flight_Id\" FROM \"Baggage\" WHERE \"Flight_Id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Baggage/{Bag_Id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlights ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{Flight_Id}" ; rr:termType rr:IRI ] ] .

