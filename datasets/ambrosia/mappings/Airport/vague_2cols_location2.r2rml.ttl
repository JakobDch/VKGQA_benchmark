@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_location2_0_Airlines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Airline_ID\", \"Name\" FROM \"Airlines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{Airline_ID}" ; rr:class :Airlines ] ;
  rr:predicateObjectMap [ rr:predicate p:Airline_ID ; rr:objectMap [ rr:column "Airline_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_vague_2cols_location2_1_Flights_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Flight_ID\", \"FlightNumber\", \"DepartureTime\", \"ArrivalTime\", \"SourceAirport\", \"DestinationAirport\", \"Airline_ID\" FROM \"Flights\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{Flight_ID}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:Flight_ID ; rr:objectMap [ rr:column "Flight_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FlightNumber ; rr:objectMap [ rr:column "FlightNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartureTime ; rr:objectMap [ rr:column "DepartureTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArrivalTime ; rr:objectMap [ rr:column "ArrivalTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SourceAirport ; rr:objectMap [ rr:column "SourceAirport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DestinationAirport ; rr:objectMap [ rr:column "DestinationAirport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Airline_ID ; rr:objectMap [ rr:column "Airline_ID" ] ] .

<#tm_vague_2cols_location2_2_Flights_DestinationAirport_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Flight_ID\", \"DestinationAirport\" FROM \"Flights\" WHERE \"DestinationAirport\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{Flight_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_DestinationAirport ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{DestinationAirport}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location2_3_Flights_SourceAirport_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Flight_ID\", \"SourceAirport\" FROM \"Flights\" WHERE \"SourceAirport\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{Flight_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirports_SourceAirport ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{SourceAirport}" ; rr:termType rr:IRI ] ] .

