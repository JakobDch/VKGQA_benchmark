  rr:predicateObjectMap [ rr:predicate p:weight_restriction ; rr:objectMap [ rr:column "weight_restriction" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airline_id ; rr:objectMap [ rr:column "airline_id" ] ] .

<#tm_vague_2cols_size_limits_3_Planes_airline_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"airline_id\" FROM \"Planes\" WHERE \"airline_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAirlines ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Airlines/{airline_id}" ; rr:termType rr:IRI ] ] .

