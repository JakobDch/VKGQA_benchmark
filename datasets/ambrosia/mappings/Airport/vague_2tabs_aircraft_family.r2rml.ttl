@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_aircraft_family_0_Manufacturer_Name_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"manufacturer_name\", \"country\" FROM \"Manufacturer_Name\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/manufacturers/{id}" ; rr:class :manufacturers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:manufacturer_name ; rr:objectMap [ rr:column "manufacturer_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_vague_2tabs_aircraft_family_1_Model_Name_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"model_name\", \"year_introduced\", \"MAX_PASSENGERS\" FROM \"Model_Name\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Model_Name/{id}" ; rr:class :Model_Name ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:model_name ; rr:objectMap [ rr:column "model_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:year_introduced ; rr:objectMap [ rr:column "year_introduced" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MAX_PASSENGERS ; rr:objectMap [ rr:column "MAX_PASSENGERS" ] ] .

<#tm_vague_2tabs_aircraft_family_2_Plane_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"plane_model_id\", \"manufacturer_id\", \"registration_number\", \"aircraft_type\", \"current_location\" FROM \"Plane\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{id}" ; rr:class :Planes ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:plane_model_id ; rr:objectMap [ rr:column "plane_model_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:manufacturer_id ; rr:objectMap [ rr:column "manufacturer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:registration_number ; rr:objectMap [ rr:column "registration_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:aircraft_type ; rr:objectMap [ rr:column "aircraft_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:current_location ; rr:objectMap [ rr:column "current_location" ] ] .

<#tm_vague_2tabs_aircraft_family_3_Plane_manufacturer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"manufacturer_id\" FROM \"Plane\" WHERE \"manufacturer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasmanufacturers ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/manufacturers/{manufacturer_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_aircraft_family_4_Plane_plane_model_id_fk> a rr:TriplesMap ;
