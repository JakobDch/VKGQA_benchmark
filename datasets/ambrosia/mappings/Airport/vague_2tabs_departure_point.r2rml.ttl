@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_departure_point_0_City_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"country\" FROM \"City\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Cities/{id}" ; rr:class :Cities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_vague_2tabs_departure_point_1_Flight_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"flight_number\", \"departure_time\", \"arrival_time\", \"terminal_id\", \"origin_city_id\", \"destination_city_id\" FROM \"Flight\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ; rr:class :Flights ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:flight_number ; rr:objectMap [ rr:column "flight_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departure_time ; rr:objectMap [ rr:column "departure_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrival_time ; rr:objectMap [ rr:column "arrival_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:terminal_id ; rr:objectMap [ rr:column "terminal_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:origin_city_id ; rr:objectMap [ rr:column "origin_city_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destination_city_id ; rr:objectMap [ rr:column "destination_city_id" ] ] .

<#tm_vague_2tabs_departure_point_2_Flight_destination_city_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"destination_city_id\" FROM \"Flight\" WHERE \"destination_city_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCities_destination_city_id ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Cities/{destination_city_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_departure_point_3_Flight_origin_city_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"origin_city_id\" FROM \"Flight\" WHERE \"origin_city_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCities_origin_city_id ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Cities/{origin_city_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_departure_point_4_Flight_terminal_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"terminal_id\" FROM \"Flight\" WHERE \"terminal_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Flights/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerminals ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Terminals/{terminal_id}" ; rr:termType rr:IRI ] ] .

