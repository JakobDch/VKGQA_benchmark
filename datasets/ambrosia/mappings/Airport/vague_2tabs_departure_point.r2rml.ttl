  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"plane_type\", \"capacity\", \"registered_to_airline_id\", \"current_pilot_id\" FROM \"Plane\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Planes/{id}" ; rr:class :Planes ] ;
