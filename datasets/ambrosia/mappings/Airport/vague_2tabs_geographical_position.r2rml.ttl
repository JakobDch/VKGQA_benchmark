@prefix : <http://ambrosia.example.org/airport#> .
@prefix p: <http://ambrosia.example.org/airport/prop#> .
@prefix ex: <http://ambrosia.example.org/airport/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_geographical_position_0_City_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"country\" FROM \"City\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Cities/{id}" ; rr:class :Cities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_vague_2tabs_geographical_position_1_Coordinates_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"latitude\", \"longitude\" FROM \"Coordinates\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Coordinates/{id}" ; rr:class :Coordinates ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:latitude ; rr:objectMap [ rr:column "latitude" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:longitude ; rr:objectMap [ rr:column "longitude" ] ] .

<#tm_vague_2tabs_geographical_position_2_Airport_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"city_id\", \"coordinates_id\" FROM \"Airport\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ; rr:class :Airports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city_id ; rr:objectMap [ rr:column "city_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:coordinates_id ; rr:objectMap [ rr:column "coordinates_id" ] ] .

<#tm_vague_2tabs_geographical_position_3_Airport_coordinates_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"coordinates_id\" FROM \"Airport\" WHERE \"coordinates_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCoordinates ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Coordinates/{coordinates_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_geographical_position_4_Airport_city_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"city_id\" FROM \"Airport\" WHERE \"city_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/airport/id/Airports/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCities ; rr:objectMap [ rr:template "http://ambrosia.example.org/airport/id/Cities/{city_id}" ; rr:termType rr:IRI ] ] .

