@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_board_member_0_Organizations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\" FROM \"Organizations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Organizations/{ID}" ; rr:class :Organizations ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_ref_board_member_1_Board_Members_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"MemberName\", \"Role\", \"OrganizationID\" FROM \"Board_Members\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Board_Members/{ID}" ; rr:class :Board_Members ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MemberName ; rr:objectMap [ rr:column "MemberName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Role ; rr:objectMap [ rr:column "Role" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OrganizationID ; rr:objectMap [ rr:column "OrganizationID" ] ] .

<#tm_attachment_1tab_ref_board_member_2_Board_Members_OrganizationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"OrganizationID\" FROM \"Board_Members\" WHERE \"OrganizationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Board_Members/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOrganizations ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Organizations/{OrganizationID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_board_member_3_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CustomerID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"EmailAddress\", \"PhoneNumber\", \"AddressLine1\", \"AddressLine2\", \"City\", \"State\", \"ZipCode\", \"Country\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{CustomerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AddressLine1 ; rr:objectMap [ rr:column "AddressLine1" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AddressLine2 ; rr:objectMap [ rr:column "AddressLine2" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:State ; rr:objectMap [ rr:column "State" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ZipCode ; rr:objectMap [ rr:column "ZipCode" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_ref_board_member_4_Accounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountID\", \"CustomerID\", \"Balance\", \"Type\" FROM \"Accounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountID ; rr:objectMap [ rr:column "AccountID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Balance ; rr:objectMap [ rr:column "Balance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] .

<#tm_attachment_1tab_ref_board_member_5_Accounts_CustomerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountID\", \"CustomerID\" FROM \"Accounts\" WHERE \"CustomerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{CustomerID}" ; rr:termType rr:IRI ] ] .

