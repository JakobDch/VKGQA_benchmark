@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_terms_0_AccountTypes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"TypeName\" FROM \"AccountTypes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/AccountTypes/{ID}" ; rr:class :AccountTypes ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeName ; rr:objectMap [ rr:column "TypeName" ] ] .

<#tm_attachment_1tab_ref_terms_1_Banks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"HeadQuarters\" FROM \"Banks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{ID}" ; rr:class :Banks ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HeadQuarters ; rr:objectMap [ rr:column "HeadQuarters" ] ] .

