@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_transaction_types_0_Transaction_Types_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TypeID\", \"TypeName\" FROM \"Transaction_Types\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Transaction_Types/{TypeID}" ; rr:class :Transaction_Types ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeID ; rr:objectMap [ rr:column "TypeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeName ; rr:objectMap [ rr:column "TypeName" ] ] .

<#tm_attachment_1tab_ref_transaction_types_1_Banks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BankID\", \"Name\" FROM \"Banks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{BankID}" ; rr:class :Banks ] ;
  rr:predicateObjectMap [ rr:predicate p:BankID ; rr:objectMap [ rr:column "BankID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_ref_transaction_types_2_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CustomerID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"PhoneNumber\", \"EmailAddress\", \"BankID\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{CustomerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BankID ; rr:objectMap [ rr:column "BankID" ] ] .

<#tm_attachment_1tab_ref_transaction_types_3_Customers_BankID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CustomerID\", \"BankID\" FROM \"Customers\" WHERE \"BankID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{CustomerID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBanks ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{BankID}" ; rr:termType rr:IRI ] ] .

