@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_digital_solutions_0_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CustomerID\", \"DateOfBirth\", \"Digital_Solutions\", \"Sign_in_Options\", \"FullName\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{CustomerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Digital_Solutions ; rr:objectMap [ rr:column "Digital_Solutions" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Sign_in_Options ; rr:objectMap [ rr:column "Sign_in_Options" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_val_digital_solutions_1_AccountTypes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountTypeID\", \"AccountTypeName\" FROM \"AccountTypes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/AccountTypes/{AccountTypeID}" ; rr:class :AccountTypes ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountTypeID ; rr:objectMap [ rr:column "AccountTypeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountTypeName ; rr:objectMap [ rr:column "AccountTypeName" ] ] .

<#tm_attachment_1tab_val_digital_solutions_2_Accounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountID\", \"CustomerID\", \"AccountTypeID\", \"OpenDate\", \"Balance\" FROM \"Accounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountID ; rr:objectMap [ rr:column "AccountID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountTypeID ; rr:objectMap [ rr:column "AccountTypeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OpenDate ; rr:objectMap [ rr:column "OpenDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Balance ; rr:objectMap [ rr:column "Balance" ] ] .

<#tm_attachment_1tab_val_digital_solutions_3_Accounts_AccountTypeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountID\", \"AccountTypeID\" FROM \"Accounts\" WHERE \"AccountTypeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccountTypes ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/AccountTypes/{AccountTypeID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_digital_solutions_4_Accounts_CustomerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountID\", \"CustomerID\" FROM \"Accounts\" WHERE \"CustomerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{CustomerID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_digital_solutions_5_Transactions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TransactionID\", \"AccountID\", \"Amount\", \"Type\", \"Date\" FROM \"Transactions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Transactions/{TransactionID}" ; rr:class :Transactions ] ;
  rr:predicateObjectMap [ rr:predicate p:TransactionID ; rr:objectMap [ rr:column "TransactionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountID ; rr:objectMap [ rr:column "AccountID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Amount ; rr:objectMap [ rr:column "Amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] .

<#tm_attachment_1tab_val_digital_solutions_6_Transactions_AccountID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TransactionID\", \"AccountID\" FROM \"Transactions\" WHERE \"AccountID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Transactions/{TransactionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccounts ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ; rr:termType rr:IRI ] ] .

