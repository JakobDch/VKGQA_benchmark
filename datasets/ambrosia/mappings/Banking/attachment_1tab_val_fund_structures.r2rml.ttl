@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_fund_structures_0_Clients_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClientID\", \"ClientName\", \"ContactEmail\" FROM \"Clients\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Clients/{ClientID}" ; rr:class :Clients ] ;
  rr:predicateObjectMap [ rr:predicate p:ClientID ; rr:objectMap [ rr:column "ClientID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClientName ; rr:objectMap [ rr:column "ClientName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ContactEmail ; rr:objectMap [ rr:column "ContactEmail" ] ] .

<#tm_attachment_1tab_val_fund_structures_1_AccountTypes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountTypeID\", \"TypeName\" FROM \"AccountTypes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/AccountTypes/{AccountTypeID}" ; rr:class :AccountTypes ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountTypeID ; rr:objectMap [ rr:column "AccountTypeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeName ; rr:objectMap [ rr:column "TypeName" ] ] .

<#tm_attachment_1tab_val_fund_structures_2_Accounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountNumber\", \"InterestRate\", \"Balance\", \"OpenDate\", \"ForeignExchange\", \"Currency\", \"AccountTypeId\" FROM \"Accounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountNumber}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountNumber ; rr:objectMap [ rr:column "AccountNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:InterestRate ; rr:objectMap [ rr:column "InterestRate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Balance ; rr:objectMap [ rr:column "Balance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OpenDate ; rr:objectMap [ rr:column "OpenDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ForeignExchange ; rr:objectMap [ rr:column "ForeignExchange" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Currency ; rr:objectMap [ rr:column "Currency" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountTypeId ; rr:objectMap [ rr:column "AccountTypeId" ] ] .

<#tm_attachment_1tab_val_fund_structures_3_Accounts_AccountTypeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountNumber\", \"AccountTypeId\" FROM \"Accounts\" WHERE \"AccountTypeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountNumber}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccountTypes ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/AccountTypes/{AccountTypeId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_fund_structures_4_Investments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InvestmentID\", \"PurchaseAmount\", \"DateOfPurchase\", \"ClientId\", \"AccountNumber\", \"FundStructure\", \"MarketShare\" FROM \"Investments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Investments/{InvestmentID}" ; rr:class :Investments ] ;
  rr:predicateObjectMap [ rr:predicate p:InvestmentID ; rr:objectMap [ rr:column "InvestmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PurchaseAmount ; rr:objectMap [ rr:column "PurchaseAmount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfPurchase ; rr:objectMap [ rr:column "DateOfPurchase" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClientId ; rr:objectMap [ rr:column "ClientId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountNumber ; rr:objectMap [ rr:column "AccountNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FundStructure ; rr:objectMap [ rr:column "FundStructure" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MarketShare ; rr:objectMap [ rr:column "MarketShare" ] ] .

<#tm_attachment_1tab_val_fund_structures_5_Investments_AccountNumber_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InvestmentID\", \"AccountNumber\" FROM \"Investments\" WHERE \"AccountNumber\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Investments/{InvestmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccounts ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountNumber}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_fund_structures_6_Investments_ClientId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InvestmentID\", \"ClientId\" FROM \"Investments\" WHERE \"ClientId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Investments/{InvestmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClients ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Clients/{ClientId}" ; rr:termType rr:IRI ] ] .

