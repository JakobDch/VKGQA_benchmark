[PrefixDeclaration]
:	http://ambrosia.example.org/banking#
p:	http://ambrosia.example.org/banking/prop#
ex:	http://ambrosia.example.org/banking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Customers_base
target		ex:Customers/{CustomerID} a :Customers ; p:CustomerID {CustomerID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:email {Email} ; p:PhoneNumber {PhoneNumber} .
source		SELECT `CustomerID`, `FirstName`, `LastName`, `Email`, `PhoneNumber` FROM `Customers`

mappingId	Accounts_base
target		ex:Accounts/{AccountID} a :Accounts ; p:AccountID {AccountID} ; p:Balance {Balance} ; p:InterestRate {InterestRate} ; p:DateOpened {DateOpened} ; p:CustomerID {CustomerID} .
source		SELECT `AccountID`, `Balance`, `InterestRate`, `DateOpened`, `CustomerID` FROM `Accounts`

mappingId	Accounts_CustomerID_fk
target		ex:Accounts/{AccountID} p:hasCustomers ex:Customers/{CustomerID} .
source		SELECT `AccountID`, `CustomerID` FROM `Accounts` WHERE `CustomerID` IS NOT NULL

mappingId	Insurance_Products_base
target		ex:Insurance_Products/{ProductID} a :Insurance_Products ; p:ProductID {ProductID} ; p:PolicyHolderID {PolicyHolderID} ; p:ProductType {ProductType} ; p:Payout {Payout} ; p:StartDate {StartDate} ; p:EndDate {EndDate} .
source		SELECT `ProductID`, `PolicyHolderID`, `ProductType`, `Payout`, `StartDate`, `EndDate` FROM `Insurance_Products`

mappingId	Insurance_Products_PolicyHolderID_fk
target		ex:Insurance_Products/{ProductID} p:hasCustomers ex:Customers/{PolicyHolderID} .
source		SELECT `ProductID`, `PolicyHolderID` FROM `Insurance_Products` WHERE `PolicyHolderID` IS NOT NULL

mappingId	Transactions_base
target		ex:Transactions/{TransactionID} a :Transactions ; p:TransactionID {TransactionID} ; p:Amount {Amount} ; p:Type {Type} ; p:Date {Date} ; p:AccountID {AccountID} .
source		SELECT `TransactionID`, `Amount`, `Type`, `Date`, `AccountID` FROM `Transactions`

mappingId	Transactions_AccountID_fk
target		ex:Transactions/{TransactionID} p:hasAccounts ex:Accounts/{AccountID} .
source		SELECT `TransactionID`, `AccountID` FROM `Transactions` WHERE `AccountID` IS NOT NULL

mappingId	Loans_base
target		ex:Loans/{LoanID} a :Loans ; p:LoanID {LoanID} ; p:Principal {Principal} ; p:InterestRate {InterestRate} ; p:TermYears {TermYears} ; p:MonthlyPayment {MonthlyPayment} ; p:ApprovalDate {ApprovalDate} ; p:AccountID {AccountID} .
source		SELECT `LoanID`, `Principal`, `InterestRate`, `TermYears`, `MonthlyPayment`, `ApprovalDate`, `AccountID` FROM `Loans`

mappingId	Loans_AccountID_fk
target		ex:Loans/{LoanID} p:hasAccounts ex:Accounts/{AccountID} .
source		SELECT `LoanID`, `AccountID` FROM `Loans` WHERE `AccountID` IS NOT NULL

]]
