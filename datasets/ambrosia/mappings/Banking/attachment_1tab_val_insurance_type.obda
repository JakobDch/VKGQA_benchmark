[PrefixDeclaration]
:	http://ambrosia.example.org/banking#
p:	http://ambrosia.example.org/banking/prop#
ex:	http://ambrosia.example.org/banking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Customers_base
target		ex:Customers/{CustomerID} a :Customers ; p:CustomerID {CustomerID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:DateOfBirth {DateOfBirth} ; p:email {Email} .
source		SELECT `CustomerID`, `FirstName`, `LastName`, `DateOfBirth`, `Email` FROM `Customers`

mappingId	Accounts_base
target		ex:Accounts/{AccountNumber} a :Accounts ; p:AccountNumber {AccountNumber} ; p:CustomerID {CustomerID} ; p:Balance {Balance} .
source		SELECT `AccountNumber`, `CustomerID`, `Balance` FROM `Accounts`

mappingId	Accounts_CustomerID_fk
target		ex:Accounts/{AccountNumber} p:hasCustomers ex:Customers/{CustomerID} .
source		SELECT `AccountNumber`, `CustomerID` FROM `Accounts` WHERE `CustomerID` IS NOT NULL

mappingId	Loans_base
target		ex:Loans/{LoanID} a :Loans ; p:LoanID {LoanID} ; p:CustomerID {CustomerID} ; p:Amount {Amount} ; p:InterestRate {InterestRate} ; p:TermYears {TermYears} .
source		SELECT `LoanID`, `CustomerID`, `Amount`, `InterestRate`, `TermYears` FROM `Loans`

mappingId	Loans_CustomerID_fk
target		ex:Loans/{LoanID} p:hasCustomers ex:Customers/{CustomerID} .
source		SELECT `LoanID`, `CustomerID` FROM `Loans` WHERE `CustomerID` IS NOT NULL

mappingId	Insurance_base
target		ex:Insurance/{InsuranceID} a :Insurance ; p:InsuranceID {InsuranceID} ; p:CustomerID {CustomerID} ; p:InsuranceType {InsuranceType} ; p:PaymentFrequency {PaymentFrequency} ; p:PremiumAmount {PremiumAmount} ; p:StartDate {StartDate} ; p:EndDate {EndDate} .
source		SELECT `InsuranceID`, `CustomerID`, `InsuranceType`, `PaymentFrequency`, `PremiumAmount`, `StartDate`, `EndDate` FROM `Insurance`

mappingId	Insurance_CustomerID_fk
target		ex:Insurance/{InsuranceID} p:hasCustomers ex:Customers/{CustomerID} .
source		SELECT `InsuranceID`, `CustomerID` FROM `Insurance` WHERE `CustomerID` IS NOT NULL

mappingId	Payments_base
target		ex:Payments/{PaymentID} a :Payments ; p:PaymentID {PaymentID} ; p:AccountNumber {AccountNumber} ; p:PaymentDate {PaymentDate} ; p:PaymentAmount {PaymentAmount} ; p:CheckNumber {CheckNumber} .
source		SELECT `PaymentID`, `AccountNumber`, `PaymentDate`, `PaymentAmount`, `CheckNumber` FROM `Payments`

mappingId	Payments_AccountNumber_fk
target		ex:Payments/{PaymentID} p:hasAccounts ex:Accounts/{AccountNumber} .
source		SELECT `PaymentID`, `AccountNumber` FROM `Payments` WHERE `AccountNumber` IS NOT NULL

]]
