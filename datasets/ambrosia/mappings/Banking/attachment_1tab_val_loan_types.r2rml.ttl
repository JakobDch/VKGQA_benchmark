@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_loan_types_0_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customerID\", \"firstName\", \"lastName\", \"dateOfBirth\", \"address\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:customerID ; rr:objectMap [ rr:column "customerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dateOfBirth ; rr:objectMap [ rr:column "dateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_attachment_1tab_val_loan_types_1_Accounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"accountID\", \"customerID\", \"balance\" FROM \"Accounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{accountID}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:accountID ; rr:objectMap [ rr:column "accountID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customerID ; rr:objectMap [ rr:column "customerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:balance ; rr:objectMap [ rr:column "balance" ] ] .

<#tm_attachment_1tab_val_loan_types_2_Accounts_customerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"accountID\", \"customerID\" FROM \"Accounts\" WHERE \"customerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{accountID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customerID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_loan_types_3_Mortgages_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"mortgageID\", \"accountID\", \"loanType\", \"principalAmount\", \"annualInterestRate\", \"repaymentPeriod\" FROM \"Mortgages\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Mortgages/{mortgageID}" ; rr:class :Mortgages ] ;
  rr:predicateObjectMap [ rr:predicate p:mortgageID ; rr:objectMap [ rr:column "mortgageID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:accountID ; rr:objectMap [ rr:column "accountID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:loanType ; rr:objectMap [ rr:column "loanType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:principalAmount ; rr:objectMap [ rr:column "principalAmount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:annualInterestRate ; rr:objectMap [ rr:column "annualInterestRate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:repaymentPeriod ; rr:objectMap [ rr:column "repaymentPeriod" ] ] .

<#tm_attachment_1tab_val_loan_types_4_Mortgages_accountID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"mortgageID\", \"accountID\" FROM \"Mortgages\" WHERE \"accountID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Mortgages/{mortgageID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccounts ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{accountID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_loan_types_5_SavingsAccounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"savingsID\", \"accountID\", \"interestRate\" FROM \"SavingsAccounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/SavingsAccounts/{savingsID}" ; rr:class :SavingsAccounts ] ;
  rr:predicateObjectMap [ rr:predicate p:savingsID ; rr:objectMap [ rr:column "savingsID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:accountID ; rr:objectMap [ rr:column "accountID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:interestRate ; rr:objectMap [ rr:column "interestRate" ] ] .

<#tm_attachment_1tab_val_loan_types_6_SavingsAccounts_accountID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"savingsID\", \"accountID\" FROM \"SavingsAccounts\" WHERE \"accountID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/SavingsAccounts/{savingsID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccounts ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{accountID}" ; rr:termType rr:IRI ] ] .

