[PrefixDeclaration]
:	http://ambrosia.example.org/banking#
p:	http://ambrosia.example.org/banking/prop#
ex:	http://ambrosia.example.org/banking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Customers_base
target		ex:Customers/{CustomerID} a :Customers ; p:CustomerID {CustomerID} ; p:name {Name} ; p:Address {Address} .
source		SELECT `CustomerID`, `Name`, `Address` FROM `Customers`

mappingId	Accounts_base
target		ex:Accounts/{AccountNumber} a :Accounts ; p:AccountNumber {AccountNumber} ; p:Balance {Balance} ; p:InterestRate {InterestRate} ; p:OpenDate {OpenDate} ; p:CustomerID {CustomerID} .
source		SELECT `AccountNumber`, `Balance`, `InterestRate`, `OpenDate`, `CustomerID` FROM `Accounts`

mappingId	Accounts_CustomerID_fk
target		ex:Accounts/{AccountNumber} p:hasCustomers ex:Customers/{CustomerID} .
source		SELECT `AccountNumber`, `CustomerID` FROM `Accounts` WHERE `CustomerID` IS NOT NULL

mappingId	Transactions_base
target		ex:Transactions/{TransactionID} a :Transactions ; p:TransactionID {TransactionID} ; p:Amount {Amount} ; p:Date {Date} ; p:AccountNumber {AccountNumber} .
source		SELECT `TransactionID`, `Amount`, `Date`, `AccountNumber` FROM `Transactions`

mappingId	Transactions_AccountNumber_fk
target		ex:Transactions/{TransactionID} p:hasAccounts ex:Accounts/{AccountNumber} .
source		SELECT `TransactionID`, `AccountNumber` FROM `Transactions` WHERE `AccountNumber` IS NOT NULL

mappingId	InvestmentPortfolios_base
target		ex:InvestmentPortfolios/{PortfolioID} a :InvestmentPortfolios ; p:PortfolioID {PortfolioID} ; p:CustomerID {CustomerID} ; p:OpenEndFunds {OpenEndFunds} ; p:Month {Month} ; p:TotalInvestments {TotalInvestments} .
source		SELECT `PortfolioID`, `CustomerID`, `OpenEndFunds`, `Month`, `TotalInvestments` FROM `InvestmentPortfolios`

mappingId	InvestmentPortfolios_CustomerID_fk
target		ex:InvestmentPortfolios/{PortfolioID} p:hasCustomers ex:Customers/{CustomerID} .
source		SELECT `PortfolioID`, `CustomerID` FROM `InvestmentPortfolios` WHERE `CustomerID` IS NOT NULL

]]
