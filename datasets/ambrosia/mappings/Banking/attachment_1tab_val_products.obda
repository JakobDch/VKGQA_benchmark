[PrefixDeclaration]
:	http://ambrosia.example.org/banking#
p:	http://ambrosia.example.org/banking/prop#
ex:	http://ambrosia.example.org/banking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Customers_base
target		ex:Customers/{CustomerID} a :Customers ; p:CustomerID {CustomerID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:email {EmailAddress} .
source		SELECT `CustomerID`, `FirstName`, `LastName`, `EmailAddress` FROM `Customers`

mappingId	AccountTypes_base
target		ex:AccountTypes/{TypeID} a :AccountTypes ; p:TypeID {TypeID} ; p:TypeName {TypeName} .
source		SELECT `TypeID`, `TypeName` FROM `AccountTypes`

mappingId	Accounts_base
target		ex:Accounts/{AccountNumber} a :Accounts ; p:AccountNumber {AccountNumber} ; p:CustomerID {CustomerID} ; p:AccountTypeID {AccountTypeID} ; p:Balance {Balance} .
source		SELECT `AccountNumber`, `CustomerID`, `AccountTypeID`, `Balance` FROM `Accounts`

mappingId	Accounts_AccountTypeID_fk
target		ex:Accounts/{AccountNumber} p:hasAccountTypes ex:AccountTypes/{AccountTypeID} .
source		SELECT `AccountNumber`, `AccountTypeID` FROM `Accounts` WHERE `AccountTypeID` IS NOT NULL

mappingId	Accounts_CustomerID_fk
target		ex:Accounts/{AccountNumber} p:hasCustomers ex:Customers/{CustomerID} .
source		SELECT `AccountNumber`, `CustomerID` FROM `Accounts` WHERE `CustomerID` IS NOT NULL

mappingId	Transactions_base
target		ex:Transactions/{TransactionID} a :Transactions ; p:TransactionID {TransactionID} ; p:AccountNumber {AccountNumber} ; p:ProductID {ProductID} ; p:Quantity {Quantity} .
source		SELECT `TransactionID`, `AccountNumber`, `ProductID`, `Quantity` FROM `Transactions`

mappingId	Transactions_ProductID_fk
target		ex:Transactions/{TransactionID} p:hasProducts ex:Products/{ProductID} .
source		SELECT `TransactionID`, `ProductID` FROM `Transactions` WHERE `ProductID` IS NOT NULL

mappingId	Transactions_AccountNumber_fk
target		ex:Transactions/{TransactionID} p:hasAccounts ex:Accounts/{AccountNumber} .
source		SELECT `TransactionID`, `AccountNumber` FROM `Transactions` WHERE `AccountNumber` IS NOT NULL

mappingId	ExchangeRates_base
target		ex:ExchangeRates/{RateId} a :ExchangeRates ; p:RateId {RateId} ; p:Currency {Currency} .
source		SELECT `RateId`, `Currency` FROM `ExchangeRates`

mappingId	Products_base
target		ex:Products/{ProductID} a :Products ; p:ProductID {ProductID} ; p:name {Name} ; p:Description {Description} ; p:ExitFee {ExitFee} ; p:Category {Category} .
source		SELECT `ProductID`, `Name`, `Description`, `ExitFee`, `Category` FROM `Products`

]]
