@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_retirement_savings_0_Clients_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClientID\", \"Email\", \"FullName\" FROM \"Clients\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Clients/{ClientID}" ; rr:class :Clients ] ;
  rr:predicateObjectMap [ rr:predicate p:ClientID ; rr:objectMap [ rr:column "ClientID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_val_retirement_savings_1_Accounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountID\", \"ClientID\", \"AccountType\", \"Balance\" FROM \"Accounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountID ; rr:objectMap [ rr:column "AccountID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClientID ; rr:objectMap [ rr:column "ClientID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountType ; rr:objectMap [ rr:column "AccountType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Balance ; rr:objectMap [ rr:column "Balance" ] ] .

<#tm_attachment_1tab_val_retirement_savings_2_Accounts_ClientID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountID\", \"ClientID\" FROM \"Accounts\" WHERE \"ClientID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClients ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Clients/{ClientID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_retirement_savings_3_Pensions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PensionID\", \"ClientID\", \"Retirement_Savings\", \"Rate_of_return\", \"ContributionAmount\" FROM \"Pensions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Pensions/{PensionID}" ; rr:class :Pensions ] ;
  rr:predicateObjectMap [ rr:predicate p:PensionID ; rr:objectMap [ rr:column "PensionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClientID ; rr:objectMap [ rr:column "ClientID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Retirement_Savings ; rr:objectMap [ rr:column "Retirement_Savings" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rate_of_return ; rr:objectMap [ rr:column "Rate_of_return" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ContributionAmount ; rr:objectMap [ rr:column "ContributionAmount" ] ] .

<#tm_attachment_1tab_val_retirement_savings_4_Pensions_ClientID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PensionID\", \"ClientID\" FROM \"Pensions\" WHERE \"ClientID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Pensions/{PensionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClients ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Clients/{ClientID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_retirement_savings_5_Investments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InvestmentID\", \"AccountID\", \"Ticker\", \"Shares\", \"PricePerShare\", \"TotalInvestment\" FROM \"Investments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Investments/{InvestmentID}" ; rr:class :Investments ] ;
  rr:predicateObjectMap [ rr:predicate p:InvestmentID ; rr:objectMap [ rr:column "InvestmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountID ; rr:objectMap [ rr:column "AccountID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Ticker ; rr:objectMap [ rr:column "Ticker" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Shares ; rr:objectMap [ rr:column "Shares" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PricePerShare ; rr:objectMap [ rr:column "PricePerShare" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalInvestment ; rr:objectMap [ rr:column "TotalInvestment" ] ] .

<#tm_attachment_1tab_val_retirement_savings_6_Investments_AccountID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InvestmentID\", \"AccountID\" FROM \"Investments\" WHERE \"AccountID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Investments/{InvestmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccounts ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ; rr:termType rr:IRI ] ] .

