@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_structured_finance_vehicles_0_Clients_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClientID\", \"FirstName\", \"LastName\", \"EmailAddress\", \"PhoneNumber\" FROM \"Clients\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Clients/{ClientID}" ; rr:class :Clients ] ;
  rr:predicateObjectMap [ rr:predicate p:ClientID ; rr:objectMap [ rr:column "ClientID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_attachment_1tab_val_structured_finance_vehicles_1_Accounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountID\", \"ClientID\", \"Balance\", \"InterestRate\" FROM \"Accounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountID ; rr:objectMap [ rr:column "AccountID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClientID ; rr:objectMap [ rr:column "ClientID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Balance ; rr:objectMap [ rr:column "Balance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:InterestRate ; rr:objectMap [ rr:column "InterestRate" ] ] .

<#tm_attachment_1tab_val_structured_finance_vehicles_2_Accounts_ClientID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountID\", \"ClientID\" FROM \"Accounts\" WHERE \"ClientID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClients ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Clients/{ClientID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_structured_finance_vehicles_3_Loans_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LoanID\", \"ClientID\", \"Principal\", \"InterestRate\", \"TermYears\", \"MonthlyPayment\" FROM \"Loans\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loans/{LoanID}" ; rr:class :Loans ] ;
  rr:predicateObjectMap [ rr:predicate p:LoanID ; rr:objectMap [ rr:column "LoanID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClientID ; rr:objectMap [ rr:column "ClientID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Principal ; rr:objectMap [ rr:column "Principal" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:InterestRate ; rr:objectMap [ rr:column "InterestRate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TermYears ; rr:objectMap [ rr:column "TermYears" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MonthlyPayment ; rr:objectMap [ rr:column "MonthlyPayment" ] ] .

<#tm_attachment_1tab_val_structured_finance_vehicles_4_Loans_ClientID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LoanID\", \"ClientID\" FROM \"Loans\" WHERE \"ClientID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loans/{LoanID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClients ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Clients/{ClientID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_structured_finance_vehicles_5_Structured_Financial_Products_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProductID\", \"Name\", \"Type\", \"Price\", \"OtherValues\" FROM \"Structured_Financial_Products\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Structured_Financial_Products/{ProductID}" ; rr:class :Structured_Financial_Products ] ;
  rr:predicateObjectMap [ rr:predicate p:ProductID ; rr:objectMap [ rr:column "ProductID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OtherValues ; rr:objectMap [ rr:column "OtherValues" ] ] .

