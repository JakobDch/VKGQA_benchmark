@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_transaction_types_0_Transaction_Type_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"transaction_id\", \"transaction_type\", \"bank_account\", \"amount\", \"date\" FROM \"Transaction_Type\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Transactions/{transaction_id}" ; rr:class :Transactions ] ;
  rr:predicateObjectMap [ rr:predicate p:transaction_id ; rr:objectMap [ rr:column "transaction_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:transaction_type ; rr:objectMap [ rr:column "transaction_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bank_account ; rr:objectMap [ rr:column "bank_account" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amount ; rr:objectMap [ rr:column "amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] .

<#tm_attachment_1tab_val_transaction_types_1_Customer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"first_name\", \"last_name\", \"email\", \"phone_number\" FROM \"Customer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customer_id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_attachment_1tab_val_transaction_types_2_Account_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"account_id\", \"bank_account\", \"balance\", \"interest_rate\" FROM \"Account\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{account_id}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:account_id ; rr:objectMap [ rr:column "account_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bank_account ; rr:objectMap [ rr:column "bank_account" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:balance ; rr:objectMap [ rr:column "balance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:interest_rate ; rr:objectMap [ rr:column "interest_rate" ] ] .

<#tm_attachment_1tab_val_transaction_types_3_Employee_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employee_id\", \"first_name\", \"last_name\", \"email\", \"hire_date\" FROM \"Employee\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Employees/{employee_id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:employee_id ; rr:objectMap [ rr:column "employee_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hire_date ; rr:objectMap [ rr:column "hire_date" ] ] .

<#tm_attachment_1tab_val_transaction_types_4_Loan_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"loan_id\", \"customer_id\", \"loan_amount\", \"interest_rate\", \"start_date\", \"end_date\" FROM \"Loan\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loans/{loan_id}" ; rr:class :Loans ] ;
  rr:predicateObjectMap [ rr:predicate p:loan_id ; rr:objectMap [ rr:column "loan_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:loan_amount ; rr:objectMap [ rr:column "loan_amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:interest_rate ; rr:objectMap [ rr:column "interest_rate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] .

<#tm_attachment_1tab_val_transaction_types_5_Loan_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"loan_id\", \"customer_id\" FROM \"Loan\" WHERE \"customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loans/{loan_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customer_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_transaction_types_6_Savings_Account_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"savings_id\", \"account_id\", \"balance\", \"annual_interst_rate\", \"created_at\" FROM \"Savings_Account\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/SavingsAccounts/{savings_id}" ; rr:class :SavingsAccounts ] ;
  rr:predicateObjectMap [ rr:predicate p:savings_id ; rr:objectMap [ rr:column "savings_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:account_id ; rr:objectMap [ rr:column "account_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:balance ; rr:objectMap [ rr:column "balance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:annual_interst_rate ; rr:objectMap [ rr:column "annual_interst_rate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:created_at ; rr:objectMap [ rr:column "created_at" ] ] .

<#tm_attachment_1tab_val_transaction_types_7_Savings_Account_account_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"savings_id\", \"account_id\" FROM \"Savings_Account\" WHERE \"account_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/SavingsAccounts/{savings_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccounts ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{account_id}" ; rr:termType rr:IRI ] ] .

