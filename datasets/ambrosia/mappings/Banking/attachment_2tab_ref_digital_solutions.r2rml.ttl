<#tm_attachment_2tab_ref_digital_solutions_4_InternetBankingPlatforms_AdditionalFeatures_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PlatformID\", \"AdditionalFeatures\" FROM \"InternetBankingPlatforms\" WHERE \"AdditionalFeatures\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/InternetBankingPlatforms/{PlatformID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSignInOptions ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/SignInOptions/{AdditionalFeatures}" ; rr:termType rr:IRI ] ] .

