@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_digital_solutions_0_SignInOptions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"OptionName\" FROM \"SignInOptions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/SignInOptions/{ID}" ; rr:class :SignInOptions ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OptionName ; rr:objectMap [ rr:column "OptionName" ] ] .

<#tm_attachment_2tab_ref_digital_solutions_1_MobileBankingApps_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AppID\", \"Name\", \"Description\", \"PlatformType\" FROM \"MobileBankingApps\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/MobileBankingApps/{AppID}" ; rr:class :MobileBankingApps ] ;
  rr:predicateObjectMap [ rr:predicate p:AppID ; rr:objectMap [ rr:column "AppID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PlatformType ; rr:objectMap [ rr:column "PlatformType" ] ] .

<#tm_attachment_2tab_ref_digital_solutions_2_MobileBankingApps_PlatformType_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AppID\", \"PlatformType\" FROM \"MobileBankingApps\" WHERE \"PlatformType\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/MobileBankingApps/{AppID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSignInOptions ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/SignInOptions/{PlatformType}" ; rr:termType rr:IRI ] ] .

