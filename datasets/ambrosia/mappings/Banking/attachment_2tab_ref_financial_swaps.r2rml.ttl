@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_financial_swaps_0_Banks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Banks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{id}" ; rr:class :Banks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_financial_swaps_1_Accounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"account_id\", \"bank_name\", \"balance\" FROM \"Accounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{account_id}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:account_id ; rr:objectMap [ rr:column "account_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bank_name ; rr:objectMap [ rr:column "bank_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:balance ; rr:objectMap [ rr:column "balance" ] ] .

<#tm_attachment_2tab_ref_financial_swaps_2_Accounts_bank_name_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"account_id\", \"bank_name\" FROM \"Accounts\" WHERE \"bank_name\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{account_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBanks ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{bank_name}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_financial_swaps_3_Currency_Swaps_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"swap_id\", \"bank_name\", \"amount\", \"maturity_date\", \"foreign_currency\" FROM \"Currency_Swaps\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Currency_Swaps/{swap_id}" ; rr:class :Currency_Swaps ] ;
  rr:predicateObjectMap [ rr:predicate p:swap_id ; rr:objectMap [ rr:column "swap_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bank_name ; rr:objectMap [ rr:column "bank_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amount ; rr:objectMap [ rr:column "amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:maturity_date ; rr:objectMap [ rr:column "maturity_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:foreign_currency ; rr:objectMap [ rr:column "foreign_currency" ] ] .

<#tm_attachment_2tab_ref_financial_swaps_4_Currency_Swaps_bank_name_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"swap_id\", \"bank_name\" FROM \"Currency_Swaps\" WHERE \"bank_name\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Currency_Swaps/{swap_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBanks ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{bank_name}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_financial_swaps_5_Interest_Rate_Swaps_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"swap_id\", \"bank_name\", \"start_date\", \"end_date\", \"fixed_rate\", \"floating_rate\" FROM \"Interest_Rate_Swaps\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Interest_Rate_Swaps/{swap_id}" ; rr:class :Interest_Rate_Swaps ] ;
  rr:predicateObjectMap [ rr:predicate p:swap_id ; rr:objectMap [ rr:column "swap_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bank_name ; rr:objectMap [ rr:column "bank_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fixed_rate ; rr:objectMap [ rr:column "fixed_rate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:floating_rate ; rr:objectMap [ rr:column "floating_rate" ] ] .

<#tm_attachment_2tab_ref_financial_swaps_6_Interest_Rate_Swaps_bank_name_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"swap_id\", \"bank_name\" FROM \"Interest_Rate_Swaps\" WHERE \"bank_name\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Interest_Rate_Swaps/{swap_id}" ] ;
