@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_types_of_banks_0_Country_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Country\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Country/{id}" ; rr:class :Country ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_types_of_banks_1_Central_Bank_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"central_bank_name\", \"country_id\" FROM \"Central_Bank\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Central_Bank/{id}" ; rr:class :Central_Bank ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:central_bank_name ; rr:objectMap [ rr:column "central_bank_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country_id ; rr:objectMap [ rr:column "country_id" ] ] .

<#tm_attachment_2tab_ref_types_of_banks_2_Central_Bank_country_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"country_id\" FROM \"Central_Bank\" WHERE \"country_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Central_Bank/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCountry ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Country/{country_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_types_of_banks_3_Commercial_Bank_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"commercial_bank_name\", \"country_id\" FROM \"Commercial_Bank\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Commercial_Bank/{id}" ; rr:class :Commercial_Bank ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:commercial_bank_name ; rr:objectMap [ rr:column "commercial_bank_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country_id ; rr:objectMap [ rr:column "country_id" ] ] .

<#tm_attachment_2tab_ref_types_of_banks_4_Commercial_Bank_country_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"country_id\" FROM \"Commercial_Bank\" WHERE \"country_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Commercial_Bank/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCountry ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Country/{country_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_types_of_banks_5_Account_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"account_number\", \"balance\", \"commercial_bank_id\" FROM \"Account\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{id}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:account_number ; rr:objectMap [ rr:column "account_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:balance ; rr:objectMap [ rr:column "balance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:commercial_bank_id ; rr:objectMap [ rr:column "commercial_bank_id" ] ] .

<#tm_attachment_2tab_ref_types_of_banks_6_Account_commercial_bank_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"commercial_bank_id\" FROM \"Account\" WHERE \"commercial_bank_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCommercial_Bank ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Commercial_Bank/{commercial_bank_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_types_of_banks_7_Account_commercial_bank_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"commercial_bank_id\" FROM \"Account\" WHERE \"commercial_bank_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCommercial_Bank ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Commercial_Bank/{commercial_bank_id}" ; rr:termType rr:IRI ] ] .

