  rr:predicateObjectMap [ rr:predicate p:total_assets ; rr:objectMap [ rr:column "total_assets" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:expense_ratio ; rr:objectMap [ rr:column "expense_ratio" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fees ; rr:objectMap [ rr:column "fees" ] ] .

