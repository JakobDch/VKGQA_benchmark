@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_capital_market_participants_0_Stockbrokers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"contact_number\", \"email\", \"fees\" FROM \"Stockbrokers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Stockbrokers/{id}" ; rr:class :Stockbrokers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contact_number ; rr:objectMap [ rr:column "contact_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fees ; rr:objectMap [ rr:column "fees" ] ] .

<#tm_attachment_2tab_val_capital_market_participants_1_Mutual_funds_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"fund_name\", \"total_assets\", \"expense_ratio\", \"fees\" FROM \"Mutual_funds\"""" ] ;
