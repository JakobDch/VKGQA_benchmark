@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_investment_company_0_growth_equity_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firm_name\", \"funding_amount\", \"deal_date\", \"notes\" FROM \"growth_equity\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/growth_equity/{id}" ; rr:class :growth_equity ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firm_name ; rr:objectMap [ rr:column "firm_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:funding_amount ; rr:objectMap [ rr:column "funding_amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:deal_date ; rr:objectMap [ rr:column "deal_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:notes ; rr:objectMap [ rr:column "notes" ] ] .

<#tm_attachment_2tab_val_investment_company_1_venture_capital_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"trust_name\", \"funding_amount\", \"investment_period\", \"exit_strategy\" FROM \"venture_capital\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/venture_capital/{id}" ; rr:class :venture_capital ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:trust_name ; rr:objectMap [ rr:column "trust_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:funding_amount ; rr:objectMap [ rr:column "funding_amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:investment_period ; rr:objectMap [ rr:column "investment_period" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:exit_strategy ; rr:objectMap [ rr:column "exit_strategy" ] ] .

<#tm_attachment_2tab_val_investment_company_2_customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"company_name\", \"address\", \"contact_person_name\", \"phone_number\", \"email\", \"equity_firm_id\", \"venture_capital_id\" FROM \"customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customer_id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_name ; rr:objectMap [ rr:column "company_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contact_person_name ; rr:objectMap [ rr:column "contact_person_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:equity_firm_id ; rr:objectMap [ rr:column "equity_firm_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:venture_capital_id ; rr:objectMap [ rr:column "venture_capital_id" ] ] .

<#tm_attachment_2tab_val_investment_company_3_customers_venture_capital_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"venture_capital_id\" FROM \"customers\" WHERE \"venture_capital_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customer_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasventure_capital ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/venture_capital/{venture_capital_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_investment_company_4_customers_equity_firm_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"equity_firm_id\" FROM \"customers\" WHERE \"equity_firm_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customer_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasgrowth_equity ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/growth_equity/{equity_firm_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_investment_company_5_employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employee_id\", \"name\", \"hire_date\", \"position\", \"assigned_customer_id\" FROM \"employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Employees/{employee_id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:employee_id ; rr:objectMap [ rr:column "employee_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hire_date ; rr:objectMap [ rr:column "hire_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position ; rr:objectMap [ rr:column "position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:assigned_customer_id ; rr:objectMap [ rr:column "assigned_customer_id" ] ] .

<#tm_attachment_2tab_val_investment_company_6_employees_assigned_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employee_id\", \"assigned_customer_id\" FROM \"employees\" WHERE \"assigned_customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Employees/{employee_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{assigned_customer_id}" ; rr:termType rr:IRI ] ] .

