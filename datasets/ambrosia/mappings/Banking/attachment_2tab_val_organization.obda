[PrefixDeclaration]
:	http://ambrosia.example.org/banking#
p:	http://ambrosia.example.org/banking/prop#
ex:	http://ambrosia.example.org/banking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Currency_Exchange_Service_base
target		ex:Currency_Exchange_Service/{id} a :Currency_Exchange_Service ; p:id {id} ; p:name {Name} ; p:Year_of_establishment {Year_of_establishment} ; p:Number_of_branches {Number_of_branches} ; p:Total_assets {Total_assets} .
source		SELECT `id`, `Name`, `Year_of_establishment`, `Number_of_branches`, `Total_assets` FROM `Currency_Exchange_Service`

mappingId	Commodity_Trading_Firm_base
target		ex:Commodity_Trading_Firm/{id} a :Commodity_Trading_Firm ; p:id {id} ; p:name {Name} ; p:Year_of_establishment {Year_of_establishment} ; p:Number_of_employees {Number_of_employees} ; p:Annual_revenue {Annual_revenue} .
source		SELECT `id`, `Name`, `Year_of_establishment`, `Number_of_employees`, `Annual_revenue` FROM `Commodity_Trading_Firm`

mappingId	Customer_base
target		ex:Customers/{id} a :Customers ; p:id {id} ; p:First_Name {First_Name} ; p:Last_Name {Last_Name} ; p:Date_of_birth {Date_of_birth} ; p:email {Email} .
source		SELECT `id`, `First_Name`, `Last_Name`, `Date_of_birth`, `Email` FROM `Customer`

mappingId	Account_base
target		ex:Accounts/{id} a :Accounts ; p:id {id} ; p:customer_id {customer_id} ; p:account_type {account_type} ; p:balance {balance} .
source		SELECT `id`, `customer_id`, `account_type`, `balance` FROM `Account`

mappingId	Account_customer_id_fk
target		ex:Accounts/{id} p:hasCustomers ex:Customers/{customer_id} .
source		SELECT `id`, `customer_id` FROM `Account` WHERE `customer_id` IS NOT NULL

mappingId	Loan_base
target		ex:Loans/{id} a :Loans ; p:id {id} ; p:customer_id {customer_id} ; p:loan_amount {loan_amount} ; p:interest_rate {interest_rate} ; p:start_date {start_date} ; p:end_date {end_date} .
source		SELECT `id`, `customer_id`, `loan_amount`, `interest_rate`, `start_date`, `end_date` FROM `Loan`

mappingId	Loan_customer_id_fk
target		ex:Loans/{id} p:hasCustomers ex:Customers/{customer_id} .
source		SELECT `id`, `customer_id` FROM `Loan` WHERE `customer_id` IS NOT NULL

mappingId	Investment_base
target		ex:Investments/{id} a :Investments ; p:id {id} ; p:customer_id {customer_id} ; p:investment_type {investment_type} ; p:amount {amount} ; p:date_purchased {date_purchased} ; p:current_value {current_value} .
source		SELECT `id`, `customer_id`, `investment_type`, `amount`, `date_purchased`, `current_value` FROM `Investment`

mappingId	Investment_customer_id_fk
target		ex:Investments/{id} p:hasCustomers ex:Customers/{customer_id} .
source		SELECT `id`, `customer_id` FROM `Investment` WHERE `customer_id` IS NOT NULL

]]
