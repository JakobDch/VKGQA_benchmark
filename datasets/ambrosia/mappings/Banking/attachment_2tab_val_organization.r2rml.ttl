<#tm_attachment_2tab_val_organization_4_Account_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"customer_id\" FROM \"Account\" WHERE \"customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customer_id}" ; rr:termType rr:IRI ] ] .

