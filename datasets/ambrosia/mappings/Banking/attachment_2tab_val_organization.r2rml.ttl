@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_organization_0_Currency_Exchange_Service_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Year_of_establishment\", \"Number_of_branches\", \"Total_assets\" FROM \"Currency_Exchange_Service\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Currency_Exchange_Service/{id}" ; rr:class :Currency_Exchange_Service ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year_of_establishment ; rr:objectMap [ rr:column "Year_of_establishment" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_branches ; rr:objectMap [ rr:column "Number_of_branches" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Total_assets ; rr:objectMap [ rr:column "Total_assets" ] ] .

<#tm_attachment_2tab_val_organization_1_Commodity_Trading_Firm_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Year_of_establishment\", \"Number_of_employees\", \"Annual_revenue\" FROM \"Commodity_Trading_Firm\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Commodity_Trading_Firm/{id}" ; rr:class :Commodity_Trading_Firm ] ;
