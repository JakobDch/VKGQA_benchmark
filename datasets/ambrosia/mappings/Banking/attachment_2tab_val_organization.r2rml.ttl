  rr:predicateObjectMap [ rr:predicate p:Year_of_establishment ; rr:objectMap [ rr:column "Year_of_establishment" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_employees ; rr:objectMap [ rr:column "Number_of_employees" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Annual_revenue ; rr:objectMap [ rr:column "Annual_revenue" ] ] .

<#tm_attachment_2tab_val_organization_2_Customer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"First_Name\", \"Last_Name\", \"Date_of_birth\", \"Email\" FROM \"Customer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:First_Name ; rr:objectMap [ rr:column "First_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Last_Name ; rr:objectMap [ rr:column "Last_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date_of_birth ; rr:objectMap [ rr:column "Date_of_birth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

