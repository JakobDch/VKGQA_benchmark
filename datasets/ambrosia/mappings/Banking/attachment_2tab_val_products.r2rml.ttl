@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_products_0_Exchange_traded_Products_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ProductName\", \"TickerSymbol\", \"AssetClass\", \"TotalAssets\", \"ExitFee\" FROM \"Exchange_traded_Products\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Exchange_traded_Products/{id}" ; rr:class :Exchange_traded_Products ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProductName ; rr:objectMap [ rr:column "ProductName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TickerSymbol ; rr:objectMap [ rr:column "TickerSymbol" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AssetClass ; rr:objectMap [ rr:column "AssetClass" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalAssets ; rr:objectMap [ rr:column "TotalAssets" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ExitFee ; rr:objectMap [ rr:column "ExitFee" ] ] .

<#tm_attachment_2tab_val_products_1_Unit_investment_Trusts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"TrustName\", \"TickerSymbol\", \"NetAssetValue\", \"NumberOfUnits\", \"ExitFee\" FROM \"Unit_investment_Trusts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Unit_investment_Trusts/{id}" ; rr:class :Unit_investment_Trusts ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TrustName ; rr:objectMap [ rr:column "TrustName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TickerSymbol ; rr:objectMap [ rr:column "TickerSymbol" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NetAssetValue ; rr:objectMap [ rr:column "NetAssetValue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfUnits ; rr:objectMap [ rr:column "NumberOfUnits" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ExitFee ; rr:objectMap [ rr:column "ExitFee" ] ] .

<#tm_attachment_2tab_val_products_2_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"CustomerName\", \"EmailAddress\", \"PhoneNumber\", \"AccountBalance\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerName ; rr:objectMap [ rr:column "CustomerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountBalance ; rr:objectMap [ rr:column "AccountBalance" ] ] .

<#tm_attachment_2tab_val_products_3_Orders_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OrderID\", \"CustomerId\", \"ProductType\", \"Quantity\", \"Price\", \"DateOrdered\" FROM \"Orders\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Orders/{OrderID}" ; rr:class :Orders ] ;
  rr:predicateObjectMap [ rr:predicate p:OrderID ; rr:objectMap [ rr:column "OrderID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerId ; rr:objectMap [ rr:column "CustomerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProductType ; rr:objectMap [ rr:column "ProductType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOrdered ; rr:objectMap [ rr:column "DateOrdered" ] ] .

<#tm_attachment_2tab_val_products_4_Orders_CustomerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OrderID\", \"CustomerId\" FROM \"Orders\" WHERE \"CustomerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Orders/{OrderID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{CustomerId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_products_5_Transactions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TransactionId\", \"OrderId\", \"Amount\", \"Fees\", \"PaymentMethod\", \"Status\", \"ProcessDate\" FROM \"Transactions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Transactions/{TransactionId}" ; rr:class :Transactions ] ;
  rr:predicateObjectMap [ rr:predicate p:TransactionId ; rr:objectMap [ rr:column "TransactionId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OrderId ; rr:objectMap [ rr:column "OrderId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Amount ; rr:objectMap [ rr:column "Amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Fees ; rr:objectMap [ rr:column "Fees" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PaymentMethod ; rr:objectMap [ rr:column "PaymentMethod" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Status ; rr:objectMap [ rr:column "Status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProcessDate ; rr:objectMap [ rr:column "ProcessDate" ] ] .

<#tm_attachment_2tab_val_products_6_Transactions_OrderId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TransactionId\", \"OrderId\" FROM \"Transactions\" WHERE \"OrderId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Transactions/{TransactionId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOrders ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Orders/{OrderId}" ; rr:termType rr:IRI ] ] .

