@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_bank_products_risks_0_Risks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RiskID\", \"RiskName\" FROM \"Risks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Risks/{RiskID}" ; rr:class :Risks ] ;
  rr:predicateObjectMap [ rr:predicate p:RiskID ; rr:objectMap [ rr:column "RiskID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RiskName ; rr:objectMap [ rr:column "RiskName" ] ] .

<#tm_scope_bank_products_risks_1_Banks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BankID\", \"BankName\", \"Location\" FROM \"Banks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{BankID}" ; rr:class :Banks ] ;
  rr:predicateObjectMap [ rr:predicate p:BankID ; rr:objectMap [ rr:column "BankID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BankName ; rr:objectMap [ rr:column "BankName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

