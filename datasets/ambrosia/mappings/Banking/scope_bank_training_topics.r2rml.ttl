<#tm_scope_bank_training_topics_5_TrainingSessions_trainer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"session_id\", \"trainer_id\" FROM \"TrainingSessions\" WHERE \"trainer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/TrainingSessions/{session_id}" ] ;
