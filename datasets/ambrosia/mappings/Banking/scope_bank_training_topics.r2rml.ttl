  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:trainer_id ; rr:objectMap [ rr:column "trainer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:topic_id ; rr:objectMap [ rr:column "topic_id" ] ] .

