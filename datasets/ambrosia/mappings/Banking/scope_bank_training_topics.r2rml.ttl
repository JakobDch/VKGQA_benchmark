@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_bank_training_topics_0_Banks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Banks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{id}" ; rr:class :Banks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_bank_training_topics_1_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\", \"bank_id\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Employees/{id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bank_id ; rr:objectMap [ rr:column "bank_id" ] ] .

<#tm_scope_bank_training_topics_2_Employees_bank_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"bank_id\" FROM \"Employees\" WHERE \"bank_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Employees/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBanks ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{bank_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_bank_training_topics_3_TrainingSessions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"session_id\", \"date\", \"trainer_id\", \"topic_id\" FROM \"TrainingSessions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/TrainingSessions/{session_id}" ; rr:class :TrainingSessions ] ;
