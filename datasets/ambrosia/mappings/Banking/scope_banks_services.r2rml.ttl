  rr:logicalTable [ rr:sqlQuery """SELECT \"bankId\", \"serviceId\" FROM \"Banks_Services\" WHERE \"serviceId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks_Services/{bankId}/{serviceId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasServices ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Services/{serviceId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_banks_services_9_Banks_Services_bankId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bankId\", \"serviceId\" FROM \"Banks_Services\" WHERE \"bankId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks_Services/{bankId}/{serviceId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBanks ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{bankId}" ; rr:termType rr:IRI ] ] .

