<#tm_scope_credit_cards_benefits_8_Credit_Card_Benefits_creditCardId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"creditCardId\" FROM \"Credit_Card_Benefits\" WHERE \"creditCardId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Credit_Card_Benefits/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCredit_Cards ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Credit_Cards/{creditCardId}" ; rr:termType rr:IRI ] ] .

