@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_finance_apps_tools_0_Finance_Apps_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"description\" FROM \"Finance_Apps\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Finance_Apps/{id}" ; rr:class :Finance_Apps ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_finance_apps_tools_1_Tools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"tool_name\", \"category\" FROM \"Tools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Tools/{id}" ; rr:class :Tools ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:tool_name ; rr:objectMap [ rr:column "tool_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:category ; rr:objectMap [ rr:column "category" ] ] .

<#tm_scope_finance_apps_tools_2_Finance_Apps_Tools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"finance_app_id\", \"tool_id\" FROM \"Finance_Apps_Tools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Finance_Apps_Tools/{finance_app_id}/{tool_id}" ; rr:class :Finance_Apps_Tools ] ;
  rr:predicateObjectMap [ rr:predicate p:finance_app_id ; rr:objectMap [ rr:column "finance_app_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:tool_id ; rr:objectMap [ rr:column "tool_id" ] ] .

<#tm_scope_finance_apps_tools_3_Finance_Apps_Tools_tool_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"finance_app_id\", \"tool_id\" FROM \"Finance_Apps_Tools\" WHERE \"tool_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Finance_Apps_Tools/{finance_app_id}/{tool_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTools ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Tools/{tool_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_finance_apps_tools_4_Finance_Apps_Tools_finance_app_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"finance_app_id\", \"tool_id\" FROM \"Finance_Apps_Tools\" WHERE \"finance_app_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Finance_Apps_Tools/{finance_app_id}/{tool_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFinance_Apps ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Finance_Apps/{finance_app_id}" ; rr:termType rr:IRI ] ] .

