@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_loan_applications_requirements_0_Loan_Applications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ApplicationID\", \"CustomerName\", \"AmountMoney\" FROM \"Loan_Applications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loan_Applications/{ApplicationID}" ; rr:class :Loan_Applications ] ;
  rr:predicateObjectMap [ rr:predicate p:ApplicationID ; rr:objectMap [ rr:column "ApplicationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerName ; rr:objectMap [ rr:column "CustomerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AmountMoney ; rr:objectMap [ rr:column "AmountMoney" ] ] .

<#tm_scope_loan_applications_requirements_1_Requirements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RequirementID\", \"RequirementDescription\" FROM \"Requirements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Requirements/{RequirementID}" ; rr:class :Requirements ] ;
  rr:predicateObjectMap [ rr:predicate p:RequirementID ; rr:objectMap [ rr:column "RequirementID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RequirementDescription ; rr:objectMap [ rr:column "RequirementDescription" ] ] .

<#tm_scope_loan_applications_requirements_2_Employee_Details_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EmployeeID\", \"Fullname\", \"Position\" FROM \"Employee_Details\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Employees/{EmployeeID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:EmployeeID ; rr:objectMap [ rr:column "EmployeeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Fullname" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Position ; rr:objectMap [ rr:column "Position" ] ] .

<#tm_scope_loan_applications_requirements_3_Applicant_Details_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ApplicantID\", \"Fullname\", \"Age\", \"Occupation\" FROM \"Applicant_Details\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Applicant_Details/{ApplicantID}" ; rr:class :Applicant_Details ] ;
  rr:predicateObjectMap [ rr:predicate p:ApplicantID ; rr:objectMap [ rr:column "ApplicantID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Fullname" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Occupation ; rr:objectMap [ rr:column "Occupation" ] ] .

<#tm_scope_loan_applications_requirements_4_Loan_Applications_Requirements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"AppID\", \"ReqID\" FROM \"Loan_Applications_Requirements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loan_Applications_Requirements/{_amb_rowid}" ; rr:class :Loan_Applications_Requirements ] ;
  rr:predicateObjectMap [ rr:predicate p:AppID ; rr:objectMap [ rr:column "AppID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReqID ; rr:objectMap [ rr:column "ReqID" ] ] .

<#tm_scope_loan_applications_requirements_5_Loan_Applications_Requirements_ReqID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ReqID\" FROM \"Loan_Applications_Requirements\" WHERE \"ReqID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loan_Applications_Requirements/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRequirements ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Requirements/{ReqID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_loan_applications_requirements_6_Loan_Applications_Requirements_AppID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"AppID\" FROM \"Loan_Applications_Requirements\" WHERE \"AppID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loan_Applications_Requirements/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLoan_Applications ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Loan_Applications/{AppID}" ; rr:termType rr:IRI ] ] .

