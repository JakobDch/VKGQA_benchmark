@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_marketing_campaigns_approaches_0_Marketing_Campaigns_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"campaign_name\", \"start_date\", \"end_date\" FROM \"Marketing_Campaigns\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Marketing_Campaigns/{id}" ; rr:class :Marketing_Campaigns ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:campaign_name ; rr:objectMap [ rr:column "campaign_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] .

<#tm_scope_marketing_campaigns_approaches_1_Approaches_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"approach_value\" FROM \"Approaches\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Approaches/{id}" ; rr:class :Approaches ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:approach_value ; rr:objectMap [ rr:column "approach_value" ] ] .

<#tm_scope_marketing_campaigns_approaches_2_Marketing_Campaigns_Approaches_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"marketing_campaign_id\", \"approach_id\" FROM \"Marketing_Campaigns_Approaches\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Marketing_Campaigns_Approaches/{marketing_campaign_id}/{approach_id}" ; rr:class :Marketing_Campaigns_Approaches ] ;
  rr:predicateObjectMap [ rr:predicate p:marketing_campaign_id ; rr:objectMap [ rr:column "marketing_campaign_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:approach_id ; rr:objectMap [ rr:column "approach_id" ] ] .

<#tm_scope_marketing_campaigns_approaches_3_Marketing_Campaigns_Approaches_approach_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"marketing_campaign_id\", \"approach_id\" FROM \"Marketing_Campaigns_Approaches\" WHERE \"approach_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Marketing_Campaigns_Approaches/{marketing_campaign_id}/{approach_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApproaches ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Approaches/{approach_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_marketing_campaigns_approaches_4_Marketing_Campaigns_Approaches_marketing_campaign_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"marketing_campaign_id\", \"approach_id\" FROM \"Marketing_Campaigns_Approaches\" WHERE \"marketing_campaign_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Marketing_Campaigns_Approaches/{marketing_campaign_id}/{approach_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMarketing_Campaigns ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Marketing_Campaigns/{marketing_campaign_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_marketing_campaigns_approaches_5_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"first_name\", \"last_name\", \"email\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customer_id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_marketing_campaigns_approaches_6_Transactions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"transaction_id\", \"amount\", \"date\", \"customer_id\" FROM \"Transactions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Transactions/{transaction_id}" ; rr:class :Transactions ] ;
  rr:predicateObjectMap [ rr:predicate p:transaction_id ; rr:objectMap [ rr:column "transaction_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amount ; rr:objectMap [ rr:column "amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] .

<#tm_scope_marketing_campaigns_approaches_7_Transactions_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"transaction_id\", \"customer_id\" FROM \"Transactions\" WHERE \"customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Transactions/{transaction_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customer_id}" ; rr:termType rr:IRI ] ] .

