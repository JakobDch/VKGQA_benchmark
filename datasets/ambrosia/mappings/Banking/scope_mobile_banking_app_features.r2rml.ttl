@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_mobile_banking_app_features_0_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"first_name\", \"last_name\", \"email\", \"phone_number\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customer_id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_scope_mobile_banking_app_features_1_Accounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"account_id\", \"customer_id\", \"account_type\", \"balance\" FROM \"Accounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{account_id}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:account_id ; rr:objectMap [ rr:column "account_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:account_type ; rr:objectMap [ rr:column "account_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:balance ; rr:objectMap [ rr:column "balance" ] ] .

<#tm_scope_mobile_banking_app_features_2_Accounts_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"account_id\", \"customer_id\" FROM \"Accounts\" WHERE \"customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{account_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customer_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_mobile_banking_app_features_3_Mobile_Banking_App_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"app_id\", \"app_version\", \"release_date\", \"platform\" FROM \"Mobile_Banking_App\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/MobileBankingApps/{app_id}" ; rr:class :MobileBankingApps ] ;
  rr:predicateObjectMap [ rr:predicate p:app_id ; rr:objectMap [ rr:column "app_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:app_version ; rr:objectMap [ rr:column "app_version" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:platform ; rr:objectMap [ rr:column "platform" ] ] .

<#tm_scope_mobile_banking_app_features_4_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"feature_id\", \"feature_value\" FROM \"Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Features/{feature_id}" ; rr:class :Features ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_id ; rr:objectMap [ rr:column "feature_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_value ; rr:objectMap [ rr:column "feature_value" ] ] .

<#tm_scope_mobile_banking_app_features_5_Mobile_Banking_App_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"mobile_app_feature_id\", \"mobile_banking_app_id\", \"feature_id\" FROM \"Mobile_Banking_App_Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Mobile_Banking_App_Features/{mobile_app_feature_id}/{mobile_banking_app_id}/{feature_id}" ; rr:class :Mobile_Banking_App_Features ] ;
  rr:predicateObjectMap [ rr:predicate p:mobile_app_feature_id ; rr:objectMap [ rr:column "mobile_app_feature_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:mobile_banking_app_id ; rr:objectMap [ rr:column "mobile_banking_app_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_id ; rr:objectMap [ rr:column "feature_id" ] ] .

<#tm_scope_mobile_banking_app_features_6_Mobile_Banking_App_Features_mobile_banking_app_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"mobile_app_feature_id\", \"mobile_banking_app_id\", \"feature_id\" FROM \"Mobile_Banking_App_Features\" WHERE \"mobile_banking_app_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Mobile_Banking_App_Features/{mobile_app_feature_id}/{mobile_banking_app_id}/{feature_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMobileBankingApps ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/MobileBankingApps/{mobile_banking_app_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_mobile_banking_app_features_7_Mobile_Banking_App_Features_feature_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"mobile_app_feature_id\", \"mobile_banking_app_id\", \"feature_id\" FROM \"Mobile_Banking_App_Features\" WHERE \"feature_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Mobile_Banking_App_Features/{mobile_app_feature_id}/{mobile_banking_app_id}/{feature_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFeatures ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Features/{feature_id}" ; rr:termType rr:IRI ] ] .

