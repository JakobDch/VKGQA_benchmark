@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_online_banking_platforms_features_0_Online_Banking_Platforms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"website\" FROM \"Online_Banking_Platforms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Online_Banking_Platforms/{id}" ; rr:class :Online_Banking_Platforms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:website ; rr:objectMap [ rr:column "website" ] ] .

<#tm_scope_online_banking_platforms_features_1_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"feature_id\", \"feature_value\" FROM \"Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Features/{feature_id}" ; rr:class :Features ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_id ; rr:objectMap [ rr:column "feature_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_value ; rr:objectMap [ rr:column "feature_value" ] ] .

<#tm_scope_online_banking_platforms_features_2_Online_Banking_Platforms_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"platform_id\", \"feature_id\" FROM \"Online_Banking_Platforms_Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Online_Banking_Platforms_Features/{_amb_rowid}" ; rr:class :Online_Banking_Platforms_Features ] ;
  rr:predicateObjectMap [ rr:predicate p:platform_id ; rr:objectMap [ rr:column "platform_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_id ; rr:objectMap [ rr:column "feature_id" ] ] .

<#tm_scope_online_banking_platforms_features_3_Online_Banking_Platforms_Features_feature_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"feature_id\" FROM \"Online_Banking_Platforms_Features\" WHERE \"feature_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Online_Banking_Platforms_Features/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFeatures ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Features/{feature_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_online_banking_platforms_features_4_Online_Banking_Platforms_Features_platform_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"platform_id\" FROM \"Online_Banking_Platforms_Features\" WHERE \"platform_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Online_Banking_Platforms_Features/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOnline_Banking_Platforms ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Online_Banking_Platforms/{platform_id}" ; rr:termType rr:IRI ] ] .

