  rr:predicateObjectMap [ rr:predicate p:Amount ; rr:objectMap [ rr:column "Amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TransactionDate ; rr:objectMap [ rr:column "TransactionDate" ] ] .

<#tm_vague_2cols_deposit_limit_4_Transactions_AccountNumber_fk> a rr:TriplesMap ;
