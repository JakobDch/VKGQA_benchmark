  rr:predicateObjectMap [ rr:predicate p:FromAccountID ; rr:objectMap [ rr:column "FromAccountID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ToAccountID ; rr:objectMap [ rr:column "ToAccountID" ] ] ;
