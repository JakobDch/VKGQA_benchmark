  rr:predicateObjectMap [ rr:predicate p:Fee_Amount ; rr:objectMap [ rr:column "Fee_Amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Commission_Percentage ; rr:objectMap [ rr:column "Commission_Percentage" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Transactions ; rr:objectMap [ rr:column "Transactions" ] ] .

