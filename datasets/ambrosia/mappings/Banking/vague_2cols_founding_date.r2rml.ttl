@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_founding_date_0_Financial_Institutions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Founding_Year\", \"Founding_Decade\", \"Total_Assets\", \"Total_Liabilities\", \"ROI_Percentage\" FROM \"Financial_Institutions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Financial_Institutions/{id}" ; rr:class :Financial_Institutions ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Founding_Year ; rr:objectMap [ rr:column "Founding_Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Founding_Decade ; rr:objectMap [ rr:column "Founding_Decade" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Total_Assets ; rr:objectMap [ rr:column "Total_Assets" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Total_Liabilities ; rr:objectMap [ rr:column "Total_Liabilities" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ROI_Percentage ; rr:objectMap [ rr:column "ROI_Percentage" ] ] .

<#tm_vague_2cols_founding_date_1_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"Address\", \"PhoneNumber\", \"EmailAddress\", \"AccountId\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountId ; rr:objectMap [ rr:column "AccountId" ] ] .

<#tm_vague_2cols_founding_date_2_Customers_AccountId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"AccountId\" FROM \"Customers\" WHERE \"AccountId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccounts ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountId}" ; rr:termType rr:IRI ] ] .

