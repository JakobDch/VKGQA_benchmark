<#tm_vague_2cols_leadership_7_Transactions_sourceAccountNumber_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"transactionId\", \"sourceAccountNumber\" FROM \"Transactions\" WHERE \"sourceAccountNumber\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Transactions/{transactionId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccounts_sourceAccountNumber ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{sourceAccountNumber}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_leadership_8_Loans_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"loanId\", \"principalAmount\", \"interestRate\", \"termMonths\", \"monthlyPayment\", \"customerId\" FROM \"Loans\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loans/{loanId}" ; rr:class :Loans ] ;
  rr:predicateObjectMap [ rr:predicate p:loanId ; rr:objectMap [ rr:column "loanId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:principalAmount ; rr:objectMap [ rr:column "principalAmount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:interestRate ; rr:objectMap [ rr:column "interestRate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:termMonths ; rr:objectMap [ rr:column "termMonths" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:monthlyPayment ; rr:objectMap [ rr:column "monthlyPayment" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customerId ; rr:objectMap [ rr:column "customerId" ] ] .

<#tm_vague_2cols_leadership_9_Loans_customerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"loanId\", \"customerId\" FROM \"Loans\" WHERE \"customerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loans/{loanId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{customerId}" ; rr:termType rr:IRI ] ] .

