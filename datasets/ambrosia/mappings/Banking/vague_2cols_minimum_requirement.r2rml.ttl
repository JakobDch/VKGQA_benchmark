  rr:predicateObjectMap [ rr:predicate p:amount ; rr:objectMap [ rr:column "amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:transaction_date ; rr:objectMap [ rr:column "transaction_date" ] ] .

