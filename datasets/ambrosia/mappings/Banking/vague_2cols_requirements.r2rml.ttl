  rr:predicateObjectMap [ rr:predicate p:ApprovalDate ; rr:objectMap [ rr:column "ApprovalDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Status ; rr:objectMap [ rr:column "Status" ] ] ;
