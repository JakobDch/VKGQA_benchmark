@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_stock_allocation_0_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CustomerID\", \"Email\", \"fullname\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{CustomerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "fullname" ] ] .

<#tm_vague_2cols_stock_allocation_1_Accounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountNumber\", \"Balance\", \"InterestRate\", \"OpenDate\", \"CustomerID\" FROM \"Accounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountNumber}" ; rr:class :Accounts ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountNumber ; rr:objectMap [ rr:column "AccountNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Balance ; rr:objectMap [ rr:column "Balance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:InterestRate ; rr:objectMap [ rr:column "InterestRate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OpenDate ; rr:objectMap [ rr:column "OpenDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] .

<#tm_vague_2cols_stock_allocation_2_Accounts_CustomerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccountNumber\", \"CustomerID\" FROM \"Accounts\" WHERE \"CustomerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Accounts/{AccountNumber}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Customers/{CustomerID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_stock_allocation_3_Stocks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StockSymbol\", \"CompanyName\", \"CurrentPrice\" FROM \"Stocks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Stocks/{StockSymbol}" ; rr:class :Stocks ] ;
  rr:predicateObjectMap [ rr:predicate p:StockSymbol ; rr:objectMap [ rr:column "StockSymbol" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyName ; rr:objectMap [ rr:column "CompanyName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CurrentPrice ; rr:objectMap [ rr:column "CurrentPrice" ] ] .

<#tm_vague_2cols_stock_allocation_4_Investments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InvestmentID\", \"AccountNumber\", \"StockSymbol\", \"Quantity\", \"PurchaseDate\" FROM \"Investments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Investments/{InvestmentID}" ; rr:class :Investments ] ;
  rr:predicateObjectMap [ rr:predicate p:InvestmentID ; rr:objectMap [ rr:column "InvestmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccountNumber ; rr:objectMap [ rr:column "AccountNumber" ] ] ;
