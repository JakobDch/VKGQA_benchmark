  rr:predicateObjectMap [ rr:predicate p:PurchaseDate ; rr:objectMap [ rr:column "PurchaseDate" ] ] .

<#tm_vague_2cols_stock_allocation_5_Investments_StockSymbol_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InvestmentID\", \"StockSymbol\" FROM \"Investments\" WHERE \"StockSymbol\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Investments/{InvestmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStocks ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Stocks/{StockSymbol}" ; rr:termType rr:IRI ] ] .

