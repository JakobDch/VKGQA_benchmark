@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_leadership_0_Ceo_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ceoID\", \"fullname\" FROM \"Ceo\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Ceo/{ceoID}" ; rr:class :Ceo ] ;
  rr:predicateObjectMap [ rr:predicate p:ceoID ; rr:objectMap [ rr:column "ceoID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "fullname" ] ] .

<#tm_vague_2tabs_leadership_1_Board_of_directors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"boardID\", \"ceoID\", \"directorfullname\" FROM \"Board_of_directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Board_of_directors/{boardID}" ; rr:class :Board_of_directors ] ;
  rr:predicateObjectMap [ rr:predicate p:boardID ; rr:objectMap [ rr:column "boardID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ceoID ; rr:objectMap [ rr:column "ceoID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:directorfullname ; rr:objectMap [ rr:column "directorfullname" ] ] .

<#tm_vague_2tabs_leadership_2_Board_of_directors_ceoID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"boardID\", \"ceoID\" FROM \"Board_of_directors\" WHERE \"ceoID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Board_of_directors/{boardID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCeo ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Ceo/{ceoID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_leadership_3_Banks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bankID\", \"bankName\", \"branchNumber\", \"ceoID\", \"boardID\" FROM \"Banks\"""" ] ;
