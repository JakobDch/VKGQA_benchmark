  rr:predicateObjectMap [ rr:predicate p:bankID ; rr:objectMap [ rr:column "bankID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bankName ; rr:objectMap [ rr:column "bankName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:branchNumber ; rr:objectMap [ rr:column "branchNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ceoID ; rr:objectMap [ rr:column "ceoID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:boardID ; rr:objectMap [ rr:column "boardID" ] ] .

<#tm_vague_2tabs_leadership_4_Banks_boardID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bankID\", \"boardID\" FROM \"Banks\" WHERE \"boardID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{bankID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBoard_of_directors ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Board_of_directors/{boardID}" ; rr:termType rr:IRI ] ] .

