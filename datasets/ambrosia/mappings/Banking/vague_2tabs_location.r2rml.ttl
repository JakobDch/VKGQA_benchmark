@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_location_0_City_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"country_id\" FROM \"City\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/City/{id}" ; rr:class :City ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country_id ; rr:objectMap [ rr:column "country_id" ] ] .

<#tm_vague_2tabs_location_1_Country_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Country\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Country/{id}" ; rr:class :Country ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_vague_2tabs_location_2_Banks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"bank_name\", \"city_id\", \"country_id\" FROM \"Banks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{id}" ; rr:class :Banks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bank_name ; rr:objectMap [ rr:column "bank_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city_id ; rr:objectMap [ rr:column "city_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country_id ; rr:objectMap [ rr:column "country_id" ] ] .

<#tm_vague_2tabs_location_3_Banks_country_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"country_id\" FROM \"Banks\" WHERE \"country_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCountry ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Country/{country_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_location_4_Banks_city_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"city_id\" FROM \"Banks\" WHERE \"city_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Banks/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCity ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/City/{city_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_location_5_Accounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"account_number\", \"balance\", \"owner_id\" FROM \"Accounts\"""" ] ;
