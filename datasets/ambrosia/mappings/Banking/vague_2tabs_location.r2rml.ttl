<#tm_vague_2tabs_location_11_Customers_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\" FROM \"Customers\" WHERE \"customer_id\" IS NOT NULL""" ] ;
