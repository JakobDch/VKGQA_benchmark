@prefix : <http://ambrosia.example.org/banking#> .
@prefix p: <http://ambrosia.example.org/banking/prop#> .
@prefix ex: <http://ambrosia.example.org/banking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_requirements_0_Eligibility_Criteria_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"criteria\", \"score\" FROM \"Eligibility_Criteria\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Eligibility_Criteria/{id}" ; rr:class :Eligibility_Criteria ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:criteria ; rr:objectMap [ rr:column "criteria" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:score ; rr:objectMap [ rr:column "score" ] ] .

<#tm_vague_2tabs_requirements_1_Documentation_Requirements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"doc_type\", \"requirement\" FROM \"Documentation_Requirements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Documentation_Requirements/{id}" ; rr:class :Documentation_Requirements ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:doc_type ; rr:objectMap [ rr:column "doc_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:requirement ; rr:objectMap [ rr:column "requirement" ] ] .

<#tm_vague_2tabs_requirements_2_Loans_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"amount\", \"term\", \"eligibility_criteria_id\", \"documentation_requirement_id\" FROM \"Loans\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loans/{id}" ; rr:class :Loans ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amount ; rr:objectMap [ rr:column "amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:term ; rr:objectMap [ rr:column "term" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:eligibility_criteria_id ; rr:objectMap [ rr:column "eligibility_criteria_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:documentation_requirement_id ; rr:objectMap [ rr:column "documentation_requirement_id" ] ] .

<#tm_vague_2tabs_requirements_3_Loans_documentation_requirement_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"documentation_requirement_id\" FROM \"Loans\" WHERE \"documentation_requirement_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loans/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDocumentation_Requirements ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Documentation_Requirements/{documentation_requirement_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_requirements_4_Loans_eligibility_criteria_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"eligibility_criteria_id\" FROM \"Loans\" WHERE \"eligibility_criteria_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Loans/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEligibility_Criteria ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Eligibility_Criteria/{eligibility_criteria_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_requirements_5_Business_Loan_Applications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"loan_name\", \"application_date\", \"annual_revenue\", \"num_employees\", \"loan_id\" FROM \"Business_Loan_Applications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Business_Loan_Applications/{id}" ; rr:class :Business_Loan_Applications ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:loan_name ; rr:objectMap [ rr:column "loan_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:application_date ; rr:objectMap [ rr:column "application_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:annual_revenue ; rr:objectMap [ rr:column "annual_revenue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:num_employees ; rr:objectMap [ rr:column "num_employees" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:loan_id ; rr:objectMap [ rr:column "loan_id" ] ] .

<#tm_vague_2tabs_requirements_6_Business_Loan_Applications_loan_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"loan_id\" FROM \"Business_Loan_Applications\" WHERE \"loan_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/banking/id/Business_Loan_Applications/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLoans ; rr:objectMap [ rr:template "http://ambrosia.example.org/banking/id/Loans/{loan_id}" ; rr:termType rr:IRI ] ] .

