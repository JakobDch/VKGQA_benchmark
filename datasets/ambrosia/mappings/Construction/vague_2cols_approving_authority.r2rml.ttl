@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_approving_authority_0_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Name\", \"JobTitle\", \"ContactInfo\", \"HireDate\", \"Salary\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Employees/{Id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:JobTitle ; rr:objectMap [ rr:column "JobTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ContactInfo ; rr:objectMap [ rr:column "ContactInfo" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HireDate ; rr:objectMap [ rr:column "HireDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "Salary" ] ] .

