[PrefixDeclaration]
:	http://ambrosia.example.org/construction#
p:	http://ambrosia.example.org/construction/prop#
ex:	http://ambrosia.example.org/construction/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Stadiums_base
target		ex:Stadiums/{ID} a :Stadiums ; p:ID {ID} ; p:Seating_Capacity {Seating_Capacity} ; p:Maximum_Occupancy {Maximum_Occupancy} ; p:name {Name} ; p:location {Location} ; p:Year_Built {Year_Built} ; p:Type_of_Stadium {Type_of_Stadium} .
source		SELECT `ID`, `Seating_Capacity`, `Maximum_Occupancy`, `Name`, `Location`, `Year_Built`, `Type_of_Stadium` FROM `Stadiums`

]]
