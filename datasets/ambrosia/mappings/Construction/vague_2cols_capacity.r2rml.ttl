@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_capacity_0_Stadiums_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Seating_Capacity\", \"Maximum_Occupancy\", \"Name\", \"Location\", \"Year_Built\", \"Type_of_Stadium\" FROM \"Stadiums\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Stadiums/{ID}" ; rr:class :Stadiums ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Seating_Capacity ; rr:objectMap [ rr:column "Seating_Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Maximum_Occupancy ; rr:objectMap [ rr:column "Maximum_Occupancy" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year_Built ; rr:objectMap [ rr:column "Year_Built" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type_of_Stadium ; rr:objectMap [ rr:column "Type_of_Stadium" ] ] .

