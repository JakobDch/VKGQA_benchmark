@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_findings_0_Workers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"ContactNumber\", \"SkillLevel\" FROM \"Workers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Workers/{ID}" ; rr:class :Workers ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ContactNumber ; rr:objectMap [ rr:column "ContactNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SkillLevel ; rr:objectMap [ rr:column "SkillLevel" ] ] .

<#tm_vague_2cols_findings_1_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Type\", \"SerialNumber\", \"PurchaseDate\" FROM \"Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Equipment/{ID}" ; rr:class :Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SerialNumber ; rr:objectMap [ rr:column "SerialNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PurchaseDate ; rr:objectMap [ rr:column "PurchaseDate" ] ] .

<#tm_vague_2cols_findings_2_Artifacts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Artifacts_Uncovered\", \"Ancient_Remains\", \"Archaeological_Site\", \"EstimatedAge\" FROM \"Artifacts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Artifacts/{ID}" ; rr:class :Artifacts ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Artifacts_Uncovered ; rr:objectMap [ rr:column "Artifacts_Uncovered" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Ancient_Remains ; rr:objectMap [ rr:column "Ancient_Remains" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Archaeological_Site ; rr:objectMap [ rr:column "Archaeological_Site" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EstimatedAge ; rr:objectMap [ rr:column "EstimatedAge" ] ] .

