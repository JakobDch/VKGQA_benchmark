@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_funding_0_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"projectID\", \"name\", \"startDate\", \"endDate\", \"budget\", \"contractorID\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{projectID}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:projectID ; rr:objectMap [ rr:column "projectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:budget ; rr:objectMap [ rr:column "budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contractorID ; rr:objectMap [ rr:column "contractorID" ] ] .

<#tm_vague_2cols_funding_1_Projects_contractorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"projectID\", \"contractorID\" FROM \"Projects\" WHERE \"contractorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{projectID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasContractors ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Contractors/{contractorID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_funding_2_Contractors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"contractorID\", \"companyName\", \"address\", \"phoneNumber\", \"employeeCount\" FROM \"Contractors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Contractors/{contractorID}" ; rr:class :Contractors ] ;
  rr:predicateObjectMap [ rr:predicate p:contractorID ; rr:objectMap [ rr:column "contractorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "companyName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:employeeCount ; rr:objectMap [ rr:column "employeeCount" ] ] .

