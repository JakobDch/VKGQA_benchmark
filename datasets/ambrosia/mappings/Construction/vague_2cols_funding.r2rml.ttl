<#tm_vague_2cols_funding_10_Funding_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"governmentAgency\", \"privateDonors\", \"publicPark\", \"fundsAmount\", \"projectID\" FROM \"Funding\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Funding/{id}" ; rr:class :Funding ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
