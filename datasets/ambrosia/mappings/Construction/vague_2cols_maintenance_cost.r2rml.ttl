@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_maintenance_cost_0_Project_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"StartDate\", \"EndDate\", \"Monetary_Value\", \"Percentage_Of_Budget\", \"Infrastructure\", DATEDIFF(\"EndDate\",\"StartDate\") AS \"durationDays\" FROM \"Project\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{id}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Monetary_Value ; rr:objectMap [ rr:column "Monetary_Value" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Percentage_Of_Budget ; rr:objectMap [ rr:column "Percentage_Of_Budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Infrastructure ; rr:objectMap [ rr:column "Infrastructure" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:durationDays ; rr:objectMap [ rr:column "durationDays" ; rr:datatype xsd:integer ] ] .

<#tm_vague_2cols_maintenance_cost_1_Worker_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"FirstName\", \"LastName\", \"JobTitle\" FROM \"Worker\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Workers/{id}" ; rr:class :Workers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:JobTitle ; rr:objectMap [ rr:column "JobTitle" ] ] .

<#tm_vague_2cols_maintenance_cost_2_Materials_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"MaterialName\", \"Quantity\", \"UnitCost\" FROM \"Materials\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Materials/{id}" ; rr:class :Materials ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "MaterialName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "Quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:UnitCost ; rr:objectMap [ rr:column "UnitCost" ] ] .

<#tm_vague_2cols_maintenance_cost_3_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"EquipName\", \"PurchasePrice\", \"RentalRate\", \"DailyUsage\" FROM \"Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Equipment/{id}" ; rr:class :Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "EquipName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PurchasePrice ; rr:objectMap [ rr:column "PurchasePrice" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RentalRate ; rr:objectMap [ rr:column "RentalRate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DailyUsage ; rr:objectMap [ rr:column "DailyUsage" ] ] .

