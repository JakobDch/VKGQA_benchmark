@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_resources_0_Construction_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProjectID\", \"Budget\", \"Staff\", \"Location\", \"StartDate\", \"EndDate\" FROM \"Construction_Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Construction_Projects/{ProjectID}" ; rr:class :Construction_Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:ProjectID ; rr:objectMap [ rr:column "ProjectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:budget ; rr:objectMap [ rr:column "Budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Staff ; rr:objectMap [ rr:column "Staff" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] .

