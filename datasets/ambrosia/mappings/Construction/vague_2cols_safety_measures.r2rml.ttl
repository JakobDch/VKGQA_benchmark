@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_safety_measures_0_Material_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"materialID\", \"name\", \"quantity\", \"cost\" FROM \"Material\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Materials/{materialID}" ; rr:class :Materials ] ;
  rr:predicateObjectMap [ rr:predicate p:materialID ; rr:objectMap [ rr:column "materialID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cost ; rr:objectMap [ rr:column "cost" ] ] .

<#tm_vague_2cols_safety_measures_1_Employee_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employeeID\", \"firstName\", \"lastName\", \"hireDate\", \"position\" FROM \"Employee\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Employees/{employeeID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:employeeID ; rr:objectMap [ rr:column "employeeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hireDate ; rr:objectMap [ rr:column "hireDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position ; rr:objectMap [ rr:column "position" ] ] .

<#tm_vague_2cols_safety_measures_2_Project_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"projectID\", \"projectName\", \"startDate\", \"endDate\", \"budget\" FROM \"Project\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{projectID}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:projectID ; rr:objectMap [ rr:column "projectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "projectName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:budget ; rr:objectMap [ rr:column "budget" ] ] .

<#tm_vague_2cols_safety_measures_3_Inventory_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"inventoryID\", \"materialID\", \"quantity\" FROM \"Inventory\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Inventory/{inventoryID}" ; rr:class :Inventory ] ;
  rr:predicateObjectMap [ rr:predicate p:inventoryID ; rr:objectMap [ rr:column "inventoryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:materialID ; rr:objectMap [ rr:column "materialID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "quantity" ] ] .

<#tm_vague_2cols_safety_measures_4_Inventory_materialID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"inventoryID\", \"materialID\" FROM \"Inventory\" WHERE \"materialID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Inventory/{inventoryID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMaterials ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Materials/{materialID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_safety_measures_5_Safety_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"safetyID\", \"employeeID\", \"personalProtectiveEquipment\", \"trainingPrograms\", \"constructionWorker\" FROM \"Safety\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Safety/{safetyID}" ; rr:class :Safety ] ;
  rr:predicateObjectMap [ rr:predicate p:safetyID ; rr:objectMap [ rr:column "safetyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:employeeID ; rr:objectMap [ rr:column "employeeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:personalProtectiveEquipment ; rr:objectMap [ rr:column "personalProtectiveEquipment" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:trainingPrograms ; rr:objectMap [ rr:column "trainingPrograms" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:constructionWorker ; rr:objectMap [ rr:column "constructionWorker" ] ] .

<#tm_vague_2cols_safety_measures_6_Safety_employeeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"safetyID\", \"employeeID\" FROM \"Safety\" WHERE \"employeeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Safety/{safetyID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployees ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Employees/{employeeID}" ; rr:termType rr:IRI ] ] .

