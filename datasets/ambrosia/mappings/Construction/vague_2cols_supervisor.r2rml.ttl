  rr:logicalTable [ rr:sqlQuery """SELECT \"supplierID\", \"companyName\", \"contactName\", \"phoneNumber\", \"address\" FROM \"Suppliers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Suppliers/{supplierID}" ; rr:class :Suppliers ] ;
