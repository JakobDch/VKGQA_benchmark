@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_supervisor_0_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"projectID\", \"projectName\", \"startDate\", \"endDate\", \"budget\", \"Project_Manager\", \"Construction_Manager\", \"Edifice\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{projectID}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:projectID ; rr:objectMap [ rr:column "projectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "projectName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:budget ; rr:objectMap [ rr:column "budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Project_Manager ; rr:objectMap [ rr:column "Project_Manager" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Construction_Manager ; rr:objectMap [ rr:column "Construction_Manager" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Edifice ; rr:objectMap [ rr:column "Edifice" ] ] .

<#tm_vague_2cols_supervisor_1_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employeeID\", \"firstName\", \"lastName\", \"jobTitle\", \"salary\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Employees/{employeeID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:employeeID ; rr:objectMap [ rr:column "employeeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobTitle ; rr:objectMap [ rr:column "jobTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] .

<#tm_vague_2cols_supervisor_2_Materials_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"materialID\", \"name\", \"quantity\", \"unitCost\" FROM \"Materials\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Materials/{materialID}" ; rr:class :Materials ] ;
  rr:predicateObjectMap [ rr:predicate p:materialID ; rr:objectMap [ rr:column "materialID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:unitCost ; rr:objectMap [ rr:column "unitCost" ] ] .

<#tm_vague_2cols_supervisor_3_Tasks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"taskID\", \"description\", \"status\", \"startTime\", \"completionTime\", \"assignedEmployeeID\" FROM \"Tasks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Tasks/{taskID}" ; rr:class :Tasks ] ;
  rr:predicateObjectMap [ rr:predicate p:taskID ; rr:objectMap [ rr:column "taskID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startTime ; rr:objectMap [ rr:column "startTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:completionTime ; rr:objectMap [ rr:column "completionTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:assignedEmployeeID ; rr:objectMap [ rr:column "assignedEmployeeID" ] ] .

<#tm_vague_2cols_supervisor_4_Tasks_assignedEmployeeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"taskID\", \"assignedEmployeeID\" FROM \"Tasks\" WHERE \"assignedEmployeeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Tasks/{taskID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployees ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Employees/{assignedEmployeeID}" ; rr:termType rr:IRI ] ] .

