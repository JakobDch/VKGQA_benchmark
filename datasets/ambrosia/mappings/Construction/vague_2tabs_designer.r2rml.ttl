@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_designer_0_Architect_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Architect\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Architect/{id}" ; rr:class :Architect ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_vague_2tabs_designer_1_Firm_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\" FROM \"Firm\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Firm/{id}" ; rr:class :Firm ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_vague_2tabs_designer_2_Building_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"building_name\", \"firm_id\", \"architect_id\" FROM \"Building\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Building/{id}" ; rr:class :Building ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:building_name ; rr:objectMap [ rr:column "building_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firm_id ; rr:objectMap [ rr:column "firm_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:architect_id ; rr:objectMap [ rr:column "architect_id" ] ] .

<#tm_vague_2tabs_designer_3_Building_architect_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"architect_id\" FROM \"Building\" WHERE \"architect_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Building/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArchitect ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Architect/{architect_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_designer_4_Building_firm_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firm_id\" FROM \"Building\" WHERE \"firm_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Building/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFirm ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Firm/{firm_id}" ; rr:termType rr:IRI ] ] .

