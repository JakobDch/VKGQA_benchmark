@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_inspection_types_0_Project_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"projectID\", \"name\", \"startDate\", \"endDate\", \"structuralInspectionID\", \"safetyInspectionID\" FROM \"Project\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{projectID}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:projectID ; rr:objectMap [ rr:column "projectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:structuralInspectionID ; rr:objectMap [ rr:column "structuralInspectionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:safetyInspectionID ; rr:objectMap [ rr:column "safetyInspectionID" ] ] .

<#tm_vague_2tabs_inspection_types_1_Project_safetyInspectionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"projectID\", \"safetyInspectionID\" FROM \"Project\" WHERE \"safetyInspectionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{projectID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInspection_Types ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Inspection_Types/{safetyInspectionID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_inspection_types_2_Project_structuralInspectionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"projectID\", \"structuralInspectionID\" FROM \"Project\" WHERE \"structuralInspectionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{projectID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInspection_Types ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Inspection_Types/{structuralInspectionID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_inspection_types_3_Material_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"materialID\", \"type\", \"quantity\", \"unit\", \"price\", \"projectID\" FROM \"Material\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Materials/{materialID}" ; rr:class :Materials ] ;
  rr:predicateObjectMap [ rr:predicate p:materialID ; rr:objectMap [ rr:column "materialID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:unit ; rr:objectMap [ rr:column "unit" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:projectID ; rr:objectMap [ rr:column "projectID" ] ] .

<#tm_vague_2tabs_inspection_types_4_Material_projectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"materialID\", \"projectID\" FROM \"Material\" WHERE \"projectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Materials/{materialID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{projectID}" ; rr:termType rr:IRI ] ] .

