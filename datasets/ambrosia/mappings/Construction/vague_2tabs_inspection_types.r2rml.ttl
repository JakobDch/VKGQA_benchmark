<#tm_vague_2tabs_inspection_types_10_Safety_Inspection_inspectorEmployeeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"inspectionID\", \"inspectorEmployeeID\" FROM \"Safety_Inspection\" WHERE \"inspectorEmployeeID\" IS NOT NULL""" ] ;
