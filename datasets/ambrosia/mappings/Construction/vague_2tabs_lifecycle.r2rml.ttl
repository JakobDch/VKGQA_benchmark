@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_lifecycle_0_Materials_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"material_id\", \"name\", \"cost\" FROM \"Materials\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Materials/{material_id}" ; rr:class :Materials ] ;
  rr:predicateObjectMap [ rr:predicate p:material_id ; rr:objectMap [ rr:column "material_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cost ; rr:objectMap [ rr:column "cost" ] ] .

<#tm_vague_2tabs_lifecycle_1_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"project_id\", \"name\", \"start_date\", \"end_date\", \"infrastructure_id\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{project_id}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:project_id ; rr:objectMap [ rr:column "project_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:infrastructure_id ; rr:objectMap [ rr:column "infrastructure_id" ] ] .

<#tm_vague_2tabs_lifecycle_2_Projects_infrastructure_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"project_id\", \"infrastructure_id\" FROM \"Projects\" WHERE \"infrastructure_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Projects/{project_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInfrastructure ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Infrastructure/{infrastructure_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_lifecycle_3_Infrastructure_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"infrastructure_id\", \"description\", \"service_life_expectancy_id\", \"renewal_schedule_id\" FROM \"Infrastructure\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Infrastructure/{infrastructure_id}" ; rr:class :Infrastructure ] ;
  rr:predicateObjectMap [ rr:predicate p:infrastructure_id ; rr:objectMap [ rr:column "infrastructure_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_life_expectancy_id ; rr:objectMap [ rr:column "service_life_expectancy_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:renewal_schedule_id ; rr:objectMap [ rr:column "renewal_schedule_id" ] ] .

<#tm_vague_2tabs_lifecycle_4_Infrastructure_renewal_schedule_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"infrastructure_id\", \"renewal_schedule_id\" FROM \"Infrastructure\" WHERE \"renewal_schedule_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Infrastructure/{infrastructure_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRenewal_Schedule ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Renewal_Schedule/{renewal_schedule_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_lifecycle_5_Infrastructure_service_life_expectancy_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"infrastructure_id\", \"service_life_expectancy_id\" FROM \"Infrastructure\" WHERE \"service_life_expectancy_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Infrastructure/{infrastructure_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasService_Life_Expectancy ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Service_Life_Expectancy/{service_life_expectancy_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_lifecycle_6_Workers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"worker_id\", \"first_name\", \"last_name\", \"skill_level\" FROM \"Workers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Workers/{worker_id}" ; rr:class :Workers ] ;
  rr:predicateObjectMap [ rr:predicate p:worker_id ; rr:objectMap [ rr:column "worker_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skill_level ; rr:objectMap [ rr:column "skill_level" ] ] .

<#tm_vague_2tabs_lifecycle_7_Tasks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"task_id\", \"description\", \"assigned_to_worker_id\", \"due_date\", \"completed\" FROM \"Tasks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Tasks/{task_id}" ; rr:class :Tasks ] ;
  rr:predicateObjectMap [ rr:predicate p:task_id ; rr:objectMap [ rr:column "task_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:assigned_to_worker_id ; rr:objectMap [ rr:column "assigned_to_worker_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:due_date ; rr:objectMap [ rr:column "due_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:completed ; rr:objectMap [ rr:column "completed" ] ] .

<#tm_vague_2tabs_lifecycle_8_Tasks_assigned_to_worker_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"task_id\", \"assigned_to_worker_id\" FROM \"Tasks\" WHERE \"assigned_to_worker_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Tasks/{task_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWorkers ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Workers/{assigned_to_worker_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_lifecycle_9_Service_Life_Expectancy_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"service_life_expectancy_id\", \"min_years\", \"max_years\" FROM \"Service_Life_Expectancy\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Service_Life_Expectancy/{service_life_expectancy_id}" ; rr:class :Service_Life_Expectancy ] ;
  rr:predicateObjectMap [ rr:predicate p:service_life_expectancy_id ; rr:objectMap [ rr:column "service_life_expectancy_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:min_years ; rr:objectMap [ rr:column "min_years" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:max_years ; rr:objectMap [ rr:column "max_years" ] ] .

<#tm_vague_2tabs_lifecycle_10_Renewal_Schedule_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"renewal_schedule_id\", \"frequency\" FROM \"Renewal_Schedule\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Renewal_Schedule/{renewal_schedule_id}" ; rr:class :Renewal_Schedule ] ;
  rr:predicateObjectMap [ rr:predicate p:renewal_schedule_id ; rr:objectMap [ rr:column "renewal_schedule_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:frequency ; rr:objectMap [ rr:column "frequency" ] ] .

