@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_overseeing_company_0_Real_Estate_Developer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"contact_info\" FROM \"Real_Estate_Developer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Real_Estate_Developer/{id}" ; rr:class :Real_Estate_Developer ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contact_info ; rr:objectMap [ rr:column "contact_info" ] ] .

<#tm_vague_2tabs_overseeing_company_1_Contractor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"specialty\", \"license_number\" FROM \"Contractor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Contractors/{id}" ; rr:class :Contractors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specialty ; rr:objectMap [ rr:column "specialty" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:license_number ; rr:objectMap [ rr:column "license_number" ] ] .

<#tm_vague_2tabs_overseeing_company_2_Development_Project_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"project_name\", \"developer_id\", \"contractor_id\" FROM \"Development_Project\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Development_Project/{id}" ; rr:class :Development_Project ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:project_name ; rr:objectMap [ rr:column "project_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:developer_id ; rr:objectMap [ rr:column "developer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contractor_id ; rr:objectMap [ rr:column "contractor_id" ] ] .

<#tm_vague_2tabs_overseeing_company_3_Development_Project_contractor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"contractor_id\" FROM \"Development_Project\" WHERE \"contractor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Development_Project/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasContractors ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Contractors/{contractor_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_overseeing_company_4_Development_Project_developer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"developer_id\" FROM \"Development_Project\" WHERE \"developer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Development_Project/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReal_Estate_Developer ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Real_Estate_Developer/{developer_id}" ; rr:termType rr:IRI ] ] .

