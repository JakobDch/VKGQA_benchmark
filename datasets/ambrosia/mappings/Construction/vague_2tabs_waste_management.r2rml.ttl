<#tm_vague_2tabs_waste_management_3_Construction_Site_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"site_id\", \"site_name\", \"location\", \"waste_disposal_method_id\", \"recycling_program_id\" FROM \"Construction_Site\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Construction_Site/{site_id}" ; rr:class :Construction_Site ] ;
  rr:predicateObjectMap [ rr:predicate p:site_id ; rr:objectMap [ rr:column "site_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:site_name ; rr:objectMap [ rr:column "site_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:waste_disposal_method_id ; rr:objectMap [ rr:column "waste_disposal_method_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:recycling_program_id ; rr:objectMap [ rr:column "recycling_program_id" ] ] .

<#tm_vague_2tabs_waste_management_4_Construction_Site_recycling_program_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"site_id\", \"recycling_program_id\" FROM \"Construction_Site\" WHERE \"recycling_program_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Construction_Site/{site_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRecycling_Program ; rr:objectMap [ rr:template "http://ambrosia.example.org/construction/id/Recycling_Program/{recycling_program_id}" ; rr:termType rr:IRI ] ] .

