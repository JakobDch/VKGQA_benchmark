@prefix : <http://ambrosia.example.org/construction#> .
@prefix p: <http://ambrosia.example.org/construction/prop#> .
@prefix ex: <http://ambrosia.example.org/construction/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_waste_management_0_Waste_Disposal_Method_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"method_name\", \"description\" FROM \"Waste_Disposal_Method\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Waste_Disposal_Method/{id}" ; rr:class :Waste_Disposal_Method ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:method_name ; rr:objectMap [ rr:column "method_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2tabs_waste_management_1_Recycling_Program_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"program_name\", \"description\" FROM \"Recycling_Program\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/construction/id/Recycling_Program/{id}" ; rr:class :Recycling_Program ] ;
