@prefix : <http://ambrosia.example.org/demographics#> .
@prefix p: <http://ambrosia.example.org/demographics/prop#> .
@prefix ex: <http://ambrosia.example.org/demographics/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_divorce_rate_0_VillageDemographics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Village\", \"Divorced_Percentage\", \"Divorced_Count\", \"TotalPopulation\", \"MaleCount\", \"FemaleCount\" FROM \"VillageDemographics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/VillageDemographics/{id}" ; rr:class :VillageDemographics ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Village ; rr:objectMap [ rr:column "Village" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Divorced_Percentage ; rr:objectMap [ rr:column "Divorced_Percentage" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Divorced_Count ; rr:objectMap [ rr:column "Divorced_Count" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalPopulation ; rr:objectMap [ rr:column "TotalPopulation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MaleCount ; rr:objectMap [ rr:column "MaleCount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FemaleCount ; rr:objectMap [ rr:column "FemaleCount" ] ] .

