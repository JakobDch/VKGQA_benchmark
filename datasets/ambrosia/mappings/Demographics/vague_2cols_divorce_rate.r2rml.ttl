  rr:predicateObjectMap [ rr:predicate p:AgeRange ; rr:objectMap [ rr:column "AgeRange" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PopulationInThisAgeRange ; rr:objectMap [ rr:column "PopulationInThisAgeRange" ] ] .

