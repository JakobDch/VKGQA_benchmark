@prefix : <http://ambrosia.example.org/demographics#> .
@prefix p: <http://ambrosia.example.org/demographics/prop#> .
@prefix ex: <http://ambrosia.example.org/demographics/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_immigrants_0_Population_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"totalPopulation\", \"year\" FROM \"Population\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Population/{id}" ; rr:class :Population ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:totalPopulation ; rr:objectMap [ rr:column "totalPopulation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:year ; rr:objectMap [ rr:column "year" ] ] .

<#tm_vague_2cols_immigrants_1_AgeGroup_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ageFrom\", \"ageTo\", \"population\" FROM \"AgeGroup\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/AgeGroup/{id}" ; rr:class :AgeGroup ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ageFrom ; rr:objectMap [ rr:column "ageFrom" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ageTo ; rr:objectMap [ rr:column "ageTo" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:population ; rr:objectMap [ rr:column "population" ] ] .

<#tm_vague_2cols_immigrants_2_AgeGroup_population_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"population\" FROM \"AgeGroup\" WHERE \"population\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/AgeGroup/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPopulation ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Population/{population}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_immigrants_3_Country_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"countryName\", \"continent\" FROM \"Country\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Countries/{id}" ; rr:class :Countries ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:countryName ; rr:objectMap [ rr:column "countryName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:continent ; rr:objectMap [ rr:column "continent" ] ] .

<#tm_vague_2cols_immigrants_4_ImmigrationStats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"numberOfImmigrants\", \"immigrantPercentage\", \"countryId\", \"year\" FROM \"ImmigrationStats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/ImmigrationStats/{id}" ; rr:class :ImmigrationStats ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:numberOfImmigrants ; rr:objectMap [ rr:column "numberOfImmigrants" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:immigrantPercentage ; rr:objectMap [ rr:column "immigrantPercentage" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:countryId ; rr:objectMap [ rr:column "countryId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:year ; rr:objectMap [ rr:column "year" ] ] .

<#tm_vague_2cols_immigrants_5_ImmigrationStats_countryId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"countryId\" FROM \"ImmigrationStats\" WHERE \"countryId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/ImmigrationStats/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCountries ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Countries/{countryId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_immigrants_6_Ethnicity_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ethnicGroupName\", \"population\" FROM \"Ethnicity\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Ethnicity/{id}" ; rr:class :Ethnicity ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ethnicGroupName ; rr:objectMap [ rr:column "ethnicGroupName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:population ; rr:objectMap [ rr:column "population" ] ] .

<#tm_vague_2cols_immigrants_7_Ethnicity_population_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"population\" FROM \"Ethnicity\" WHERE \"population\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Ethnicity/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPopulation ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Population/{population}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_immigrants_8_EducationLevel_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"levelName\", \"percentage\" FROM \"EducationLevel\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/EducationLevel/{id}" ; rr:class :EducationLevel ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:levelName ; rr:objectMap [ rr:column "levelName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:percentage ; rr:objectMap [ rr:column "percentage" ] ] .

<#tm_vague_2cols_immigrants_9_EducationLevel_levelName_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"levelName\" FROM \"EducationLevel\" WHERE \"levelName\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/EducationLevel/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEthnicity ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Ethnicity/{levelName}" ; rr:termType rr:IRI ] ] .

