  rr:predicateObjectMap [ rr:predicate p:Employed ; rr:objectMap [ rr:column "Employed" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Labor_Force_Participation_Rate ; rr:objectMap [ rr:column "Labor_Force_Participation_Rate" ] ] .

