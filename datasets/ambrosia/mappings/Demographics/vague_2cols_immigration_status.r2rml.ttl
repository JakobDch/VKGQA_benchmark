  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Age_Group\", \"Graduation_Rate\", \"HighSchool_Diploma_or_Higher\", \"College_Degree\" FROM \"EducationLevel\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/EducationLevel/{id}" ; rr:class :EducationLevel ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age_Group ; rr:objectMap [ rr:column "Age_Group" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Graduation_Rate ; rr:objectMap [ rr:column "Graduation_Rate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HighSchool_Diploma_or_Higher ; rr:objectMap [ rr:column "HighSchool_Diploma_or_Higher" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:College_Degree ; rr:objectMap [ rr:column "College_Degree" ] ] .

