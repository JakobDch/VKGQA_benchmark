@prefix : <http://ambrosia.example.org/demographics#> .
@prefix p: <http://ambrosia.example.org/demographics/prop#> .
@prefix ex: <http://ambrosia.example.org/demographics/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_immigration_status_0_Population_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Total_Population\", \"Foreign_born_Population\", \"Naturalized_Citizens\", \"Municipality\" FROM \"Population\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Population/{id}" ; rr:class :Population ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Total_Population ; rr:objectMap [ rr:column "Total_Population" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Foreign_born_Population ; rr:objectMap [ rr:column "Foreign_born_Population" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Naturalized_Citizens ; rr:objectMap [ rr:column "Naturalized_Citizens" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Municipality ; rr:objectMap [ rr:column "Municipality" ] ] .

