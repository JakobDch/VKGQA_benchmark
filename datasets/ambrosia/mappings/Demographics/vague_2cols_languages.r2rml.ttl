@prefix : <http://ambrosia.example.org/demographics#> .
@prefix p: <http://ambrosia.example.org/demographics/prop#> .
@prefix ex: <http://ambrosia.example.org/demographics/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_languages_0_Countries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CountryID\", \"Name\", \"Capital\", \"Population\", \"Official_Language\", \"Spoken_Language\", \"Community\" FROM \"Countries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Countries/{CountryID}" ; rr:class :Countries ] ;
  rr:predicateObjectMap [ rr:predicate p:CountryID ; rr:objectMap [ rr:column "CountryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capital ; rr:objectMap [ rr:column "Capital" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Population ; rr:objectMap [ rr:column "Population" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Official_Language ; rr:objectMap [ rr:column "Official_Language" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Spoken_Language ; rr:objectMap [ rr:column "Spoken_Language" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Community ; rr:objectMap [ rr:column "Community" ] ] .

<#tm_vague_2cols_languages_1_Regions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RegionID\", \"Name\", \"Area\", \"PopulationCount\" FROM \"Regions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Regions/{RegionID}" ; rr:class :Regions ] ;
  rr:predicateObjectMap [ rr:predicate p:RegionID ; rr:objectMap [ rr:column "RegionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Area ; rr:objectMap [ rr:column "Area" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PopulationCount ; rr:objectMap [ rr:column "PopulationCount" ] ] .

<#tm_vague_2cols_languages_2_Cities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CityID\", \"Name\", \"Province\", \"Population\", \"RegionID\" FROM \"Cities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Cities/{CityID}" ; rr:class :Cities ] ;
  rr:predicateObjectMap [ rr:predicate p:CityID ; rr:objectMap [ rr:column "CityID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Province ; rr:objectMap [ rr:column "Province" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Population ; rr:objectMap [ rr:column "Population" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RegionID ; rr:objectMap [ rr:column "RegionID" ] ] .

<#tm_vague_2cols_languages_3_Cities_RegionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CityID\", \"RegionID\" FROM \"Cities\" WHERE \"RegionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Cities/{CityID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRegions ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Regions/{RegionID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_languages_4_EthnicGroups_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GroupID\", \"Name\", \"Population\" FROM \"EthnicGroups\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/EthnicGroup/{GroupID}" ; rr:class :EthnicGroup ] ;
  rr:predicateObjectMap [ rr:predicate p:GroupID ; rr:objectMap [ rr:column "GroupID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Population ; rr:objectMap [ rr:column "Population" ] ] .

<#tm_vague_2cols_languages_5_Religion_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Denomination\", \"Adherents\" FROM \"Religion\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Religion/{ID}" ; rr:class :Religion ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Denomination ; rr:objectMap [ rr:column "Denomination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Adherents ; rr:objectMap [ rr:column "Adherents" ] ] .

<#tm_vague_2cols_languages_6_EducationLevel_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LevelID\", \"Description\", \"Percentage\" FROM \"EducationLevel\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/EducationLevel/{LevelID}" ; rr:class :EducationLevel ] ;
  rr:predicateObjectMap [ rr:predicate p:LevelID ; rr:objectMap [ rr:column "LevelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Percentage ; rr:objectMap [ rr:column "Percentage" ] ] .

