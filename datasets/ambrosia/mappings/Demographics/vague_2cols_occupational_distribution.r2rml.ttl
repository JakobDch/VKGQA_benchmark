<#tm_vague_2cols_occupational_distribution_3_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"Title\", \"Description\", \"SkillsRequired\", \"AverageSalary\", \"GrowthProspects\", \"RequiredEducation\" FROM \"Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Jobs/{JobID}" ; rr:class :Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:JobID ; rr:objectMap [ rr:column "JobID" ] ] ;
