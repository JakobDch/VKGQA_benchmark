@prefix : <http://ambrosia.example.org/demographics#> .
@prefix p: <http://ambrosia.example.org/demographics/prop#> .
@prefix ex: <http://ambrosia.example.org/demographics/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_occupational_distribution_0_Industries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"IndustryID\", \"Primary_Industry\", \"Most_Common_Job\", \"Region\", \"NumberOfEmployees\", \"AnnualRevenue\" FROM \"Industries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Industries/{IndustryID}" ; rr:class :Industries ] ;
  rr:predicateObjectMap [ rr:predicate p:IndustryID ; rr:objectMap [ rr:column "IndustryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Primary_Industry ; rr:objectMap [ rr:column "Primary_Industry" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Most_Common_Job ; rr:objectMap [ rr:column "Most_Common_Job" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Region ; rr:objectMap [ rr:column "Region" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfEmployees ; rr:objectMap [ rr:column "NumberOfEmployees" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AnnualRevenue ; rr:objectMap [ rr:column "AnnualRevenue" ] ] .

<#tm_vague_2cols_occupational_distribution_1_People_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PersonID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"Gender\", \"Race\", \"Ethnicity\", \"MaritalStatus\", \"EducationLevel\", \"Occupation\" FROM \"People\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Person/{PersonID}" ; rr:class :Person ] ;
  rr:predicateObjectMap [ rr:predicate p:PersonID ; rr:objectMap [ rr:column "PersonID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Gender ; rr:objectMap [ rr:column "Gender" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Race ; rr:objectMap [ rr:column "Race" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Ethnicity ; rr:objectMap [ rr:column "Ethnicity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MaritalStatus ; rr:objectMap [ rr:column "MaritalStatus" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EducationLevel ; rr:objectMap [ rr:column "EducationLevel" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Occupation ; rr:objectMap [ rr:column "Occupation" ] ] .

<#tm_vague_2cols_occupational_distribution_2_Regions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RegionID\", \"Name\", \"Population\", \"AreaInSqKm\", \"CapitalCity\", \"Climate\", \"MajorCities\" FROM \"Regions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Regions/{RegionID}" ; rr:class :Regions ] ;
  rr:predicateObjectMap [ rr:predicate p:RegionID ; rr:objectMap [ rr:column "RegionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Population ; rr:objectMap [ rr:column "Population" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AreaInSqKm ; rr:objectMap [ rr:column "AreaInSqKm" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CapitalCity ; rr:objectMap [ rr:column "CapitalCity" ] ] ;
