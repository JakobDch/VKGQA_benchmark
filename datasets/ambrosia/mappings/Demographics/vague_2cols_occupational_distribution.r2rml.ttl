<#tm_vague_2cols_occupational_distribution_4_EmploymentStats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Year\", \"TotalNumberOfJobs\", \"UnemployedCount\", \"UnemploymentRate\", \"MinimumWage\", \"MaximumWage\" FROM \"EmploymentStats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/EmploymentStats/{Year}" ; rr:class :EmploymentStats ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalNumberOfJobs ; rr:objectMap [ rr:column "TotalNumberOfJobs" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:UnemployedCount ; rr:objectMap [ rr:column "UnemployedCount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:UnemploymentRate ; rr:objectMap [ rr:column "UnemploymentRate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MinimumWage ; rr:objectMap [ rr:column "MinimumWage" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MaximumWage ; rr:objectMap [ rr:column "MaximumWage" ] ] .

<#tm_vague_2cols_occupational_distribution_5_HousingData_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"HouseID\", \"Address\", \"Type\", \"Price\", \"SizeInSquareFeet\", \"Bedrooms\", \"Bathrooms\", \"Age\", \"Neighborhood\" FROM \"HousingData\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/HousingData/{HouseID}" ; rr:class :HousingData ] ;
  rr:predicateObjectMap [ rr:predicate p:HouseID ; rr:objectMap [ rr:column "HouseID" ] ] ;
