@prefix : <http://ambrosia.example.org/demographics#> .
@prefix p: <http://ambrosia.example.org/demographics/prop#> .
@prefix ex: <http://ambrosia.example.org/demographics/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_pay_gap_0_People_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"dateOfBirth\", \"occupation\" FROM \"People\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Person/{id}" ; rr:class :Person ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dateOfBirth ; rr:objectMap [ rr:column "dateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:occupation ; rr:objectMap [ rr:column "occupation" ] ] .

<#tm_vague_2cols_pay_gap_1_SalaryData_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"personId\", \"salary\", \"hireDate\" FROM \"SalaryData\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/SalaryData/{_amb_rowid}" ; rr:class :SalaryData ] ;
  rr:predicateObjectMap [ rr:predicate p:personId ; rr:objectMap [ rr:column "personId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hireDate ; rr:objectMap [ rr:column "hireDate" ] ] .

<#tm_vague_2cols_pay_gap_2_SalaryData_personId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"personId\" FROM \"SalaryData\" WHERE \"personId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/SalaryData/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPerson ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Person/{personId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_pay_gap_3_OccupationalStats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"occupation\", \"percentageGap\", \"differenceInSalaries\", \"jobSatisfactionIndex\" FROM \"OccupationalStats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/OccupationalStats/{_amb_rowid}" ; rr:class :OccupationalStats ] ;
  rr:predicateObjectMap [ rr:predicate p:occupation ; rr:objectMap [ rr:column "occupation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:percentageGap ; rr:objectMap [ rr:column "percentageGap" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:differenceInSalaries ; rr:objectMap [ rr:column "differenceInSalaries" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobSatisfactionIndex ; rr:objectMap [ rr:column "jobSatisfactionIndex" ] ] .

<#tm_vague_2cols_pay_gap_4_OccupationalStats_occupation_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"occupation\" FROM \"OccupationalStats\" WHERE \"occupation\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/OccupationalStats/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPerson ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Person/{occupation}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_pay_gap_5_EducationLevel_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"educationLevel\", \"avgYearsOfEducation\", \"avgAnnualIncome\" FROM \"EducationLevel\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/EducationLevel/{_amb_rowid}" ; rr:class :EducationLevel ] ;
  rr:predicateObjectMap [ rr:predicate p:educationLevel ; rr:objectMap [ rr:column "educationLevel" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:avgYearsOfEducation ; rr:objectMap [ rr:column "avgYearsOfEducation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:avgAnnualIncome ; rr:objectMap [ rr:column "avgAnnualIncome" ] ] .

<#tm_vague_2cols_pay_gap_6_LocationData_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"locationID\", \"city\", \"state\", \"country\", \"numPeople\" FROM \"LocationData\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/LocationData/{locationID}" ; rr:class :LocationData ] ;
  rr:predicateObjectMap [ rr:predicate p:locationID ; rr:objectMap [ rr:column "locationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:state ; rr:objectMap [ rr:column "state" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:numPeople ; rr:objectMap [ rr:column "numPeople" ] ] .

<#tm_vague_2cols_pay_gap_7_CityPopulationByDemographics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"locationID\", \"ageRange\", \"gender\", \"ethnicity\", \"population\" FROM \"CityPopulationByDemographics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/CityPopulationByDemographics/{_amb_rowid}" ; rr:class :CityPopulationByDemographics ] ;
  rr:predicateObjectMap [ rr:predicate p:locationID ; rr:objectMap [ rr:column "locationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ageRange ; rr:objectMap [ rr:column "ageRange" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:gender ; rr:objectMap [ rr:column "gender" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ethnicity ; rr:objectMap [ rr:column "ethnicity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:population ; rr:objectMap [ rr:column "population" ] ] .

<#tm_vague_2cols_pay_gap_8_CityPopulationByDemographics_locationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"locationID\" FROM \"CityPopulationByDemographics\" WHERE \"locationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/CityPopulationByDemographics/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocationData ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/LocationData/{locationID}" ; rr:termType rr:IRI ] ] .

