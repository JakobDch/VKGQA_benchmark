  rr:predicateObjectMap [ rr:predicate p:CityID ; rr:objectMap [ rr:column "CityID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalEnrolled ; rr:objectMap [ rr:column "TotalEnrolled" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalGraduated ; rr:objectMap [ rr:column "TotalGraduated" ] ] .

<#tm_vague_2cols_speakers_8_EducationLevel_CityID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EducationLevelID\", \"CityID\" FROM \"EducationLevel\" WHERE \"CityID\" IS NOT NULL""" ] ;
