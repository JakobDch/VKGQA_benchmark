  rr:predicateObjectMap [ rr:predicate p:hasCities ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Cities/{CityID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_speakers_9_Language_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LanguageID\", \"Name\", \"Number_of_speakers\", \"Percentage_of_population\" FROM \"Language\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Language/{LanguageID}" ; rr:class :Language ] ;
  rr:predicateObjectMap [ rr:predicate p:LanguageID ; rr:objectMap [ rr:column "LanguageID" ] ] ;
