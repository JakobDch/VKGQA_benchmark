@prefix : <http://ambrosia.example.org/demographics#> .
@prefix p: <http://ambrosia.example.org/demographics/prop#> .
@prefix ex: <http://ambrosia.example.org/demographics/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_timeframe_0_Annual_Demographics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Year\", \"Month\", \"Census\", \"Population\", \"Area\", \"Density\" FROM \"Annual_Demographics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Annual_Demographics/{Year}" ; rr:class :Annual_Demographics ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Month ; rr:objectMap [ rr:column "Month" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Census ; rr:objectMap [ rr:column "Census" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Population ; rr:objectMap [ rr:column "Population" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Area ; rr:objectMap [ rr:column "Area" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Density ; rr:objectMap [ rr:column "Density" ] ] .

<#tm_vague_2cols_timeframe_1_Age_Groups_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AgeGroupID\", \"CityName\", \"PercentageOfTotalPopulation\" FROM \"Age_Groups\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Age_Groups/{AgeGroupID}" ; rr:class :Age_Groups ] ;
  rr:predicateObjectMap [ rr:predicate p:AgeGroupID ; rr:objectMap [ rr:column "AgeGroupID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CityName ; rr:objectMap [ rr:column "CityName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PercentageOfTotalPopulation ; rr:objectMap [ rr:column "PercentageOfTotalPopulation" ] ] .

<#tm_vague_2cols_timeframe_2_Educational_Levels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EducationLevelID\", \"CityName\", \"BachelorsOrHigher\", \"HighSchoolGraduate\", \"LessThanHighSchoolDiploma\" FROM \"Educational_Levels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Educational_Levels/{EducationLevelID}" ; rr:class :Educational_Levels ] ;
  rr:predicateObjectMap [ rr:predicate p:EducationLevelID ; rr:objectMap [ rr:column "EducationLevelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CityName ; rr:objectMap [ rr:column "CityName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BachelorsOrHigher ; rr:objectMap [ rr:column "BachelorsOrHigher" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HighSchoolGraduate ; rr:objectMap [ rr:column "HighSchoolGraduate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LessThanHighSchoolDiploma ; rr:objectMap [ rr:column "LessThanHighSchoolDiploma" ] ] .

<#tm_vague_2cols_timeframe_3_Income_Brackets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"IncomeBracketID\", \"CityName\", \"Under50k\", \"Between50And100K\", \"Above100k\" FROM \"Income_Brackets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Income_Brackets/{IncomeBracketID}" ; rr:class :Income_Brackets ] ;
  rr:predicateObjectMap [ rr:predicate p:IncomeBracketID ; rr:objectMap [ rr:column "IncomeBracketID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CityName ; rr:objectMap [ rr:column "CityName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Under50k ; rr:objectMap [ rr:column "Under50k" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Between50And100K ; rr:objectMap [ rr:column "Between50And100K" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Above100k ; rr:objectMap [ rr:column "Above100k" ] ] .

<#tm_vague_2cols_timeframe_4_Ethnicities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EthnicityID\", \"CityName\", \"White\", \"BlackOrAfricanAmerican\", \"HispanicOrLatino\", \"Asian\", \"NativeAmericanAlaskanNative\", \"OtherPacificIslander\", \"TwoOrMoreRaces\" FROM \"Ethnicities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Ethnicities/{EthnicityID}" ; rr:class :Ethnicities ] ;
