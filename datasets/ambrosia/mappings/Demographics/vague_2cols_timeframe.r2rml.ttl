  rr:predicateObjectMap [ rr:predicate p:CityName ; rr:objectMap [ rr:column "CityName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:White ; rr:objectMap [ rr:column "White" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BlackOrAfricanAmerican ; rr:objectMap [ rr:column "BlackOrAfricanAmerican" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HispanicOrLatino ; rr:objectMap [ rr:column "HispanicOrLatino" ] ] ;
