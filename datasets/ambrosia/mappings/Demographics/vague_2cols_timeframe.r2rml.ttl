  rr:predicateObjectMap [ rr:predicate p:TwoOrMoreRaces ; rr:objectMap [ rr:column "TwoOrMoreRaces" ] ] .

<#tm_vague_2cols_timeframe_5_Occupations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OccupationID\", \"CityName\", \"ManagementOrProfessional\", \"ServiceIndustry\", \"Sales\", \"OfficeAdminSupport\", \"FarmingFishing\", \"ConstructionTrades\", \"ProductionTransportation\", \"MaterialMoving\", \"PersonalServices\", \"HealthcareTechnician\", \"Teachers\", \"ArmedForces\", \"None\" FROM \"Occupations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Occupations/{OccupationID}" ; rr:class :Occupations ] ;
  rr:predicateObjectMap [ rr:predicate p:OccupationID ; rr:objectMap [ rr:column "OccupationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CityName ; rr:objectMap [ rr:column "CityName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ManagementOrProfessional ; rr:objectMap [ rr:column "ManagementOrProfessional" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ServiceIndustry ; rr:objectMap [ rr:column "ServiceIndustry" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Sales ; rr:objectMap [ rr:column "Sales" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OfficeAdminSupport ; rr:objectMap [ rr:column "OfficeAdminSupport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FarmingFishing ; rr:objectMap [ rr:column "FarmingFishing" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ConstructionTrades ; rr:objectMap [ rr:column "ConstructionTrades" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProductionTransportation ; rr:objectMap [ rr:column "ProductionTransportation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MaterialMoving ; rr:objectMap [ rr:column "MaterialMoving" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PersonalServices ; rr:objectMap [ rr:column "PersonalServices" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HealthcareTechnician ; rr:objectMap [ rr:column "HealthcareTechnician" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Teachers ; rr:objectMap [ rr:column "Teachers" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArmedForces ; rr:objectMap [ rr:column "ArmedForces" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:None ; rr:objectMap [ rr:column "None" ] ] .

