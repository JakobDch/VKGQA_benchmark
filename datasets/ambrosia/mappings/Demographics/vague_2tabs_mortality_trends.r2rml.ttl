@prefix : <http://ambrosia.example.org/demographics#> .
@prefix p: <http://ambrosia.example.org/demographics/prop#> .
@prefix ex: <http://ambrosia.example.org/demographics/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_mortality_trends_0_Person_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"personID\", \"name\", \"dateofbirth\" FROM \"Person\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Person/{personID}" ; rr:class :Person ] ;
  rr:predicateObjectMap [ rr:predicate p:personID ; rr:objectMap [ rr:column "personID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dateofbirth ; rr:objectMap [ rr:column "dateofbirth" ] ] .

<#tm_vague_2tabs_mortality_trends_1_Disease_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"diseaseID\", \"name\", \"deathrate\" FROM \"Disease\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Disease/{diseaseID}" ; rr:class :Disease ] ;
  rr:predicateObjectMap [ rr:predicate p:diseaseID ; rr:objectMap [ rr:column "diseaseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:deathrate ; rr:objectMap [ rr:column "deathrate" ] ] .

<#tm_vague_2tabs_mortality_trends_2_Number_Of_Deaths_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"year\", \"total_deaths\" FROM \"Number_Of_Deaths\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Number_Of_Deaths/{year}" ; rr:class :Number_Of_Deaths ] ;
  rr:predicateObjectMap [ rr:predicate p:year ; rr:objectMap [ rr:column "year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:total_deaths ; rr:objectMap [ rr:column "total_deaths" ] ] .

<#tm_vague_2tabs_mortality_trends_3_Number_Of_Deaths_year_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"year\" FROM \"Number_Of_Deaths\" WHERE \"year\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Number_Of_Deaths/{year}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProvince ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Province/{year}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_mortality_trends_4_Crude_Death_Rate_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"year\", \"rate\" FROM \"Crude_Death_Rate\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Crude_Death_Rate/{year}" ; rr:class :Crude_Death_Rate ] ;
  rr:predicateObjectMap [ rr:predicate p:year ; rr:objectMap [ rr:column "year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rate ; rr:objectMap [ rr:column "rate" ] ] .

<#tm_vague_2tabs_mortality_trends_5_Crude_Death_Rate_year_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"year\" FROM \"Crude_Death_Rate\" WHERE \"year\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Crude_Death_Rate/{year}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProvince ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Province/{year}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_mortality_trends_6_Province_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"provinceID\", \"name\", \"year\", \"population\" FROM \"Province\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Province/{provinceID}" ; rr:class :Province ] ;
  rr:predicateObjectMap [ rr:predicate p:provinceID ; rr:objectMap [ rr:column "provinceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:year ; rr:objectMap [ rr:column "year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:population ; rr:objectMap [ rr:column "population" ] ] .

<#tm_vague_2tabs_mortality_trends_7_Province_year_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"provinceID\", \"year\" FROM \"Province\" WHERE \"year\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Province/{provinceID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNumber_Of_Deaths ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Number_Of_Deaths/{year}" ; rr:termType rr:IRI ] ] .

