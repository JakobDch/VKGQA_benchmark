@prefix : <http://ambrosia.example.org/demographics#> .
@prefix p: <http://ambrosia.example.org/demographics/prop#> .
@prefix ex: <http://ambrosia.example.org/demographics/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_owner_population_0_Person_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Age\" FROM \"Person\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Person/{ID}" ; rr:class :Person ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] .

<#tm_vague_2tabs_owner_population_1_Address_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Street\", \"City\", \"PersonId\" FROM \"Address\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Address/{ID}" ; rr:class :Address ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Street ; rr:objectMap [ rr:column "Street" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PersonId ; rr:objectMap [ rr:column "PersonId" ] ] .

<#tm_vague_2tabs_owner_population_2_Address_PersonId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"PersonId\" FROM \"Address\" WHERE \"PersonId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/Address/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPerson ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/Person/{PersonId}" ; rr:termType rr:IRI ] ] .

