<#tm_vague_2tabs_owner_population_7_OwnerPercentage_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Year\", \"Percentage\", \"TotalPopulation\" FROM \"OwnerPercentage\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/OwnerPercentage/{Year}" ; rr:class :OwnerPercentage ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Percentage ; rr:objectMap [ rr:column "Percentage" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalPopulation ; rr:objectMap [ rr:column "TotalPopulation" ] ] .

<#tm_vague_2tabs_owner_population_8_NumbersOfOwners_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Year\", \"NumberOfHouseholds\" FROM \"NumbersOfOwners\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/NumbersOfOwners/{_amb_rowid}" ; rr:class :NumbersOfOwners ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfHouseholds ; rr:objectMap [ rr:column "NumberOfHouseholds" ] ] .

<#tm_vague_2tabs_owner_population_9_NumbersOfOwners_Year_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Year\" FROM \"NumbersOfOwners\" WHERE \"Year\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/NumbersOfOwners/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOwnerPercentage ; rr:objectMap [ rr:template "http://ambrosia.example.org/demographics/id/OwnerPercentage/{Year}" ; rr:termType rr:IRI ] ] .

