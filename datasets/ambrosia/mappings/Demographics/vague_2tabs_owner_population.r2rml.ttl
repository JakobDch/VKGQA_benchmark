<#tm_vague_2tabs_owner_population_5_IncomeLevel_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Level\", \"PersonId\" FROM \"IncomeLevel\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/demographics/id/IncomeLevel/{ID}" ; rr:class :IncomeLevel ] ;
