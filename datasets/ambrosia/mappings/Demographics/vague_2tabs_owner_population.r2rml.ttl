  rr:predicateObjectMap [ rr:predicate p:Status ; rr:objectMap [ rr:column "Status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PersonId ; rr:objectMap [ rr:column "PersonId" ] ] .

<#tm_vague_2tabs_owner_population_4_EmploymentStatus_PersonId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"PersonId\" FROM \"EmploymentStatus\" WHERE \"PersonId\" IS NOT NULL""" ] ;
