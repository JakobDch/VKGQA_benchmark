@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_educational_methods_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studentID\", \"firstName\", \"lastName\", \"dateOfBirth\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:studentID ; rr:objectMap [ rr:column "studentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dateOfBirth ; rr:objectMap [ rr:column "dateOfBirth" ] ] .

<#tm_attachment_1tab_ref_educational_methods_1_Educators_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"educatorID\", \"firstName\", \"lastName\", \"subject\" FROM \"Educators\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Educators/{educatorID}" ; rr:class :Educators ] ;
  rr:predicateObjectMap [ rr:predicate p:educatorID ; rr:objectMap [ rr:column "educatorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subject ; rr:objectMap [ rr:column "subject" ] ] .

<#tm_attachment_1tab_ref_educational_methods_2_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classID\", \"title\", \"startDate\", \"endDate\", \"EducatorID\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classID}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:classID ; rr:objectMap [ rr:column "classID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EducatorID ; rr:objectMap [ rr:column "EducatorID" ] ] .

<#tm_attachment_1tab_ref_educational_methods_3_Classes_classID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classID\" FROM \"Classes\" WHERE \"classID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEnrollments ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{classID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_educational_methods_4_Classes_EducatorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classID\", \"EducatorID\" FROM \"Classes\" WHERE \"EducatorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEducators ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Educators/{EducatorID}" ; rr:termType rr:IRI ] ] .

