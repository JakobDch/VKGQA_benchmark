  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Venue_Tickets/{VenueID}/{TicketID}" ; rr:class :Venue_Tickets ] ;
  rr:predicateObjectMap [ rr:predicate p:VenueID ; rr:objectMap [ rr:column "VenueID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TicketID ; rr:objectMap [ rr:column "TicketID" ] ] .

<#tm_attachment_1tab_ref_educational_venues_3_Venue_Tickets_TicketID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"VenueID\", \"TicketID\" FROM \"Venue_Tickets\" WHERE \"TicketID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Venue_Tickets/{VenueID}/{TicketID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTickets ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Tickets/{TicketID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_educational_venues_4_Venue_Tickets_VenueID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"VenueID\", \"TicketID\" FROM \"Venue_Tickets\" WHERE \"VenueID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Venue_Tickets/{VenueID}/{TicketID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEducational_Venues ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Educational_Venues/{VenueID}" ; rr:termType rr:IRI ] ] .

