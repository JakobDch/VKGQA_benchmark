@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_educational_venues_0_Educational_Venues_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"VenueID\", \"Name\", \"Type\", \"Address\", \"City\", \"State\" FROM \"Educational_Venues\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Educational_Venues/{VenueID}" ; rr:class :Educational_Venues ] ;
  rr:predicateObjectMap [ rr:predicate p:VenueID ; rr:objectMap [ rr:column "VenueID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:State ; rr:objectMap [ rr:column "State" ] ] .

<#tm_attachment_1tab_ref_educational_venues_1_Tickets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TicketID\", \"Price\" FROM \"Tickets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Tickets/{TicketID}" ; rr:class :Tickets ] ;
  rr:predicateObjectMap [ rr:predicate p:TicketID ; rr:objectMap [ rr:column "TicketID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_attachment_1tab_ref_educational_venues_2_Venue_Tickets_base> a rr:TriplesMap ;
