@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_learning_activities_0_Student_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FirstName\", \"LastName\", \"Age\", \"GradeLevel\" FROM \"Student\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{ID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GradeLevel ; rr:objectMap [ rr:column "GradeLevel" ] ] .

<#tm_attachment_1tab_ref_learning_activities_1_Course_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Subject\", \"TeacherID\" FROM \"Course\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{ID}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Subject ; rr:objectMap [ rr:column "Subject" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TeacherID ; rr:objectMap [ rr:column "TeacherID" ] ] .

<#tm_attachment_1tab_ref_learning_activities_2_Course_TeacherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"TeacherID\" FROM \"Course\" WHERE \"TeacherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTeachers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{TeacherID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_learning_activities_3_LearningActivity_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Description\", \"ActivityType\", \"PurposeID\" FROM \"LearningActivity\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/LearningActivities/{ID}" ; rr:class :LearningActivities ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ActivityType ; rr:objectMap [ rr:column "ActivityType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PurposeID ; rr:objectMap [ rr:column "PurposeID" ] ] .

<#tm_attachment_1tab_ref_learning_activities_4_LearningActivity_PurposeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"PurposeID\" FROM \"LearningActivity\" WHERE \"PurposeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/LearningActivities/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPurpose ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Purpose/{PurposeID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_learning_activities_5_Purpose_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\" FROM \"Purpose\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Purpose/{ID}" ; rr:class :Purpose ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_ref_learning_activities_6_Teacher_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FirstName\", \"LastName\", \"Department\" FROM \"Teacher\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{ID}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Department ; rr:objectMap [ rr:column "Department" ] ] .

<#tm_attachment_1tab_ref_learning_activities_7_Enrollment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"StudentID\", \"CourseID\", \"DateEnrolled\", \"Grades\" FROM \"Enrollment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{_amb_rowid}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseID ; rr:objectMap [ rr:column "CourseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateEnrolled ; rr:objectMap [ rr:column "DateEnrolled" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Grades ; rr:objectMap [ rr:column "Grades" ] ] .

<#tm_attachment_1tab_ref_learning_activities_8_Enrollment_CourseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"CourseID\" FROM \"Enrollment\" WHERE \"CourseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{CourseID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_learning_activities_9_Enrollment_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"StudentID\" FROM \"Enrollment\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

