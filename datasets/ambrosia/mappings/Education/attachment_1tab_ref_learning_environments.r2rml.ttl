@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_learning_environments_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"FirstName\", \"LastName\", \"Age\", \"Email\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

<#tm_attachment_1tab_ref_learning_environments_1_LearningEnvironments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnvironmentID\", \"Value\" FROM \"LearningEnvironments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/LearningEnvironments/{EnvironmentID}" ; rr:class :LearningEnvironments ] ;
  rr:predicateObjectMap [ rr:predicate p:EnvironmentID ; rr:objectMap [ rr:column "EnvironmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Value ; rr:objectMap [ rr:column "Value" ] ] .

<#tm_attachment_1tab_ref_learning_environments_2_Enrollments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\", \"ClassroomID\", \"StartDate\", \"EndDate\" FROM \"Enrollments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentID ; rr:objectMap [ rr:column "EnrollmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassroomID ; rr:objectMap [ rr:column "ClassroomID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] .

<#tm_attachment_1tab_ref_learning_environments_3_Enrollments_ClassroomID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"ClassroomID\" FROM \"Enrollments\" WHERE \"ClassroomID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClassrooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Classrooms/{ClassroomID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_learning_environments_4_Enrollments_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\" FROM \"Enrollments\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_learning_environments_5_Classrooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassroomID\", \"Name\", \"Capacity\", \"TypeOfEnvironment\" FROM \"Classrooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classrooms/{ClassroomID}" ; rr:class :Classrooms ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassroomID ; rr:objectMap [ rr:column "ClassroomID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeOfEnvironment ; rr:objectMap [ rr:column "TypeOfEnvironment" ] ] .

<#tm_attachment_1tab_ref_learning_environments_6_Classrooms_TypeOfEnvironment_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassroomID\", \"TypeOfEnvironment\" FROM \"Classrooms\" WHERE \"TypeOfEnvironment\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classrooms/{ClassroomID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLearningEnvironments ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/LearningEnvironments/{TypeOfEnvironment}" ; rr:termType rr:IRI ] ] .

