@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_learning_materials_0_Subjects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"subjectName\" FROM \"Subjects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{id}" ; rr:class :Subjects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subjectName ; rr:objectMap [ rr:column "subjectName" ] ] .

<#tm_attachment_1tab_ref_learning_materials_1_Teachers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"teacherId\", \"firstName\", \"lastName\", \"email\" FROM \"Teachers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{teacherId}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:teacherId ; rr:objectMap [ rr:column "teacherId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_attachment_1tab_ref_learning_materials_2_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classId\", \"className\", \"startDate\", \"endDate\", \"teacherId\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classId}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:classId ; rr:objectMap [ rr:column "classId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:className ; rr:objectMap [ rr:column "className" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:teacherId ; rr:objectMap [ rr:column "teacherId" ] ] .

<#tm_attachment_1tab_ref_learning_materials_3_Classes_teacherId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classId\", \"teacherId\" FROM \"Classes\" WHERE \"teacherId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTeachers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{teacherId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_learning_materials_4_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studentId\", \"firstName\", \"lastName\", \"enrollmentYear\", \"classId\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentId}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:studentId ; rr:objectMap [ rr:column "studentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:enrollmentYear ; rr:objectMap [ rr:column "enrollmentYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:classId ; rr:objectMap [ rr:column "classId" ] ] .

<#tm_attachment_1tab_ref_learning_materials_5_Students_classId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studentId\", \"classId\" FROM \"Students\" WHERE \"classId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClasses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_learning_materials_6_Learning_Materials_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"materialId\", \"typeOfMaterial\", \"title\", \"description\", \"difficultyLevel\" FROM \"Learning_Materials\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Learning_Materials/{materialId}" ; rr:class :Learning_Materials ] ;
  rr:predicateObjectMap [ rr:predicate p:materialId ; rr:objectMap [ rr:column "materialId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:typeOfMaterial ; rr:objectMap [ rr:column "typeOfMaterial" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:difficultyLevel ; rr:objectMap [ rr:column "difficultyLevel" ] ] .

<#tm_attachment_1tab_ref_learning_materials_7_Learning_Materials_difficultyLevel_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"materialId\", \"difficultyLevel\" FROM \"Learning_Materials\" WHERE \"difficultyLevel\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Learning_Materials/{materialId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDifficulty_Level ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Difficulty_Level/{difficultyLevel}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_learning_materials_8_Difficulty_levels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"difficultyLevel\", \"levelDescription\" FROM \"Difficulty_levels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Difficulty_Level/{difficultyLevel}" ; rr:class :Difficulty_Level ] ;
  rr:predicateObjectMap [ rr:predicate p:difficultyLevel ; rr:objectMap [ rr:column "difficultyLevel" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:levelDescription ; rr:objectMap [ rr:column "levelDescription" ] ] .

