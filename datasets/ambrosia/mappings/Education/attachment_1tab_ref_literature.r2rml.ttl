@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_literature_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"age\", \"gender\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:age ; rr:objectMap [ rr:column "age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:gender ; rr:objectMap [ rr:column "gender" ] ] .

<#tm_attachment_1tab_ref_literature_1_Reviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"rating\", \"book_id\", \"student_id\" FROM \"Reviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Reviews/{id}" ; rr:class :Reviews ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rating ; rr:objectMap [ rr:column "rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:book_id ; rr:objectMap [ rr:column "book_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:student_id ; rr:objectMap [ rr:column "student_id" ] ] .

<#tm_attachment_1tab_ref_literature_2_Reviews_student_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"student_id\" FROM \"Reviews\" WHERE \"student_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Reviews/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{student_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_literature_3_Reviews_book_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"book_id\" FROM \"Reviews\" WHERE \"book_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Reviews/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBooks ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Books/{book_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_literature_4_Books_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"type_of_book\", \"literature\" FROM \"Books\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Books/{id}" ; rr:class :Books ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type_of_book ; rr:objectMap [ rr:column "type_of_book" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:literature ; rr:objectMap [ rr:column "literature" ] ] .

