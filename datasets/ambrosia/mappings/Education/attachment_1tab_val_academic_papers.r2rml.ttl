@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_academic_papers_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"Major\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Major ; rr:objectMap [ rr:column "Major" ] ] .

<#tm_attachment_1tab_val_academic_papers_1_Professors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProfessorID\", \"FirstName\", \"LastName\", \"Department\" FROM \"Professors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Professors/{ProfessorID}" ; rr:class :Professors ] ;
  rr:predicateObjectMap [ rr:predicate p:ProfessorID ; rr:objectMap [ rr:column "ProfessorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Department ; rr:objectMap [ rr:column "Department" ] ] .

<#tm_attachment_1tab_val_academic_papers_2_Papers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PaperID\", \"Title\", \"AbstractText\", \"Academic_PaperType\", \"Citation_Style\", \"AuthorID\" FROM \"Papers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Research_Papers/{PaperID}" ; rr:class :Research_Papers ] ;
  rr:predicateObjectMap [ rr:predicate p:PaperID ; rr:objectMap [ rr:column "PaperID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AbstractText ; rr:objectMap [ rr:column "AbstractText" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Academic_PaperType ; rr:objectMap [ rr:column "Academic_PaperType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Citation_Style ; rr:objectMap [ rr:column "Citation_Style" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] .

<#tm_attachment_1tab_val_academic_papers_3_Papers_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PaperID\", \"AuthorID\" FROM \"Papers\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Research_Papers/{PaperID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProfessors ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Professors/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_academic_papers_4_Papers_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PaperID\", \"AuthorID\" FROM \"Papers\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Research_Papers/{PaperID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{AuthorID}" ; rr:termType rr:IRI ] ] .

