<#tm_attachment_1tab_val_assessment_methods_9_Grades_EnrollmentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GradeID\", \"EnrollmentID\" FROM \"Grades\" WHERE \"EnrollmentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Grades/{GradeID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEnrollments ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_assessment_methods_10_Assessments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AssessmentID\", \"AssessmentMethod\", \"Assessor\", \"TotalMarks\", \"PassingMark\", \"DateOfAssessment\" FROM \"Assessments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Assessments/{AssessmentID}" ; rr:class :Assessments ] ;
  rr:predicateObjectMap [ rr:predicate p:AssessmentID ; rr:objectMap [ rr:column "AssessmentID" ] ] ;
