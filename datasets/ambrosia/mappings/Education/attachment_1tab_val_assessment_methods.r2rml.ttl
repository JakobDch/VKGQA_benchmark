  rr:predicateObjectMap [ rr:predicate p:PassingMark ; rr:objectMap [ rr:column "PassingMark" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfAssessment ; rr:objectMap [ rr:column "DateOfAssessment" ] ] .

