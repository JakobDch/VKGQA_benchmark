@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_assessment_methods_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"FirstName\", \"LastName\", \"Age\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] .

<#tm_attachment_1tab_val_assessment_methods_1_Courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CourseID\", \"Title\", \"Department\" FROM \"Courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{CourseID}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseID ; rr:objectMap [ rr:column "CourseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Department ; rr:objectMap [ rr:column "Department" ] ] .

<#tm_attachment_1tab_val_assessment_methods_2_Enrollments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\", \"CourseID\", \"Semester\" FROM \"Enrollments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentID ; rr:objectMap [ rr:column "EnrollmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseID ; rr:objectMap [ rr:column "CourseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Semester ; rr:objectMap [ rr:column "Semester" ] ] .

<#tm_attachment_1tab_val_assessment_methods_3_Enrollments_CourseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"CourseID\" FROM \"Enrollments\" WHERE \"CourseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{CourseID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_assessment_methods_4_Enrollments_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\" FROM \"Enrollments\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_assessment_methods_5_Scores_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ScoreID\", \"EnrollmentID\", \"AssessmentID\", \"Score\" FROM \"Scores\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Scores/{ScoreID}" ; rr:class :Scores ] ;
  rr:predicateObjectMap [ rr:predicate p:ScoreID ; rr:objectMap [ rr:column "ScoreID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentID ; rr:objectMap [ rr:column "EnrollmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AssessmentID ; rr:objectMap [ rr:column "AssessmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Score ; rr:objectMap [ rr:column "Score" ] ] .

<#tm_attachment_1tab_val_assessment_methods_6_Scores_AssessmentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ScoreID\", \"AssessmentID\" FROM \"Scores\" WHERE \"AssessmentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Scores/{ScoreID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAssessments ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Assessments/{AssessmentID}" ; rr:termType rr:IRI ] ] .

