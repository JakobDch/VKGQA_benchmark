[PrefixDeclaration]
:	http://ambrosia.example.org/education#
p:	http://ambrosia.example.org/education/prop#
ex:	http://ambrosia.example.org/education/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Students_base
target		ex:Students/{StudentID} a :Students ; p:StudentID {StudentID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:BirthDate {BirthDate} ; p:email {Email} .
source		SELECT `StudentID`, `FirstName`, `LastName`, `BirthDate`, `Email` FROM `Students`

mappingId	Teachers_base
target		ex:Teachers/{TeacherID} a :Teachers ; p:TeacherID {TeacherID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:HireDate {HireDate} ; p:email {Email} .
source		SELECT `TeacherID`, `FirstName`, `LastName`, `HireDate`, `Email` FROM `Teachers`

mappingId	Awards_base
target		ex:Awards/{AwardType} a :Awards ; p:AwardType {AwardType} ; p:Description {Description} .
source		SELECT `AwardType`, `Description` FROM `Awards`

mappingId	Enrollments_base
target		ex:Enrollments/{EnrollmentID} a :Enrollments ; p:EnrollmentID {EnrollmentID} ; p:CourseID {CourseID} ; p:StudentID {StudentID} ; p:TeacherID {TeacherID} ; p:DateEnrolled {DateEnrolled} .
source		SELECT `EnrollmentID`, `CourseID`, `StudentID`, `TeacherID`, `DateEnrolled` FROM `Enrollments`

mappingId	Enrollments_CourseID_fk
target		ex:Enrollments/{EnrollmentID} p:hasCourses ex:Courses/{CourseID} .
source		SELECT `EnrollmentID`, `CourseID` FROM `Enrollments` WHERE `CourseID` IS NOT NULL

mappingId	Enrollments_TeacherID_fk
target		ex:Enrollments/{EnrollmentID} p:hasTeachers ex:Teachers/{TeacherID} .
source		SELECT `EnrollmentID`, `TeacherID` FROM `Enrollments` WHERE `TeacherID` IS NOT NULL

mappingId	Enrollments_StudentID_fk
target		ex:Enrollments/{EnrollmentID} p:hasStudents ex:Students/{StudentID} .
source		SELECT `EnrollmentID`, `StudentID` FROM `Enrollments` WHERE `StudentID` IS NOT NULL

mappingId	Courses_base
target		ex:Courses/{CourseID} a :Courses ; p:CourseID {CourseID} ; p:Title {Title} ; p:CreditHours {CreditHours} ; p:CompletionRequirements {CompletionRequirements} ; p:AwardProgram {AwardProgram} ; p:UniqueConstraint {UniqueConstraint} .
source		SELECT `CourseID`, `Title`, `CreditHours`, `CompletionRequirements`, `AwardProgram`, `UniqueConstraint` FROM `Courses`

]]
