@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_educational_activities_0_Schools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SchoolID\", \"Name\", \"Address\", \"PhoneText\" FROM \"Schools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Schools/{SchoolID}" ; rr:class :Schools ] ;
  rr:predicateObjectMap [ rr:predicate p:SchoolID ; rr:objectMap [ rr:column "SchoolID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneText ; rr:objectMap [ rr:column "PhoneText" ] ] .

<#tm_attachment_1tab_val_educational_activities_1_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"SchoolID\", \"TeacherName\", \"Subject\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassID ; rr:objectMap [ rr:column "ClassID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SchoolID ; rr:objectMap [ rr:column "SchoolID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TeacherName ; rr:objectMap [ rr:column "TeacherName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Subject ; rr:objectMap [ rr:column "Subject" ] ] .

<#tm_attachment_1tab_val_educational_activities_2_Classes_SchoolID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"SchoolID\" FROM \"Classes\" WHERE \"SchoolID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSchools ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Schools/{SchoolID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_educational_activities_3_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"FirstName\", \"LastName\", \"Age\", \"EnrollmentDate\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentDate ; rr:objectMap [ rr:column "EnrollmentDate" ] ] .

<#tm_attachment_1tab_val_educational_activities_4_Enrollments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\", \"ClassID\", \"Educational_Activity\", \"Number_of_students\" FROM \"Enrollments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentID ; rr:objectMap [ rr:column "EnrollmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassID ; rr:objectMap [ rr:column "ClassID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Educational_Activity ; rr:objectMap [ rr:column "Educational_Activity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_students ; rr:objectMap [ rr:column "Number_of_students" ] ] .

<#tm_attachment_1tab_val_educational_activities_5_Enrollments_ClassID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"ClassID\" FROM \"Enrollments\" WHERE \"ClassID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClasses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_educational_activities_6_Enrollments_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\" FROM \"Enrollments\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

