[PrefixDeclaration]
:	http://ambrosia.example.org/education#
p:	http://ambrosia.example.org/education/prop#
ex:	http://ambrosia.example.org/education/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Authors_base
target		ex:Authors/{AuthorID} a :Authors ; p:AuthorID {AuthorID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:BirthDate {BirthDate} ; p:Country {Country} .
source		SELECT `AuthorID`, `FirstName`, `LastName`, `BirthDate`, `Country` FROM `Authors`

mappingId	Subjects_base
target		ex:Subjects/{SubjectID} a :Subjects ; p:SubjectID {SubjectID} ; p:name {Name} .
source		SELECT `SubjectID`, `Name` FROM `Subjects`

mappingId	Books_base
target		ex:Books/{BookID} a :Books ; p:BookID {BookID} ; p:Title {Title} ; p:PublicationYear {PublicationYear} ; p:Pages {Pages} ; p:Educational_Materials {Educational_Materials} ; p:PublisherID {PublisherID} .
source		SELECT `BookID`, `Title`, `PublicationYear`, `Pages`, `Educational_Materials`, `PublisherID` FROM `Books`

mappingId	Books_PublisherID_fk
target		ex:Books/{BookID} p:hasPublishers ex:Publishers/{PublisherID} .
source		SELECT `BookID`, `PublisherID` FROM `Books` WHERE `PublisherID` IS NOT NULL

mappingId	Publishers_base
target		ex:Publishers/{PublisherID} a :Publishers ; p:PublisherID {PublisherID} ; p:CompanyName {CompanyName} ; p:Address {Address} ; p:ContactNumber {ContactNumber} ; p:email {Email} .
source		SELECT `PublisherID`, `CompanyName`, `Address`, `ContactNumber`, `Email` FROM `Publishers`

]]
