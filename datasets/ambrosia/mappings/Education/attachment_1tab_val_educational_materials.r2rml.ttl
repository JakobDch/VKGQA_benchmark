@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_educational_materials_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorID\", \"FirstName\", \"LastName\", \"BirthDate\", \"Country\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Authors/{AuthorID}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_val_educational_materials_1_Subjects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SubjectID\", \"Name\" FROM \"Subjects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{SubjectID}" ; rr:class :Subjects ] ;
  rr:predicateObjectMap [ rr:predicate p:SubjectID ; rr:objectMap [ rr:column "SubjectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_val_educational_materials_2_Books_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"Title\", \"PublicationYear\", \"Pages\", \"Educational_Materials\", \"PublisherID\" FROM \"Books\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Books/{BookID}" ; rr:class :Books ] ;
  rr:predicateObjectMap [ rr:predicate p:BookID ; rr:objectMap [ rr:column "BookID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationYear ; rr:objectMap [ rr:column "PublicationYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Pages ; rr:objectMap [ rr:column "Pages" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Educational_Materials ; rr:objectMap [ rr:column "Educational_Materials" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] .

<#tm_attachment_1tab_val_educational_materials_3_Books_PublisherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"PublisherID\" FROM \"Books\" WHERE \"PublisherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Books/{BookID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublishers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Publishers/{PublisherID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_educational_materials_4_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PublisherID\", \"CompanyName\", \"Address\", \"ContactNumber\", \"Email\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Publishers/{PublisherID}" ; rr:class :Publishers ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyName ; rr:objectMap [ rr:column "CompanyName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ContactNumber ; rr:objectMap [ rr:column "ContactNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

