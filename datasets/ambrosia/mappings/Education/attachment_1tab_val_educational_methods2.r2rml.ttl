@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_educational_methods2_0_Teacher_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"teacherID\", \"name\", \"age\", \"experience\" FROM \"Teacher\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{teacherID}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:teacherID ; rr:objectMap [ rr:column "teacherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:age ; rr:objectMap [ rr:column "age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] .

<#tm_attachment_1tab_val_educational_methods2_1_Student_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studentID\", \"name\", \"grade\", \"teacherID\" FROM \"Student\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:studentID ; rr:objectMap [ rr:column "studentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:grade ; rr:objectMap [ rr:column "grade" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:teacherID ; rr:objectMap [ rr:column "teacherID" ] ] .

<#tm_attachment_1tab_val_educational_methods2_2_Student_teacherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studentID\", \"teacherID\" FROM \"Student\" WHERE \"teacherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTeachers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{teacherID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_educational_methods2_3_Subject_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"subjectID\", \"name\" FROM \"Subject\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{subjectID}" ; rr:class :Subjects ] ;
  rr:predicateObjectMap [ rr:predicate p:subjectID ; rr:objectMap [ rr:column "subjectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_val_educational_methods2_4_Class_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classID\", \"subjectID\", \"teacherID\" FROM \"Class\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classID}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:classID ; rr:objectMap [ rr:column "classID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subjectID ; rr:objectMap [ rr:column "subjectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:teacherID ; rr:objectMap [ rr:column "teacherID" ] ] .

<#tm_attachment_1tab_val_educational_methods2_5_Class_teacherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classID\", \"teacherID\" FROM \"Class\" WHERE \"teacherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTeachers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{teacherID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_educational_methods2_6_Class_subjectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classID\", \"subjectID\" FROM \"Class\" WHERE \"subjectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{subjectID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_educational_methods2_7_Assignment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignmentID\", \"title\", \"dueDate\", \"educationalMethod\", \"participants\", \"classID\" FROM \"Assignment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Assignments/{assignmentID}" ; rr:class :Assignments ] ;
  rr:predicateObjectMap [ rr:predicate p:assignmentID ; rr:objectMap [ rr:column "assignmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dueDate ; rr:objectMap [ rr:column "dueDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:educationalMethod ; rr:objectMap [ rr:column "educationalMethod" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:participants ; rr:objectMap [ rr:column "participants" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:classID ; rr:objectMap [ rr:column "classID" ] ] .

<#tm_attachment_1tab_val_educational_methods2_8_Assignment_classID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignmentID\", \"classID\" FROM \"Assignment\" WHERE \"classID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Assignments/{assignmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClasses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classID}" ; rr:termType rr:IRI ] ] .

