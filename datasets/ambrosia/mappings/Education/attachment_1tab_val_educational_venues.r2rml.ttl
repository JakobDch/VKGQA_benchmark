@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_educational_venues_0_Educator_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"specialization\", \"yearsOfExperience\" FROM \"Educator\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Educators/{id}" ; rr:class :Educators ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specialization ; rr:objectMap [ rr:column "specialization" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:yearsOfExperience ; rr:objectMap [ rr:column "yearsOfExperience" ] ] .

<#tm_attachment_1tab_val_educational_venues_1_Course_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"courseId\", \"title\", \"description\", \"duration\", \"educatorId\" FROM \"Course\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{courseId}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:courseId ; rr:objectMap [ rr:column "courseId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration ; rr:objectMap [ rr:column "duration" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:educatorId ; rr:objectMap [ rr:column "educatorId" ] ] .

<#tm_attachment_1tab_val_educational_venues_2_Course_educatorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"courseId\", \"educatorId\" FROM \"Course\" WHERE \"educatorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{courseId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEducators ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Educators/{educatorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_educational_venues_3_Student_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studentId\", \"firstName\", \"lastName\", \"dateOfBirth\", \"enrolledCourses\" FROM \"Student\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentId}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:studentId ; rr:objectMap [ rr:column "studentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dateOfBirth ; rr:objectMap [ rr:column "dateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:enrolledCourses ; rr:objectMap [ rr:column "enrolledCourses" ] ] .

<#tm_attachment_1tab_val_educational_venues_4_Venue_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"venueId\", \"name\", \"location\", \"educationalVenue\", \"ticketPrice\" FROM \"Venue\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Venue/{venueId}" ; rr:class :Venue ] ;
  rr:predicateObjectMap [ rr:predicate p:venueId ; rr:objectMap [ rr:column "venueId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:educationalVenue ; rr:objectMap [ rr:column "educationalVenue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ticketPrice ; rr:objectMap [ rr:column "ticketPrice" ] ] .

