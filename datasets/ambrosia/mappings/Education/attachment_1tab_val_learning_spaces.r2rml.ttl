@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_learning_spaces_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"EmailAddress\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] .

<#tm_attachment_1tab_val_learning_spaces_1_Teachers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TeacherID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"EmailAddress\" FROM \"Teachers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{TeacherID}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:TeacherID ; rr:objectMap [ rr:column "TeacherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] .

<#tm_attachment_1tab_val_learning_spaces_2_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"ClassName\", \"TeacherID\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassID ; rr:objectMap [ rr:column "ClassID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassName ; rr:objectMap [ rr:column "ClassName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TeacherID ; rr:objectMap [ rr:column "TeacherID" ] ] .

<#tm_attachment_1tab_val_learning_spaces_3_Classes_TeacherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"TeacherID\" FROM \"Classes\" WHERE \"TeacherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTeachers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{TeacherID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_learning_spaces_4_ResourceAllocation_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AllocationID\", \"ClassID\", \"ResourceType\", \"Quantity\" FROM \"ResourceAllocation\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/ResourceAllocation/{AllocationID}" ; rr:class :ResourceAllocation ] ;
  rr:predicateObjectMap [ rr:predicate p:AllocationID ; rr:objectMap [ rr:column "AllocationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassID ; rr:objectMap [ rr:column "ClassID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ResourceType ; rr:objectMap [ rr:column "ResourceType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] .

<#tm_attachment_1tab_val_learning_spaces_5_ResourceAllocation_ClassID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AllocationID\", \"ClassID\" FROM \"ResourceAllocation\" WHERE \"ClassID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/ResourceAllocation/{AllocationID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClasses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_learning_spaces_6_Learning_Spaces_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SpaceID\", \"Name\", \"Type\", \"AvailableResources\", \"Capacity\" FROM \"Learning_Spaces\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Learning_Spaces/{SpaceID}" ; rr:class :Learning_Spaces ] ;
  rr:predicateObjectMap [ rr:predicate p:SpaceID ; rr:objectMap [ rr:column "SpaceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AvailableResources ; rr:objectMap [ rr:column "AvailableResources" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] .

