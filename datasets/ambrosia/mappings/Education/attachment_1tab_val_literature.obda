[PrefixDeclaration]
:	http://ambrosia.example.org/education#
p:	http://ambrosia.example.org/education/prop#
ex:	http://ambrosia.example.org/education/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Authors_base
target		ex:Authors/{AuthorId} a :Authors ; p:AuthorId {AuthorId} ; p:name {Name} ; p:BirthDate {BirthDate} ; p:Country {Country} .
source		SELECT `AuthorId`, `Name`, `BirthDate`, `Country` FROM `Authors`

mappingId	Subjects_base
target		ex:Subjects/{SubjectId} a :Subjects ; p:SubjectId {SubjectId} ; p:name {Name} ; p:Description {Description} .
source		SELECT `SubjectId`, `Name`, `Description` FROM `Subjects`

mappingId	Books_base
target		ex:Books/{BookId} a :Books ; p:BookId {BookId} ; p:Title {Title} ; p:Literature {Literature} ; p:Rating {Rating} ; p:AuthorId {AuthorId} ; p:SubjectId {SubjectId} .
source		SELECT `BookId`, `Title`, `Literature`, `Rating`, `AuthorId`, `SubjectId` FROM `Books`

mappingId	Books_SubjectId_fk
target		ex:Books/{BookId} p:hasSubjects ex:Subjects/{SubjectId} .
source		SELECT `BookId`, `SubjectId` FROM `Books` WHERE `SubjectId` IS NOT NULL

mappingId	Books_AuthorId_fk
target		ex:Books/{BookId} p:hasAuthors ex:Authors/{AuthorId} .
source		SELECT `BookId`, `AuthorId` FROM `Books` WHERE `AuthorId` IS NOT NULL

mappingId	Reviews_base
target		ex:Reviews/{ReviewId} a :Reviews ; p:ReviewId {ReviewId} ; p:Rating {Rating} ; p:Comment {Comment} ; p:BookId {BookId} .
source		SELECT `ReviewId`, `Rating`, `Comment`, `BookId` FROM `Reviews`

mappingId	Reviews_BookId_fk
target		ex:Reviews/{ReviewId} p:hasBooks ex:Books/{BookId} .
source		SELECT `ReviewId`, `BookId` FROM `Reviews` WHERE `BookId` IS NOT NULL

]]
