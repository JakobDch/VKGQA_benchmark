@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_literature_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorId\", \"Name\", \"BirthDate\", \"Country\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Authors/{AuthorId}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorId ; rr:objectMap [ rr:column "AuthorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_val_literature_1_Subjects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SubjectId\", \"Name\", \"Description\" FROM \"Subjects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{SubjectId}" ; rr:class :Subjects ] ;
  rr:predicateObjectMap [ rr:predicate p:SubjectId ; rr:objectMap [ rr:column "SubjectId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_attachment_1tab_val_literature_2_Books_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookId\", \"Title\", \"Literature\", \"Rating\", \"AuthorId\", \"SubjectId\" FROM \"Books\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Books/{BookId}" ; rr:class :Books ] ;
  rr:predicateObjectMap [ rr:predicate p:BookId ; rr:objectMap [ rr:column "BookId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Literature ; rr:objectMap [ rr:column "Literature" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorId ; rr:objectMap [ rr:column "AuthorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SubjectId ; rr:objectMap [ rr:column "SubjectId" ] ] .

<#tm_attachment_1tab_val_literature_3_Books_SubjectId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookId\", \"SubjectId\" FROM \"Books\" WHERE \"SubjectId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Books/{BookId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{SubjectId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_literature_4_Books_AuthorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookId\", \"AuthorId\" FROM \"Books\" WHERE \"AuthorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Books/{BookId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Authors/{AuthorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_literature_5_Reviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReviewId\", \"Rating\", \"Comment\", \"BookId\" FROM \"Reviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Reviews/{ReviewId}" ; rr:class :Reviews ] ;
  rr:predicateObjectMap [ rr:predicate p:ReviewId ; rr:objectMap [ rr:column "ReviewId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Comment ; rr:objectMap [ rr:column "Comment" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BookId ; rr:objectMap [ rr:column "BookId" ] ] .

<#tm_attachment_1tab_val_literature_6_Reviews_BookId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReviewId\", \"BookId\" FROM \"Reviews\" WHERE \"BookId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Reviews/{ReviewId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBooks ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Books/{BookId}" ; rr:termType rr:IRI ] ] .

