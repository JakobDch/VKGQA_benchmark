@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_research_methods_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"age\", \"major\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:age ; rr:objectMap [ rr:column "age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:major ; rr:objectMap [ rr:column "major" ] ] .

<#tm_attachment_1tab_val_research_methods_1_Instructors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"department\" FROM \"Instructors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Instructors/{id}" ; rr:class :Instructors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:department ; rr:objectMap [ rr:column "department" ] ] .

<#tm_attachment_1tab_val_research_methods_2_Courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"courseName\", \"instructorId\" FROM \"Courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{id}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:courseName ; rr:objectMap [ rr:column "courseName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:instructorId ; rr:objectMap [ rr:column "instructorId" ] ] .

<#tm_attachment_1tab_val_research_methods_3_Courses_instructorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"instructorId\" FROM \"Courses\" WHERE \"instructorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInstructors ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Instructors/{instructorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_research_methods_4_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"researchMethod\", \"topic\", \"studentId\", \"courseId\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{id}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:researchMethod ; rr:objectMap [ rr:column "researchMethod" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:topic ; rr:objectMap [ rr:column "topic" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:studentId ; rr:objectMap [ rr:column "studentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:courseId ; rr:objectMap [ rr:column "courseId" ] ] .

<#tm_attachment_1tab_val_research_methods_5_Projects_courseId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"courseId\" FROM \"Projects\" WHERE \"courseId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{courseId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_research_methods_6_Projects_studentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"studentId\" FROM \"Projects\" WHERE \"studentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentId}" ; rr:termType rr:IRI ] ] .

