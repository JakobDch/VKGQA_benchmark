<#tm_attachment_1tab_val_written_works_7_CourseTeachings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CourseTeachingID\", \"CourseSubjectID\", \"TeacherID\", \"Semester\", \"Year\", \"StartDate\", \"EndDate\" FROM \"CourseTeachings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/CourseTeachings/{CourseTeachingID}" ; rr:class :CourseTeachings ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseTeachingID ; rr:objectMap [ rr:column "CourseTeachingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseSubjectID ; rr:objectMap [ rr:column "CourseSubjectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TeacherID ; rr:objectMap [ rr:column "TeacherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Semester ; rr:objectMap [ rr:column "Semester" ] ] ;
