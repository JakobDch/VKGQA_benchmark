<#tm_attachment_1tab_val_written_works_5_Students_SchoolID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"SchoolID\" FROM \"Students\" WHERE \"SchoolID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSchools ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Schools/{SchoolID}" ; rr:termType rr:IRI ] ] .

