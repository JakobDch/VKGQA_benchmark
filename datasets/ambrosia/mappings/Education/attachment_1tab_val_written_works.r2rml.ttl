  rr:logicalTable [ rr:sqlQuery """SELECT \"CourseTeachingID\", \"CourseSubjectID\" FROM \"CourseTeachings\" WHERE \"CourseSubjectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/CourseTeachings/{CourseTeachingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{CourseSubjectID}" ; rr:termType rr:IRI ] ] .

