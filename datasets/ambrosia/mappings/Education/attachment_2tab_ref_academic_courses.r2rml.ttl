<#tm_attachment_2tab_ref_academic_courses_4_Projects_DesignClassId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProjectID\", \"DesignClassId\" FROM \"Projects\" WHERE \"DesignClassId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{ProjectID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDesignClasses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/DesignClasses/{DesignClassId}" ; rr:termType rr:IRI ] ] .

