@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_academic_performance_metrics_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"student_id\", \"first_name\", \"last_name\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{student_id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:student_id ; rr:objectMap [ rr:column "student_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] .

<#tm_attachment_2tab_ref_academic_performance_metrics_1_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"class_id\", \"course_name\", \"teacher_name\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{class_id}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:class_id ; rr:objectMap [ rr:column "class_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:course_name ; rr:objectMap [ rr:column "course_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:teacher_name ; rr:objectMap [ rr:column "teacher_name" ] ] .

<#tm_attachment_2tab_ref_academic_performance_metrics_2_Enrollments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"student_id\", \"class_id\" FROM \"Enrollments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{enrollment_id}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:enrollment_id ; rr:objectMap [ rr:column "enrollment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:student_id ; rr:objectMap [ rr:column "student_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:class_id ; rr:objectMap [ rr:column "class_id" ] ] .

<#tm_attachment_2tab_ref_academic_performance_metrics_3_Enrollments_class_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"class_id\" FROM \"Enrollments\" WHERE \"class_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{enrollment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClasses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{class_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_academic_performance_metrics_4_Enrollments_student_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"student_id\" FROM \"Enrollments\" WHERE \"student_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{enrollment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{student_id}" ; rr:termType rr:IRI ] ] .

