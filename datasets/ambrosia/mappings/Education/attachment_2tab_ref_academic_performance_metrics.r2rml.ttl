  rr:logicalTable [ rr:sqlQuery """SELECT \"attendance_id\", \"student_id\" FROM \"Attendance\" WHERE \"student_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Attendance/{attendance_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{student_id}" ; rr:termType rr:IRI ] ] .

