@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_educational_materials_0_Publisher_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Publisher\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Publishers/{id}" ; rr:class :Publishers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_educational_materials_1_Textbooks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"publisherId\", \"author\", \"price\" FROM \"Textbooks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks/{id}" ; rr:class :Textbooks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publisherId ; rr:objectMap [ rr:column "publisherId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author ; rr:objectMap [ rr:column "author" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_attachment_2tab_ref_educational_materials_2_Textbooks_publisherId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"publisherId\" FROM \"Textbooks\" WHERE \"publisherId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublishers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Publishers/{publisherId}" ; rr:termType rr:IRI ] ] .

