  rr:predicateObjectMap [ rr:predicate p:Instructor ; rr:objectMap [ rr:column "Instructor" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Platform ; rr:objectMap [ rr:column "Platform" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:URL ; rr:objectMap [ rr:column "URL" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SubjectID ; rr:objectMap [ rr:column "SubjectID" ] ] .

<#tm_attachment_2tab_ref_learning_materials_6_Online_Courses_SubjectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"SubjectID\" FROM \"Online_Courses\" WHERE \"SubjectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Online_Courses/{ID}" ] ;
