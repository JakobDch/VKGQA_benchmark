@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_learning_materials_0_Difficulty_Level_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Level\" FROM \"Difficulty_Level\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Difficulty_Level/{ID}" ; rr:class :Difficulty_Level ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Level ; rr:objectMap [ rr:column "Level" ] ] .

<#tm_attachment_2tab_ref_learning_materials_1_Subjects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Description\", \"DifficultyID\" FROM \"Subjects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{ID}" ; rr:class :Subjects ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DifficultyID ; rr:objectMap [ rr:column "DifficultyID" ] ] .

<#tm_attachment_2tab_ref_learning_materials_2_Subjects_DifficultyID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"DifficultyID\" FROM \"Subjects\" WHERE \"DifficultyID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDifficulty_Level ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Difficulty_Level/{DifficultyID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_learning_materials_3_Textbooks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Author\", \"ISBN\", \"SubjectID\" FROM \"Textbooks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks/{ID}" ; rr:class :Textbooks ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Author ; rr:objectMap [ rr:column "Author" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ISBN ; rr:objectMap [ rr:column "ISBN" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SubjectID ; rr:objectMap [ rr:column "SubjectID" ] ] .

<#tm_attachment_2tab_ref_learning_materials_4_Textbooks_SubjectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"SubjectID\" FROM \"Textbooks\" WHERE \"SubjectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{SubjectID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_learning_materials_5_Online_Courses_base> a rr:TriplesMap ;
