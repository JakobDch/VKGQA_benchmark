  rr:predicateObjectMap [ rr:predicate p:Model ; rr:objectMap [ rr:column "Model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Processor ; rr:objectMap [ rr:column "Processor" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RAM_Size ; rr:objectMap [ rr:column "RAM_Size" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Hard_Disk_Space ; rr:objectMap [ rr:column "Hard_Disk_Space" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Graphics_Card ; rr:objectMap [ rr:column "Graphics_Card" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Weight ; rr:objectMap [ rr:column "Weight" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OS_ID ; rr:objectMap [ rr:column "OS_ID" ] ] .

<#tm_attachment_2tab_ref_personal_computing_devices_4_Laptops_OS_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Laptop_ID\", \"OS_ID\" FROM \"Laptops\" WHERE \"OS_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Laptops/{Laptop_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOperating_System ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Operating_System/{OS_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_personal_computing_devices_5_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Student_ID\", \"First_Name\", \"Last_Name\", \"Age\", \"Grade_Level\", \"Tablet_ID\", \"Laptop_ID\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{Student_ID}" ; rr:class :Students ] ;
