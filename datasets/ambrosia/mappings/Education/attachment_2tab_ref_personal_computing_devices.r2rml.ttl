  rr:logicalTable [ rr:sqlQuery """SELECT \"Student_ID\", \"Laptop_ID\" FROM \"Students\" WHERE \"Laptop_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{Student_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLaptops ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Laptops/{Laptop_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_personal_computing_devices_7_Students_Tablet_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Student_ID\", \"Tablet_ID\" FROM \"Students\" WHERE \"Tablet_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{Student_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTablets ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Tablets/{Tablet_ID}" ; rr:termType rr:IRI ] ] .

