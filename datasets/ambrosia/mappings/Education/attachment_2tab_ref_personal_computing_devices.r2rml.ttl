@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_personal_computing_devices_0_Operating_System_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OS_ID\", \"Name\" FROM \"Operating_System\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Operating_System/{OS_ID}" ; rr:class :Operating_System ] ;
  rr:predicateObjectMap [ rr:predicate p:OS_ID ; rr:objectMap [ rr:column "OS_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_ref_personal_computing_devices_1_Tablets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Tablet_ID\", \"Model\", \"Screen_Size\", \"RAM_Size\", \"Storage_Capacity\", \"Purchase_Price\", \"OS_ID\" FROM \"Tablets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Tablets/{Tablet_ID}" ; rr:class :Tablets ] ;
  rr:predicateObjectMap [ rr:predicate p:Tablet_ID ; rr:objectMap [ rr:column "Tablet_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Model ; rr:objectMap [ rr:column "Model" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Screen_Size ; rr:objectMap [ rr:column "Screen_Size" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RAM_Size ; rr:objectMap [ rr:column "RAM_Size" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Storage_Capacity ; rr:objectMap [ rr:column "Storage_Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Purchase_Price ; rr:objectMap [ rr:column "Purchase_Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OS_ID ; rr:objectMap [ rr:column "OS_ID" ] ] .

<#tm_attachment_2tab_ref_personal_computing_devices_2_Tablets_OS_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Tablet_ID\", \"OS_ID\" FROM \"Tablets\" WHERE \"OS_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Tablets/{Tablet_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOperating_System ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Operating_System/{OS_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_personal_computing_devices_3_Laptops_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Laptop_ID\", \"Model\", \"Processor\", \"RAM_Size\", \"Hard_Disk_Space\", \"Graphics_Card\", \"Weight\", \"Price\", \"OS_ID\" FROM \"Laptops\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Laptops/{Laptop_ID}" ; rr:class :Laptops ] ;
