  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PathToIllust ; rr:objectMap [ rr:column "PathToIllust" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SubjectID ; rr:objectMap [ rr:column "SubjectID" ] ] .

<#tm_attachment_2tab_ref_visual_arts_6_Illustrations_SubjectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"IllustID\", \"SubjectID\" FROM \"Illustrations\" WHERE \"SubjectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Illustrations/{IllustID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{SubjectID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_visual_arts_7_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"TeacherID\", \"StudentID\", \"StartTime\", \"EndTime\", \"Classroom\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassID ; rr:objectMap [ rr:column "ClassID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TeacherID ; rr:objectMap [ rr:column "TeacherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartTime ; rr:objectMap [ rr:column "StartTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndTime ; rr:objectMap [ rr:column "EndTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Classroom ; rr:objectMap [ rr:column "Classroom" ] ] .

<#tm_attachment_2tab_ref_visual_arts_8_Classes_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"StudentID\" FROM \"Classes\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_visual_arts_9_Classes_TeacherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"TeacherID\" FROM \"Classes\" WHERE \"TeacherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTeachers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{TeacherID}" ; rr:termType rr:IRI ] ] .

