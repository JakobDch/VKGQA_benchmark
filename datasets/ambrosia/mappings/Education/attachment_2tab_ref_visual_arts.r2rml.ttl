@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_visual_arts_0_Subjects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\" FROM \"Subjects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{ID}" ; rr:class :Subjects ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_ref_visual_arts_1_Teachers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Age\", \"HiredDate\" FROM \"Teachers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{ID}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HiredDate ; rr:objectMap [ rr:column "HiredDate" ] ] .

<#tm_attachment_2tab_ref_visual_arts_2_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Age\", \"EnrollmentDate\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{ID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentDate ; rr:objectMap [ rr:column "EnrollmentDate" ] ] .

<#tm_attachment_2tab_ref_visual_arts_3_Photos_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PhotoID\", \"Description\", \"PathToPhoto\", \"SubjectID\" FROM \"Photos\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Photos/{PhotoID}" ; rr:class :Photos ] ;
  rr:predicateObjectMap [ rr:predicate p:PhotoID ; rr:objectMap [ rr:column "PhotoID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PathToPhoto ; rr:objectMap [ rr:column "PathToPhoto" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SubjectID ; rr:objectMap [ rr:column "SubjectID" ] ] .

<#tm_attachment_2tab_ref_visual_arts_4_Photos_SubjectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PhotoID\", \"SubjectID\" FROM \"Photos\" WHERE \"SubjectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Photos/{PhotoID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{SubjectID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_visual_arts_5_Illustrations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"IllustID\", \"Description\", \"PathToIllust\", \"SubjectID\" FROM \"Illustrations\"""" ] ;
