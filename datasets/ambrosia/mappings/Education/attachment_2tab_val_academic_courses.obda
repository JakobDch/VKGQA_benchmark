[PrefixDeclaration]
:	http://ambrosia.example.org/education#
p:	http://ambrosia.example.org/education/prop#
ex:	http://ambrosia.example.org/education/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Engineering_Class_base
target		ex:Engineering_Class/{id} a :Engineering_Class ; p:id {id} ; p:name {Name} ; p:Age {Age} ; p:Grade {Grade} ; p:Projects {Projects} .
source		SELECT `id`, `Name`, `Age`, `Grade`, `Projects` FROM `Engineering_Class`

mappingId	Design_Class_base
target		ex:Design_Class/{id} a :Design_Class ; p:id {id} ; p:name {Name} ; p:Age {Age} ; p:Skills {Skills} ; p:Projects {Projects} .
source		SELECT `id`, `Name`, `Age`, `Skills`, `Projects` FROM `Design_Class`

mappingId	Subjects_base
target		ex:Subjects/{id} a :Subjects ; p:id {id} ; p:name {Name} ; p:Teacher {Teacher} ; p:Classroom {Classroom} .
source		SELECT `id`, `Name`, `Teacher`, `Classroom` FROM `Subjects`

mappingId	Students_base
target		ex:Students/{id} a :Students ; p:id {id} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:DateOfBirth {DateOfBirth} ; p:email {Email} .
source		SELECT `id`, `FirstName`, `LastName`, `DateOfBirth`, `Email` FROM `Students`

mappingId	Parents_base
target		ex:Parents/{id} a :Parents ; p:id {id} ; p:name {FullName} ; p:PhoneNumber {PhoneNumber} ; p:Address {Address} .
source		SELECT `id`, `FullName`, `PhoneNumber`, `Address` FROM `Parents`

mappingId	School_base
target		ex:Schools/{id} a :Schools ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:NumberOfStudents {NumberOfStudents} ; p:Principal {Principal} .
source		SELECT `id`, `Name`, `Location`, `NumberOfStudents`, `Principal` FROM `School`

]]
