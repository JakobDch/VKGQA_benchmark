  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"paper_id\", \"journal_id\", \"volume\", \"issue\", \"page_start\", \"page_end\" FROM \"Publications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Publications/{id}" ; rr:class :Publications ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:paper_id ; rr:objectMap [ rr:column "paper_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:journal_id ; rr:objectMap [ rr:column "journal_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:volume ; rr:objectMap [ rr:column "volume" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:issue ; rr:objectMap [ rr:column "issue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:page_start ; rr:objectMap [ rr:column "page_start" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:page_end ; rr:objectMap [ rr:column "page_end" ] ] .

<#tm_attachment_2tab_val_academic_papers_8_Publications_journal_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"journal_id\" FROM \"Publications\" WHERE \"journal_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Publications/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJournals ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Journals/{journal_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_academic_papers_9_Publications_paper_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"paper_id\" FROM \"Publications\" WHERE \"paper_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Publications/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasResearch_Papers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Research_Papers/{paper_id}" ; rr:termType rr:IRI ] ] .

