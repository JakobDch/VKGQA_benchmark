@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_academic_papers_0_Research_Papers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"abstract\", \"publication_date\", \"citation_style\" FROM \"Research_Papers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Research_Papers/{id}" ; rr:class :Research_Papers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:abstract ; rr:objectMap [ rr:column "abstract" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_date ; rr:objectMap [ rr:column "publication_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:citation_style ; rr:objectMap [ rr:column "citation_style" ] ] .

<#tm_attachment_2tab_val_academic_papers_1_Review_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"reviewer\", \"publication_date\", \"citation_style\" FROM \"Review_Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Review_Articles/{id}" ; rr:class :Review_Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:reviewer ; rr:objectMap [ rr:column "reviewer" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_date ; rr:objectMap [ rr:column "publication_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:citation_style ; rr:objectMap [ rr:column "citation_style" ] ] .

<#tm_attachment_2tab_val_academic_papers_2_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Authors/{id}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_attachment_2tab_val_academic_papers_3_Papers_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"paper_id\", \"author_id\" FROM \"Papers_Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Papers_Authors/{paper_id}/{author_id}" ; rr:class :Papers_Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:paper_id ; rr:objectMap [ rr:column "paper_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] .

<#tm_attachment_2tab_val_academic_papers_4_Papers_Authors_author_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"paper_id\", \"author_id\" FROM \"Papers_Authors\" WHERE \"author_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Papers_Authors/{paper_id}/{author_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Authors/{author_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_academic_papers_5_Papers_Authors_paper_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"paper_id\", \"author_id\" FROM \"Papers_Authors\" WHERE \"paper_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Papers_Authors/{paper_id}/{author_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasResearch_Papers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Research_Papers/{paper_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_academic_papers_6_Journals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"journal_name\", \"ISSN\" FROM \"Journals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Journals/{id}" ; rr:class :Journals ] ;
