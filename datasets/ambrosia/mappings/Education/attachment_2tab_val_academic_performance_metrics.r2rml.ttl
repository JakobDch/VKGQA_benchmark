@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_academic_performance_metrics_0_Student_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\" FROM \"Student\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{ID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_val_academic_performance_metrics_1_Attendance_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AttendID\", \"StudentID\", \"Date\", \"Status\" FROM \"Attendance\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Attendance/{AttendID}" ; rr:class :Attendance ] ;
  rr:predicateObjectMap [ rr:predicate p:AttendID ; rr:objectMap [ rr:column "AttendID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Status ; rr:objectMap [ rr:column "Status" ] ] .

<#tm_attachment_2tab_val_academic_performance_metrics_2_Attendance_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AttendID\", \"StudentID\" FROM \"Attendance\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Attendance/{AttendID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_academic_performance_metrics_3_Teacher_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TeachID\", \"Name\" FROM \"Teacher\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{TeachID}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:TeachID ; rr:objectMap [ rr:column "TeachID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_val_academic_performance_metrics_4_Classroom_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"TeachID\", \"Location\" FROM \"Classroom\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classrooms/{ClassID}" ; rr:class :Classrooms ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassID ; rr:objectMap [ rr:column "ClassID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TeachID ; rr:objectMap [ rr:column "TeachID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_attachment_2tab_val_academic_performance_metrics_5_Classroom_TeachID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"TeachID\" FROM \"Classroom\" WHERE \"TeachID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classrooms/{ClassID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTeachers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{TeachID}" ; rr:termType rr:IRI ] ] .

