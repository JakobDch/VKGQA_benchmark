  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"SupervisorID\", \"DissertationID\", \"ThesisProposalID\" FROM \"Student_Supervision\" WHERE \"ThesisProposalID\" IS NOT NULL""" ] ;
