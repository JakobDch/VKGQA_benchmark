  rr:predicateObjectMap [ rr:predicate p:hasThesis_Proposals ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Thesis_Proposals/{ThesisProposalID}" ; rr:termType rr:IRI ] ] .

