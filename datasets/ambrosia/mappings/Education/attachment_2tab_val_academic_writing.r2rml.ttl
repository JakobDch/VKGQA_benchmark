@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_academic_writing_0_Dissertations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Abstract\", \"Date\", \"Academic_Supervisor\" FROM \"Dissertations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Dissertations/{ID}" ; rr:class :Dissertations ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Abstract ; rr:objectMap [ rr:column "Abstract" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Academic_Supervisor ; rr:objectMap [ rr:column "Academic_Supervisor" ] ] .

