@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_assessment_methods_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"FirstName\", \"LastName\", \"BirthDate\", \"Major\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Major ; rr:objectMap [ rr:column "Major" ] ] .

<#tm_attachment_2tab_val_assessment_methods_1_Assessors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AssessorID\", \"Name\", \"Title\", \"Department\" FROM \"Assessors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Assessors/{AssessorID}" ; rr:class :Assessors ] ;
  rr:predicateObjectMap [ rr:predicate p:AssessorID ; rr:objectMap [ rr:column "AssessorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Department ; rr:objectMap [ rr:column "Department" ] ] .

<#tm_attachment_2tab_val_assessment_methods_2_Exams_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ExamID\", \"CourseTitle\", \"TotalMarks\", \"PassingMark\", \"AssessorId\" FROM \"Exams\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Exams/{ExamID}" ; rr:class :Exams ] ;
  rr:predicateObjectMap [ rr:predicate p:ExamID ; rr:objectMap [ rr:column "ExamID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseTitle ; rr:objectMap [ rr:column "CourseTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalMarks ; rr:objectMap [ rr:column "TotalMarks" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PassingMark ; rr:objectMap [ rr:column "PassingMark" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AssessorId ; rr:objectMap [ rr:column "AssessorId" ] ] .

<#tm_attachment_2tab_val_assessment_methods_3_Exams_AssessorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ExamID\", \"AssessorId\" FROM \"Exams\" WHERE \"AssessorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Exams/{ExamID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAssessors ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Assessors/{AssessorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_assessment_methods_4_Quizzes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"QuizID\", \"Description\", \"MaxScore\", \"MinPassingScore\", \"AssessorId\" FROM \"Quizzes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Quizzes/{QuizID}" ; rr:class :Quizzes ] ;
  rr:predicateObjectMap [ rr:predicate p:QuizID ; rr:objectMap [ rr:column "QuizID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MaxScore ; rr:objectMap [ rr:column "MaxScore" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MinPassingScore ; rr:objectMap [ rr:column "MinPassingScore" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AssessorId ; rr:objectMap [ rr:column "AssessorId" ] ] .

<#tm_attachment_2tab_val_assessment_methods_5_Quizzes_AssessorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"QuizID\", \"AssessorId\" FROM \"Quizzes\" WHERE \"AssessorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Quizzes/{QuizID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAssessors ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Assessors/{AssessorId}" ; rr:termType rr:IRI ] ] .

