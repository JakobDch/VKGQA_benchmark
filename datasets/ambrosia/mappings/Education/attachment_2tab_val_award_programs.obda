[PrefixDeclaration]
:	http://ambrosia.example.org/education#
p:	http://ambrosia.example.org/education/prop#
ex:	http://ambrosia.example.org/education/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Students_base
target		ex:Students/{StudentID} a :Students ; p:StudentID {StudentID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:DateOfBirth {DateOfBirth} .
source		SELECT `StudentID`, `FirstName`, `LastName`, `DateOfBirth` FROM `Students`

mappingId	Diplomas_base
target		ex:Diplomas/{DiplomaID} a :Diplomas ; p:DiplomaID {DiplomaID} ; p:Title {Title} ; p:CompletionRequirements {CompletionRequirements} ; p:UnitsRequired {UnitsRequired} .
source		SELECT `DiplomaID`, `Title`, `CompletionRequirements`, `UnitsRequired` FROM `Diplomas`

mappingId	Certificates_base
target		ex:Certificates/{CertificateID} a :Certificates ; p:CertificateID {CertificateID} ; p:Title {Title} ; p:CompletionRequirements {CompletionRequirements} ; p:Duration {Duration} .
source		SELECT `CertificateID`, `Title`, `CompletionRequirements`, `Duration` FROM `Certificates`

mappingId	Subjects_base
target		ex:Subjects/{SubjectID} a :Subjects ; p:SubjectID {SubjectID} ; p:name {Name} ; p:Teacher {Teacher} ; p:MaxScore {MaxScore} .
source		SELECT `SubjectID`, `Name`, `Teacher`, `MaxScore` FROM `Subjects`

mappingId	Enrolment_base
target		ex:Enrollments/{EnrollmentID} a :Enrollments ; p:EnrollmentID {EnrollmentID} ; p:StudentID {StudentID} ; p:SubjectID {SubjectID} ; p:StartDate {StartDate} ; p:EndDate {EndDate} .
source		SELECT `EnrollmentID`, `StudentID`, `SubjectID`, `StartDate`, `EndDate` FROM `Enrolment`

mappingId	Enrolment_SubjectID_fk
target		ex:Enrollments/{EnrollmentID} p:hasSubjects ex:Subjects/{SubjectID} .
source		SELECT `EnrollmentID`, `SubjectID` FROM `Enrolment` WHERE `SubjectID` IS NOT NULL

mappingId	Enrolment_StudentID_fk
target		ex:Enrollments/{EnrollmentID} p:hasStudents ex:Students/{StudentID} .
source		SELECT `EnrollmentID`, `StudentID` FROM `Enrolment` WHERE `StudentID` IS NOT NULL

mappingId	Grades_base
target		ex:Grades/{GradeID} a :Grades ; p:GradeID {GradeID} ; p:EnrollmenID {EnrollmenID} ; p:Score {Score} ; p:DateAwarded {DateAwarded} .
source		SELECT `GradeID`, `EnrollmenID`, `Score`, `DateAwarded` FROM `Grades`

mappingId	Grades_EnrollmenID_fk
target		ex:Grades/{GradeID} p:hasEnrollments ex:Enrollments/{EnrollmenID} .
source		SELECT `GradeID`, `EnrollmenID` FROM `Grades` WHERE `EnrollmenID` IS NOT NULL

]]
