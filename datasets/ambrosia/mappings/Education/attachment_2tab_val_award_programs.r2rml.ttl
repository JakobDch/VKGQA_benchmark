@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_award_programs_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"FirstName\", \"LastName\", \"DateOfBirth\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] .

<#tm_attachment_2tab_val_award_programs_1_Diplomas_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DiplomaID\", \"Title\", \"CompletionRequirements\", \"UnitsRequired\" FROM \"Diplomas\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Diplomas/{DiplomaID}" ; rr:class :Diplomas ] ;
  rr:predicateObjectMap [ rr:predicate p:DiplomaID ; rr:objectMap [ rr:column "DiplomaID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompletionRequirements ; rr:objectMap [ rr:column "CompletionRequirements" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:UnitsRequired ; rr:objectMap [ rr:column "UnitsRequired" ] ] .

<#tm_attachment_2tab_val_award_programs_2_Certificates_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CertificateID\", \"Title\", \"CompletionRequirements\", \"Duration\" FROM \"Certificates\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Certificates/{CertificateID}" ; rr:class :Certificates ] ;
  rr:predicateObjectMap [ rr:predicate p:CertificateID ; rr:objectMap [ rr:column "CertificateID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompletionRequirements ; rr:objectMap [ rr:column "CompletionRequirements" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Duration ; rr:objectMap [ rr:column "Duration" ] ] .

<#tm_attachment_2tab_val_award_programs_3_Subjects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SubjectID\", \"Name\", \"Teacher\", \"MaxScore\" FROM \"Subjects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{SubjectID}" ; rr:class :Subjects ] ;
  rr:predicateObjectMap [ rr:predicate p:SubjectID ; rr:objectMap [ rr:column "SubjectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Teacher ; rr:objectMap [ rr:column "Teacher" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MaxScore ; rr:objectMap [ rr:column "MaxScore" ] ] .

<#tm_attachment_2tab_val_award_programs_4_Enrolment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\", \"SubjectID\", \"StartDate\", \"EndDate\" FROM \"Enrolment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentID ; rr:objectMap [ rr:column "EnrollmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SubjectID ; rr:objectMap [ rr:column "SubjectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] .

<#tm_attachment_2tab_val_award_programs_5_Enrolment_SubjectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"SubjectID\" FROM \"Enrolment\" WHERE \"SubjectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{SubjectID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_award_programs_6_Enrolment_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\" FROM \"Enrolment\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_award_programs_7_Grades_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GradeID\", \"EnrollmenID\", \"Score\", \"DateAwarded\" FROM \"Grades\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Grades/{GradeID}" ; rr:class :Grades ] ;
  rr:predicateObjectMap [ rr:predicate p:GradeID ; rr:objectMap [ rr:column "GradeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmenID ; rr:objectMap [ rr:column "EnrollmenID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Score ; rr:objectMap [ rr:column "Score" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateAwarded ; rr:objectMap [ rr:column "DateAwarded" ] ] .

<#tm_attachment_2tab_val_award_programs_8_Grades_EnrollmenID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GradeID\", \"EnrollmenID\" FROM \"Grades\" WHERE \"EnrollmenID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Grades/{GradeID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEnrollments ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{EnrollmenID}" ; rr:termType rr:IRI ] ] .

