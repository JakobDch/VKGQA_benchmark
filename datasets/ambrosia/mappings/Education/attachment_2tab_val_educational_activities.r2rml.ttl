@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_educational_activities_0_StudyHalls_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"building\", \"capacity\", \"available_hours\", \"number_of_students\" FROM \"StudyHalls\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/StudyHalls/{id}" ; rr:class :StudyHalls ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:building ; rr:objectMap [ rr:column "building" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:available_hours ; rr:objectMap [ rr:column "available_hours" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number_of_students ; rr:objectMap [ rr:column "number_of_students" ] ] .

<#tm_attachment_2tab_val_educational_activities_1_Teachers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"subject\", \"years_experience\", \"office_number\" FROM \"Teachers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{id}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subject ; rr:objectMap [ rr:column "subject" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_experience ; rr:objectMap [ rr:column "years_experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:office_number ; rr:objectMap [ rr:column "office_number" ] ] .

<#tm_attachment_2tab_val_educational_activities_2_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"teacher_id\", \"class_name\", \"grade_level\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{id}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:teacher_id ; rr:objectMap [ rr:column "teacher_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:class_name ; rr:objectMap [ rr:column "class_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:grade_level ; rr:objectMap [ rr:column "grade_level" ] ] .

<#tm_attachment_2tab_val_educational_activities_3_Classes_teacher_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"teacher_id\" FROM \"Classes\" WHERE \"teacher_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTeachers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{teacher_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_educational_activities_4_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"studentId\", \"birthDate\", \"fieldtrip_participant\", \"studyhall_user\", \"class_id\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:studentId ; rr:objectMap [ rr:column "studentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthDate ; rr:objectMap [ rr:column "birthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fieldtrip_participant ; rr:objectMap [ rr:column "fieldtrip_participant" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:studyhall_user ; rr:objectMap [ rr:column "studyhall_user" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:class_id ; rr:objectMap [ rr:column "class_id" ] ] .

<#tm_attachment_2tab_val_educational_activities_5_Students_class_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"class_id\" FROM \"Students\" WHERE \"class_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClasses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{class_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_educational_activities_6_FieldTrips_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"trip\", \"destination\", \"date\", \"budget\", \"Number_of_students\" FROM \"FieldTrips\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Field_Trips/{id}" ; rr:class :Field_Trips ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:trip ; rr:objectMap [ rr:column "trip" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destination ; rr:objectMap [ rr:column "destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:budget ; rr:objectMap [ rr:column "budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_students ; rr:objectMap [ rr:column "Number_of_students" ] ] .

