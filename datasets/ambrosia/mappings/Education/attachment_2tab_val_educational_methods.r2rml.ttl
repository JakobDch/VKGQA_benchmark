@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_educational_methods_0_courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"courseID\", \"courseName\", \"department\", \"semester\", \"year\" FROM \"courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{courseID}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:courseID ; rr:objectMap [ rr:column "courseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:courseName ; rr:objectMap [ rr:column "courseName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:department ; rr:objectMap [ rr:column "department" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:semester ; rr:objectMap [ rr:column "semester" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:year ; rr:objectMap [ rr:column "year" ] ] .

<#tm_attachment_2tab_val_educational_methods_1_students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studentID\", \"firstName\", \"lastName\", \"email\", \"major\", \"enrollmentYear\" FROM \"students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:studentID ; rr:objectMap [ rr:column "studentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:major ; rr:objectMap [ rr:column "major" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:enrollmentYear ; rr:objectMap [ rr:column "enrollmentYear" ] ] .

<#tm_attachment_2tab_val_educational_methods_2_instructors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"instructorID\", \"firstName\", \"lastName\", \"email\", \"department\" FROM \"instructors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Instructors/{instructorID}" ; rr:class :Instructors ] ;
  rr:predicateObjectMap [ rr:predicate p:instructorID ; rr:objectMap [ rr:column "instructorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:department ; rr:objectMap [ rr:column "department" ] ] .

<#tm_attachment_2tab_val_educational_methods_3_peer_tutoring_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"sessionID\", \"courseID\", \"startDateTime\", \"endDateTime\", \"participants\" FROM \"peer_tutoring\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/peer_tutoring/{sessionID}" ; rr:class :peer_tutoring ] ;
  rr:predicateObjectMap [ rr:predicate p:sessionID ; rr:objectMap [ rr:column "sessionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:courseID ; rr:objectMap [ rr:column "courseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDateTime ; rr:objectMap [ rr:column "startDateTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDateTime ; rr:objectMap [ rr:column "endDateTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:participants ; rr:objectMap [ rr:column "participants" ] ] .

<#tm_attachment_2tab_val_educational_methods_4_peer_tutoring_courseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"sessionID\", \"courseID\" FROM \"peer_tutoring\" WHERE \"courseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/peer_tutoring/{sessionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{courseID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_educational_methods_5_group_work_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignmentID\", \"courseID\", \"dueDate\", \"maxScore\", \"participants\" FROM \"group_work\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/group_work/{assignmentID}" ; rr:class :group_work ] ;
  rr:predicateObjectMap [ rr:predicate p:assignmentID ; rr:objectMap [ rr:column "assignmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:courseID ; rr:objectMap [ rr:column "courseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dueDate ; rr:objectMap [ rr:column "dueDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:maxScore ; rr:objectMap [ rr:column "maxScore" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:participants ; rr:objectMap [ rr:column "participants" ] ] .

<#tm_attachment_2tab_val_educational_methods_6_group_work_courseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignmentID\", \"courseID\" FROM \"group_work\" WHERE \"courseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/group_work/{assignmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{courseID}" ; rr:termType rr:IRI ] ] .

