  rr:logicalTable [ rr:sqlQuery """SELECT \"ProgramID\", \"Name\", \"Description\", \"Participants\" FROM \"LeadershipPrograms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/LeadershipPrograms/{ProgramID}" ; rr:class :LeadershipPrograms ] ;
  rr:predicateObjectMap [ rr:predicate p:ProgramID ; rr:objectMap [ rr:column "ProgramID" ] ] ;
