<#tm_attachment_2tab_val_extracurricular_activities_3_Teachers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TeacherID\", \"FirstName\", \"LastName\", \"SubjectTaught\" FROM \"Teachers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{TeacherID}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:TeacherID ; rr:objectMap [ rr:column "TeacherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SubjectTaught ; rr:objectMap [ rr:column "SubjectTaught" ] ] .

<#tm_attachment_2tab_val_extracurricular_activities_4_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"ClassroomNumber\", \"StartTime\", \"EndTime\", \"TeacherId\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassID ; rr:objectMap [ rr:column "ClassID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClassroomNumber ; rr:objectMap [ rr:column "ClassroomNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartTime ; rr:objectMap [ rr:column "StartTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndTime ; rr:objectMap [ rr:column "EndTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TeacherId ; rr:objectMap [ rr:column "TeacherId" ] ] .

<#tm_attachment_2tab_val_extracurricular_activities_5_Classes_TeacherId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ClassID\", \"TeacherId\" FROM \"Classes\" WHERE \"TeacherId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{ClassID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTeachers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{TeacherId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_extracurricular_activities_6_Enrollments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\", \"ClassId\", \"Grade\" FROM \"Enrollments\"""" ] ;
