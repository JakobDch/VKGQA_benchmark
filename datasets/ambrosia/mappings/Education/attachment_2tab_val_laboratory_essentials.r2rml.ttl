@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_laboratory_essentials_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studentID\", \"firstName\", \"lastName\", \"email\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:studentID ; rr:objectMap [ rr:column "studentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_attachment_2tab_val_laboratory_essentials_1_Instructors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"instructorID\", \"firstName\", \"lastName\", \"email\" FROM \"Instructors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Instructors/{instructorID}" ; rr:class :Instructors ] ;
  rr:predicateObjectMap [ rr:predicate p:instructorID ; rr:objectMap [ rr:column "instructorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_attachment_2tab_val_laboratory_essentials_2_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classID\", \"className\", \"instructorID\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classID}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:classID ; rr:objectMap [ rr:column "classID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:className ; rr:objectMap [ rr:column "className" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:instructorID ; rr:objectMap [ rr:column "instructorID" ] ] .

<#tm_attachment_2tab_val_laboratory_essentials_3_Classes_instructorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classID\", \"instructorID\" FROM \"Classes\" WHERE \"instructorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInstructors ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Instructors/{instructorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_laboratory_essentials_4_StudentsEnrolledInClasses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollmentID\", \"studentID\", \"classID\" FROM \"StudentsEnrolledInClasses\"""" ] ;
