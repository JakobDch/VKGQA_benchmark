  rr:predicateObjectMap [ rr:predicate p:hasClasses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Classes/{classID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_laboratory_essentials_6_StudentsEnrolledInClasses_studentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollmentID\", \"studentID\" FROM \"StudentsEnrolledInClasses\" WHERE \"studentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/StudentsEnrolledInClasses/{enrollmentID}" ] ;
