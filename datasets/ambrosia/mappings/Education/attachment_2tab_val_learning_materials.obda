[PrefixDeclaration]
:	http://ambrosia.example.org/education#
p:	http://ambrosia.example.org/education/prop#
ex:	http://ambrosia.example.org/education/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Textbooks_base
target		ex:Textbooks/{id} a :Textbooks ; p:id {id} ; p:Title {Title} ; p:Author {Author} ; p:Subject {Subject} ; p:Difficulty_Level {Difficulty_Level} ; p:ISBN {ISBN} .
source		SELECT `id`, `Title`, `Author`, `Subject`, `Difficulty_Level`, `ISBN` FROM `Textbooks`

mappingId	Online_Courses_base
target		ex:Online_Courses/{id} a :Online_Courses ; p:id {id} ; p:Course_Name {Course_Name} ; p:Instructor {Instructor} ; p:Topic {Topic} ; p:Difficulty_Level {Difficulty_Level} ; p:URL {URL} .
source		SELECT `id`, `Course_Name`, `Instructor`, `Topic`, `Difficulty_Level`, `URL` FROM `Online_Courses`

mappingId	Schools_base
target		ex:Schools/{id} a :Schools ; p:id {id} ; p:name {Name} ; p:Address {Address} ; p:City {City} ; p:State {State} .
source		SELECT `id`, `Name`, `Address`, `City`, `State` FROM `Schools`

mappingId	Teachers_base
target		ex:Teachers/{id} a :Teachers ; p:id {id} ; p:name {Name} ; p:School_ID {School_ID} ; p:Degree {Degree} ; p:Years_Experience {Years_Experience} .
source		SELECT `id`, `Name`, `School_ID`, `Degree`, `Years_Experience` FROM `Teachers`

mappingId	Teachers_School_ID_fk
target		ex:Teachers/{id} p:hasSchools ex:Schools/{School_ID} .
source		SELECT `id`, `School_ID` FROM `Teachers` WHERE `School_ID` IS NOT NULL

mappingId	Students_base
target		ex:Students/{id} a :Students ; p:id {id} ; p:First_Name {First_Name} ; p:Last_Name {Last_Name} ; p:Age {Age} ; p:Grade_Level {Grade_Level} .
source		SELECT `id`, `First_Name`, `Last_Name`, `Age`, `Grade_Level` FROM `Students`

]]
