@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_learning_materials_0_Textbooks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Author\", \"Subject\", \"Difficulty_Level\", \"ISBN\" FROM \"Textbooks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks/{id}" ; rr:class :Textbooks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Author ; rr:objectMap [ rr:column "Author" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Subject ; rr:objectMap [ rr:column "Subject" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Difficulty_Level ; rr:objectMap [ rr:column "Difficulty_Level" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ISBN ; rr:objectMap [ rr:column "ISBN" ] ] .

<#tm_attachment_2tab_val_learning_materials_1_Online_Courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Course_Name\", \"Instructor\", \"Topic\", \"Difficulty_Level\", \"URL\" FROM \"Online_Courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Online_Courses/{id}" ; rr:class :Online_Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Course_Name ; rr:objectMap [ rr:column "Course_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Instructor ; rr:objectMap [ rr:column "Instructor" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Topic ; rr:objectMap [ rr:column "Topic" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Difficulty_Level ; rr:objectMap [ rr:column "Difficulty_Level" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:URL ; rr:objectMap [ rr:column "URL" ] ] .

<#tm_attachment_2tab_val_learning_materials_2_Schools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Address\", \"City\", \"State\" FROM \"Schools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Schools/{id}" ; rr:class :Schools ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:State ; rr:objectMap [ rr:column "State" ] ] .

<#tm_attachment_2tab_val_learning_materials_3_Teachers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"School_ID\", \"Degree\", \"Years_Experience\" FROM \"Teachers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{id}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:School_ID ; rr:objectMap [ rr:column "School_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Degree ; rr:objectMap [ rr:column "Degree" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Years_Experience ; rr:objectMap [ rr:column "Years_Experience" ] ] .

<#tm_attachment_2tab_val_learning_materials_4_Teachers_School_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"School_ID\" FROM \"Teachers\" WHERE \"School_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSchools ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Schools/{School_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_learning_materials_5_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"First_Name\", \"Last_Name\", \"Age\", \"Grade_Level\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:First_Name ; rr:objectMap [ rr:column "First_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Last_Name ; rr:objectMap [ rr:column "Last_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Grade_Level ; rr:objectMap [ rr:column "Grade_Level" ] ] .

