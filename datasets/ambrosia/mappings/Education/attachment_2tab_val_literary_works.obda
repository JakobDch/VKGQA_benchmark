[PrefixDeclaration]
:	http://ambrosia.example.org/education#
p:	http://ambrosia.example.org/education/prop#
ex:	http://ambrosia.example.org/education/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Novels_base
target		ex:Novels/{id} a :Novels ; p:id {id} ; p:Title {Title} ; p:Author {Author} ; p:Year {Year} ; p:Genre {Genre} ; p:Character {Character} .
source		SELECT `id`, `Title`, `Author`, `Year`, `Genre`, `Character` FROM `Novels`

mappingId	ShortStories_base
target		ex:ShortStories/{id} a :ShortStories ; p:id {id} ; p:Title {Title} ; p:Author {Author} ; p:Year {Year} ; p:Theme {Theme} ; p:Character {Character} .
source		SELECT `id`, `Title`, `Author`, `Year`, `Theme`, `Character` FROM `ShortStories`

mappingId	Authors_base
target		ex:Authors/{id} a :Authors ; p:id {id} ; p:name {Name} ; p:BirthDate {BirthDate} ; p:Nationality {Nationality} ; p:Biography {Biography} .
source		SELECT `id`, `Name`, `BirthDate`, `Nationality`, `Biography` FROM `Authors`

mappingId	Publishers_base
target		ex:Publishers/{id} a :Publishers ; p:id {id} ; p:name {Name} ; p:EstablishedYear {EstablishedYear} ; p:location {Location} ; p:NumberOfEmployees {NumberOfEmployees} .
source		SELECT `id`, `Name`, `EstablishedYear`, `Location`, `NumberOfEmployees` FROM `Publishers`

]]
