<#tm_attachment_2tab_val_literary_works_3_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"EstablishedYear\", \"Location\", \"NumberOfEmployees\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Publishers/{id}" ; rr:class :Publishers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EstablishedYear ; rr:objectMap [ rr:column "EstablishedYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfEmployees ; rr:objectMap [ rr:column "NumberOfEmployees" ] ] .

