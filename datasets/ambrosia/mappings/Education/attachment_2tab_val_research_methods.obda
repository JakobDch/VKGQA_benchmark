[PrefixDeclaration]
:	http://ambrosia.example.org/education#
p:	http://ambrosia.example.org/education/prop#
ex:	http://ambrosia.example.org/education/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Case_Studies_base
target		ex:Case_Studies/{ID} a :Case_Studies ; p:ID {ID} ; p:Topic {Topic} ; p:Description {Description} ; p:Date {Date} ; p:Author {Author} .
source		SELECT `ID`, `Topic`, `Description`, `Date`, `Author` FROM `Case_Studies`

mappingId	Interviews_base
target		ex:Interviews/{ID} a :Interviews ; p:ID {ID} ; p:Topic {Topic} ; p:Description {Description} ; p:IntervieweeName {IntervieweeName} ; p:InterviewDate {InterviewDate} .
source		SELECT `ID`, `Topic`, `Description`, `IntervieweeName`, `InterviewDate` FROM `Interviews`

mappingId	Students_base
target		ex:Students/{ID} a :Students ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:GradeLevel {GradeLevel} .
source		SELECT `ID`, `Name`, `Age`, `GradeLevel` FROM `Students`

mappingId	Teachers_base
target		ex:Teachers/{ID} a :Teachers ; p:ID {ID} ; p:name {Name} ; p:Subject {Subject} ; p:YearsOfExperience {YearsOfExperience} .
source		SELECT `ID`, `Name`, `Subject`, `YearsOfExperience` FROM `Teachers`

mappingId	Classes_base
target		ex:Classes/{ID} a :Classes ; p:ID {ID} ; p:ClassroomNumber {ClassroomNumber} ; p:MaxCapacity {MaxCapacity} ; p:SchoolYear {SchoolYear} .
source		SELECT `ID`, `ClassroomNumber`, `MaxCapacity`, `SchoolYear` FROM `Classes`

]]
