@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_career_pathways_opportunities_0_Career_Pathways_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PathwayID\", \"Name\", \"Description\" FROM \"Career_Pathways\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Career_Pathways/{PathwayID}" ; rr:class :Career_Pathways ] ;
  rr:predicateObjectMap [ rr:predicate p:PathwayID ; rr:objectMap [ rr:column "PathwayID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_scope_career_pathways_opportunities_1_Opportunities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OpportunityID\", \"Value\" FROM \"Opportunities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Opportunities/{OpportunityID}" ; rr:class :Opportunities ] ;
  rr:predicateObjectMap [ rr:predicate p:OpportunityID ; rr:objectMap [ rr:column "OpportunityID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Value ; rr:objectMap [ rr:column "Value" ] ] .

<#tm_scope_career_pathways_opportunities_2_Career_Pathways_Opportunities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CareerPathwayID\", \"OpportunityID\" FROM \"Career_Pathways_Opportunities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Career_Pathways_Opportunities/{CareerPathwayID}/{OpportunityID}" ; rr:class :Career_Pathways_Opportunities ] ;
  rr:predicateObjectMap [ rr:predicate p:CareerPathwayID ; rr:objectMap [ rr:column "CareerPathwayID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OpportunityID ; rr:objectMap [ rr:column "OpportunityID" ] ] .

<#tm_scope_career_pathways_opportunities_3_Career_Pathways_Opportunities_OpportunityID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CareerPathwayID\", \"OpportunityID\" FROM \"Career_Pathways_Opportunities\" WHERE \"OpportunityID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Career_Pathways_Opportunities/{CareerPathwayID}/{OpportunityID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOpportunities ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Opportunities/{OpportunityID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_career_pathways_opportunities_4_Career_Pathways_Opportunities_CareerPathwayID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CareerPathwayID\", \"OpportunityID\" FROM \"Career_Pathways_Opportunities\" WHERE \"CareerPathwayID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Career_Pathways_Opportunities/{CareerPathwayID}/{OpportunityID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCareer_Pathways ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Career_Pathways/{CareerPathwayID}" ; rr:termType rr:IRI ] ] .

