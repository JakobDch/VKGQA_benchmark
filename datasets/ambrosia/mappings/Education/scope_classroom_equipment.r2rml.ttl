@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_classroom_equipment_0_Classroom_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"capacity\" FROM \"Classroom\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classrooms/{id}" ; rr:class :Classrooms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

<#tm_scope_classroom_equipment_1_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"equipmentName\", \"quantity\" FROM \"Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Equipment/{id}" ; rr:class :Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:equipmentName ; rr:objectMap [ rr:column "equipmentName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "quantity" ] ] .

<#tm_scope_classroom_equipment_2_Classroom_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"classroomId\", \"equipmentId\" FROM \"Classroom_Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classroom_Equipment/{_amb_rowid}" ; rr:class :Classroom_Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:classroomId ; rr:objectMap [ rr:column "classroomId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:equipmentId ; rr:objectMap [ rr:column "equipmentId" ] ] .

<#tm_scope_classroom_equipment_3_Classroom_Equipment_equipmentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"equipmentId\" FROM \"Classroom_Equipment\" WHERE \"equipmentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classroom_Equipment/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEquipment ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Equipment/{equipmentId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_classroom_equipment_4_Classroom_Equipment_classroomId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"classroomId\" FROM \"Classroom_Equipment\" WHERE \"classroomId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classroom_Equipment/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClassrooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Classrooms/{classroomId}" ; rr:termType rr:IRI ] ] .

