@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_college_campuses_buildings_0_College_Campuses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"College_Campuses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/College_Campuses/{id}" ; rr:class :College_Campuses ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_college_campuses_buildings_1_Buildings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\", \"description\" FROM \"Buildings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Buildings/{id}" ; rr:class :Buildings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_college_campuses_buildings_2_College_Campuses_Buildings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"campusId\", \"buildingId\" FROM \"College_Campuses_Buildings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/College_Campuses_Buildings/{campusId}/{buildingId}" ; rr:class :College_Campuses_Buildings ] ;
  rr:predicateObjectMap [ rr:predicate p:campusId ; rr:objectMap [ rr:column "campusId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:buildingId ; rr:objectMap [ rr:column "buildingId" ] ] .

<#tm_scope_college_campuses_buildings_3_College_Campuses_Buildings_buildingId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"campusId\", \"buildingId\" FROM \"College_Campuses_Buildings\" WHERE \"buildingId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/College_Campuses_Buildings/{campusId}/{buildingId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBuildings ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Buildings/{buildingId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_college_campuses_buildings_4_College_Campuses_Buildings_campusId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"campusId\", \"buildingId\" FROM \"College_Campuses_Buildings\" WHERE \"campusId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/College_Campuses_Buildings/{campusId}/{buildingId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCollege_Campuses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/College_Campuses/{campusId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_college_campuses_buildings_5_College_Campuses_Buildings_buildingId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"campusId\", \"buildingId\" FROM \"College_Campuses_Buildings\" WHERE \"buildingId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/College_Campuses_Buildings/{campusId}/{buildingId}" ] ;
