@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_conferences_sessions_0_Conferences_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"conference_id\", \"name\", \"date\" FROM \"Conferences\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Conferences/{conference_id}" ; rr:class :Conferences ] ;
  rr:predicateObjectMap [ rr:predicate p:conference_id ; rr:objectMap [ rr:column "conference_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] .

<#tm_scope_conferences_sessions_1_Speakers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"speaker_id\", \"first_name\", \"last_name\", \"title\" FROM \"Speakers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Speakers/{speaker_id}" ; rr:class :Speakers ] ;
  rr:predicateObjectMap [ rr:predicate p:speaker_id ; rr:objectMap [ rr:column "speaker_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] .

<#tm_scope_conferences_sessions_2_Conference_Speakers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"conference_speaker_id\", \"conference_id\", \"speaker_id\" FROM \"Conference_Speakers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Conference_Speakers/{conference_speaker_id}" ; rr:class :Conference_Speakers ] ;
  rr:predicateObjectMap [ rr:predicate p:conference_speaker_id ; rr:objectMap [ rr:column "conference_speaker_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:conference_id ; rr:objectMap [ rr:column "conference_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:speaker_id ; rr:objectMap [ rr:column "speaker_id" ] ] .

<#tm_scope_conferences_sessions_3_Conference_Speakers_speaker_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"conference_speaker_id\", \"speaker_id\" FROM \"Conference_Speakers\" WHERE \"speaker_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Conference_Speakers/{conference_speaker_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSpeakers ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Speakers/{speaker_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_conferences_sessions_4_Conference_Speakers_conference_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"conference_speaker_id\", \"conference_id\" FROM \"Conference_Speakers\" WHERE \"conference_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Conference_Speakers/{conference_speaker_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasConferences ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Conferences/{conference_id}" ; rr:termType rr:IRI ] ] .

