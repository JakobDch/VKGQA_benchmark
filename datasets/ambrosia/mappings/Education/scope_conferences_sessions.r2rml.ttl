  rr:predicateObjectMap [ rr:predicate p:hasConferences ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Conferences/{conference_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_conferences_sessions_8_Sessions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"session_type_id\", \"session_type\", \"duration\" FROM \"Sessions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Sessions/{session_type_id}" ; rr:class :Sessions ] ;
