@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_courses_assignments_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studentID\", \"firstName\", \"lastName\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:studentID ; rr:objectMap [ rr:column "studentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] .

<#tm_scope_courses_assignments_1_Departments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"departmentID\", \"name\", \"head\" FROM \"Departments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Departments/{departmentID}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:departmentID ; rr:objectMap [ rr:column "departmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:head ; rr:objectMap [ rr:column "head" ] ] .

<#tm_scope_courses_assignments_2_Professors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"professorID\", \"firstName\", \"lastName\", \"departmentID\" FROM \"Professors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Professors/{professorID}" ; rr:class :Professors ] ;
  rr:predicateObjectMap [ rr:predicate p:professorID ; rr:objectMap [ rr:column "professorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departmentID ; rr:objectMap [ rr:column "departmentID" ] ] .

<#tm_scope_courses_assignments_3_Professors_departmentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"professorID\", \"departmentID\" FROM \"Professors\" WHERE \"departmentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Professors/{professorID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDepartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Departments/{departmentID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_courses_assignments_4_Courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"courseID\", \"title\", \"credits\", \"professorID\" FROM \"Courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{courseID}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:courseID ; rr:objectMap [ rr:column "courseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:credits ; rr:objectMap [ rr:column "credits" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:professorID ; rr:objectMap [ rr:column "professorID" ] ] .

<#tm_scope_courses_assignments_5_Courses_professorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"courseID\", \"professorID\" FROM \"Courses\" WHERE \"professorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{courseID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProfessors ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Professors/{professorID}" ; rr:termType rr:IRI ] ] .

