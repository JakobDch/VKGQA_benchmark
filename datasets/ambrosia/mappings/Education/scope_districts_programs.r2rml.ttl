<#tm_scope_districts_programs_5_Schools_DistrictID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"DistrictID\" FROM \"Schools\" WHERE \"DistrictID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Schools/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDistricts ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Districts/{DistrictID}" ; rr:termType rr:IRI ] ] .

