@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_exam_type_of_question_0_Exam_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"examName\", \"date\" FROM \"Exam\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Exams/{id}" ; rr:class :Exams ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:examName ; rr:objectMap [ rr:column "examName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] .

<#tm_scope_exam_type_of_question_1_Type_Of_Question_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"questionType\" FROM \"Type_Of_Question\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Type_Of_Question/{id}" ; rr:class :Type_Of_Question ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:questionType ; rr:objectMap [ rr:column "questionType" ] ] .

<#tm_scope_exam_type_of_question_2_Exam_Type_Of_Question_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"examID\", \"questionTypeID\" FROM \"Exam_Type_Of_Question\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Exam_Type_Of_Question/{_amb_rowid}" ; rr:class :Exam_Type_Of_Question ] ;
  rr:predicateObjectMap [ rr:predicate p:examID ; rr:objectMap [ rr:column "examID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:questionTypeID ; rr:objectMap [ rr:column "questionTypeID" ] ] .

<#tm_scope_exam_type_of_question_3_Exam_Type_Of_Question_questionTypeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"questionTypeID\" FROM \"Exam_Type_Of_Question\" WHERE \"questionTypeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Exam_Type_Of_Question/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasType_Of_Question ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Type_Of_Question/{questionTypeID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_exam_type_of_question_4_Exam_Type_Of_Question_examID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"examID\" FROM \"Exam_Type_Of_Question\" WHERE \"examID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Exam_Type_Of_Question/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasExams ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Exams/{examID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_exam_type_of_question_5_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studentId\", \"firstName\", \"lastName\", \"enrollmentDate\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentId}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:studentId ; rr:objectMap [ rr:column "studentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:enrollmentDate ; rr:objectMap [ rr:column "enrollmentDate" ] ] .

<#tm_scope_exam_type_of_question_6_Student_Grades_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"studentId\", \"examId\", \"grade\" FROM \"Student_Grades\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Student_Grades/{_amb_rowid}" ; rr:class :Student_Grades ] ;
  rr:predicateObjectMap [ rr:predicate p:studentId ; rr:objectMap [ rr:column "studentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:examId ; rr:objectMap [ rr:column "examId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:grade ; rr:objectMap [ rr:column "grade" ] ] .

<#tm_scope_exam_type_of_question_7_Student_Grades_examId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"examId\" FROM \"Student_Grades\" WHERE \"examId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Student_Grades/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasExams ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Exams/{examId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_exam_type_of_question_8_Student_Grades_studentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"studentId\" FROM \"Student_Grades\" WHERE \"studentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Student_Grades/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentId}" ; rr:termType rr:IRI ] ] .

