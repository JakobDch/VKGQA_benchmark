<#tm_scope_field_trips_stops_5_Field_Trips_Students_studentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"studentID\" FROM \"Field_Trips_Students\" WHERE \"studentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Field_Trips_Students/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{studentID}" ; rr:termType rr:IRI ] ] .

