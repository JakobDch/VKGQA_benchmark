@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_field_trips_stops_0_Field_Trips_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"tripID\", \"fieldTripName\", \"date\" FROM \"Field_Trips\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Field_Trips/{tripID}" ; rr:class :Field_Trips ] ;
  rr:predicateObjectMap [ rr:predicate p:tripID ; rr:objectMap [ rr:column "tripID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fieldTripName ; rr:objectMap [ rr:column "fieldTripName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] .

<#tm_scope_field_trips_stops_1_Stops_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"stopID\", \"stopLocation\" FROM \"Stops\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Stops/{stopID}" ; rr:class :Stops ] ;
  rr:predicateObjectMap [ rr:predicate p:stopID ; rr:objectMap [ rr:column "stopID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:stopLocation ; rr:objectMap [ rr:column "stopLocation" ] ] .

