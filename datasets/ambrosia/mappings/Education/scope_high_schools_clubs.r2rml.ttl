@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_high_schools_clubs_0_High_Schools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"High_Schools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/High_Schools/{id}" ; rr:class :High_Schools ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_high_schools_clubs_1_Clubs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"club_name\" FROM \"Clubs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Clubs/{id}" ; rr:class :Clubs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:club_name ; rr:objectMap [ rr:column "club_name" ] ] .

<#tm_scope_high_schools_clubs_2_High_Schools_Clubs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"high_school_id\", \"club_id\" FROM \"High_Schools_Clubs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/High_Schools_Clubs/{_amb_rowid}" ; rr:class :High_Schools_Clubs ] ;
  rr:predicateObjectMap [ rr:predicate p:high_school_id ; rr:objectMap [ rr:column "high_school_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:club_id ; rr:objectMap [ rr:column "club_id" ] ] .

<#tm_scope_high_schools_clubs_3_High_Schools_Clubs_club_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"club_id\" FROM \"High_Schools_Clubs\" WHERE \"club_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/High_Schools_Clubs/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClubs ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Clubs/{club_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_high_schools_clubs_4_High_Schools_Clubs_high_school_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"high_school_id\" FROM \"High_Schools_Clubs\" WHERE \"high_school_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/High_Schools_Clubs/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHigh_Schools ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/High_Schools/{high_school_id}" ; rr:termType rr:IRI ] ] .

