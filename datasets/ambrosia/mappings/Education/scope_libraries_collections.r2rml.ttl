@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_libraries_collections_0_Libraries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"phone_number\" FROM \"Libraries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Libraries/{id}" ; rr:class :Libraries ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_scope_libraries_collections_1_Collections_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"collection_id\", \"collection_name\" FROM \"Collections\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Collections/{collection_id}" ; rr:class :Collections ] ;
  rr:predicateObjectMap [ rr:predicate p:collection_id ; rr:objectMap [ rr:column "collection_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:collection_name ; rr:objectMap [ rr:column "collection_name" ] ] .

<#tm_scope_libraries_collections_2_Libraries_Collections_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"library_id\", \"collection_id\" FROM \"Libraries_Collections\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Libraries_Collections/{_amb_rowid}" ; rr:class :Libraries_Collections ] ;
  rr:predicateObjectMap [ rr:predicate p:library_id ; rr:objectMap [ rr:column "library_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:collection_id ; rr:objectMap [ rr:column "collection_id" ] ] .

<#tm_scope_libraries_collections_3_Libraries_Collections_collection_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"collection_id\" FROM \"Libraries_Collections\" WHERE \"collection_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Libraries_Collections/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCollections ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Collections/{collection_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_libraries_collections_4_Libraries_Collections_library_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"library_id\" FROM \"Libraries_Collections\" WHERE \"library_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Libraries_Collections/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLibraries ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Libraries/{library_id}" ; rr:termType rr:IRI ] ] .

