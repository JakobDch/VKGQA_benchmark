  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"courseID\" FROM \"Enrolled_Students\" WHERE \"courseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrolled_Students/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourses ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{courseID}" ; rr:termType rr:IRI ] ] .

