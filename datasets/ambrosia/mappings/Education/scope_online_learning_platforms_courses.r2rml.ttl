<#tm_scope_online_learning_platforms_courses_0_Users_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"userID\", \"username\", \"password\" FROM \"Users\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Users/{userID}" ; rr:class :Users ] ;
  rr:predicateObjectMap [ rr:predicate p:userID ; rr:objectMap [ rr:column "userID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:username ; rr:objectMap [ rr:column "username" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:password ; rr:objectMap [ rr:column "password" ] ] .

