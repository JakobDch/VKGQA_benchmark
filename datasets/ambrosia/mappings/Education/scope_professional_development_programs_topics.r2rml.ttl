@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_professional_development_programs_topics_0_Topics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"topic_name\" FROM \"Topics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Topics/{id}" ; rr:class :Topics ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:topic_name ; rr:objectMap [ rr:column "topic_name" ] ] .

<#tm_scope_professional_development_programs_topics_1_Professional_Development_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"program_id\", \"program_name\", \"duration\", \"cost\" FROM \"Professional_Development_Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Professional_Development_Programs/{program_id}" ; rr:class :Professional_Development_Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:program_id ; rr:objectMap [ rr:column "program_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:program_name ; rr:objectMap [ rr:column "program_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration ; rr:objectMap [ rr:column "duration" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cost ; rr:objectMap [ rr:column "cost" ] ] .

<#tm_scope_professional_development_programs_topics_2_Professional_Development_Programs_Topics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"pdp_topics_id\", \"topics_id\" FROM \"Professional_Development_Programs_Topics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Professional_Development_Programs_Topics/{_amb_rowid}" ; rr:class :Professional_Development_Programs_Topics ] ;
  rr:predicateObjectMap [ rr:predicate p:pdp_topics_id ; rr:objectMap [ rr:column "pdp_topics_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:topics_id ; rr:objectMap [ rr:column "topics_id" ] ] .

<#tm_scope_professional_development_programs_topics_3_Professional_Development_Programs_Topics_topics_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"topics_id\" FROM \"Professional_Development_Programs_Topics\" WHERE \"topics_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Professional_Development_Programs_Topics/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTopics ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Topics/{topics_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_professional_development_programs_topics_4_Professional_Development_Programs_Topics_pdp_topics_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"pdp_topics_id\" FROM \"Professional_Development_Programs_Topics\" WHERE \"pdp_topics_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Professional_Development_Programs_Topics/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProfessional_Development_Programs ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Professional_Development_Programs/{pdp_topics_id}" ; rr:termType rr:IRI ] ] .

