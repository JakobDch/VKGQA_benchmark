@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_projects_research_techniques_0_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"project_name\", \"description\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{id}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:project_name ; rr:objectMap [ rr:column "project_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_projects_research_techniques_1_Research_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"technique_name\", \"description\" FROM \"Research_Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Research_Techniques/{id}" ; rr:class :Research_Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_name ; rr:objectMap [ rr:column "technique_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_projects_research_techniques_2_Projects_Research_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"project_id\", \"technique_id\" FROM \"Projects_Research_Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects_Research_Techniques/{project_id}/{technique_id}" ; rr:class :Projects_Research_Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:project_id ; rr:objectMap [ rr:column "project_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_id ; rr:objectMap [ rr:column "technique_id" ] ] .

<#tm_scope_projects_research_techniques_3_Projects_Research_Techniques_technique_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"project_id\", \"technique_id\" FROM \"Projects_Research_Techniques\" WHERE \"technique_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects_Research_Techniques/{project_id}/{technique_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasResearch_Techniques ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Research_Techniques/{technique_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_projects_research_techniques_4_Projects_Research_Techniques_project_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"project_id\", \"technique_id\" FROM \"Projects_Research_Techniques\" WHERE \"project_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects_Research_Techniques/{project_id}/{technique_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{project_id}" ; rr:termType rr:IRI ] ] .

