@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_scholarships_criteria_0_Scholarships_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"amount\" FROM \"Scholarships\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Scholarships/{id}" ; rr:class :Scholarships ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amount ; rr:objectMap [ rr:column "amount" ] ] .

<#tm_scope_scholarships_criteria_1_Criteria_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"value\" FROM \"Criteria\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Criteria/{id}" ; rr:class :Criteria ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:value ; rr:objectMap [ rr:column "value" ] ] .

<#tm_scope_scholarships_criteria_2_Scholarship_Criteria_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"scholarship_id\", \"criterion_id\" FROM \"Scholarship_Criteria\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Scholarship_Criteria/{_amb_rowid}" ; rr:class :Scholarship_Criteria ] ;
  rr:predicateObjectMap [ rr:predicate p:scholarship_id ; rr:objectMap [ rr:column "scholarship_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:criterion_id ; rr:objectMap [ rr:column "criterion_id" ] ] .

<#tm_scope_scholarships_criteria_3_Scholarship_Criteria_criterion_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"criterion_id\" FROM \"Scholarship_Criteria\" WHERE \"criterion_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Scholarship_Criteria/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCriteria ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Criteria/{criterion_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_scholarships_criteria_4_Scholarship_Criteria_scholarship_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"scholarship_id\" FROM \"Scholarship_Criteria\" WHERE \"scholarship_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Scholarship_Criteria/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasScholarships ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Scholarships/{scholarship_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_scholarships_criteria_5_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"student_id\", \"first_name\", \"last_name\", \"email\", \"phone_number\", \"admission_date\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{student_id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:student_id ; rr:objectMap [ rr:column "student_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:admission_date ; rr:objectMap [ rr:column "admission_date" ] ] .

<#tm_scope_scholarships_criteria_6_Applications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"student_id\", \"scholarship_id\", \"submission_date\", \"status\" FROM \"Applications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Applications/{application_id}" ; rr:class :Applications ] ;
  rr:predicateObjectMap [ rr:predicate p:application_id ; rr:objectMap [ rr:column "application_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:student_id ; rr:objectMap [ rr:column "student_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:scholarship_id ; rr:objectMap [ rr:column "scholarship_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:submission_date ; rr:objectMap [ rr:column "submission_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] .

<#tm_scope_scholarships_criteria_7_Applications_scholarship_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"scholarship_id\" FROM \"Applications\" WHERE \"scholarship_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Applications/{application_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasScholarships ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Scholarships/{scholarship_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_scholarships_criteria_8_Applications_student_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"student_id\" FROM \"Applications\" WHERE \"student_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Applications/{application_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{student_id}" ; rr:termType rr:IRI ] ] .

