@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_summer_camps_themes_0_Themes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"themeName\" FROM \"Themes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Themes/{id}" ; rr:class :Themes ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:themeName ; rr:objectMap [ rr:column "themeName" ] ] .

<#tm_scope_summer_camps_themes_1_Summer_Camps_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"campName\", \"location\", \"startDate\", \"endDate\" FROM \"Summer_Camps\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Summer_Camps/{id}" ; rr:class :Summer_Camps ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:campName ; rr:objectMap [ rr:column "campName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] .

<#tm_scope_summer_camps_themes_2_Summer_Camp_Themes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"summerCampId\", \"themeId\" FROM \"Summer_Camp_Themes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Summer_Camp_Themes/{_amb_rowid}" ; rr:class :Summer_Camp_Themes ] ;
  rr:predicateObjectMap [ rr:predicate p:summerCampId ; rr:objectMap [ rr:column "summerCampId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:themeId ; rr:objectMap [ rr:column "themeId" ] ] .

<#tm_scope_summer_camps_themes_3_Summer_Camp_Themes_themeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"themeId\" FROM \"Summer_Camp_Themes\" WHERE \"themeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Summer_Camp_Themes/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasThemes ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Themes/{themeId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_summer_camps_themes_4_Summer_Camp_Themes_summerCampId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"summerCampId\" FROM \"Summer_Camp_Themes\" WHERE \"summerCampId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Summer_Camp_Themes/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSummer_Camps ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Summer_Camps/{summerCampId}" ; rr:termType rr:IRI ] ] .

