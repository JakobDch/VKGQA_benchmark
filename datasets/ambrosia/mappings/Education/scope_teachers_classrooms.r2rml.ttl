@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_teachers_classrooms_0_Teachers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"teacher_id\", \"full_name\" FROM \"Teachers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{teacher_id}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:teacher_id ; rr:objectMap [ rr:column "teacher_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_scope_teachers_classrooms_1_Classrooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classroom_id\", \"room_number\", \"capacity\" FROM \"Classrooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Classrooms/{classroom_id}" ; rr:class :Classrooms ] ;
  rr:predicateObjectMap [ rr:predicate p:classroom_id ; rr:objectMap [ rr:column "classroom_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:room_number ; rr:objectMap [ rr:column "room_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

<#tm_scope_teachers_classrooms_2_Subjects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"subject_id\", \"name\", \"description\" FROM \"Subjects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{subject_id}" ; rr:class :Subjects ] ;
  rr:predicateObjectMap [ rr:predicate p:subject_id ; rr:objectMap [ rr:column "subject_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_teachers_classrooms_3_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"student_id\", \"first_name\", \"last_name\", \"date_of_birth\", \"enrollment_date\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{student_id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:student_id ; rr:objectMap [ rr:column "student_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date_of_birth ; rr:objectMap [ rr:column "date_of_birth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:enrollment_date ; rr:objectMap [ rr:column "enrollment_date" ] ] .

<#tm_scope_teachers_classrooms_4_Enrollments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"student_id\", \"subject_id\", \"classroom_id\", \"grade\" FROM \"Enrollments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{enrollment_id}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:enrollment_id ; rr:objectMap [ rr:column "enrollment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:student_id ; rr:objectMap [ rr:column "student_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subject_id ; rr:objectMap [ rr:column "subject_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:classroom_id ; rr:objectMap [ rr:column "classroom_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:grade ; rr:objectMap [ rr:column "grade" ] ] .

<#tm_scope_teachers_classrooms_5_Enrollments_classroom_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"classroom_id\" FROM \"Enrollments\" WHERE \"classroom_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{enrollment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClassrooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Classrooms/{classroom_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_teachers_classrooms_6_Enrollments_subject_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"subject_id\" FROM \"Enrollments\" WHERE \"subject_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{enrollment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Subjects/{subject_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_teachers_classrooms_7_Enrollments_student_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"student_id\" FROM \"Enrollments\" WHERE \"student_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Enrollments/{enrollment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{student_id}" ; rr:termType rr:IRI ] ] .

