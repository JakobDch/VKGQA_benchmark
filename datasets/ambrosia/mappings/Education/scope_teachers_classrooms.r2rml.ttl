<#tm_scope_teachers_classrooms_10_Teachers_Classrooms_teacher_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"teachers_classrooms_id\", \"teacher_id\" FROM \"Teachers_Classrooms\" WHERE \"teacher_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers_Classrooms/{teachers_classrooms_id}" ] ;
