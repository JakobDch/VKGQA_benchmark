<#tm_scope_teachers_classrooms_9_Teachers_Classrooms_classroom_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"teachers_classrooms_id\", \"classroom_id\" FROM \"Teachers_Classrooms\" WHERE \"classroom_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers_Classrooms/{teachers_classrooms_id}" ] ;
