  rr:logicalTable [ rr:sqlQuery """SELECT \"teachers_classrooms_id\", \"teacher_id\", \"classroom_id\", \"start_date\", \"end_date\" FROM \"Teachers_Classrooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers_Classrooms/{teachers_classrooms_id}" ; rr:class :Teachers_Classrooms ] ;
