@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_textbooks_chapters1_0_Textbooks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"author\", \"publication_year\" FROM \"Textbooks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks/{id}" ; rr:class :Textbooks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author ; rr:objectMap [ rr:column "author" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_year ; rr:objectMap [ rr:column "publication_year" ] ] .

<#tm_scope_textbooks_chapters1_1_Textbook_Chapters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"textbook_chapter_id\", \"textbook_id\", \"chapter_id\", \"content\", \"created_at\", \"updated_at\" FROM \"Textbook_Chapters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbook_Chapters/{textbook_chapter_id}" ; rr:class :Textbook_Chapters ] ;
  rr:predicateObjectMap [ rr:predicate p:textbook_chapter_id ; rr:objectMap [ rr:column "textbook_chapter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:textbook_id ; rr:objectMap [ rr:column "textbook_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:chapter_id ; rr:objectMap [ rr:column "chapter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:created_at ; rr:objectMap [ rr:column "created_at" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:updated_at ; rr:objectMap [ rr:column "updated_at" ] ] .

<#tm_scope_textbooks_chapters1_2_Textbook_Chapters_chapter_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"textbook_chapter_id\", \"chapter_id\" FROM \"Textbook_Chapters\" WHERE \"chapter_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbook_Chapters/{textbook_chapter_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasChapters ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Chapters/{chapter_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_textbooks_chapters1_3_Textbook_Chapters_textbook_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"textbook_chapter_id\", \"textbook_id\" FROM \"Textbook_Chapters\" WHERE \"textbook_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbook_Chapters/{textbook_chapter_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTextbooks ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks/{textbook_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_textbooks_chapters1_4_Chapters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"chapter_id\", \"chapter_name\" FROM \"Chapters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Chapters/{chapter_id}" ; rr:class :Chapters ] ;
  rr:predicateObjectMap [ rr:predicate p:chapter_id ; rr:objectMap [ rr:column "chapter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:chapter_name ; rr:objectMap [ rr:column "chapter_name" ] ] .

