@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_textbooks_chapters2_0_Textbooks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"author\" FROM \"Textbooks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks/{id}" ; rr:class :Textbooks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author ; rr:objectMap [ rr:column "author" ] ] .

<#tm_scope_textbooks_chapters2_1_Chapters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"chapterName\", \"subject\" FROM \"Chapters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Chapters/{chapterName}" ; rr:class :Chapters ] ;
  rr:predicateObjectMap [ rr:predicate p:chapterName ; rr:objectMap [ rr:column "chapterName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subject ; rr:objectMap [ rr:column "subject" ] ] .

<#tm_scope_textbooks_chapters2_2_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"authorId\", \"name\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Authors/{authorId}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:authorId ; rr:objectMap [ rr:column "authorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_textbooks_chapters2_3_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"publisherId\", \"companyName\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Publishers/{publisherId}" ; rr:class :Publishers ] ;
  rr:predicateObjectMap [ rr:predicate p:publisherId ; rr:objectMap [ rr:column "publisherId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:companyName ; rr:objectMap [ rr:column "companyName" ] ] .

<#tm_scope_textbooks_chapters2_4_BookAuthors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"bookId\", \"authorId\" FROM \"BookAuthors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/BookAuthors/{_amb_rowid}" ; rr:class :BookAuthors ] ;
  rr:predicateObjectMap [ rr:predicate p:bookId ; rr:objectMap [ rr:column "bookId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:authorId ; rr:objectMap [ rr:column "authorId" ] ] .

<#tm_scope_textbooks_chapters2_5_BookAuthors_authorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"authorId\" FROM \"BookAuthors\" WHERE \"authorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/BookAuthors/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Authors/{authorId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_textbooks_chapters2_6_BookPublishers_base> a rr:TriplesMap ;
