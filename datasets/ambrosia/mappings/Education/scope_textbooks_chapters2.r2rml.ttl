  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbook_Chapters/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasChapters ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Chapters/{chapterName}" ; rr:termType rr:IRI ] ] .

