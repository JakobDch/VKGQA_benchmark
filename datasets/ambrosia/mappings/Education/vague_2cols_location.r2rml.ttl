  rr:predicateObjectMap [ rr:predicate p:RoomNumber ; rr:objectMap [ rr:column "RoomNumber" ] ] .

<#tm_vague_2cols_location_3_Departments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DepartmentID\", \"Name\", \"DeanName\", \"Building\" FROM \"Departments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Departments/{DepartmentID}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartmentID ; rr:objectMap [ rr:column "DepartmentID" ] ] ;
