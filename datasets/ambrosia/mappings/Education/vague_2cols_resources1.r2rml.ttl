<#tm_vague_2cols_resources1_4_Assignments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Description\", \"DueDate\", \"MaxPoints\" FROM \"Assignments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Assignments/{ID}" ; rr:class :Assignments ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DueDate ; rr:objectMap [ rr:column "DueDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MaxPoints ; rr:objectMap [ rr:column "MaxPoints" ] ] .

<#tm_vague_2cols_resources1_5_Grades_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"StudentID\", \"AssignmentID\", \"Score\", \"Feedback\" FROM \"Grades\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Grades/{ID}" ; rr:class :Grades ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AssignmentID ; rr:objectMap [ rr:column "AssignmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Score ; rr:objectMap [ rr:column "Score" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Feedback ; rr:objectMap [ rr:column "Feedback" ] ] .

<#tm_vague_2cols_resources1_6_Grades_AssignmentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"AssignmentID\" FROM \"Grades\" WHERE \"AssignmentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Grades/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAssignments ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Assignments/{AssignmentID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_resources1_7_Grades_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"StudentID\" FROM \"Grades\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Grades/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

