  rr:predicateObjectMap [ rr:predicate p:Building ; rr:objectMap [ rr:column "Building" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] .

<#tm_vague_2cols_resources1_3_Textbooks_Supplies_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"TextbookTitle\", \"SupplyItem\", \"ProjectDescription\" FROM \"Textbooks_Supplies_Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks_Supplies_Projects/{ID}" ; rr:class :Textbooks_Supplies_Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
