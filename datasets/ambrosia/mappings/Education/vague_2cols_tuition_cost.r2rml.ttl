  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HireDate ; rr:objectMap [ rr:column "HireDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

<#tm_vague_2cols_tuition_cost_7_Courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CourseID\", \"Title\", \"Description\", \"DepartmentID\", \"Credits\", \"InstructorID\" FROM \"Courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{CourseID}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseID ; rr:objectMap [ rr:column "CourseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartmentID ; rr:objectMap [ rr:column "DepartmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Credits ; rr:objectMap [ rr:column "Credits" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:InstructorID ; rr:objectMap [ rr:column "InstructorID" ] ] .

<#tm_vague_2cols_tuition_cost_8_Courses_InstructorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CourseID\", \"InstructorID\" FROM \"Courses\" WHERE \"InstructorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{CourseID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInstructors ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Instructors/{InstructorID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_tuition_cost_9_Courses_DepartmentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CourseID\", \"DepartmentID\" FROM \"Courses\" WHERE \"DepartmentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Courses/{CourseID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDepartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Departments/{DepartmentID}" ; rr:termType rr:IRI ] ] .

