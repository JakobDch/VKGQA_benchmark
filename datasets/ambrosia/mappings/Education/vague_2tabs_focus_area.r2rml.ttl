@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_focus_area_0_Topic_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"description\" FROM \"Topic\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Topics/{id}" ; rr:class :Topics ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2tabs_focus_area_1_Field_Of_Study_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"description\" FROM \"Field_Of_Study\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Field_Of_Study/{id}" ; rr:class :Field_Of_Study ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2tabs_focus_area_2_Project_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"details\", \"topicId\", \"fieldOfStudyId\" FROM \"Project\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{id}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:details ; rr:objectMap [ rr:column "details" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:topicId ; rr:objectMap [ rr:column "topicId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fieldOfStudyId ; rr:objectMap [ rr:column "fieldOfStudyId" ] ] .

<#tm_vague_2tabs_focus_area_3_Project_fieldOfStudyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"fieldOfStudyId\" FROM \"Project\" WHERE \"fieldOfStudyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasField_Of_Study ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Field_Of_Study/{fieldOfStudyId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_focus_area_4_Project_topicId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"topicId\" FROM \"Project\" WHERE \"topicId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTopics ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Topics/{topicId}" ; rr:termType rr:IRI ] ] .

