@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_location_0_City_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"population\" FROM \"City\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/City/{id}" ; rr:class :City ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:population ; rr:objectMap [ rr:column "population" ] ] .

<#tm_vague_2tabs_location_1_State_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"full_name\" FROM \"State\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/State/{id}" ; rr:class :State ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_vague_2tabs_location_2_Campus_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"campus_name\", \"city_id\", \"state_id\" FROM \"Campus\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Campus/{id}" ; rr:class :Campus ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:campus_name ; rr:objectMap [ rr:column "campus_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city_id ; rr:objectMap [ rr:column "city_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:state_id ; rr:objectMap [ rr:column "state_id" ] ] .

<#tm_vague_2tabs_location_3_Campus_state_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"state_id\" FROM \"Campus\" WHERE \"state_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Campus/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasState ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/State/{state_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_location_4_Campus_city_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"city_id\" FROM \"Campus\" WHERE \"city_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Campus/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCity ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/City/{city_id}" ; rr:termType rr:IRI ] ] .

