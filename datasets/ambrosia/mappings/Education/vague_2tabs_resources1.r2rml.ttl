@prefix : <http://ambrosia.example.org/education#> .
@prefix p: <http://ambrosia.example.org/education/prop#> .
@prefix ex: <http://ambrosia.example.org/education/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_resources1_0_Textbooks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"author\" FROM \"Textbooks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks/{id}" ; rr:class :Textbooks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author ; rr:objectMap [ rr:column "author" ] ] .

<#tm_vague_2tabs_resources1_1_Supplies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"quantity_needed\" FROM \"Supplies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Supplies/{id}" ; rr:class :Supplies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity_needed ; rr:objectMap [ rr:column "quantity_needed" ] ] .

<#tm_vague_2tabs_resources1_2_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"project_name\", \"description\", \"supplies_id\", \"textbook_id\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{id}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:project_name ; rr:objectMap [ rr:column "project_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:supplies_id ; rr:objectMap [ rr:column "supplies_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:textbook_id ; rr:objectMap [ rr:column "textbook_id" ] ] .

<#tm_vague_2tabs_resources1_3_Projects_textbook_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"textbook_id\" FROM \"Projects\" WHERE \"textbook_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTextbooks ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Textbooks/{textbook_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_resources1_4_Projects_supplies_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"supplies_id\" FROM \"Projects\" WHERE \"supplies_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Projects/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSupplies ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Supplies/{supplies_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_resources1_5_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"student_name\", \"age\", \"class_id\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:student_name ; rr:objectMap [ rr:column "student_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:age ; rr:objectMap [ rr:column "age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:class_id ; rr:objectMap [ rr:column "class_id" ] ] .

<#tm_vague_2tabs_resources1_6_Teachers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"teacher_name\", \"subject\", \"class_id\" FROM \"Teachers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{id}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:teacher_name ; rr:objectMap [ rr:column "teacher_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subject ; rr:objectMap [ rr:column "subject" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:class_id ; rr:objectMap [ rr:column "class_id" ] ] .

<#tm_vague_2tabs_resources1_7_Teachers_class_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"class_id\" FROM \"Teachers\" WHERE \"class_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/education/id/Teachers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/education/id/Students/{class_id}" ; rr:termType rr:IRI ] ] .

