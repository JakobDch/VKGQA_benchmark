@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_audio_media_0_Audio_Media_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MediaID\", \"Title\", \"Category\", \"ReleaseDate\", \"Creator\" FROM \"Audio_Media\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Audio_Media/{MediaID}" ; rr:class :Audio_Media ] ;
  rr:predicateObjectMap [ rr:predicate p:MediaID ; rr:objectMap [ rr:column "MediaID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Category ; rr:objectMap [ rr:column "Category" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Creator ; rr:objectMap [ rr:column "Creator" ] ] .

<#tm_attachment_1tab_ref_audio_media_1_Episode_Details_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EpisodeID\", \"AudioMediaID\", \"Title\", \"Length\" FROM \"Episode_Details\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Episode_Details/{EpisodeID}" ; rr:class :Episode_Details ] ;
  rr:predicateObjectMap [ rr:predicate p:EpisodeID ; rr:objectMap [ rr:column "EpisodeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AudioMediaID ; rr:objectMap [ rr:column "AudioMediaID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Length ; rr:objectMap [ rr:column "Length" ] ] .

<#tm_attachment_1tab_ref_audio_media_2_Episode_Details_AudioMediaID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EpisodeID\", \"AudioMediaID\" FROM \"Episode_Details\" WHERE \"AudioMediaID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Episode_Details/{EpisodeID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAudio_Media ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Audio_Media/{AudioMediaID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_audio_media_3_Podcast_Category_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CategoryID\", \"Name\" FROM \"Podcast_Category\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Podcast_Category/{CategoryID}" ; rr:class :Podcast_Category ] ;
  rr:predicateObjectMap [ rr:predicate p:CategoryID ; rr:objectMap [ rr:column "CategoryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_ref_audio_media_4_RadioShow_Category_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CategoryID\", \"Name\" FROM \"RadioShow_Category\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/RadioShow_Category/{CategoryID}" ; rr:class :RadioShow_Category ] ;
  rr:predicateObjectMap [ rr:predicate p:CategoryID ; rr:objectMap [ rr:column "CategoryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_ref_audio_media_5_Other_Category_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CategoryID\", \"Name\" FROM \"Other_Category\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Other_Category/{CategoryID}" ; rr:class :Other_Category ] ;
  rr:predicateObjectMap [ rr:predicate p:CategoryID ; rr:objectMap [ rr:column "CategoryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

