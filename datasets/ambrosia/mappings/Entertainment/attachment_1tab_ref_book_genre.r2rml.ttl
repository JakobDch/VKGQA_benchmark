  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearOfPublication ; rr:objectMap [ rr:column "YearOfPublication" ] ] .

