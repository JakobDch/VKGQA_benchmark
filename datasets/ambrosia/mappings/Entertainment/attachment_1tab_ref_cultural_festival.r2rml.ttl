@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_cultural_festival_0_Festivals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Cultural_Festival\", \"Location\" FROM \"Festivals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Festivals/{id}" ; rr:class :Festivals ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Cultural_Festival ; rr:objectMap [ rr:column "Cultural_Festival" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_attachment_1tab_ref_cultural_festival_1_Participants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"FirstName\", \"LastName\", \"Role\", \"Age\" FROM \"Participants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Participant/{id}" ; rr:class :Participant ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Role ; rr:objectMap [ rr:column "Role" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] .

<#tm_attachment_1tab_ref_cultural_festival_2_Events_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"FestivalID\", \"Attendance\", \"ParticipantID\" FROM \"Events\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Events/{id}" ; rr:class :Events ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FestivalID ; rr:objectMap [ rr:column "FestivalID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Attendance ; rr:objectMap [ rr:column "Attendance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ParticipantID ; rr:objectMap [ rr:column "ParticipantID" ] ] .

<#tm_attachment_1tab_ref_cultural_festival_3_Events_ParticipantID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ParticipantID\" FROM \"Events\" WHERE \"ParticipantID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Events/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasParticipant ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Participant/{ParticipantID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_cultural_festival_4_Events_FestivalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"FestivalID\" FROM \"Events\" WHERE \"FestivalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Events/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFestivals ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Festivals/{FestivalID}" ; rr:termType rr:IRI ] ] .

