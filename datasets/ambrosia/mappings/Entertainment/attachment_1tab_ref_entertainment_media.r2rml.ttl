  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:typeName ; rr:objectMap [ rr:column "typeName" ] ] .

<#tm_attachment_1tab_ref_entertainment_media_2_EntertainmentItem_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"releaseYear\", \"genreId\", \"mediaTypeId\" FROM \"EntertainmentItem\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/EntertainmentItem/{id}" ; rr:class :EntertainmentItem ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
