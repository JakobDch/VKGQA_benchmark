  rr:predicateObjectMap [ rr:predicate p:releaseYear ; rr:objectMap [ rr:column "releaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genreId ; rr:objectMap [ rr:column "genreId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:mediaTypeId ; rr:objectMap [ rr:column "mediaTypeId" ] ] .

<#tm_attachment_1tab_ref_entertainment_media_3_EntertainmentItem_mediaTypeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"mediaTypeId\" FROM \"EntertainmentItem\" WHERE \"mediaTypeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/EntertainmentItem/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMediaType ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/MediaType/{mediaTypeId}" ; rr:termType rr:IRI ] ] .

