@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_family_entertainment_0_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Location/{id}" ; rr:class :Location ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_family_entertainment_1_ThemeParks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"parkName\", \"locationId\", \"familyEntertainment\" FROM \"ThemeParks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ThemeParks/{id}" ; rr:class :ThemeParks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:parkName ; rr:objectMap [ rr:column "parkName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationId ; rr:objectMap [ rr:column "locationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:familyEntertainment ; rr:objectMap [ rr:column "familyEntertainment" ] ] .

<#tm_attachment_1tab_ref_family_entertainment_2_ThemeParks_locationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"locationId\" FROM \"ThemeParks\" WHERE \"locationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ThemeParks/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocation ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Location/{locationId}" ; rr:termType rr:IRI ] ] .

