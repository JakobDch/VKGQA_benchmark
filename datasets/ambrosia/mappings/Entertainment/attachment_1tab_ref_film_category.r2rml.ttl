@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_film_category_0_Categories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"categoryName\" FROM \"Categories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Categories/{id}" ; rr:class :Categories ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:categoryName ; rr:objectMap [ rr:column "categoryName" ] ] .

<#tm_attachment_1tab_ref_film_category_1_Films_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"budget\", \"categoryId\" FROM \"Films\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Film/{id}" ; rr:class :Film ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:budget ; rr:objectMap [ rr:column "budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:categoryId ; rr:objectMap [ rr:column "categoryId" ] ] .

<#tm_attachment_1tab_ref_film_category_2_Films_categoryId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"categoryId\" FROM \"Films\" WHERE \"categoryId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Film/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCategories ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Categories/{categoryId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_film_category_3_Actors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\" FROM \"Actors\"""" ] ;
