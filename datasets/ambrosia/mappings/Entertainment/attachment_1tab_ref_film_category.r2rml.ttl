<#tm_attachment_1tab_ref_film_category_5_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"filmId\", \"actorId\", \"roleType\", \"directorId\" FROM \"Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Role/{filmId}/{actorId}/{roleType}/{directorId}" ; rr:class :Role ] ;
  rr:predicateObjectMap [ rr:predicate p:filmId ; rr:objectMap [ rr:column "filmId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:actorId ; rr:objectMap [ rr:column "actorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roleType ; rr:objectMap [ rr:column "roleType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:directorId ; rr:objectMap [ rr:column "directorId" ] ] .

