  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Role/{filmId}/{actorId}/{roleType}/{directorId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirector ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Director/{directorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_film_category_7_Roles_actorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"filmId\", \"actorId\", \"roleType\", \"directorId\" FROM \"Roles\" WHERE \"actorId\" IS NOT NULL""" ] ;
