<#tm_attachment_1tab_ref_film_category_8_Roles_filmId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"filmId\", \"actorId\", \"roleType\", \"directorId\" FROM \"Roles\" WHERE \"filmId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Role/{filmId}/{actorId}/{roleType}/{directorId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilm ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Film/{filmId}" ; rr:termType rr:IRI ] ] .

