@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_film_style_0_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MovieId\", \"Title\", \"FilmStyle\", \"DirectorId\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{MovieId}" ; rr:class :Movie ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieId ; rr:objectMap [ rr:column "MovieId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FilmStyle ; rr:objectMap [ rr:column "FilmStyle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorId ; rr:objectMap [ rr:column "DirectorId" ] ] .

<#tm_attachment_1tab_ref_film_style_1_Movies_DirectorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MovieId\", \"DirectorId\" FROM \"Movies\" WHERE \"DirectorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{MovieId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirector ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Director/{DirectorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_film_style_2_Directors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorId\", \"Name\" FROM \"Directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Director/{DirectorId}" ; rr:class :Director ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorId ; rr:objectMap [ rr:column "DirectorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_ref_film_style_3_MovieDetails_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DetailID\", \"MovieId\", \"ReleaseYear\", \"Budget\", \"Revenue\", \"Duration\", \"Rating\" FROM \"MovieDetails\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/MovieDetails/{DetailID}" ; rr:class :MovieDetails ] ;
  rr:predicateObjectMap [ rr:predicate p:DetailID ; rr:objectMap [ rr:column "DetailID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieId ; rr:objectMap [ rr:column "MovieId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Budget ; rr:objectMap [ rr:column "Budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Revenue ; rr:objectMap [ rr:column "Revenue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Duration ; rr:objectMap [ rr:column "Duration" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] .

<#tm_attachment_1tab_ref_film_style_4_MovieDetails_MovieId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DetailID\", \"MovieId\" FROM \"MovieDetails\" WHERE \"MovieId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/MovieDetails/{DetailID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovie ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{MovieId}" ; rr:termType rr:IRI ] ] .

