@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_music_0_Instrument_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\" FROM \"Instrument\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Instrument/{id}" ; rr:class :Instrument ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_attachment_1tab_ref_music_1_Singer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\", \"birth_date\", \"death_date\" FROM \"Singer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Singer/{id}" ; rr:class :Singer ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birth_date ; rr:objectMap [ rr:column "birth_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:death_date ; rr:objectMap [ rr:column "death_date" ] ] .

<#tm_attachment_1tab_ref_music_2_Music_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"length\", \"MUSIC_TYPE\", \"INSTRUMENT_id\", \"ALBUM_id\", \"SINGER_id\" FROM \"Music\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Music/{id}" ; rr:class :Music ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:length ; rr:objectMap [ rr:column "length" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MUSIC_TYPE ; rr:objectMap [ rr:column "MUSIC_TYPE" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:INSTRUMENT_id ; rr:objectMap [ rr:column "INSTRUMENT_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ALBUM_id ; rr:objectMap [ rr:column "ALBUM_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SINGER_id ; rr:objectMap [ rr:column "SINGER_id" ] ] .

<#tm_attachment_1tab_ref_music_3_Music_INSTRUMENT_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"INSTRUMENT_id\" FROM \"Music\" WHERE \"INSTRUMENT_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Music/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInstrument ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Instrument/{INSTRUMENT_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_music_4_Music_SINGER_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"SINGER_id\" FROM \"Music\" WHERE \"SINGER_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Music/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSinger ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Singer/{SINGER_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_music_5_Music_ALBUM_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ALBUM_id\" FROM \"Music\" WHERE \"ALBUM_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Music/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAlbum ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{ALBUM_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_music_6_Album_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_date\" FROM \"Album\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ; rr:class :Album ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] .

