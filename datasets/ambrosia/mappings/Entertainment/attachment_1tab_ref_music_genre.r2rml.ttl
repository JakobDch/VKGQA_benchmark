@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_music_genre_0_Music_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Music_Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Music_Genre/{id}" ; rr:class :Music_Genre ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_music_genre_1_Songs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"artist_id\", \"album_id\", \"concert_id\", \"music_genre_id\" FROM \"Songs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ; rr:class :Song ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:artist_id ; rr:objectMap [ rr:column "artist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:album_id ; rr:objectMap [ rr:column "album_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:concert_id ; rr:objectMap [ rr:column "concert_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:music_genre_id ; rr:objectMap [ rr:column "music_genre_id" ] ] .

<#tm_attachment_1tab_ref_music_genre_2_Songs_music_genre_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"music_genre_id\" FROM \"Songs\" WHERE \"music_genre_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMusic_Genre ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Music_Genre/{music_genre_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_music_genre_3_Songs_concert_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"concert_id\" FROM \"Songs\" WHERE \"concert_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasConcert ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Concert/{concert_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_music_genre_4_Songs_album_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"album_id\" FROM \"Songs\" WHERE \"album_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAlbum ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{album_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_music_genre_5_Artists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Artists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{id}" ; rr:class :Artist ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_music_genre_6_Albums_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"release_date\", \"artist_id\" FROM \"Albums\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ; rr:class :Album ] ;
