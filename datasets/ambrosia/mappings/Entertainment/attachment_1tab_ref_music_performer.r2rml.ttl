@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_music_performer_0_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"genre_id\", \"name\" FROM \"Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{genre_id}" ; rr:class :Genre ] ;
  rr:predicateObjectMap [ rr:predicate p:genre_id ; rr:objectMap [ rr:column "genre_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_music_performer_1_Albums_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_date\", \"artist_id\" FROM \"Albums\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ; rr:class :Album ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:artist_id ; rr:objectMap [ rr:column "artist_id" ] ] .

<#tm_attachment_1tab_ref_music_performer_2_Albums_artist_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"artist_id\" FROM \"Albums\" WHERE \"artist_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArtist ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{artist_id}" ; rr:termType rr:IRI ] ] .

