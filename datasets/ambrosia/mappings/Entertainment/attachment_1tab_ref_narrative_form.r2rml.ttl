@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_narrative_form_0_NarrativeForms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Narrative_Form\" FROM \"NarrativeForms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/NarrativeForms/{id}" ; rr:class :NarrativeForms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Narrative_Form ; rr:objectMap [ rr:column "Narrative_Form" ] ] .

<#tm_attachment_1tab_ref_narrative_form_1_Epochs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Epoch\" FROM \"Epochs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Epoch/{id}" ; rr:class :Epoch ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Epoch ; rr:objectMap [ rr:column "Epoch" ] ] .

<#tm_attachment_1tab_ref_narrative_form_2_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Birthdate\", \"Deathdate\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{id}" ; rr:class :Author ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Birthdate ; rr:objectMap [ rr:column "Birthdate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Deathdate ; rr:objectMap [ rr:column "Deathdate" ] ] .

<#tm_attachment_1tab_ref_narrative_form_3_Narratives_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"narrative_form_id\", \"epoch_id\", \"title\", \"publication_year\", \"author_id\" FROM \"Narratives\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Narratives/{id}" ; rr:class :Narratives ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:narrative_form_id ; rr:objectMap [ rr:column "narrative_form_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:epoch_id ; rr:objectMap [ rr:column "epoch_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_year ; rr:objectMap [ rr:column "publication_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] .

<#tm_attachment_1tab_ref_narrative_form_4_Narratives_epoch_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"epoch_id\" FROM \"Narratives\" WHERE \"epoch_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Narratives/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEpoch ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Epoch/{epoch_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_narrative_form_5_Narratives_narrative_form_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"narrative_form_id\" FROM \"Narratives\" WHERE \"narrative_form_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Narratives/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNarrativeForms ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/NarrativeForms/{narrative_form_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_narrative_form_6_Narratives_author_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"author_id\" FROM \"Narratives\" WHERE \"author_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Narratives/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{author_id}" ; rr:termType rr:IRI ] ] .

