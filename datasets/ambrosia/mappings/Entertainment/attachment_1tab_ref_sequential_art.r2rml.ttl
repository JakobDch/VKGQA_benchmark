@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_sequential_art_0_Publisher_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Publisher\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{id}" ; rr:class :Publisher ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_sequential_art_1_SequentialArtType_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\" FROM \"SequentialArtType\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/SequentialArtType/{id}" ; rr:class :SequentialArtType ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_attachment_1tab_ref_sequential_art_2_ArtWork_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"publishDate\", \"publisherId\", \"sequentialArtTypeId\" FROM \"ArtWork\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ArtWork/{id}" ; rr:class :ArtWork ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publishDate ; rr:objectMap [ rr:column "publishDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publisherId ; rr:objectMap [ rr:column "publisherId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:sequentialArtTypeId ; rr:objectMap [ rr:column "sequentialArtTypeId" ] ] .

<#tm_attachment_1tab_ref_sequential_art_3_ArtWork_sequentialArtTypeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"sequentialArtTypeId\" FROM \"ArtWork\" WHERE \"sequentialArtTypeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ArtWork/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSequentialArtType ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/SequentialArtType/{sequentialArtTypeId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_sequential_art_4_ArtWork_publisherId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"publisherId\" FROM \"ArtWork\" WHERE \"publisherId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ArtWork/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublisher ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{publisherId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_sequential_art_5_Artist_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"artWorkId\" FROM \"Artist\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{id}" ; rr:class :Artist ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:artWorkId ; rr:objectMap [ rr:column "artWorkId" ] ] .

<#tm_attachment_1tab_ref_sequential_art_6_Artist_artWorkId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"artWorkId\" FROM \"Artist\" WHERE \"artWorkId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArtWork ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ArtWork/{artWorkId}" ; rr:termType rr:IRI ] ] .

