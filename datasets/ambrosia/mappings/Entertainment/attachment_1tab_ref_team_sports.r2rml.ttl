  rr:predicateObjectMap [ rr:predicate p:PlayerId ; rr:objectMap [ rr:column "PlayerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FitnessLevelId ; rr:objectMap [ rr:column "FitnessLevelId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StatsText ; rr:objectMap [ rr:column "StatsText" ] ] .

