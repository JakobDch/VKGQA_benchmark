@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_team_sports_0_Team_Type_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"TypeName\" FROM \"Team_Type\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Team_Type/{id}" ; rr:class :Team_Type ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeName ; rr:objectMap [ rr:column "TypeName" ] ] .

<#tm_attachment_1tab_ref_team_sports_1_Sports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"SportName\" FROM \"Sports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Sports/{id}" ; rr:class :Sports ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SportName ; rr:objectMap [ rr:column "SportName" ] ] .

<#tm_attachment_1tab_ref_team_sports_2_Players_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Age\", \"TeamTypeId\", \"SportId\" FROM \"Players\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Players/{id}" ; rr:class :Players ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TeamTypeId ; rr:objectMap [ rr:column "TeamTypeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SportId ; rr:objectMap [ rr:column "SportId" ] ] .

<#tm_attachment_1tab_ref_team_sports_3_Players_SportId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"SportId\" FROM \"Players\" WHERE \"SportId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Players/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSports ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Sports/{SportId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_team_sports_4_Players_TeamTypeId_fk> a rr:TriplesMap ;
