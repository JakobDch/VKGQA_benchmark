<#tm_attachment_1tab_ref_team_sports_5_FitnessLevels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"LevelName\" FROM \"FitnessLevels\"""" ] ;
