  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/PlayerStats/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPlayers ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Players/{PlayerId}" ; rr:termType rr:IRI ] ] .

