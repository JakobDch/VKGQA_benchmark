<#tm_attachment_1tab_ref_team_sports_6_PlayerStats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"PlayerId\", \"FitnessLevelId\", \"StatsText\" FROM \"PlayerStats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/PlayerStats/{id}" ; rr:class :PlayerStats ] ;
