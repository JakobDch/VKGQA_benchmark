@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_television_genre_0_TelevisionShows_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"year\", \"network\", \"genre\" FROM \"TelevisionShows\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{id}" ; rr:class :Tv_Show ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:year ; rr:objectMap [ rr:column "year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:network ; rr:objectMap [ rr:column "network" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] .

<#tm_attachment_1tab_ref_television_genre_1_TelevisionShows_genre_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"genre\" FROM \"TelevisionShows\" WHERE \"genre\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenre ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{genre}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_television_genre_2_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"name\" FROM \"Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{name}" ; rr:class :Genre ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_television_genre_3_Seasons_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"show_id\", \"number_of_seasons\", \"release_year\" FROM \"Seasons\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Seasons/{id}" ; rr:class :Seasons ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:show_id ; rr:objectMap [ rr:column "show_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number_of_seasons ; rr:objectMap [ rr:column "number_of_seasons" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_year ; rr:objectMap [ rr:column "release_year" ] ] .

<#tm_attachment_1tab_ref_television_genre_4_Seasons_show_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"show_id\" FROM \"Seasons\" WHERE \"show_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Seasons/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTv_Show ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{show_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_television_genre_5_Episodes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"season_id\", \"episode_number\", \"title\", \"run_time\", \"airdate\" FROM \"Episodes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Episodes/{id}" ; rr:class :Episodes ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:season_id ; rr:objectMap [ rr:column "season_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:episode_number ; rr:objectMap [ rr:column "episode_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:run_time ; rr:objectMap [ rr:column "run_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:airdate ; rr:objectMap [ rr:column "airdate" ] ] .

<#tm_attachment_1tab_ref_television_genre_6_Episodes_season_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"season_id\" FROM \"Episodes\" WHERE \"season_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Episodes/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSeasons ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Seasons/{season_id}" ; rr:termType rr:IRI ] ] .

