@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_theatrical_form_0_Author_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Author\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{id}" ; rr:class :Author ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_theatrical_form_1_Theatrical_Form_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"form\" FROM \"Theatrical_Form\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Theatrical_Form/{id}" ; rr:class :Theatrical_Form ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:form ; rr:objectMap [ rr:column "form" ] ] .

<#tm_attachment_1tab_ref_theatrical_form_2_Play_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"authorId\", \"theatricalFormId\" FROM \"Play\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Play/{id}" ; rr:class :Play ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:authorId ; rr:objectMap [ rr:column "authorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:theatricalFormId ; rr:objectMap [ rr:column "theatricalFormId" ] ] .

<#tm_attachment_1tab_ref_theatrical_form_3_Play_theatricalFormId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"theatricalFormId\" FROM \"Play\" WHERE \"theatricalFormId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Play/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTheatrical_Form ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Theatrical_Form/{theatricalFormId}" ; rr:termType rr:IRI ] ] .

