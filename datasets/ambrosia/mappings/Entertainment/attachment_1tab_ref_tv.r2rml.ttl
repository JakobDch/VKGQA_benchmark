@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_tv_0_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Name\" FROM \"Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{Id}" ; rr:class :Genre ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_ref_tv_1_TVShows_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Title\", \"Type\", \"ReleaseDate\", \"GENRE_ID\" FROM \"TVShows\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{Id}" ; rr:class :Tv_Show ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GENRE_ID ; rr:objectMap [ rr:column "GENRE_ID" ] ] .

<#tm_attachment_1tab_ref_tv_2_TVShows_GENRE_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"GENRE_ID\" FROM \"TVShows\" WHERE \"GENRE_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{Id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenre ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{GENRE_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_tv_3_EpisodeCounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Show_ID\", \"Number_of_Episodes\" FROM \"EpisodeCounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/EpisodeCounts/{_amb_rowid}" ; rr:class :EpisodeCounts ] ;
  rr:predicateObjectMap [ rr:predicate p:Show_ID ; rr:objectMap [ rr:column "Show_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_Episodes ; rr:objectMap [ rr:column "Number_of_Episodes" ] ] .

<#tm_attachment_1tab_ref_tv_4_EpisodeCounts_Show_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Show_ID\" FROM \"EpisodeCounts\" WHERE \"Show_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/EpisodeCounts/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTv_Show ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{Show_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_tv_5_Ratings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Show_ID\", \"RatingValue\", \"ReviewText\", \"RaterName\", \"RatedOn\" FROM \"Ratings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Rating/{_amb_rowid}" ; rr:class :Rating ] ;
  rr:predicateObjectMap [ rr:predicate p:Show_ID ; rr:objectMap [ rr:column "Show_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RatingValue ; rr:objectMap [ rr:column "RatingValue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReviewText ; rr:objectMap [ rr:column "ReviewText" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RaterName ; rr:objectMap [ rr:column "RaterName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RatedOn ; rr:objectMap [ rr:column "RatedOn" ] ] .

<#tm_attachment_1tab_ref_tv_6_Ratings_Show_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Show_ID\" FROM \"Ratings\" WHERE \"Show_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Rating/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTv_Show ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{Show_ID}" ; rr:termType rr:IRI ] ] .

