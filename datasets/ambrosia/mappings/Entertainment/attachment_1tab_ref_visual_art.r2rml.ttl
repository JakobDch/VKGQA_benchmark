@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_visual_art_0_ArtType_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"TypeName\" FROM \"ArtType\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ArtType/{id}" ; rr:class :ArtType ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeName ; rr:objectMap [ rr:column "TypeName" ] ] .

<#tm_attachment_1tab_ref_visual_art_1_VisualArt_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ArtTypeId\", \"Title\", \"Description\" FROM \"VisualArt\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/VisualArt/{id}" ; rr:class :VisualArt ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtTypeId ; rr:objectMap [ rr:column "ArtTypeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_attachment_1tab_ref_visual_art_2_VisualArt_ArtTypeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ArtTypeId\" FROM \"VisualArt\" WHERE \"ArtTypeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/VisualArt/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArtType ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ArtType/{ArtTypeId}" ; rr:termType rr:IRI ] ] .

