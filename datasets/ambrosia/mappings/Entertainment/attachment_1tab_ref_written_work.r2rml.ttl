@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_written_work_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorID\", \"Name\", \"Country\", \"BirthDate\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{AuthorID}" ; rr:class :Author ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] .

<#tm_attachment_1tab_ref_written_work_1_WrittenWorks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"WorkID\", \"Title\", \"TypeOfWork\", \"PublishedDate\", \"WordCount\" FROM \"WrittenWorks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WrittenWorks/{WorkID}" ; rr:class :WrittenWorks ] ;
  rr:predicateObjectMap [ rr:predicate p:WorkID ; rr:objectMap [ rr:column "WorkID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeOfWork ; rr:objectMap [ rr:column "TypeOfWork" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublishedDate ; rr:objectMap [ rr:column "PublishedDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:WordCount ; rr:objectMap [ rr:column "WordCount" ] ] .

<#tm_attachment_1tab_ref_written_work_2_WrittenWorks_TypeOfWork_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"WorkID\", \"TypeOfWork\" FROM \"WrittenWorks\" WHERE \"TypeOfWork\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WrittenWorks/{WorkID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTypesOfWork ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/TypesOfWork/{TypeOfWork}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_written_work_3_TypesOfWork_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TypeID\", \"Type\" FROM \"TypesOfWork\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/TypesOfWork/{TypeID}" ; rr:class :TypesOfWork ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeID ; rr:objectMap [ rr:column "TypeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] .

<#tm_attachment_1tab_ref_written_work_4_Writes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"WriteID\", \"AuthorID\", \"WorkID\" FROM \"Writes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Writes/{WriteID}" ; rr:class :Writes ] ;
  rr:predicateObjectMap [ rr:predicate p:WriteID ; rr:objectMap [ rr:column "WriteID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:WorkID ; rr:objectMap [ rr:column "WorkID" ] ] .

<#tm_attachment_1tab_ref_written_work_5_Writes_WorkID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"WriteID\", \"WorkID\" FROM \"Writes\" WHERE \"WorkID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Writes/{WriteID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWrittenWorks ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WrittenWorks/{WorkID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_written_work_6_Writes_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"WriteID\", \"AuthorID\" FROM \"Writes\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Writes/{WriteID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_written_work_7_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PublisherID\", \"Name\", \"Address\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{PublisherID}" ; rr:class :Publisher ] ;
