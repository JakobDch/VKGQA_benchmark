<#tm_attachment_1tab_ref_written_work_8_WorksPublishedByPublisher_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"WorkID\", \"PublisherID\", \"PublicationYear\" FROM \"WorksPublishedByPublisher\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WorksPublishedByPublisher/{_amb_rowid}" ; rr:class :WorksPublishedByPublisher ] ;
  rr:predicateObjectMap [ rr:predicate p:WorkID ; rr:objectMap [ rr:column "WorkID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationYear ; rr:objectMap [ rr:column "PublicationYear" ] ] .

<#tm_attachment_1tab_ref_written_work_9_WorksPublishedByPublisher_PublisherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"PublisherID\" FROM \"WorksPublishedByPublisher\" WHERE \"PublisherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WorksPublishedByPublisher/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublisher ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{PublisherID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_written_work_10_WorksPublishedByPublisher_WorkID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"WorkID\" FROM \"WorksPublishedByPublisher\" WHERE \"WorkID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WorksPublishedByPublisher/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWrittenWorks ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WrittenWorks/{WorkID}" ; rr:termType rr:IRI ] ] .

