  rr:predicateObjectMap [ rr:predicate p:character_name ; rr:objectMap [ rr:column "character_name" ] ] .

<#tm_attachment_1tab_val_age_group_4_Book_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"age_group\", \"illustrator\", \"author_id\", \"publisher_id\", \"genre_id\", \"main_character_id\" FROM \"Book\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{id}" ; rr:class :Book ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:age_group ; rr:objectMap [ rr:column "age_group" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:illustrator ; rr:objectMap [ rr:column "illustrator" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publisher_id ; rr:objectMap [ rr:column "publisher_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre_id ; rr:objectMap [ rr:column "genre_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:main_character_id ; rr:objectMap [ rr:column "main_character_id" ] ] .

<#tm_attachment_1tab_val_age_group_5_Book_main_character_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"main_character_id\" FROM \"Book\" WHERE \"main_character_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCharacter ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Character/{main_character_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_age_group_6_Book_genre_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"genre_id\" FROM \"Book\" WHERE \"genre_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenre ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{genre_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_age_group_7_Book_publisher_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"publisher_id\" FROM \"Book\" WHERE \"publisher_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublisher ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{publisher_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_age_group_8_Book_author_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"author_id\" FROM \"Book\" WHERE \"author_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{author_id}" ; rr:termType rr:IRI ] ] .

