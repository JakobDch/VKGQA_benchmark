@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_audio_format_0_Podcasters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\", \"years_experience\" FROM \"Podcasters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Podcasters/{id}" ; rr:class :Podcasters ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_experience ; rr:objectMap [ rr:column "years_experience" ] ] .

<#tm_attachment_1tab_val_audio_format_1_Shows_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"genre\", \"network\", \"audio_format\", \"host\" FROM \"Shows\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Show/{id}" ; rr:class :Show ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:network ; rr:objectMap [ rr:column "network" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:audio_format ; rr:objectMap [ rr:column "audio_format" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:host ; rr:objectMap [ rr:column "host" ] ] .

<#tm_attachment_1tab_val_audio_format_2_Shows_host_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"host\" FROM \"Shows\" WHERE \"host\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Show/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPodcasters ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Podcasters/{host}" ; rr:termType rr:IRI ] ] .

