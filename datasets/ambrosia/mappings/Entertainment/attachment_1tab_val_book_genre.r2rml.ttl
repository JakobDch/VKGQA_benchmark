@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_book_genre_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorID\", \"Name\", \"BirthDate\", \"Country\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{AuthorID}" ; rr:class :Author ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_val_book_genre_1_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PublisherID\", \"Name\", \"Address\", \"YearEstablished\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{PublisherID}" ; rr:class :Publisher ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearEstablished ; rr:objectMap [ rr:column "YearEstablished" ] ] .

<#tm_attachment_1tab_val_book_genre_2_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GenreID\", \"Description\" FROM \"Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{GenreID}" ; rr:class :Genre ] ;
  rr:predicateObjectMap [ rr:predicate p:GenreID ; rr:objectMap [ rr:column "GenreID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_attachment_1tab_val_book_genre_3_Books_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"Title\", \"PageCount\", \"Book_Genre\", \"Year_Of_Publication\", \"AuthorID\", \"PublisherID\", \"GenreID\" FROM \"Books\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{BookID}" ; rr:class :Book ] ;
  rr:predicateObjectMap [ rr:predicate p:BookID ; rr:objectMap [ rr:column "BookID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PageCount ; rr:objectMap [ rr:column "PageCount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Book_Genre ; rr:objectMap [ rr:column "Book_Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year_Of_Publication ; rr:objectMap [ rr:column "Year_Of_Publication" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GenreID ; rr:objectMap [ rr:column "GenreID" ] ] .

<#tm_attachment_1tab_val_book_genre_4_Books_GenreID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"GenreID\" FROM \"Books\" WHERE \"GenreID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{BookID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenre ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{GenreID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_book_genre_5_Books_PublisherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"PublisherID\" FROM \"Books\" WHERE \"PublisherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{BookID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublisher ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{PublisherID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_book_genre_6_Books_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"AuthorID\" FROM \"Books\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{BookID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{AuthorID}" ; rr:termType rr:IRI ] ] .

