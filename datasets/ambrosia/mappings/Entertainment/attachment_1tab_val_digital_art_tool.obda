[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Digital_Tools_base
target		ex:Digital_Tools/{id} a :Digital_Tools ; p:id {id} ; p:name {Name} ; p:Category {Category} ; p:Access {Access} ; p:Price {Price} .
source		SELECT `id`, `Name`, `Category`, `Access`, `Price` FROM `Digital_Tools`

mappingId	Graphics_Designers_base
target		ex:Graphics_Designers/{id} a :Graphics_Designers ; p:id {id} ; p:name {Name} ; p:Age {Age} ; p:Experience {Experience} ; p:Digital_Tool_ID {Digital_Tool_ID} .
source		SELECT `id`, `Name`, `Age`, `Experience`, `Digital_Tool_ID` FROM `Graphics_Designers`

mappingId	Graphics_Designers_Digital_Tool_ID_fk
target		ex:Graphics_Designers/{id} p:hasDigital_Tools ex:Digital_Tools/{Digital_Tool_ID} .
source		SELECT `id`, `Digital_Tool_ID` FROM `Graphics_Designers` WHERE `Digital_Tool_ID` IS NOT NULL

mappingId	Web_Designers_base
target		ex:Web_Designers/{id} a :Web_Designers ; p:id {id} ; p:name {Name} ; p:Age {Age} ; p:Experience {Experience} ; p:Digital_Tool_ID {Digital_Tool_ID} .
source		SELECT `id`, `Name`, `Age`, `Experience`, `Digital_Tool_ID` FROM `Web_Designers`

mappingId	Web_Designers_Digital_Tool_ID_fk
target		ex:Web_Designers/{id} p:hasDigital_Tools ex:Digital_Tools/{Digital_Tool_ID} .
source		SELECT `id`, `Digital_Tool_ID` FROM `Web_Designers` WHERE `Digital_Tool_ID` IS NOT NULL

mappingId	Movie_Producers_base
target		ex:Movie_Producers/{id} a :Movie_Producers ; p:id {id} ; p:name {Name} ; p:Company {Company} ; p:Budget {Budget} .
source		SELECT `id`, `Name`, `Company`, `Budget` FROM `Movie_Producers`

mappingId	Movie_Directors_base
target		ex:Movie_Directors/{id} a :Movie_Directors ; p:id {id} ; p:name {Name} ; p:Age {Age} ; p:YearsOfExperience {YearsOfExperience} .
source		SELECT `id`, `Name`, `Age`, `YearsOfExperience` FROM `Movie_Directors`

mappingId	Movies_base
target		ex:Movie/{id} a :Movie ; p:id {id} ; p:Title {Title} ; p:Producer_ID {Producer_ID} ; p:Director_ID {Director_ID} ; p:ReleaseDate {ReleaseDate} ; p:BoxOfficeCollection {BoxOfficeCollection} .
source		SELECT `id`, `Title`, `Producer_ID`, `Director_ID`, `ReleaseDate`, `BoxOfficeCollection` FROM `Movies`

mappingId	Movies_Director_ID_fk
target		ex:Movie/{id} p:hasMovie_Directors ex:Movie_Directors/{Director_ID} .
source		SELECT `id`, `Director_ID` FROM `Movies` WHERE `Director_ID` IS NOT NULL

mappingId	Movies_Producer_ID_fk
target		ex:Movie/{id} p:hasMovie_Producers ex:Movie_Producers/{Producer_ID} .
source		SELECT `id`, `Producer_ID` FROM `Movies` WHERE `Producer_ID` IS NOT NULL

]]
