@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_digital_art_tool_0_Digital_Tools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Category\", \"Access\", \"Price\" FROM \"Digital_Tools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Digital_Tools/{id}" ; rr:class :Digital_Tools ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Category ; rr:objectMap [ rr:column "Category" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Access ; rr:objectMap [ rr:column "Access" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_attachment_1tab_val_digital_art_tool_1_Graphics_Designers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Age\", \"Experience\", \"Digital_Tool_ID\" FROM \"Graphics_Designers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Graphics_Designers/{id}" ; rr:class :Graphics_Designers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience ; rr:objectMap [ rr:column "Experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Digital_Tool_ID ; rr:objectMap [ rr:column "Digital_Tool_ID" ] ] .

<#tm_attachment_1tab_val_digital_art_tool_2_Graphics_Designers_Digital_Tool_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Digital_Tool_ID\" FROM \"Graphics_Designers\" WHERE \"Digital_Tool_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Graphics_Designers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDigital_Tools ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Digital_Tools/{Digital_Tool_ID}" ; rr:termType rr:IRI ] ] .

