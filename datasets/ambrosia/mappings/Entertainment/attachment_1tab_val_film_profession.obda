[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Production_base
target		ex:Production/{ID} a :Production ; p:ID {ID} ; p:BirthDate {BirthDate} ; p:Film_Profession {Film_Profession} ; p:Award {Award} ; p:name {FullName} .
source		SELECT `ID`, `BirthDate`, `Film_Profession`, `Award`, `FullName` FROM `Production`

mappingId	Movies_base
target		ex:Movie/{MovieID} a :Movie ; p:MovieID {MovieID} ; p:Title {Title} ; p:ReleaseYear {ReleaseYear} ; p:Genre {Genre} .
source		SELECT `MovieID`, `Title`, `ReleaseYear`, `Genre` FROM `Movies`

]]
