  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Role ; rr:objectMap [ rr:column "Role" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Film_ID ; rr:objectMap [ rr:column "Film_ID" ] ] .

<#tm_attachment_1tab_val_film_style_3_Character_Film_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Film_ID\" FROM \"Character\" WHERE \"Film_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Character/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilm ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Film/{Film_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_film_style_4_Character_Role_fk> a rr:TriplesMap ;
