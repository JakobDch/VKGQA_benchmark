@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_film_style_0_Film_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"ReleaseYear\", \"Runtime\", \"Film_Style\", \"Director\" FROM \"Film\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Film/{ID}" ; rr:class :Film ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Runtime ; rr:objectMap [ rr:column "Runtime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Film_Style ; rr:objectMap [ rr:column "Film_Style" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Director ; rr:objectMap [ rr:column "Director" ] ] .

<#tm_attachment_1tab_val_film_style_1_Actor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Birthdate\", \"Nationality\", \"Gender\" FROM \"Actor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Actor/{ID}" ; rr:class :Actor ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Birthdate ; rr:objectMap [ rr:column "Birthdate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Nationality ; rr:objectMap [ rr:column "Nationality" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Gender ; rr:objectMap [ rr:column "Gender" ] ] .

<#tm_attachment_1tab_val_film_style_2_Character_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Description\", \"Role\", \"Film_ID\" FROM \"Character\"""" ] ;
