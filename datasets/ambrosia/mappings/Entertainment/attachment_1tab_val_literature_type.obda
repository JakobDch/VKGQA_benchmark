[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Authors_base
target		ex:Author/{AuthorID} a :Author ; p:AuthorID {AuthorID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:BirthDate {BirthDate} ; p:Country {Country} .
source		SELECT `AuthorID`, `FirstName`, `LastName`, `BirthDate`, `Country` FROM `Authors`

mappingId	Publishers_base
target		ex:Publisher/{PublisherID} a :Publisher ; p:PublisherID {PublisherID} ; p:name {Name} ; p:Address {Address} ; p:PhoneNumber {PhoneNumber} .
source		SELECT `PublisherID`, `Name`, `Address`, `PhoneNumber` FROM `Publishers`

mappingId	Literatures_base
target		ex:Literatures/{LitID} a :Literatures ; p:LitID {LitID} ; p:Title {Title} ; p:Synopsis {Synopsis} ; p:Language {Language} ; p:PublicationYear {PublicationYear} ; p:LiteratureType {LiteratureType} ; p:AuthorID {AuthorID} ; p:PublisherID {PublisherID} .
source		SELECT `LitID`, `Title`, `Synopsis`, `Language`, `PublicationYear`, `LiteratureType`, `AuthorID`, `PublisherID` FROM `Literatures`

mappingId	Literatures_PublisherID_fk
target		ex:Literatures/{LitID} p:hasPublisher ex:Publisher/{PublisherID} .
source		SELECT `LitID`, `PublisherID` FROM `Literatures` WHERE `PublisherID` IS NOT NULL

mappingId	Literatures_AuthorID_fk
target		ex:Literatures/{LitID} p:hasAuthor ex:Author/{AuthorID} .
source		SELECT `LitID`, `AuthorID` FROM `Literatures` WHERE `AuthorID` IS NOT NULL

mappingId	Editions_base
target		ex:Editions/{EditionID} a :Editions ; p:EditionID {EditionID} ; p:ISBN {ISBN} ; p:ReleaseDate {ReleaseDate} ; p:Price {Price} ; p:Quantity {Quantity} ; p:LitID {LitID} .
source		SELECT `EditionID`, `ISBN`, `ReleaseDate`, `Price`, `Quantity`, `LitID` FROM `Editions`

mappingId	Editions_LitID_fk
target		ex:Editions/{EditionID} p:hasLiteratures ex:Literatures/{LitID} .
source		SELECT `EditionID`, `LitID` FROM `Editions` WHERE `LitID` IS NOT NULL

mappingId	Reviews_base
target		ex:Review/{ReviewID} a :Review ; p:ReviewID {ReviewID} ; p:Rating {Rating} ; p:CommentText {CommentText} ; p:ReviewerID {ReviewerID} ; p:EditionID {EditionID} .
source		SELECT `ReviewID`, `Rating`, `CommentText`, `ReviewerID`, `EditionID` FROM `Reviews`

mappingId	Reviews_EditionID_fk
target		ex:Review/{ReviewID} p:hasEditions ex:Editions/{EditionID} .
source		SELECT `ReviewID`, `EditionID` FROM `Reviews` WHERE `EditionID` IS NOT NULL

mappingId	Reviews_ReviewerID_fk
target		ex:Review/{ReviewID} p:hasAuthor ex:Author/{ReviewerID} .
source		SELECT `ReviewID`, `ReviewerID` FROM `Reviews` WHERE `ReviewerID` IS NOT NULL

]]
