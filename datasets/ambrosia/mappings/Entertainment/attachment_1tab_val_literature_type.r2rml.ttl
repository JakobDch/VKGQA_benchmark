@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_literature_type_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorID\", \"FirstName\", \"LastName\", \"BirthDate\", \"Country\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{AuthorID}" ; rr:class :Author ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_val_literature_type_1_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PublisherID\", \"Name\", \"Address\", \"PhoneNumber\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{PublisherID}" ; rr:class :Publisher ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_attachment_1tab_val_literature_type_2_Literatures_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LitID\", \"Title\", \"Synopsis\", \"Language\", \"PublicationYear\", \"LiteratureType\", \"AuthorID\", \"PublisherID\" FROM \"Literatures\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Literatures/{LitID}" ; rr:class :Literatures ] ;
  rr:predicateObjectMap [ rr:predicate p:LitID ; rr:objectMap [ rr:column "LitID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Synopsis ; rr:objectMap [ rr:column "Synopsis" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Language ; rr:objectMap [ rr:column "Language" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationYear ; rr:objectMap [ rr:column "PublicationYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LiteratureType ; rr:objectMap [ rr:column "LiteratureType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] .

<#tm_attachment_1tab_val_literature_type_3_Literatures_PublisherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LitID\", \"PublisherID\" FROM \"Literatures\" WHERE \"PublisherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Literatures/{LitID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublisher ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{PublisherID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_literature_type_4_Literatures_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LitID\", \"AuthorID\" FROM \"Literatures\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Literatures/{LitID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_literature_type_5_Editions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EditionID\", \"ISBN\", \"ReleaseDate\", \"Price\", \"Quantity\", \"LitID\" FROM \"Editions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Editions/{EditionID}" ; rr:class :Editions ] ;
  rr:predicateObjectMap [ rr:predicate p:EditionID ; rr:objectMap [ rr:column "EditionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ISBN ; rr:objectMap [ rr:column "ISBN" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LitID ; rr:objectMap [ rr:column "LitID" ] ] .

<#tm_attachment_1tab_val_literature_type_6_Editions_LitID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EditionID\", \"LitID\" FROM \"Editions\" WHERE \"LitID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Editions/{EditionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLiteratures ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Literatures/{LitID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_literature_type_7_Reviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReviewID\", \"Rating\", \"CommentText\", \"ReviewerID\", \"EditionID\" FROM \"Reviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Review/{ReviewID}" ; rr:class :Review ] ;
  rr:predicateObjectMap [ rr:predicate p:ReviewID ; rr:objectMap [ rr:column "ReviewID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CommentText ; rr:objectMap [ rr:column "CommentText" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReviewerID ; rr:objectMap [ rr:column "ReviewerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EditionID ; rr:objectMap [ rr:column "EditionID" ] ] .

<#tm_attachment_1tab_val_literature_type_8_Reviews_EditionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReviewID\", \"EditionID\" FROM \"Reviews\" WHERE \"EditionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Review/{ReviewID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEditions ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Editions/{EditionID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_literature_type_9_Reviews_ReviewerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReviewID\", \"ReviewerID\" FROM \"Reviews\" WHERE \"ReviewerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Review/{ReviewID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{ReviewerID}" ; rr:termType rr:IRI ] ] .

