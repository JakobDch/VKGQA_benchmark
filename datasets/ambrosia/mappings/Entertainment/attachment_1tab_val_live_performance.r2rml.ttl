  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Plays_at_Venues/{PlayID}/{VenueName}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLive_Event ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Live_Event/{VenueName}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_live_performance_9_Plays_at_Venues_PlayID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PlayID\", \"VenueName\" FROM \"Plays_at_Venues\" WHERE \"PlayID\" IS NOT NULL""" ] ;
