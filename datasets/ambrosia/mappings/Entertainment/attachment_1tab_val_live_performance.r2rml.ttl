@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_live_performance_0_Live_Event_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EventID\", \"Title\", \"Date\", \"Time\", \"VenueName\", \"Live_Performance\", \"Venue_Capacity\" FROM \"Live_Event\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Live_Event/{EventID}" ; rr:class :Live_Event ] ;
  rr:predicateObjectMap [ rr:predicate p:EventID ; rr:objectMap [ rr:column "EventID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Time ; rr:objectMap [ rr:column "Time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:VenueName ; rr:objectMap [ rr:column "VenueName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Live_Performance ; rr:objectMap [ rr:column "Live_Performance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Venue_Capacity ; rr:objectMap [ rr:column "Venue_Capacity" ] ] .

<#tm_attachment_1tab_val_live_performance_1_Artist_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArtistID\", \"Name\", \"Genre\" FROM \"Artist\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{ArtistID}" ; rr:class :Artist ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtistID ; rr:objectMap [ rr:column "ArtistID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] .

