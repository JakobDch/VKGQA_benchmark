<#tm_attachment_1tab_val_live_performance_5_Artists_in_Concert_ArtistID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ConcertID\", \"ArtistID\" FROM \"Artists_in_Concert\" WHERE \"ArtistID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artists_in_Concert/{ConcertID}/{ArtistID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArtist ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{ArtistID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_live_performance_6_Artists_in_Concert_ConcertID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ConcertID\", \"ArtistID\" FROM \"Artists_in_Concert\" WHERE \"ConcertID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artists_in_Concert/{ConcertID}/{ArtistID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasConcert ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Concert/{ConcertID}" ; rr:termType rr:IRI ] ] .

