<#tm_attachment_1tab_val_live_performance_4_Artists_in_Concert_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ConcertID\", \"ArtistID\" FROM \"Artists_in_Concert\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artists_in_Concert/{ConcertID}/{ArtistID}" ; rr:class :Artists_in_Concert ] ;
  rr:predicateObjectMap [ rr:predicate p:ConcertID ; rr:objectMap [ rr:column "ConcertID" ] ] ;
