  rr:predicateObjectMap [ rr:predicate p:Author ; rr:objectMap [ rr:column "Author" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] .

<#tm_attachment_1tab_val_live_performance_3_Concert_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ConcertID\", \"Band_or_Artist_name\", \"Album\" FROM \"Concert\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Concert/{ConcertID}" ; rr:class :Concert ] ;
  rr:predicateObjectMap [ rr:predicate p:ConcertID ; rr:objectMap [ rr:column "ConcertID" ] ] ;
