@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_music_0_Music_Genre_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Genre\" FROM \"Music_Genre\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Music_Genre/{id}" ; rr:class :Music_Genre ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] .

<#tm_attachment_1tab_val_music_1_Singers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"SingerName\" FROM \"Singers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Singer/{id}" ; rr:class :Singer ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SingerName ; rr:objectMap [ rr:column "SingerName" ] ] .

<#tm_attachment_1tab_val_music_2_Albums_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"AlbumTitle\", \"ReleaseYear\", \"Music_Genre_id\" FROM \"Albums\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ; rr:class :Album ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AlbumTitle ; rr:objectMap [ rr:column "AlbumTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Music_Genre_id ; rr:objectMap [ rr:column "Music_Genre_id" ] ] .

<#tm_attachment_1tab_val_music_3_Albums_Music_Genre_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Music_Genre_id\" FROM \"Albums\" WHERE \"Music_Genre_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMusic_Genre ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Music_Genre/{Music_Genre_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_music_4_Songs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"SongTitle\", \"Duration\", \"Music\", \"Singer_id\", \"Album_id\" FROM \"Songs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ; rr:class :Song ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SongTitle ; rr:objectMap [ rr:column "SongTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Duration ; rr:objectMap [ rr:column "Duration" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Music ; rr:objectMap [ rr:column "Music" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Singer_id ; rr:objectMap [ rr:column "Singer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Album_id ; rr:objectMap [ rr:column "Album_id" ] ] .

<#tm_attachment_1tab_val_music_5_Songs_Album_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Album_id\" FROM \"Songs\" WHERE \"Album_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAlbum ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{Album_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_music_6_Songs_Singer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Singer_id\" FROM \"Songs\" WHERE \"Singer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSinger ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Singer/{Singer_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_music_7_Performances_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"PerformanceDate\", \"Venue\", \"Song_id\" FROM \"Performances\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performance/{id}" ; rr:class :Performance ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PerformanceDate ; rr:objectMap [ rr:column "PerformanceDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Venue ; rr:objectMap [ rr:column "Venue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Song_id ; rr:objectMap [ rr:column "Song_id" ] ] .

<#tm_attachment_1tab_val_music_8_Performances_Song_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Song_id\" FROM \"Performances\" WHERE \"Song_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performance/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSong ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{Song_id}" ; rr:termType rr:IRI ] ] .

