@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_music_band_0_Music_Bands_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Genre\", \"Founding_Year\", \"Country\" FROM \"Music_Bands\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Music_Bands/{id}" ; rr:class :Music_Bands ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Founding_Year ; rr:objectMap [ rr:column "Founding_Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_val_music_band_1_Albums_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Release_Date\", \"Label\", \"Genre\" FROM \"Albums\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ; rr:class :Album ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Release_Date ; rr:objectMap [ rr:column "Release_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Label ; rr:objectMap [ rr:column "Label" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] .

<#tm_attachment_1tab_val_music_band_2_Albums_Genre_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Genre\" FROM \"Albums\" WHERE \"Genre\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMusic_Bands ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Music_Bands/{Genre}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_music_band_3_Songs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Length\", \"Album_id\" FROM \"Songs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ; rr:class :Song ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Length ; rr:objectMap [ rr:column "Length" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Album_id ; rr:objectMap [ rr:column "Album_id" ] ] .

<#tm_attachment_1tab_val_music_band_4_Songs_Album_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Album_id\" FROM \"Songs\" WHERE \"Album_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAlbum ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{Album_id}" ; rr:termType rr:IRI ] ] .

