  rr:predicateObjectMap [ rr:predicate p:Favorite_band_id ; rr:objectMap [ rr:column "Favorite_band_id" ] ] .

<#tm_attachment_1tab_val_music_band_8_Fans_Favorite_band_id_fk> a rr:TriplesMap ;
