<#tm_attachment_1tab_val_music_band_10_Reviews_Song_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Song_id\" FROM \"Reviews\" WHERE \"Song_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Review/{id}" ] ;
