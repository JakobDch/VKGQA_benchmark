@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_music_performer_0_MovieActor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ActorID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"Nationality\" FROM \"MovieActor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/MovieActor/{ActorID}" ; rr:class :MovieActor ] ;
  rr:predicateObjectMap [ rr:predicate p:ActorID ; rr:objectMap [ rr:column "ActorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Nationality ; rr:objectMap [ rr:column "Nationality" ] ] .

<#tm_attachment_1tab_val_music_performer_1_MusicPerformer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PerformerID\", \"Name\", \"Genre\", \"YearsInIndustry\", \"MusicPerformerType\" FROM \"MusicPerformer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/MusicPerformer/{PerformerID}" ; rr:class :MusicPerformer ] ;
  rr:predicateObjectMap [ rr:predicate p:PerformerID ; rr:objectMap [ rr:column "PerformerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearsInIndustry ; rr:objectMap [ rr:column "YearsInIndustry" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MusicPerformerType ; rr:objectMap [ rr:column "MusicPerformerType" ] ] .

<#tm_attachment_1tab_val_music_performer_2_Album_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AlbumID\", \"Title\", \"ReleaseDate\", \"PerformerID\" FROM \"Album\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{AlbumID}" ; rr:class :Album ] ;
  rr:predicateObjectMap [ rr:predicate p:AlbumID ; rr:objectMap [ rr:column "AlbumID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PerformerID ; rr:objectMap [ rr:column "PerformerID" ] ] .

<#tm_attachment_1tab_val_music_performer_3_Album_PerformerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AlbumID\", \"PerformerID\" FROM \"Album\" WHERE \"PerformerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{AlbumID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMusicPerformer ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/MusicPerformer/{PerformerID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_music_performer_4_Song_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SongID\", \"Title\", \"Length\", \"AlbumID\" FROM \"Song\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{SongID}" ; rr:class :Song ] ;
  rr:predicateObjectMap [ rr:predicate p:SongID ; rr:objectMap [ rr:column "SongID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Length ; rr:objectMap [ rr:column "Length" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AlbumID ; rr:objectMap [ rr:column "AlbumID" ] ] .

<#tm_attachment_1tab_val_music_performer_5_Song_AlbumID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SongID\", \"AlbumID\" FROM \"Song\" WHERE \"AlbumID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{SongID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAlbum ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{AlbumID}" ; rr:termType rr:IRI ] ] .

