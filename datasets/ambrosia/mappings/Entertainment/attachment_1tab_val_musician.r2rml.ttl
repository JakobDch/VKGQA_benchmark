@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_musician_0_Musician_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Genre\", \"Instrument\", \"YearOfBirth\" FROM \"Musician\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Musician/{id}" ; rr:class :Musician ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Instrument ; rr:objectMap [ rr:column "Instrument" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearOfBirth ; rr:objectMap [ rr:column "YearOfBirth" ] ] .

<#tm_attachment_1tab_val_musician_1_Album_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"ReleaseYear\", \"ArtistId\" FROM \"Album\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ; rr:class :Album ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtistId ; rr:objectMap [ rr:column "ArtistId" ] ] .

<#tm_attachment_1tab_val_musician_2_Album_ArtistId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ArtistId\" FROM \"Album\" WHERE \"ArtistId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMusician ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Musician/{ArtistId}" ; rr:termType rr:IRI ] ] .

