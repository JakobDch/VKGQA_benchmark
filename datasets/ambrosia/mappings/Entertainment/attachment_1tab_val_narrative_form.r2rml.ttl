@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_narrative_form_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorID\", \"FirstName\", \"LastName\", \"BirthDate\", \"Nationality\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{AuthorID}" ; rr:class :Author ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Nationality ; rr:objectMap [ rr:column "Nationality" ] ] .

<#tm_attachment_1tab_val_narrative_form_1_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GenreID\", \"Name\" FROM \"Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{GenreID}" ; rr:class :Genre ] ;
  rr:predicateObjectMap [ rr:predicate p:GenreID ; rr:objectMap [ rr:column "GenreID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_val_narrative_form_2_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PublisherID\", \"Name\", \"Address\", \"YearEstablished\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{PublisherID}" ; rr:class :Publisher ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearEstablished ; rr:objectMap [ rr:column "YearEstablished" ] ] .

<#tm_attachment_1tab_val_narrative_form_3_Books_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"Title\", \"Narrative_Form\", \"Epoch\", \"PageCount\", \"PublicationYear\", \"AuthorID\", \"GenreID\" FROM \"Books\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{BookID}" ; rr:class :Book ] ;
  rr:predicateObjectMap [ rr:predicate p:BookID ; rr:objectMap [ rr:column "BookID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Narrative_Form ; rr:objectMap [ rr:column "Narrative_Form" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Epoch ; rr:objectMap [ rr:column "Epoch" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PageCount ; rr:objectMap [ rr:column "PageCount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationYear ; rr:objectMap [ rr:column "PublicationYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GenreID ; rr:objectMap [ rr:column "GenreID" ] ] .

<#tm_attachment_1tab_val_narrative_form_4_Books_GenreID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"GenreID\" FROM \"Books\" WHERE \"GenreID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{BookID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenre ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{GenreID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_narrative_form_5_Books_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"AuthorID\" FROM \"Books\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{BookID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_narrative_form_6_Published_Works_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"WorkID\", \"BookID\", \"PublisherID\", \"ReleaseDate\", \"SalesAmount\" FROM \"Published_Works\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Published_Works/{WorkID}" ; rr:class :Published_Works ] ;
  rr:predicateObjectMap [ rr:predicate p:WorkID ; rr:objectMap [ rr:column "WorkID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BookID ; rr:objectMap [ rr:column "BookID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SalesAmount ; rr:objectMap [ rr:column "SalesAmount" ] ] .

<#tm_attachment_1tab_val_narrative_form_7_Published_Works_PublisherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"WorkID\", \"PublisherID\" FROM \"Published_Works\" WHERE \"PublisherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Published_Works/{WorkID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublisher ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Publisher/{PublisherID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_narrative_form_8_Published_Works_BookID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"WorkID\", \"BookID\" FROM \"Published_Works\" WHERE \"BookID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Published_Works/{WorkID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBook ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{BookID}" ; rr:termType rr:IRI ] ] .

