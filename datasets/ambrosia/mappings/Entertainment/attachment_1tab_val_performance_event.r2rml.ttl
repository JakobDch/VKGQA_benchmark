@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_performance_event_0_Artists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArtistID\", \"Name\", \"Age\", \"Genre\" FROM \"Artists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{ArtistID}" ; rr:class :Artist ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtistID ; rr:objectMap [ rr:column "ArtistID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] .

<#tm_attachment_1tab_val_performance_event_1_Events_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EventID\", \"Name\", \"Date\", \"Location\" FROM \"Events\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Events/{EventID}" ; rr:class :Events ] ;
  rr:predicateObjectMap [ rr:predicate p:EventID ; rr:objectMap [ rr:column "EventID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_attachment_1tab_val_performance_event_2_Performances_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PerformanceID\", \"EventID\", \"Type\", \"AudienceSize\", \"PerformanceEvent\", \"AuditionRoom\" FROM \"Performances\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performance/{PerformanceID}" ; rr:class :Performance ] ;
  rr:predicateObjectMap [ rr:predicate p:PerformanceID ; rr:objectMap [ rr:column "PerformanceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EventID ; rr:objectMap [ rr:column "EventID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AudienceSize ; rr:objectMap [ rr:column "AudienceSize" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PerformanceEvent ; rr:objectMap [ rr:column "PerformanceEvent" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuditionRoom ; rr:objectMap [ rr:column "AuditionRoom" ] ] .

<#tm_attachment_1tab_val_performance_event_3_Performances_EventID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PerformanceID\", \"EventID\" FROM \"Performances\" WHERE \"EventID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performance/{PerformanceID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEvents ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Events/{EventID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_performance_event_4_Participants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ParticipantID\", \"ArtistID\", \"PerformanceID\", \"Role\" FROM \"Participants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Participant/{ParticipantID}" ; rr:class :Participant ] ;
  rr:predicateObjectMap [ rr:predicate p:ParticipantID ; rr:objectMap [ rr:column "ParticipantID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtistID ; rr:objectMap [ rr:column "ArtistID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PerformanceID ; rr:objectMap [ rr:column "PerformanceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Role ; rr:objectMap [ rr:column "Role" ] ] .

<#tm_attachment_1tab_val_performance_event_5_Participants_PerformanceID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ParticipantID\", \"PerformanceID\" FROM \"Participants\" WHERE \"PerformanceID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Participant/{ParticipantID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPerformance ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performance/{PerformanceID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_performance_event_6_Participants_ArtistID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ParticipantID\", \"ArtistID\" FROM \"Participants\" WHERE \"ArtistID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Participant/{ParticipantID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArtist ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{ArtistID}" ; rr:termType rr:IRI ] ] .

