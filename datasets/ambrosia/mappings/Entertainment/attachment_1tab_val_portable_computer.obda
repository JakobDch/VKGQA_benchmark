[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Devices_base
target		ex:Devices/{DeviceID} a :Devices ; p:DeviceID {DeviceID} ; p:Portable_Computer {Portable_Computer} ; p:Operating_System {Operating_System} ; p:ReleaseDate {ReleaseDate} ; p:Price {Price} .
source		SELECT `DeviceID`, `Portable_Computer`, `Operating_System`, `ReleaseDate`, `Price` FROM `Devices`

mappingId	Games_base
target		ex:Games/{GameID} a :Games ; p:GameID {GameID} ; p:Title {Title} ; p:Developer {Developer} ; p:Genre {Genre} ; p:PlatformId {PlatformId} .
source		SELECT `GameID`, `Title`, `Developer`, `Genre`, `PlatformId` FROM `Games`

mappingId	Games_PlatformId_fk
target		ex:Games/{GameID} p:hasDevices ex:Devices/{PlatformId} .
source		SELECT `GameID`, `PlatformId` FROM `Games` WHERE `PlatformId` IS NOT NULL

mappingId	Movies_base
target		ex:Movie/{MovieID} a :Movie ; p:MovieID {MovieID} ; p:Title {Title} ; p:Director {Director} ; p:ReleaseYear {ReleaseYear} ; p:Runtime {Runtime} ; p:Rating {Rating} .
source		SELECT `MovieID`, `Title`, `Director`, `ReleaseYear`, `Runtime`, `Rating` FROM `Movies`

mappingId	MusicAlbums_base
target		ex:MusicAlbums/{AlbumID} a :MusicAlbums ; p:AlbumID {AlbumID} ; p:ArtistName {ArtistName} ; p:AlbumTitle {AlbumTitle} ; p:YearReleased {YearReleased} ; p:NumTracks {NumTracks} .
source		SELECT `AlbumID`, `ArtistName`, `AlbumTitle`, `YearReleased`, `NumTracks` FROM `MusicAlbums`

]]
