@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_portable_computer_0_Devices_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DeviceID\", \"Portable_Computer\", \"Operating_System\", \"ReleaseDate\", \"Price\" FROM \"Devices\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Devices/{DeviceID}" ; rr:class :Devices ] ;
  rr:predicateObjectMap [ rr:predicate p:DeviceID ; rr:objectMap [ rr:column "DeviceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Portable_Computer ; rr:objectMap [ rr:column "Portable_Computer" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Operating_System ; rr:objectMap [ rr:column "Operating_System" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_attachment_1tab_val_portable_computer_1_Games_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GameID\", \"Title\", \"Developer\", \"Genre\", \"PlatformId\" FROM \"Games\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Games/{GameID}" ; rr:class :Games ] ;
  rr:predicateObjectMap [ rr:predicate p:GameID ; rr:objectMap [ rr:column "GameID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Developer ; rr:objectMap [ rr:column "Developer" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PlatformId ; rr:objectMap [ rr:column "PlatformId" ] ] .

<#tm_attachment_1tab_val_portable_computer_2_Games_PlatformId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GameID\", \"PlatformId\" FROM \"Games\" WHERE \"PlatformId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Games/{GameID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDevices ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Devices/{PlatformId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_portable_computer_3_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MovieID\", \"Title\", \"Director\", \"ReleaseYear\", \"Runtime\", \"Rating\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{MovieID}" ; rr:class :Movie ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieID ; rr:objectMap [ rr:column "MovieID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Director ; rr:objectMap [ rr:column "Director" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Runtime ; rr:objectMap [ rr:column "Runtime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] .

<#tm_attachment_1tab_val_portable_computer_4_MusicAlbums_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AlbumID\", \"ArtistName\", \"AlbumTitle\", \"YearReleased\", \"NumTracks\" FROM \"MusicAlbums\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/MusicAlbums/{AlbumID}" ; rr:class :MusicAlbums ] ;
  rr:predicateObjectMap [ rr:predicate p:AlbumID ; rr:objectMap [ rr:column "AlbumID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtistName ; rr:objectMap [ rr:column "ArtistName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AlbumTitle ; rr:objectMap [ rr:column "AlbumTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearReleased ; rr:objectMap [ rr:column "YearReleased" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumTracks ; rr:objectMap [ rr:column "NumTracks" ] ] .

