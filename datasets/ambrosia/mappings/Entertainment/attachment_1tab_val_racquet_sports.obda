[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	RacquetsAndTournaments_base
target		ex:RacquetsAndTournaments/{ID} a :RacquetsAndTournaments ; p:ID {ID} ; p:EventName {EventName} ; p:EventType {EventType} ; p:Sponsor {Sponsor} ; p:Participants {Participants} ; p:PrizeMoney {PrizeMoney} .
source		SELECT `ID`, `EventName`, `EventType`, `Sponsor`, `Participants`, `PrizeMoney` FROM `RacquetsAndTournaments`

]]
