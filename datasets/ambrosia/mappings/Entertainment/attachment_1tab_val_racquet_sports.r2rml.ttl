<#tm_attachment_1tab_val_racquet_sports_0_RacquetsAndTournaments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"EventName\", \"EventType\", \"Sponsor\", \"Participants\", \"PrizeMoney\" FROM \"RacquetsAndTournaments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/RacquetsAndTournaments/{ID}" ; rr:class :RacquetsAndTournaments ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EventName ; rr:objectMap [ rr:column "EventName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EventType ; rr:objectMap [ rr:column "EventType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Sponsor ; rr:objectMap [ rr:column "Sponsor" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Participants ; rr:objectMap [ rr:column "Participants" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PrizeMoney ; rr:objectMap [ rr:column "PrizeMoney" ] ] .

