@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_sports_0_sports_team_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"sport\", \"country\", \"founded_year\" FROM \"sports_team\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/sports_team/{id}" ; rr:class :sports_team ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:sport ; rr:objectMap [ rr:column "sport" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:founded_year ; rr:objectMap [ rr:column "founded_year" ] ] .

