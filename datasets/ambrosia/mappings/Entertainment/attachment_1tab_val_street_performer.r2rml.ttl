@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_street_performer_0_PERFORMERS_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"NAME\", \"AGE\", \"GENRE\", \"STREET_PERFORMER\", \"STREET_LOCATION\" FROM \"PERFORMERS\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performers/{ID}" ; rr:class :Performers ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "NAME" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AGE ; rr:objectMap [ rr:column "AGE" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GENRE ; rr:objectMap [ rr:column "GENRE" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:STREET_PERFORMER ; rr:objectMap [ rr:column "STREET_PERFORMER" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:STREET_LOCATION ; rr:objectMap [ rr:column "STREET_LOCATION" ] ] .

<#tm_attachment_1tab_val_street_performer_1_SHOWS_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"TITLE\", \"DURATION\" FROM \"SHOWS\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Show/{ID}" ; rr:class :Show ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TITLE ; rr:objectMap [ rr:column "TITLE" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DURATION ; rr:objectMap [ rr:column "DURATION" ] ] .

<#tm_attachment_1tab_val_street_performer_2_VENUES_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"NAME\", \"LOCATION\" FROM \"VENUES\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Venue/{ID}" ; rr:class :Venue ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "NAME" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "LOCATION" ] ] .

<#tm_attachment_1tab_val_street_performer_3_SHOW_VENUE_MAPPINGS_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"SHOW_ID\", \"VENUE_ID\" FROM \"SHOW_VENUE_MAPPINGS\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ShowVenues/{_amb_rowid}" ; rr:class :ShowVenues ] ;
  rr:predicateObjectMap [ rr:predicate p:SHOW_ID ; rr:objectMap [ rr:column "SHOW_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:VENUE_ID ; rr:objectMap [ rr:column "VENUE_ID" ] ] .

<#tm_attachment_1tab_val_street_performer_4_SHOW_VENUE_MAPPINGS_VENUE_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"VENUE_ID\" FROM \"SHOW_VENUE_MAPPINGS\" WHERE \"VENUE_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ShowVenues/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVenue ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Venue/{VENUE_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_street_performer_5_SHOW_VENUE_MAPPINGS_SHOW_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"SHOW_ID\" FROM \"SHOW_VENUE_MAPPINGS\" WHERE \"SHOW_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ShowVenues/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasShow ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Show/{SHOW_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_street_performer_6_PERFORMER_SHOW_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"PERFORMER_ID\", \"SHOW_ID\" FROM \"PERFORMER_SHOW\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/PERFORMER_SHOW/{_amb_rowid}" ; rr:class :PERFORMER_SHOW ] ;
  rr:predicateObjectMap [ rr:predicate p:PERFORMER_ID ; rr:objectMap [ rr:column "PERFORMER_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SHOW_ID ; rr:objectMap [ rr:column "SHOW_ID" ] ] .

<#tm_attachment_1tab_val_street_performer_7_PERFORMER_SHOW_SHOW_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"SHOW_ID\" FROM \"PERFORMER_SHOW\" WHERE \"SHOW_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/PERFORMER_SHOW/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasShow ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Show/{SHOW_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_street_performer_8_PERFORMER_SHOW_PERFORMER_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"PERFORMER_ID\" FROM \"PERFORMER_SHOW\" WHERE \"PERFORMER_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/PERFORMER_SHOW/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPerformers ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performers/{PERFORMER_ID}" ; rr:termType rr:IRI ] ] .

