<#tm_attachment_1tab_val_television_format_7_ShowDirectors_DirectorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"DirectorID\" FROM \"ShowDirectors\" WHERE \"DirectorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ShowDirectors/{_amb_rowid}" ] ;
