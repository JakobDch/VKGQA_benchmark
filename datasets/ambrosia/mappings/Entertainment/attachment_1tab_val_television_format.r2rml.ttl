@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_television_format_0_TelevisionShows_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Genre\", \"Country\", \"Television_Format\", \"Audience_Score\" FROM \"TelevisionShows\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{ID}" ; rr:class :Tv_Show ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Television_Format ; rr:objectMap [ rr:column "Television_Format" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Audience_Score ; rr:objectMap [ rr:column "Audience_Score" ] ] .

<#tm_attachment_1tab_val_television_format_1_Actors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ActorID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"Nationality\" FROM \"Actors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Actor/{ActorID}" ; rr:class :Actor ] ;
  rr:predicateObjectMap [ rr:predicate p:ActorID ; rr:objectMap [ rr:column "ActorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Nationality ; rr:objectMap [ rr:column "Nationality" ] ] .

<#tm_attachment_1tab_val_television_format_2_ShowsActors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ShowID\", \"ActorID\", \"Role\" FROM \"ShowsActors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ShowsActors/{_amb_rowid}" ; rr:class :ShowsActors ] ;
  rr:predicateObjectMap [ rr:predicate p:ShowID ; rr:objectMap [ rr:column "ShowID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ActorID ; rr:objectMap [ rr:column "ActorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Role ; rr:objectMap [ rr:column "Role" ] ] .

<#tm_attachment_1tab_val_television_format_3_ShowsActors_ActorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ActorID\" FROM \"ShowsActors\" WHERE \"ActorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ShowsActors/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Actor/{ActorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_television_format_4_ShowsActors_ShowID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ShowID\" FROM \"ShowsActors\" WHERE \"ShowID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ShowsActors/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTv_Show ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{ShowID}" ; rr:termType rr:IRI ] ] .

