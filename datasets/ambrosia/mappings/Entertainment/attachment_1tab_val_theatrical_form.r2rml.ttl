@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_theatrical_form_0_Play_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Theatrical_Form\", \"Author\", \"Year_Published\" FROM \"Play\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Play/{ID}" ; rr:class :Play ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Theatrical_Form ; rr:objectMap [ rr:column "Theatrical_Form" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Author ; rr:objectMap [ rr:column "Author" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year_Published ; rr:objectMap [ rr:column "Year_Published" ] ] .

<#tm_attachment_1tab_val_theatrical_form_1_Character_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"PlayID\" FROM \"Character\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Character/{ID}" ; rr:class :Character ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PlayID ; rr:objectMap [ rr:column "PlayID" ] ] .

<#tm_attachment_1tab_val_theatrical_form_2_Character_PlayID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"PlayID\" FROM \"Character\" WHERE \"PlayID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Character/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPlay ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Play/{PlayID}" ; rr:termType rr:IRI ] ] .

