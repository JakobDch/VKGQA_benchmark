[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Genre_base
target		ex:Genre/{id} a :Genre ; p:id {id} ; p:name {name} .
source		SELECT `id`, `name` FROM `Genre`

mappingId	TvShow_base
target		ex:Tv_Show/{id} a :Tv_Show ; p:id {id} ; p:title {title} ; p:tv {tv} ; p:number_of_episodes {number_of_episodes} ; p:release_date {release_date} ; p:genre_id {genre_id} .
source		SELECT `id`, `title`, `tv`, `number_of_episodes`, `release_date`, `genre_id` FROM `TvShow`

mappingId	TvShow_genre_id_fk
target		ex:Tv_Show/{id} p:hasGenre ex:Genre/{genre_id} .
source		SELECT `id`, `genre_id` FROM `TvShow` WHERE `genre_id` IS NOT NULL

mappingId	CastMember_base
target		ex:CastMember/{id} a :CastMember ; p:id {id} ; p:first_name {first_name} ; p:last_name {last_name} ; p:birth_date {birth_date} .
source		SELECT `id`, `first_name`, `last_name`, `birth_date` FROM `CastMember`

mappingId	ShowCast_base
target		ex:ShowCast/{_amb_rowid} a :ShowCast ; p:show_id {show_id} ; p:member_id {member_id} ; p:role {role} ; p:appearance_start_year {appearance_start_year} ; p:appearance_end_year {appearance_end_year} .
source		SELECT `_amb_rowid`, `show_id`, `member_id`, `role`, `appearance_start_year`, `appearance_end_year` FROM `ShowCast`

mappingId	ShowCast_member_id_fk
target		ex:ShowCast/{_amb_rowid} p:hasCastMember ex:CastMember/{member_id} .
source		SELECT `_amb_rowid`, `member_id` FROM `ShowCast` WHERE `member_id` IS NOT NULL

mappingId	ShowCast_show_id_fk
target		ex:ShowCast/{_amb_rowid} p:hasTv_Show ex:Tv_Show/{show_id} .
source		SELECT `_amb_rowid`, `show_id` FROM `ShowCast` WHERE `show_id` IS NOT NULL

]]
