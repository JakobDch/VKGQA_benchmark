@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_tv_0_Genre_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Genre\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{id}" ; rr:class :Genre ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_val_tv_1_TvShow_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"tv\", \"number_of_episodes\", \"release_date\", \"genre_id\" FROM \"TvShow\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{id}" ; rr:class :Tv_Show ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:tv ; rr:objectMap [ rr:column "tv" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number_of_episodes ; rr:objectMap [ rr:column "number_of_episodes" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre_id ; rr:objectMap [ rr:column "genre_id" ] ] .

<#tm_attachment_1tab_val_tv_2_TvShow_genre_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"genre_id\" FROM \"TvShow\" WHERE \"genre_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenre ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{genre_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_tv_3_CastMember_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\", \"birth_date\" FROM \"CastMember\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/CastMember/{id}" ; rr:class :CastMember ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birth_date ; rr:objectMap [ rr:column "birth_date" ] ] .

<#tm_attachment_1tab_val_tv_4_ShowCast_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"show_id\", \"member_id\", \"role\", \"appearance_start_year\", \"appearance_end_year\" FROM \"ShowCast\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ShowCast/{_amb_rowid}" ; rr:class :ShowCast ] ;
  rr:predicateObjectMap [ rr:predicate p:show_id ; rr:objectMap [ rr:column "show_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:member_id ; rr:objectMap [ rr:column "member_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role ; rr:objectMap [ rr:column "role" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:appearance_start_year ; rr:objectMap [ rr:column "appearance_start_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:appearance_end_year ; rr:objectMap [ rr:column "appearance_end_year" ] ] .

<#tm_attachment_1tab_val_tv_5_ShowCast_member_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"member_id\" FROM \"ShowCast\" WHERE \"member_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ShowCast/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCastMember ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/CastMember/{member_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_tv_6_ShowCast_show_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"show_id\" FROM \"ShowCast\" WHERE \"show_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ShowCast/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTv_Show ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tv_Show/{show_id}" ; rr:termType rr:IRI ] ] .

