@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_written_work_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{id}" ; rr:class :Author ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_val_written_work_1_Written_Works_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"AuthorID\", \"Type\", \"Title\", \"DatePublished\" FROM \"Written_Works\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WrittenWorks/{id}" ; rr:class :WrittenWorks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DatePublished ; rr:objectMap [ rr:column "DatePublished" ] ] .

<#tm_attachment_1tab_val_written_work_2_Written_Works_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"AuthorID\" FROM \"Written_Works\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WrittenWorks/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_written_work_3_Movie_Ratings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"MovieID\", \"Rating\", \"ReviewerID\", \"DateRated\" FROM \"Movie_Ratings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/FilmRatings/{id}" ; rr:class :FilmRatings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieID ; rr:objectMap [ rr:column "MovieID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReviewerID ; rr:objectMap [ rr:column "ReviewerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateRated ; rr:objectMap [ rr:column "DateRated" ] ] .

<#tm_attachment_1tab_val_written_work_4_Books_Sales_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"BookID\", \"Quantity\", \"SaleDate\", \"Revenue\" FROM \"Books_Sales\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Books_Sales/{id}" ; rr:class :Books_Sales ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BookID ; rr:objectMap [ rr:column "BookID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SaleDate ; rr:objectMap [ rr:column "SaleDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Revenue ; rr:objectMap [ rr:column "Revenue" ] ] .

