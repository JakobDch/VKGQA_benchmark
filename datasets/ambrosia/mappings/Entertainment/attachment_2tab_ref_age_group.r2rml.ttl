  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"illustratorId\" FROM \"YoungAdultBooks\" WHERE \"illustratorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ChildrensBooks/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasIllustrator ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Illustrator/{illustratorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_age_group_7_YoungAdultBooks_authorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"authorId\" FROM \"YoungAdultBooks\" WHERE \"authorId\" IS NOT NULL""" ] ;
