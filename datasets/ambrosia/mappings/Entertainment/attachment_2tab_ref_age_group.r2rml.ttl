@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_age_group_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{id}" ; rr:class :Author ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_age_group_1_Illustrators_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"illustratorName\" FROM \"Illustrators\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Illustrator/{id}" ; rr:class :Illustrator ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:illustratorName ; rr:objectMap [ rr:column "illustratorName" ] ] .

<#tm_attachment_2tab_ref_age_group_2_ChildrensBooks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"authorId\", \"illustratorId\" FROM \"ChildrensBooks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ChildrensBooks/{id}" ; rr:class :ChildrensBooks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:authorId ; rr:objectMap [ rr:column "authorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:illustratorId ; rr:objectMap [ rr:column "illustratorId" ] ] .

<#tm_attachment_2tab_ref_age_group_3_ChildrensBooks_illustratorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"illustratorId\" FROM \"ChildrensBooks\" WHERE \"illustratorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ChildrensBooks/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasIllustrator ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Illustrator/{illustratorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_age_group_4_ChildrensBooks_authorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"authorId\" FROM \"ChildrensBooks\" WHERE \"authorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ChildrensBooks/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{authorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_age_group_5_YoungAdultBooks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"authorId\", \"illustratorId\" FROM \"YoungAdultBooks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/ChildrensBooks/{id}" ; rr:class :ChildrensBooks ] ;
