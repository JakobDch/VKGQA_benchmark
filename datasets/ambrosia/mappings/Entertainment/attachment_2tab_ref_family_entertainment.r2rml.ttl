@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_family_entertainment_0_Location_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"city\", \"state\" FROM \"Location\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Location/{id}" ; rr:class :Location ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:state ; rr:objectMap [ rr:column "state" ] ] .

<#tm_attachment_2tab_ref_family_entertainment_1_AmusementPark_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"locationID\" FROM \"AmusementPark\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/AmusementPark/{id}" ; rr:class :AmusementPark ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationID ; rr:objectMap [ rr:column "locationID" ] ] .

<#tm_attachment_2tab_ref_family_entertainment_2_AmusementPark_locationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"locationID\" FROM \"AmusementPark\" WHERE \"locationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/AmusementPark/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocation ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Location/{locationID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_family_entertainment_3_WaterPark_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"locationID\" FROM \"WaterPark\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WaterPark/{id}" ; rr:class :WaterPark ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationID ; rr:objectMap [ rr:column "locationID" ] ] .

<#tm_attachment_2tab_ref_family_entertainment_4_WaterPark_locationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"locationID\" FROM \"WaterPark\" WHERE \"locationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/WaterPark/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocation ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Location/{locationID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_family_entertainment_5_Rides_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"parkID\", \"rideName\", \"description\" FROM \"Rides\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Rides/{id}" ; rr:class :Rides ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:parkID ; rr:objectMap [ rr:column "parkID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rideName ; rr:objectMap [ rr:column "rideName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_attachment_2tab_ref_family_entertainment_6_Rides_parkID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"parkID\" FROM \"Rides\" WHERE \"parkID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Rides/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAmusementPark ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/AmusementPark/{parkID}" ; rr:termType rr:IRI ] ] .

