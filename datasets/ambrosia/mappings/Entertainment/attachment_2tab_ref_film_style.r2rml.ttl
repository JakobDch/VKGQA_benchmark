@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_film_style_0_Director_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Director\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Director/{id}" ; rr:class :Director ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_film_style_1_Movie_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"directorId\", \"releaseYear\" FROM \"Movie\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ; rr:class :Movie ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:directorId ; rr:objectMap [ rr:column "directorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:releaseYear ; rr:objectMap [ rr:column "releaseYear" ] ] .

<#tm_attachment_2tab_ref_film_style_2_Movie_directorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"directorId\" FROM \"Movie\" WHERE \"directorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirector ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Director/{directorId}" ; rr:termType rr:IRI ] ] .

