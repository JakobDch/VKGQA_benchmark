@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_live_performance_0_Venue_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"venue_capacity\" FROM \"Venue\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Venue/{id}" ; rr:class :Venue ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:venue_capacity ; rr:objectMap [ rr:column "venue_capacity" ] ] .

<#tm_attachment_2tab_ref_live_performance_1_Concert_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"date\", \"artist_name\", \"venue_id\" FROM \"Concert\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Concert/{id}" ; rr:class :Concert ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:artist_name ; rr:objectMap [ rr:column "artist_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:venue_id ; rr:objectMap [ rr:column "venue_id" ] ] .

<#tm_attachment_2tab_ref_live_performance_2_Concert_venue_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"venue_id\" FROM \"Concert\" WHERE \"venue_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Concert/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVenue ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Venue/{venue_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_live_performance_3_Theater_Play_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"start_date\", \"end_date\", \"theater_company\", \"venue_id\" FROM \"Theater_Play\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Theater_Play/{id}" ; rr:class :Theater_Play ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:theater_company ; rr:objectMap [ rr:column "theater_company" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:venue_id ; rr:objectMap [ rr:column "venue_id" ] ] .

<#tm_attachment_2tab_ref_live_performance_4_Theater_Play_venue_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"venue_id\" FROM \"Theater_Play\" WHERE \"venue_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Theater_Play/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVenue ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Venue/{venue_id}" ; rr:termType rr:IRI ] ] .

