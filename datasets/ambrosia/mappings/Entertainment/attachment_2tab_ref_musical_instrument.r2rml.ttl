@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_musical_instrument_0_Manufacturers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Manufacturers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Manufacturers/{id}" ; rr:class :Manufacturers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_musical_instrument_1_Guitars_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"model_name\", \"price\", \"manufacturer_id\" FROM \"Guitars\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Guitars/{id}" ; rr:class :Guitars ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:model_name ; rr:objectMap [ rr:column "model_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:manufacturer_id ; rr:objectMap [ rr:column "manufacturer_id" ] ] .

<#tm_attachment_2tab_ref_musical_instrument_2_Guitars_manufacturer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"manufacturer_id\" FROM \"Guitars\" WHERE \"manufacturer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Guitars/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasManufacturers ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Manufacturers/{manufacturer_id}" ; rr:termType rr:IRI ] ] .

