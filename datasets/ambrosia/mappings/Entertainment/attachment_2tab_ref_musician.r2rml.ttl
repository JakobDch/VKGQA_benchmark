@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_musician_0_Instruments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"instrumentName\" FROM \"Instruments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Instrument/{id}" ; rr:class :Instrument ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:instrumentName ; rr:objectMap [ rr:column "instrumentName" ] ] .

<#tm_attachment_2tab_ref_musician_1_CountrySingers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"singerName\", \"country\", \"foreignKey\" FROM \"CountrySingers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/CountrySingers/{id}" ; rr:class :CountrySingers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:singerName ; rr:objectMap [ rr:column "singerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:foreignKey ; rr:objectMap [ rr:column "foreignKey" ] ] .

<#tm_attachment_2tab_ref_musician_2_CountrySingers_foreignKey_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"foreignKey\" FROM \"CountrySingers\" WHERE \"foreignKey\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/CountrySingers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInstrument ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Instrument/{foreignKey}" ; rr:termType rr:IRI ] ] .

