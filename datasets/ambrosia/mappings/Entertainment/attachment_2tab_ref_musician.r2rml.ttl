<#tm_attachment_2tab_ref_musician_8_SingsOnAlbum_albumId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"albumId\" FROM \"SingsOnAlbum\" WHERE \"albumId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/SingsOnAlbum/{id}" ] ;
