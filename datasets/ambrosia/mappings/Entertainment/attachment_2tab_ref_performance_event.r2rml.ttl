@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_performance_event_0_Audition_Room_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoomID\", \"RoomName\" FROM \"Audition_Room\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Audition_Room/{RoomID}" ; rr:class :Audition_Room ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomID ; rr:objectMap [ rr:column "RoomID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomName ; rr:objectMap [ rr:column "RoomName" ] ] .

<#tm_attachment_2tab_ref_performance_event_1_Talent_Show_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ShowID\", \"Name\", \"Description\", \"RoomID\" FROM \"Talent_Show\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Talent_Show/{ShowID}" ; rr:class :Talent_Show ] ;
  rr:predicateObjectMap [ rr:predicate p:ShowID ; rr:objectMap [ rr:column "ShowID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomID ; rr:objectMap [ rr:column "RoomID" ] ] .

<#tm_attachment_2tab_ref_performance_event_2_Talent_Show_RoomID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ShowID\", \"RoomID\" FROM \"Talent_Show\" WHERE \"RoomID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Talent_Show/{ShowID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAudition_Room ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Audition_Room/{RoomID}" ; rr:termType rr:IRI ] ] .

