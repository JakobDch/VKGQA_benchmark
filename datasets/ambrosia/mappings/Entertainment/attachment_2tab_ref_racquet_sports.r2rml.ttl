@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_racquet_sports_0_Sponsors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Sponsors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Sponsors/{id}" ; rr:class :Sponsors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_racquet_sports_1_Tennis_Players_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"playerName\", \"tennisTournaments\" FROM \"Tennis_Players\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tennis_Players/{id}" ; rr:class :Tennis_Players ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:playerName ; rr:objectMap [ rr:column "playerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:tennisTournaments ; rr:objectMap [ rr:column "tennisTournaments" ] ] .

<#tm_attachment_2tab_ref_racquet_sports_2_Tennis_Players_tennisTournaments_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"tennisTournaments\" FROM \"Tennis_Players\" WHERE \"tennisTournaments\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tennis_Players/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTennis_Tournaments ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tennis_Tournaments/{tennisTournaments}" ; rr:termType rr:IRI ] ] .

