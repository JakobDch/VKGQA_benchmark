@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_sports_0_Countries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Countries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Country/{id}" ; rr:class :Country ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_sports_1_BaseballTeams_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"teamName\", \"countryId\" FROM \"BaseballTeams\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/BaseballTeams/{id}" ; rr:class :BaseballTeams ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:teamName ; rr:objectMap [ rr:column "teamName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:countryId ; rr:objectMap [ rr:column "countryId" ] ] .

<#tm_attachment_2tab_ref_sports_2_BaseballTeams_countryId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"countryId\" FROM \"BaseballTeams\" WHERE \"countryId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/BaseballTeams/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCountry ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Country/{countryId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_sports_3_BasketballTeams_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"teamName\", \"countryId\" FROM \"BasketballTeams\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/BasketballTeams/{id}" ; rr:class :BasketballTeams ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:teamName ; rr:objectMap [ rr:column "teamName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:countryId ; rr:objectMap [ rr:column "countryId" ] ] .

<#tm_attachment_2tab_ref_sports_4_BasketballTeams_countryId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"countryId\" FROM \"BasketballTeams\" WHERE \"countryId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/BasketballTeams/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCountry ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Country/{countryId}" ; rr:termType rr:IRI ] ] .

