@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_street_performer_0_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"LocationName\" FROM \"Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Location/{id}" ; rr:class :Location ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationName ; rr:objectMap [ rr:column "LocationName" ] ] .

