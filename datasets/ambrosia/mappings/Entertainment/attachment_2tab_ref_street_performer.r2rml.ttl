<#tm_attachment_2tab_ref_street_performer_2_Shows_MimeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"MimeID\" FROM \"Shows\" WHERE \"MimeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Show/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMimes ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Mimes/{MimeID}" ; rr:termType rr:IRI ] ] .

