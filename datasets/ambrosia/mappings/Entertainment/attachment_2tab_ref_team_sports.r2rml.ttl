@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_team_sports_0_Fitness_Level_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Level\" FROM \"Fitness_Level\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Fitness_Level/{ID}" ; rr:class :Fitness_Level ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Level ; rr:objectMap [ rr:column "Level" ] ] .

<#tm_attachment_2tab_ref_team_sports_1_Football_Players_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"PlayerName\", \"Team\", \"Position\", \"Age\", \"Fitness_ID\" FROM \"Football_Players\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Football_Players/{ID}" ; rr:class :Football_Players ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PlayerName ; rr:objectMap [ rr:column "PlayerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Team ; rr:objectMap [ rr:column "Team" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Position ; rr:objectMap [ rr:column "Position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Fitness_ID ; rr:objectMap [ rr:column "Fitness_ID" ] ] .

<#tm_attachment_2tab_ref_team_sports_2_Football_Players_Fitness_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Fitness_ID\" FROM \"Football_Players\" WHERE \"Fitness_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Football_Players/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFitness_Level ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Fitness_Level/{Fitness_ID}" ; rr:termType rr:IRI ] ] .

