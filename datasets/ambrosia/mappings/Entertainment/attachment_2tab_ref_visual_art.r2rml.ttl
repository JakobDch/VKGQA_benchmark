@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_visual_art_0_Artist_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArtistID\", \"Name\" FROM \"Artist\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{ArtistID}" ; rr:class :Artist ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtistID ; rr:objectMap [ rr:column "ArtistID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_ref_visual_art_1_Painting_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PaintingID\", \"Title\", \"Year\", \"Description\", \"GalleryId\" FROM \"Painting\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Painting/{PaintingID}" ; rr:class :Painting ] ;
  rr:predicateObjectMap [ rr:predicate p:PaintingID ; rr:objectMap [ rr:column "PaintingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GalleryId ; rr:objectMap [ rr:column "GalleryId" ] ] .

<#tm_attachment_2tab_ref_visual_art_2_Painting_GalleryId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PaintingID\", \"GalleryId\" FROM \"Painting\" WHERE \"GalleryId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Painting/{PaintingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGallery ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Gallery/{GalleryId}" ; rr:termType rr:IRI ] ] .

