[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Science_Fiction_Book_base
target		ex:Science_Fiction_Book/{ID} a :Science_Fiction_Book ; p:ID {ID} ; p:Title {Title} ; p:Author {Author} ; p:Year_of_publication {Year_of_publication} ; p:Genre {Genre} .
source		SELECT `ID`, `Title`, `Author`, `Year_of_publication`, `Genre` FROM `Science_Fiction_Book`

mappingId	Romance_Book_base
target		ex:Romance_Book/{ID} a :Romance_Book ; p:ID {ID} ; p:Title {Title} ; p:Author {Author} ; p:Year_of_publication {Year_of_publication} ; p:Genre {Genre} .
source		SELECT `ID`, `Title`, `Author`, `Year_of_publication`, `Genre` FROM `Romance_Book`

mappingId	Movie_base
target		ex:Movie/{ID} a :Movie ; p:ID {ID} ; p:Title {Title} ; p:Director {Director} ; p:Release_year {Release_year} .
source		SELECT `ID`, `Title`, `Director`, `Release_year` FROM `Movie`

mappingId	Music_Album_base
target		ex:MusicAlbums/{ID} a :MusicAlbums ; p:ID {ID} ; p:Artist {Artist} ; p:Album_name {Album_name} ; p:Release_year {Release_year} .
source		SELECT `ID`, `Artist`, `Album_name`, `Release_year` FROM `Music_Album`

mappingId	VideoGame_base
target		ex:VideoGame/{ID} a :VideoGame ; p:ID {ID} ; p:Game_Name {Game_Name} ; p:Developer {Developer} ; p:Release_year {Release_year} .
source		SELECT `ID`, `Game_Name`, `Developer`, `Release_year` FROM `VideoGame`

]]
