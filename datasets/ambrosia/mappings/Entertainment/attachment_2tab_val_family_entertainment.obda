[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Amusement_Parks_base
target		ex:AmusementPark/{id} a :AmusementPark ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Opening_Year {Opening_Year} ; p:Attractions {Attractions} .
source		SELECT `id`, `Name`, `Location`, `Opening_Year`, `Attractions` FROM `Amusement_Parks`

mappingId	Water_Parks_base
target		ex:WaterPark/{id} a :WaterPark ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Opening_Month {Opening_Month} ; p:Pool_Type {Pool_Type} .
source		SELECT `id`, `Name`, `Location`, `Opening_Month`, `Pool_Type` FROM `Water_Parks`

mappingId	Cinemas_base
target		ex:Cinemas/{id} a :Cinemas ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Genre {Genre} ; p:Seats {Seats} .
source		SELECT `id`, `Name`, `Location`, `Genre`, `Seats` FROM `Cinemas`

mappingId	Concert_Venues_base
target		ex:Concert_Venues/{id} a :Concert_Venues ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Artist {Artist} ; p:Date {Date} .
source		SELECT `id`, `Name`, `Location`, `Artist`, `Date` FROM `Concert_Venues`

mappingId	Theaters_base
target		ex:Theatre/{id} a :Theatre ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Show_Time {Show_Time} ; p:Ticket_Price {Ticket_Price} .
source		SELECT `id`, `Name`, `Location`, `Show_Time`, `Ticket_Price` FROM `Theaters`

mappingId	Restaurants_base
target		ex:Restaurants/{id} a :Restaurants ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Cuisine {Cuisine} ; p:Price_Range {Price_Range} .
source		SELECT `id`, `Name`, `Location`, `Cuisine`, `Price_Range` FROM `Restaurants`

]]
