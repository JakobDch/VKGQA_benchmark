@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_family_entertainment_0_Amusement_Parks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Location\", \"Opening_Year\", \"Attractions\" FROM \"Amusement_Parks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/AmusementPark/{id}" ; rr:class :AmusementPark ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Opening_Year ; rr:objectMap [ rr:column "Opening_Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Attractions ; rr:objectMap [ rr:column "Attractions" ] ] .

