<#tm_attachment_2tab_val_film_profession_4_Casting_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"movie_id\", \"actor_id\", \"role\" FROM \"Casting\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Cast/{_amb_rowid}" ; rr:class :Cast ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:actor_id ; rr:objectMap [ rr:column "actor_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role ; rr:objectMap [ rr:column "role" ] ] .

<#tm_attachment_2tab_val_film_profession_5_Casting_actor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"actor_id\" FROM \"Casting\" WHERE \"actor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Cast/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Actor/{actor_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_film_profession_6_Casting_movie_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"movie_id\" FROM \"Casting\" WHERE \"movie_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Cast/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovie ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{movie_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_film_profession_7_Review_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"review_id\", \"movie_id\", \"rating\", \"comment\" FROM \"Review\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Review/{review_id}" ; rr:class :Review ] ;
  rr:predicateObjectMap [ rr:predicate p:review_id ; rr:objectMap [ rr:column "review_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rating ; rr:objectMap [ rr:column "rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:comment ; rr:objectMap [ rr:column "comment" ] ] .

<#tm_attachment_2tab_val_film_profession_8_Review_movie_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"review_id\", \"movie_id\" FROM \"Review\" WHERE \"movie_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Review/{review_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovie ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{movie_id}" ; rr:termType rr:IRI ] ] .

