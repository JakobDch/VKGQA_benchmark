[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Adventure_Movies_base
target		ex:Adventure_Movies/{id} a :Adventure_Movies ; p:id {id} ; p:title {title} ; p:release_year {release_year} ; p:genre {genre} ; p:Director {Director} .
source		SELECT `id`, `title`, `release_year`, `genre`, `Director` FROM `Adventure_Movies`

mappingId	Action_Movies_base
target		ex:Action_Movies/{id} a :Action_Movies ; p:id {id} ; p:title {title} ; p:release_year {release_year} ; p:genre {genre} ; p:Director {Director} .
source		SELECT `id`, `title`, `release_year`, `genre`, `Director` FROM `Action_Movies`

mappingId	Comedy_Movies_base
target		ex:Comedy_Movies/{id} a :Comedy_Movies ; p:id {id} ; p:title {title} ; p:release_year {release_year} ; p:genre {genre} ; p:Director {Director} .
source		SELECT `id`, `title`, `release_year`, `genre`, `Director` FROM `Comedy_Movies`

mappingId	SciFi_Movies_base
target		ex:SciFi_Movies/{id} a :SciFi_Movies ; p:id {id} ; p:title {title} ; p:release_year {release_year} ; p:genre {genre} ; p:Director {Director} .
source		SELECT `id`, `title`, `release_year`, `genre`, `Director` FROM `SciFi_Movies`

mappingId	Fantasy_Movies_base
target		ex:Fantasy_Movies/{id} a :Fantasy_Movies ; p:id {id} ; p:title {title} ; p:release_year {release_year} ; p:genre {genre} ; p:Director {Director} .
source		SELECT `id`, `title`, `release_year`, `genre`, `Director` FROM `Fantasy_Movies`

mappingId	Animated_Movies_base
target		ex:Animated_Movies/{id} a :Animated_Movies ; p:id {id} ; p:title {title} ; p:release_year {release_year} ; p:genre {genre} ; p:Director {Director} .
source		SELECT `id`, `title`, `release_year`, `genre`, `Director` FROM `Animated_Movies`

]]
