[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Novels_base
target		ex:Novel/{id} a :Novel ; p:id {id} ; p:title {title} ; p:author {author} ; p:publication_year {publication_year} ; p:genre {genre} ; p:language {language} .
source		SELECT `id`, `title`, `author`, `publication_year`, `genre`, `language` FROM `Novels`

mappingId	Poems_base
target		ex:Poems/{id} a :Poems ; p:id {id} ; p:poem_name {poem_name} ; p:poet {poet} ; p:published_date {published_date} ; p:theme {theme} ; p:language {language} .
source		SELECT `id`, `poem_name`, `poet`, `published_date`, `theme`, `language` FROM `Poems`

mappingId	Movies_base
target		ex:Movie/{id} a :Movie ; p:id {id} ; p:movie_title {movie_title} ; p:director {director} ; p:release_year {release_year} ; p:genre {genre} ; p:rating {rating} .
source		SELECT `id`, `movie_title`, `director`, `release_year`, `genre`, `rating` FROM `Movies`

mappingId	MusicAlbums_base
target		ex:MusicAlbums/{id} a :MusicAlbums ; p:id {id} ; p:album_name {album_name} ; p:artist {artist} ; p:release_date {release_date} ; p:genre {genre} ; p:number_of_tracks {number_of_tracks} .
source		SELECT `id`, `album_name`, `artist`, `release_date`, `genre`, `number_of_tracks` FROM `MusicAlbums`

mappingId	VideoGames_base
target		ex:VideoGames/{id} a :VideoGames ; p:id {id} ; p:game_name {game_name} ; p:developer {developer} ; p:release_date {release_date} ; p:genre {genre} ; p:platform {platform} .
source		SELECT `id`, `game_name`, `developer`, `release_date`, `genre`, `platform` FROM `VideoGames`

mappingId	TVShows_base
target		ex:Tv_Show/{id} a :Tv_Show ; p:id {id} ; p:show_name {show_name} ; p:creator {creator} ; p:start_year {start_year} ; p:end_year {end_year} ; p:genre {genre} .
source		SELECT `id`, `show_name`, `creator`, `start_year`, `end_year`, `genre` FROM `TVShows`

]]
