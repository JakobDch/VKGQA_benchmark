@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_literature_type_0_Novels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"author\", \"publication_year\", \"genre\", \"language\" FROM \"Novels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Novel/{id}" ; rr:class :Novel ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author ; rr:objectMap [ rr:column "author" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_year ; rr:objectMap [ rr:column "publication_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:language ; rr:objectMap [ rr:column "language" ] ] .

