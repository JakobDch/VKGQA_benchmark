[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Jazz_Bands_base
target		ex:Jazz_Bands/{_amb_rowid} a :Jazz_Bands ; p:Band {Band} ; p:Founding_Year {Founding_Year} ; p:Genre {Genre} ; p:Lead_Singer {Lead_Singer} ; p:Instruments {Instruments} .
source		SELECT `_amb_rowid`, `Band`, `Founding_Year`, `Genre`, `Lead_Singer`, `Instruments` FROM `Jazz_Bands`

mappingId	Rock_Bands_base
target		ex:Rock_Bands/{_amb_rowid} a :Rock_Bands ; p:Band {Band} ; p:Founding_Year {Founding_Year} ; p:Genre {Genre} ; p:Lead_Guitarist {Lead_Guitarist} ; p:Drummer {Drummer} .
source		SELECT `_amb_rowid`, `Band`, `Founding_Year`, `Genre`, `Lead_Guitarist`, `Drummer` FROM `Rock_Bands`

mappingId	Concerts_base
target		ex:Concert/{_amb_rowid} a :Concert ; p:Date {Date} ; p:location {Location} ; p:Headliner {Headliner} ; p:Openers {Openers} ; p:Ticket_Price {Ticket_Price} .
source		SELECT `_amb_rowid`, `Date`, `Location`, `Headliner`, `Openers`, `Ticket_Price` FROM `Concerts`

mappingId	Venues_base
target		ex:Venue/{_amb_rowid} a :Venue ; p:name {Name} ; p:Address {Address} ; p:Capacity {Capacity} .
source		SELECT `_amb_rowid`, `Name`, `Address`, `Capacity` FROM `Venues`

mappingId	Fans_base
target		ex:Fans/{_amb_rowid} a :Fans ; p:name {Name} ; p:Age {Age} ; p:Preferred_Genre {Preferred_Genre} .
source		SELECT `_amb_rowid`, `Name`, `Age`, `Preferred_Genre` FROM `Fans`

mappingId	Music_Labels_base
target		ex:Music_Labels/{_amb_rowid} a :Music_Labels ; p:Label_Name {Label_Name} ; p:Artists {Artists} ; p:Year_Established {Year_Established} .
source		SELECT `_amb_rowid`, `Label_Name`, `Artists`, `Year_Established` FROM `Music_Labels`

]]
