@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_music_band_0_Jazz_Bands_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Band\", \"Founding_Year\", \"Genre\", \"Lead_Singer\", \"Instruments\" FROM \"Jazz_Bands\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Jazz_Bands/{_amb_rowid}" ; rr:class :Jazz_Bands ] ;
  rr:predicateObjectMap [ rr:predicate p:Band ; rr:objectMap [ rr:column "Band" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Founding_Year ; rr:objectMap [ rr:column "Founding_Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Lead_Singer ; rr:objectMap [ rr:column "Lead_Singer" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Instruments ; rr:objectMap [ rr:column "Instruments" ] ] .

