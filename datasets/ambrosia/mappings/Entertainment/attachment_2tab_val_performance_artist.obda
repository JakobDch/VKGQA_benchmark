[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	standupcomedians_base
target		ex:standupcomedians/{id} a :standupcomedians ; p:id {id} ; p:name {name} ; p:duration_of_performance {duration_of_performance} ; p:performance_venue {performance_venue} ; p:date {date} .
source		SELECT `id`, `name`, `duration_of_performance`, `performance_venue`, `date` FROM `standupcomedians`

mappingId	magicians_base
target		ex:Magicians/{id} a :Magicians ; p:id {id} ; p:name {name} ; p:duration_of_performance {duration_of_performance} ; p:venue_type {venue_type} ; p:show_date {show_date} .
source		SELECT `id`, `name`, `duration_of_performance`, `venue_type`, `show_date` FROM `magicians`

mappingId	movies_base
target		ex:Movie/{id} a :Movie ; p:id {id} ; p:title {title} ; p:release_year {release_year} ; p:genre {genre} ; p:director {director} .
source		SELECT `id`, `title`, `release_year`, `genre`, `director` FROM `movies`

mappingId	tvshows_base
target		ex:Tv_Show/{id} a :Tv_Show ; p:id {id} ; p:title {title} ; p:season {season} ; p:episode {episode} ; p:network {network} .
source		SELECT `id`, `title`, `season`, `episode`, `network` FROM `tvshows`

mappingId	games_base
target		ex:Games/{id} a :Games ; p:id {id} ; p:title {title} ; p:platform {platform} ; p:genre {genre} ; p:developer {developer} .
source		SELECT `id`, `title`, `platform`, `genre`, `developer` FROM `games`

mappingId	musicalbums_base
target		ex:MusicAlbums/{id} a :MusicAlbums ; p:id {id} ; p:artist {artist} ; p:albumname {albumname} ; p:genre {genre} ; p:releaseyear {releaseyear} .
source		SELECT `id`, `artist`, `albumname`, `genre`, `releaseyear` FROM `musicalbums`

]]
