<#tm_attachment_2tab_val_performance_artist_0_standupcomedians_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"duration_of_performance\", \"performance_venue\", \"date\" FROM \"standupcomedians\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/standupcomedians/{id}" ; rr:class :standupcomedians ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration_of_performance ; rr:objectMap [ rr:column "duration_of_performance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:performance_venue ; rr:objectMap [ rr:column "performance_venue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] .

