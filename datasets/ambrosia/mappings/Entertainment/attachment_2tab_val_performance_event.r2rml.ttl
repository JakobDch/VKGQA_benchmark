@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_performance_event_0_Dance_Recitals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RecitalID\", \"Name\", \"Date\", \"Time\", \"Audition_Room\" FROM \"Dance_Recitals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Dance_Recital/{RecitalID}" ; rr:class :Dance_Recital ] ;
  rr:predicateObjectMap [ rr:predicate p:RecitalID ; rr:objectMap [ rr:column "RecitalID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Time ; rr:objectMap [ rr:column "Time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Audition_Room ; rr:objectMap [ rr:column "Audition_Room" ] ] .

<#tm_attachment_2tab_val_performance_event_1_Talent_Shows_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ShowID\", \"Name\", \"Theme\", \"Location\", \"Audition_Room\" FROM \"Talent_Shows\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Talent_Show/{ShowID}" ; rr:class :Talent_Show ] ;
  rr:predicateObjectMap [ rr:predicate p:ShowID ; rr:objectMap [ rr:column "ShowID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Theme ; rr:objectMap [ rr:column "Theme" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Audition_Room ; rr:objectMap [ rr:column "Audition_Room" ] ] .

<#tm_attachment_2tab_val_performance_event_2_Performers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PerformerID\", \"FirstName\", \"LastName\", \"Age\", \"Role\" FROM \"Performers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performers/{PerformerID}" ; rr:class :Performers ] ;
  rr:predicateObjectMap [ rr:predicate p:PerformerID ; rr:objectMap [ rr:column "PerformerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Role ; rr:objectMap [ rr:column "Role" ] ] .

<#tm_attachment_2tab_val_performance_event_3_Participation_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ParticipantID\", \"PerformerID\", \"Dance_RecitalID\", \"Talent_ShowID\" FROM \"Participation\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Participation/{ParticipantID}" ; rr:class :Participation ] ;
  rr:predicateObjectMap [ rr:predicate p:ParticipantID ; rr:objectMap [ rr:column "ParticipantID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PerformerID ; rr:objectMap [ rr:column "PerformerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Dance_RecitalID ; rr:objectMap [ rr:column "Dance_RecitalID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Talent_ShowID ; rr:objectMap [ rr:column "Talent_ShowID" ] ] .

<#tm_attachment_2tab_val_performance_event_4_Participation_Talent_ShowID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ParticipantID\", \"Talent_ShowID\" FROM \"Participation\" WHERE \"Talent_ShowID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Participation/{ParticipantID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTalent_Show ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Talent_Show/{Talent_ShowID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_performance_event_5_Participation_Dance_RecitalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ParticipantID\", \"Dance_RecitalID\" FROM \"Participation\" WHERE \"Dance_RecitalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Participation/{ParticipantID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDance_Recital ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Dance_Recital/{Dance_RecitalID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_performance_event_6_Participation_PerformerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ParticipantID\", \"PerformerID\" FROM \"Participation\" WHERE \"PerformerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Participation/{ParticipantID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPerformers ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performers/{PerformerID}" ; rr:termType rr:IRI ] ] .

