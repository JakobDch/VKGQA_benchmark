[PrefixDeclaration]
:	http://ambrosia.example.org/entertainment#
p:	http://ambrosia.example.org/entertainment/prop#
ex:	http://ambrosia.example.org/entertainment/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Magicians_base
target		ex:Magicians/{id} a :Magicians ; p:id {id} ; p:name {Name} ; p:Street_Location {Street_Location} ; p:MagicType {MagicType} ; p:YearsExperience {YearsExperience} .
source		SELECT `id`, `Name`, `Street_Location`, `MagicType`, `YearsExperience` FROM `Magicians`

mappingId	Mimes_base
target		ex:Mimes/{id} a :Mimes ; p:id {id} ; p:name {Name} ; p:Street_Location {Street_Location} ; p:StyleOfMiming {StyleOfMiming} ; p:PerformanceDuration {PerformanceDuration} .
source		SELECT `id`, `Name`, `Street_Location`, `StyleOfMiming`, `PerformanceDuration` FROM `Mimes`

mappingId	Shows_base
target		ex:Show/{id} a :Show ; p:id {id} ; p:ShowName {ShowName} ; p:StartTime {StartTime} ; p:EndTime {EndTime} ; p:LocationID {LocationID} .
source		SELECT `id`, `ShowName`, `StartTime`, `EndTime`, `LocationID` FROM `Shows`

mappingId	Shows_LocationID_fk
target		ex:Show/{id} p:hasVenue ex:Venue/{LocationID} .
source		SELECT `id`, `LocationID` FROM `Shows` WHERE `LocationID` IS NOT NULL

mappingId	Venues_base
target		ex:Venue/{id} a :Venue ; p:id {id} ; p:VenueName {VenueName} ; p:Address {Address} ; p:City {City} ; p:Capacity {Capacity} .
source		SELECT `id`, `VenueName`, `Address`, `City`, `Capacity` FROM `Venues`

mappingId	Performers_base
target		ex:Performers/{id} a :Performers ; p:id {id} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:Age {Age} ; p:Genre {Genre} .
source		SELECT `id`, `FirstName`, `LastName`, `Age`, `Genre` FROM `Performers`

]]
