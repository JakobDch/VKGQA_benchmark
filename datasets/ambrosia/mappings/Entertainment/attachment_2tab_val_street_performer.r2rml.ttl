@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_street_performer_0_Magicians_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Street_Location\", \"MagicType\", \"YearsExperience\" FROM \"Magicians\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Magicians/{id}" ; rr:class :Magicians ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Street_Location ; rr:objectMap [ rr:column "Street_Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MagicType ; rr:objectMap [ rr:column "MagicType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearsExperience ; rr:objectMap [ rr:column "YearsExperience" ] ] .

<#tm_attachment_2tab_val_street_performer_1_Mimes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Street_Location\", \"StyleOfMiming\", \"PerformanceDuration\" FROM \"Mimes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Mimes/{id}" ; rr:class :Mimes ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Street_Location ; rr:objectMap [ rr:column "Street_Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StyleOfMiming ; rr:objectMap [ rr:column "StyleOfMiming" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PerformanceDuration ; rr:objectMap [ rr:column "PerformanceDuration" ] ] .

<#tm_attachment_2tab_val_street_performer_2_Shows_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ShowName\", \"StartTime\", \"EndTime\", \"LocationID\" FROM \"Shows\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Show/{id}" ; rr:class :Show ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ShowName ; rr:objectMap [ rr:column "ShowName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartTime ; rr:objectMap [ rr:column "StartTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndTime ; rr:objectMap [ rr:column "EndTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationID ; rr:objectMap [ rr:column "LocationID" ] ] .

<#tm_attachment_2tab_val_street_performer_3_Shows_LocationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"LocationID\" FROM \"Shows\" WHERE \"LocationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Show/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVenue ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Venue/{LocationID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_street_performer_4_Venues_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"VenueName\", \"Address\", \"City\", \"Capacity\" FROM \"Venues\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Venue/{id}" ; rr:class :Venue ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:VenueName ; rr:objectMap [ rr:column "VenueName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] .

<#tm_attachment_2tab_val_street_performer_5_Performers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"FirstName\", \"LastName\", \"Age\", \"Genre\" FROM \"Performers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performers/{id}" ; rr:class :Performers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
