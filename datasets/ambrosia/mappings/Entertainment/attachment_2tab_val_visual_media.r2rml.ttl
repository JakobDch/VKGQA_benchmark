  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:episodeCount ; rr:objectMap [ rr:column "episodeCount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:network ; rr:objectMap [ rr:column "network" ] ] .

