<#tm_attachment_2tab_val_visual_media_4_Role_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"movieId\", \"actorId\", \"roleType\" FROM \"Role\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Role/{_amb_rowid}" ; rr:class :Role ] ;
  rr:predicateObjectMap [ rr:predicate p:movieId ; rr:objectMap [ rr:column "movieId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:actorId ; rr:objectMap [ rr:column "actorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roleType ; rr:objectMap [ rr:column "roleType" ] ] .

<#tm_attachment_2tab_val_visual_media_5_Role_actorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"actorId\" FROM \"Role\" WHERE \"actorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Role/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Actor/{actorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_visual_media_6_Role_movieId_fk> a rr:TriplesMap ;
