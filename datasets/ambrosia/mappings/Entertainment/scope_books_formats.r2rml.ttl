@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_books_formats_0_Formats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Formats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Formats/{id}" ; rr:class :Formats ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_books_formats_1_Books_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"author\" FROM \"Books\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{id}" ; rr:class :Book ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author ; rr:objectMap [ rr:column "author" ] ] .

<#tm_scope_books_formats_2_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstname\", \"lastname\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{id}" ; rr:class :Author ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstname ; rr:objectMap [ rr:column "firstname" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastname ; rr:objectMap [ rr:column "lastname" ] ] .

<#tm_scope_books_formats_3_Books_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"book_id\", \"author_id\" FROM \"Books_Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book_Authors/{_amb_rowid}" ; rr:class :Book_Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:book_id ; rr:objectMap [ rr:column "book_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] .

<#tm_scope_books_formats_4_Books_Authors_author_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"author_id\" FROM \"Books_Authors\" WHERE \"author_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book_Authors/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{author_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_books_formats_5_Books_Authors_book_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"book_id\" FROM \"Books_Authors\" WHERE \"book_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book_Authors/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBook ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{book_id}" ; rr:termType rr:IRI ] ] .

