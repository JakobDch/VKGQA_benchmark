@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_comedy_shows_acts_0_Acts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"act_id\", \"act_name\" FROM \"Acts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Acts/{act_id}" ; rr:class :Acts ] ;
  rr:predicateObjectMap [ rr:predicate p:act_id ; rr:objectMap [ rr:column "act_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:act_name ; rr:objectMap [ rr:column "act_name" ] ] .

<#tm_scope_comedy_shows_acts_1_Comedy_Shows_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"comedy_show_id\", \"show_title\", \"date\", \"location\" FROM \"Comedy_Shows\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Comedy_Shows/{comedy_show_id}" ; rr:class :Comedy_Shows ] ;
  rr:predicateObjectMap [ rr:predicate p:comedy_show_id ; rr:objectMap [ rr:column "comedy_show_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:show_title ; rr:objectMap [ rr:column "show_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_comedy_shows_acts_2_Comedy_Shows_Acts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"acts_comedy_shows_id\", \"comedy_show_id\" FROM \"Comedy_Shows_Acts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Comedy_Shows_Acts/{_amb_rowid}" ; rr:class :Comedy_Shows_Acts ] ;
  rr:predicateObjectMap [ rr:predicate p:acts_comedy_shows_id ; rr:objectMap [ rr:column "acts_comedy_shows_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:comedy_show_id ; rr:objectMap [ rr:column "comedy_show_id" ] ] .

<#tm_scope_comedy_shows_acts_3_Comedy_Shows_Acts_comedy_show_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"comedy_show_id\" FROM \"Comedy_Shows_Acts\" WHERE \"comedy_show_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Comedy_Shows_Acts/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasComedy_Shows ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Comedy_Shows/{comedy_show_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_comedy_shows_acts_4_Comedy_Shows_Acts_acts_comedy_shows_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"acts_comedy_shows_id\" FROM \"Comedy_Shows_Acts\" WHERE \"acts_comedy_shows_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Comedy_Shows_Acts/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActs ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Acts/{acts_comedy_shows_id}" ; rr:termType rr:IRI ] ] .

