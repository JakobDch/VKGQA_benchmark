<#tm_scope_festivals_performances_8_Festivals_Performances_FestivalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"FestivalID\" FROM \"Festivals_Performances\" WHERE \"FestivalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Festivals_Performances/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFestivals ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Festivals/{FestivalID}" ; rr:termType rr:IRI ] ] .

