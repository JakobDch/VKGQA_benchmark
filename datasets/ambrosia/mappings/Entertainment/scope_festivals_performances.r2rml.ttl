  rr:predicateObjectMap [ rr:predicate p:PerformanceID ; rr:objectMap [ rr:column "PerformanceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] .

<#tm_scope_festivals_performances_7_Festivals_Performances_PerformanceID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"PerformanceID\" FROM \"Festivals_Performances\" WHERE \"PerformanceID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Festivals_Performances/{_amb_rowid}" ] ;
