@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_festivals_performances_0_Festivals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FestivalID\", \"Name\", \"Location\" FROM \"Festivals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Festivals/{FestivalID}" ; rr:class :Festivals ] ;
  rr:predicateObjectMap [ rr:predicate p:FestivalID ; rr:objectMap [ rr:column "FestivalID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_scope_festivals_performances_1_Performances_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PerformanceID\", \"Type\", \"Description\" FROM \"Performances\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Performance/{PerformanceID}" ; rr:class :Performance ] ;
  rr:predicateObjectMap [ rr:predicate p:PerformanceID ; rr:objectMap [ rr:column "PerformanceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_scope_festivals_performances_2_Artists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArtistID\", \"Name\", \"Genre\" FROM \"Artists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{ArtistID}" ; rr:class :Artist ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtistID ; rr:objectMap [ rr:column "ArtistID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] .

<#tm_scope_festivals_performances_3_Festivals_Artists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"FestivalID\", \"ArtistID\" FROM \"Festivals_Artists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Festivals_Artists/{_amb_rowid}" ; rr:class :Festivals_Artists ] ;
  rr:predicateObjectMap [ rr:predicate p:FestivalID ; rr:objectMap [ rr:column "FestivalID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtistID ; rr:objectMap [ rr:column "ArtistID" ] ] .

<#tm_scope_festivals_performances_4_Festivals_Artists_ArtistID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ArtistID\" FROM \"Festivals_Artists\" WHERE \"ArtistID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Festivals_Artists/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArtist ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{ArtistID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_festivals_performances_5_Festivals_Artists_FestivalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"FestivalID\" FROM \"Festivals_Artists\" WHERE \"FestivalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Festivals_Artists/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFestivals ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Festivals/{FestivalID}" ; rr:termType rr:IRI ] ] .

