@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_games_platforms_0_Platforms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"platformID\", \"name\" FROM \"Platforms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Platforms/{platformID}" ; rr:class :Platforms ] ;
  rr:predicateObjectMap [ rr:predicate p:platformID ; rr:objectMap [ rr:column "platformID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_games_platforms_1_Games_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"gameID\", \"title\", \"genre\", \"releaseDate\" FROM \"Games\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Games/{gameID}" ; rr:class :Games ] ;
  rr:predicateObjectMap [ rr:predicate p:gameID ; rr:objectMap [ rr:column "gameID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:releaseDate ; rr:objectMap [ rr:column "releaseDate" ] ] .

<#tm_scope_games_platforms_2_Games_Platforms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"gamesID\", \"platformsID\" FROM \"Games_Platforms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Games_Platforms/{_amb_rowid}" ; rr:class :Games_Platforms ] ;
  rr:predicateObjectMap [ rr:predicate p:gamesID ; rr:objectMap [ rr:column "gamesID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:platformsID ; rr:objectMap [ rr:column "platformsID" ] ] .

<#tm_scope_games_platforms_3_Games_Platforms_platformsID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"platformsID\" FROM \"Games_Platforms\" WHERE \"platformsID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Games_Platforms/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPlatforms ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Platforms/{platformsID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_games_platforms_4_Games_Platforms_gamesID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"gamesID\" FROM \"Games_Platforms\" WHERE \"gamesID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Games_Platforms/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGames ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Games/{gamesID}" ; rr:termType rr:IRI ] ] .

