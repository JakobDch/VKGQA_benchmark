@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_orchestras_instruments_0_Conductors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"birthdate\" FROM \"Conductors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Conductors/{id}" ; rr:class :Conductors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthdate ; rr:objectMap [ rr:column "birthdate" ] ] .

<#tm_scope_orchestras_instruments_1_Orchestras_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"orchestra_name\", \"conductor_id\" FROM \"Orchestras\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Orchestras/{id}" ; rr:class :Orchestras ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:orchestra_name ; rr:objectMap [ rr:column "orchestra_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:conductor_id ; rr:objectMap [ rr:column "conductor_id" ] ] .

<#tm_scope_orchestras_instruments_2_Orchestras_conductor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"conductor_id\" FROM \"Orchestras\" WHERE \"conductor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Orchestras/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasConductors ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Conductors/{conductor_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_orchestras_instruments_3_Instruments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"instrument_type\" FROM \"Instruments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Instrument/{id}" ; rr:class :Instrument ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:instrument_type ; rr:objectMap [ rr:column "instrument_type" ] ] .

<#tm_scope_orchestras_instruments_4_Orchestras_Instruments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"orchestra_id\", \"instrument_id\" FROM \"Orchestras_Instruments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Orchestras_Instruments/{id}" ; rr:class :Orchestras_Instruments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:orchestra_id ; rr:objectMap [ rr:column "orchestra_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:instrument_id ; rr:objectMap [ rr:column "instrument_id" ] ] .

<#tm_scope_orchestras_instruments_5_Orchestras_Instruments_instrument_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"instrument_id\" FROM \"Orchestras_Instruments\" WHERE \"instrument_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Orchestras_Instruments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInstrument ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Instrument/{instrument_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_orchestras_instruments_6_Orchestras_Instruments_orchestra_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"orchestra_id\" FROM \"Orchestras_Instruments\" WHERE \"orchestra_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Orchestras_Instruments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOrchestras ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Orchestras/{orchestra_id}" ; rr:termType rr:IRI ] ] .

