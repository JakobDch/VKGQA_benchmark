  rr:predicateObjectMap [ rr:predicate p:host_name ; rr:objectMap [ rr:column "host_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:host_gender ; rr:objectMap [ rr:column "host_gender" ] ] .

<#tm_scope_radio_stations_programs_3_Radio_Stations_Hosts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"radio_station_id\", \"host_id\" FROM \"Radio_Stations_Hosts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Radio_Stations_Hosts/{radio_station_id}/{host_id}" ; rr:class :Radio_Stations_Hosts ] ;
