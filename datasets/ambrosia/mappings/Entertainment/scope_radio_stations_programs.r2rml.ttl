@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_radio_stations_programs_0_Radio_Stations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"station_id\", \"station_name\", \"frequency\" FROM \"Radio_Stations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Radio_Stations/{station_id}" ; rr:class :Radio_Stations ] ;
  rr:predicateObjectMap [ rr:predicate p:station_id ; rr:objectMap [ rr:column "station_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:station_name ; rr:objectMap [ rr:column "station_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:frequency ; rr:objectMap [ rr:column "frequency" ] ] .

<#tm_scope_radio_stations_programs_1_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"program_type_id\", \"program_type_name\" FROM \"Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Programs/{program_type_id}" ; rr:class :Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:program_type_id ; rr:objectMap [ rr:column "program_type_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:program_type_name ; rr:objectMap [ rr:column "program_type_name" ] ] .

<#tm_scope_radio_stations_programs_2_Hosts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"host_id\", \"host_name\", \"host_gender\" FROM \"Hosts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Hosts/{host_id}" ; rr:class :Hosts ] ;
