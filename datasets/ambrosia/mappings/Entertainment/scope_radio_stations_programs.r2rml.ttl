<#tm_scope_radio_stations_programs_4_Radio_Stations_Hosts_host_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"radio_station_id\", \"host_id\" FROM \"Radio_Stations_Hosts\" WHERE \"host_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Radio_Stations_Hosts/{radio_station_id}/{host_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHosts ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Hosts/{host_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_radio_stations_programs_5_Radio_Stations_Hosts_radio_station_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"radio_station_id\", \"host_id\" FROM \"Radio_Stations_Hosts\" WHERE \"radio_station_id\" IS NOT NULL""" ] ;
