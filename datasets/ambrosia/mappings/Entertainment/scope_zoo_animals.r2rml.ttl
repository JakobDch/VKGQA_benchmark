@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_zoo_animals_0_Zoo_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"zooID\", \"zooName\", \"location\" FROM \"Zoo\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Zoo/{zooID}" ; rr:class :Zoo ] ;
  rr:predicateObjectMap [ rr:predicate p:zooID ; rr:objectMap [ rr:column "zooID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:zooName ; rr:objectMap [ rr:column "zooName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_zoo_animals_1_Animals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"animalID\", \"animalName\" FROM \"Animals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Animals/{animalID}" ; rr:class :Animals ] ;
  rr:predicateObjectMap [ rr:predicate p:animalID ; rr:objectMap [ rr:column "animalID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:animalName ; rr:objectMap [ rr:column "animalName" ] ] .

<#tm_scope_zoo_animals_2_Zoo_Animals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"zooID\", \"animalID\" FROM \"Zoo_Animals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Zoo_Animals/{_amb_rowid}" ; rr:class :Zoo_Animals ] ;
  rr:predicateObjectMap [ rr:predicate p:zooID ; rr:objectMap [ rr:column "zooID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:animalID ; rr:objectMap [ rr:column "animalID" ] ] .

<#tm_scope_zoo_animals_3_Zoo_Animals_animalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"animalID\" FROM \"Zoo_Animals\" WHERE \"animalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Zoo_Animals/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAnimals ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Animals/{animalID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_zoo_animals_4_Zoo_Animals_zooID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"zooID\" FROM \"Zoo_Animals\" WHERE \"zooID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Zoo_Animals/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasZoo ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Zoo/{zooID}" ; rr:termType rr:IRI ] ] .

