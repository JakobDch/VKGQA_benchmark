@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_author_0_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"ReleaseDate\", \"Runtime\", \"Filmmaker\", \"Screenwriter\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ; rr:class :Movie ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Runtime ; rr:objectMap [ rr:column "Runtime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Filmmaker ; rr:objectMap [ rr:column "Filmmaker" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Screenwriter ; rr:objectMap [ rr:column "Screenwriter" ] ] .

