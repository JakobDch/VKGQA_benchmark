  rr:logicalTable [ rr:sqlQuery """SELECT \"DocumentaryID\", \"Title\", \"HistoricalEra\", \"Event\", \"DirectorID\" FROM \"Documentary\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Documentary/{DocumentaryID}" ; rr:class :Documentary ] ;
