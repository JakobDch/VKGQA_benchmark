  rr:predicateObjectMap [ rr:predicate p:HistoricalEra ; rr:objectMap [ rr:column "HistoricalEra" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Event ; rr:objectMap [ rr:column "Event" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorID ; rr:objectMap [ rr:column "DirectorID" ] ] .

<#tm_vague_2cols_context1_8_Documentary_DirectorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DocumentaryID\", \"DirectorID\" FROM \"Documentary\" WHERE \"DirectorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Documentary/{DocumentaryID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirector ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Director/{DirectorID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_context1_9_Director_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorID\", \"BirthYear\", \"DeathYear\", \"fullname\" FROM \"Director\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Director/{DirectorID}" ; rr:class :Director ] ;
