  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"title\", \"release_year\", \"genre\", \"box_office\" FROM \"Movie\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{movie_id}" ; rr:class :Movie ] ;
