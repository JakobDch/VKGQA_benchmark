<#tm_vague_2cols_context2_4_Role_movie_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"role_id\", \"movie_id\" FROM \"Role\" WHERE \"movie_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Role/{role_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovie ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{movie_id}" ; rr:termType rr:IRI ] ] .

