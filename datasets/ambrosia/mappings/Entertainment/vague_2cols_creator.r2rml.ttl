  rr:predicateObjectMap [ rr:predicate p:hasArtist_opening_act_artist_id ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{opening_act_artist_id}" ; rr:termType rr:IRI ] ] .

