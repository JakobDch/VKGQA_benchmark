<#tm_vague_2cols_duration_3_Role_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"movie_id\", \"actor_id\", \"role_name\" FROM \"Role\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Role/{_amb_rowid}" ; rr:class :Role ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:actor_id ; rr:objectMap [ rr:column "actor_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role_name ; rr:objectMap [ rr:column "role_name" ] ] .

<#tm_vague_2cols_duration_4_Role_actor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"actor_id\" FROM \"Role\" WHERE \"actor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Role/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Actor/{actor_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_duration_5_Role_movie_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"movie_id\" FROM \"Role\" WHERE \"movie_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Role/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovie ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{movie_id}" ; rr:termType rr:IRI ] ] .

