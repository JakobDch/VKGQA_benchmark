@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_duration_0_Movie_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_date\", \"Total_length\", \"Number_of_acts\", \"Theater_play\" FROM \"Movie\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ; rr:class :Movie ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Total_length ; rr:objectMap [ rr:column "Total_length" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_acts ; rr:objectMap [ rr:column "Number_of_acts" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Theater_play ; rr:objectMap [ rr:column "Theater_play" ] ] .

<#tm_vague_2cols_duration_1_Actor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"birth_date\", \"nationality\" FROM \"Actor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Actor/{id}" ; rr:class :Actor ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birth_date ; rr:objectMap [ rr:column "birth_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:nationality ; rr:objectMap [ rr:column "nationality" ] ] .

