@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_length_0_Actor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"actor_id\", \"first_name\", \"last_name\", \"birthdate\" FROM \"Actor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Actor/{actor_id}" ; rr:class :Actor ] ;
  rr:predicateObjectMap [ rr:predicate p:actor_id ; rr:objectMap [ rr:column "actor_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthdate ; rr:objectMap [ rr:column "birthdate" ] ] .

<#tm_vague_2cols_length_1_Actress_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"actress_id\", \"first_name\", \"last_name\", \"birthdate\" FROM \"Actress\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Actress/{actress_id}" ; rr:class :Actress ] ;
  rr:predicateObjectMap [ rr:predicate p:actress_id ; rr:objectMap [ rr:column "actress_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthdate ; rr:objectMap [ rr:column "birthdate" ] ] .

<#tm_vague_2cols_length_2_Show_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"show_id\", \"title\", \"genre\", \"Number_of_seasons\", \"Number_of_episodes\", \"release_year\" FROM \"Show\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Show/{show_id}" ; rr:class :Show ] ;
  rr:predicateObjectMap [ rr:predicate p:show_id ; rr:objectMap [ rr:column "show_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_seasons ; rr:objectMap [ rr:column "Number_of_seasons" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_episodes ; rr:objectMap [ rr:column "Number_of_episodes" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_year ; rr:objectMap [ rr:column "release_year" ] ] .

<#tm_vague_2cols_length_3_Show_genre_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"show_id\", \"genre\" FROM \"Show\" WHERE \"genre\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Show/{show_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenre ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{genre}" ; rr:termType rr:IRI ] ] .

