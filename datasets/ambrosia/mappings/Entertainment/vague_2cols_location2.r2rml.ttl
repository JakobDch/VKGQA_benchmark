  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:VenueName ; rr:objectMap [ rr:column "VenueName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HeadlineArtistID ; rr:objectMap [ rr:column "HeadlineArtistID" ] ] .

<#tm_vague_2cols_location2_4_Concerts_HeadlineArtistID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ConcertID\", \"HeadlineArtistID\" FROM \"Concerts\" WHERE \"HeadlineArtistID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Concert/{ConcertID}" ] ;
