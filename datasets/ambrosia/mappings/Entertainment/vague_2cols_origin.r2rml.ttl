@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_origin_0_Artists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"genre\", \"birthdate\", \"country\" FROM \"Artists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{id}" ; rr:class :Artist ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthdate ; rr:objectMap [ rr:column "birthdate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_vague_2cols_origin_1_Albums_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"releaseDate\", \"artistId\" FROM \"Albums\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ; rr:class :Album ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:releaseDate ; rr:objectMap [ rr:column "releaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:artistId ; rr:objectMap [ rr:column "artistId" ] ] .

<#tm_vague_2cols_origin_2_Albums_artistId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"artistId\" FROM \"Albums\" WHERE \"artistId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArtist ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{artistId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_origin_3_Songs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"length\", \"albumId\" FROM \"Songs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ; rr:class :Song ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:length ; rr:objectMap [ rr:column "length" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:albumId ; rr:objectMap [ rr:column "albumId" ] ] .

<#tm_vague_2cols_origin_4_Songs_albumId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"albumId\" FROM \"Songs\" WHERE \"albumId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Song/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAlbum ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{albumId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_origin_5_DanceTable_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Culture\", \"Geographical_Area\", \"DanceName\", \"Popularity\", \"Tradition\" FROM \"DanceTable\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Dance/{id}" ; rr:class :Dance ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Culture ; rr:objectMap [ rr:column "Culture" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Geographical_Area ; rr:objectMap [ rr:column "Geographical_Area" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DanceName ; rr:objectMap [ rr:column "DanceName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Popularity ; rr:objectMap [ rr:column "Popularity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Tradition ; rr:objectMap [ rr:column "Tradition" ] ] .

