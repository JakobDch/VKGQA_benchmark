@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_production2_0_Producers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ProducerName\", \"Company\" FROM \"Producers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Producer/{id}" ; rr:class :Producer ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProducerName ; rr:objectMap [ rr:column "ProducerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Company ; rr:objectMap [ rr:column "Company" ] ] .

<#tm_vague_2cols_production2_1_Directors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"DirectorName\", \"YearsExperience\" FROM \"Directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Director/{id}" ; rr:class :Director ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorName ; rr:objectMap [ rr:column "DirectorName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearsExperience ; rr:objectMap [ rr:column "YearsExperience" ] ] .

<#tm_vague_2cols_production2_2_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"MovieTitle\", \"ReleaseYear\", \"Genre\", \"ProducerId\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ; rr:class :Movie ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieTitle ; rr:objectMap [ rr:column "MovieTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProducerId ; rr:objectMap [ rr:column "ProducerId" ] ] .

<#tm_vague_2cols_production2_3_Movies_ProducerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ProducerId\" FROM \"Movies\" WHERE \"ProducerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProducer ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Producer/{ProducerId}" ; rr:termType rr:IRI ] ] .

