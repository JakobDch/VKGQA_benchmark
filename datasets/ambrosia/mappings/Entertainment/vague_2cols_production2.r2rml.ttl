  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ActorName\", \"Age\", \"FeePerMovie\", \"MovieId\" FROM \"Actors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Actor/{id}" ; rr:class :Actor ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ActorName ; rr:objectMap [ rr:column "ActorName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FeePerMovie ; rr:objectMap [ rr:column "FeePerMovie" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieId ; rr:objectMap [ rr:column "MovieId" ] ] .

<#tm_vague_2cols_production2_5_Actors_MovieId_fk> a rr:TriplesMap ;
