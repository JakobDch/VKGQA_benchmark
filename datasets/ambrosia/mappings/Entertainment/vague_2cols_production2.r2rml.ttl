  rr:predicateObjectMap [ rr:predicate p:MovieId ; rr:objectMap [ rr:column "MovieId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RatingId ; rr:objectMap [ rr:column "RatingId" ] ] .

<#tm_vague_2cols_production2_8_MovieRatings_RatingId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"RatingId\" FROM \"MovieRatings\" WHERE \"RatingId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/MovieRatings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilmRatings ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/FilmRatings/{RatingId}" ; rr:termType rr:IRI ] ] .

