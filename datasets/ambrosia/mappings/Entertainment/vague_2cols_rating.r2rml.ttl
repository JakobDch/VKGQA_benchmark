<#tm_vague_2cols_rating_6_Rating_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"movieId\", \"ageRating\", \"criticalRating\", \"tvShow\" FROM \"Rating\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Rating/{_amb_rowid}" ; rr:class :Rating ] ;
  rr:predicateObjectMap [ rr:predicate p:movieId ; rr:objectMap [ rr:column "movieId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ageRating ; rr:objectMap [ rr:column "ageRating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:criticalRating ; rr:objectMap [ rr:column "criticalRating" ] ] ;
