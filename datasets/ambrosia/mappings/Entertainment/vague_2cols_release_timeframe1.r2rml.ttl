  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorName\", \"Birthdate\", \"Country\", \"KnownFor\" FROM \"Directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Director/{DirectorName}" ; rr:class :Director ] ;
