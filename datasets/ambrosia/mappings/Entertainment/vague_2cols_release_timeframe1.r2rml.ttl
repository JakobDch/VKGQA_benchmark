<#tm_vague_2cols_release_timeframe1_9_FilmRatings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RatingID\", \"MovieID\", \"Rating\", \"Review\" FROM \"FilmRatings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/FilmRatings/{RatingID}" ; rr:class :FilmRatings ] ;
  rr:predicateObjectMap [ rr:predicate p:RatingID ; rr:objectMap [ rr:column "RatingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieID ; rr:objectMap [ rr:column "MovieID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Review ; rr:objectMap [ rr:column "Review" ] ] .

<#tm_vague_2cols_release_timeframe1_10_FilmRatings_MovieID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RatingID\", \"MovieID\" FROM \"FilmRatings\" WHERE \"MovieID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/FilmRatings/{RatingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovie ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{MovieID}" ; rr:termType rr:IRI ] ] .

