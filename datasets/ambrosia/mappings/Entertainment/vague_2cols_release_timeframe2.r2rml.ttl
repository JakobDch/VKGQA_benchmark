<#tm_vague_2cols_release_timeframe2_8_GameReviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ReviewText\", \"Rating\", \"GameId\", \"ReviewerId\" FROM \"GameReviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/GameReviews/{id}" ; rr:class :GameReviews ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReviewText ; rr:objectMap [ rr:column "ReviewText" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GameId ; rr:objectMap [ rr:column "GameId" ] ] ;
