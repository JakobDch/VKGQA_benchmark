<#tm_vague_2cols_sale_date_6_Events_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EventID\", \"EventName\", \"StartDateTime\", \"EndDateTime\", \"VenueID\", \"TICKETID\" FROM \"Events\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Events/{EventID}" ; rr:class :Events ] ;
