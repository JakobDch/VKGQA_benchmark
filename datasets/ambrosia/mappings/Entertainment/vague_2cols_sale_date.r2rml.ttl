  rr:logicalTable [ rr:sqlQuery """SELECT \"EventID\", \"TICKETID\" FROM \"Events\" WHERE \"TICKETID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Events/{EventID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTickets ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tickets/{TICKETID}" ; rr:termType rr:IRI ] ] .

