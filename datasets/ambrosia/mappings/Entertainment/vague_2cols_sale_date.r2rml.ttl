@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_sale_date_0_Artists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArtistID\", \"ArtistName\" FROM \"Artists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{ArtistID}" ; rr:class :Artist ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtistID ; rr:objectMap [ rr:column "ArtistID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArtistName ; rr:objectMap [ rr:column "ArtistName" ] ] .

<#tm_vague_2cols_sale_date_1_Albums_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AlbumID\", \"AlbumTitle\", \"ReleaseDate\", \"ARTISTID\" FROM \"Albums\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{AlbumID}" ; rr:class :Album ] ;
  rr:predicateObjectMap [ rr:predicate p:AlbumID ; rr:objectMap [ rr:column "AlbumID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AlbumTitle ; rr:objectMap [ rr:column "AlbumTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ARTISTID ; rr:objectMap [ rr:column "ARTISTID" ] ] .

<#tm_vague_2cols_sale_date_2_Albums_ARTISTID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AlbumID\", \"ARTISTID\" FROM \"Albums\" WHERE \"ARTISTID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Album/{AlbumID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArtist ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{ARTISTID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_sale_date_3_Tickets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TicketID\", \"EventID\", \"Quantity\", \"On_Sale_Date\", \"Pre_sale_Date\", \"Price\" FROM \"Tickets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tickets/{TicketID}" ; rr:class :Tickets ] ;
  rr:predicateObjectMap [ rr:predicate p:TicketID ; rr:objectMap [ rr:column "TicketID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EventID ; rr:objectMap [ rr:column "EventID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:On_Sale_Date ; rr:objectMap [ rr:column "On_Sale_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Pre_sale_Date ; rr:objectMap [ rr:column "Pre_sale_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_vague_2cols_sale_date_4_Tickets_EventID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TicketID\", \"EventID\" FROM \"Tickets\" WHERE \"EventID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Tickets/{TicketID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEvents ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Events/{EventID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_sale_date_5_Venues_base> a rr:TriplesMap ;
