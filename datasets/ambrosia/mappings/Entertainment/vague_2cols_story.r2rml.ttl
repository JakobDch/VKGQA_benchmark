@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_story_0_Books_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"Title\", \"Author\", \"PublicationYear\", \"Summary\", \"Themes\", \"Novel\" FROM \"Books\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book/{BookID}" ; rr:class :Book ] ;
  rr:predicateObjectMap [ rr:predicate p:BookID ; rr:objectMap [ rr:column "BookID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Author ; rr:objectMap [ rr:column "Author" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationYear ; rr:objectMap [ rr:column "PublicationYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Summary ; rr:objectMap [ rr:column "Summary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Themes ; rr:objectMap [ rr:column "Themes" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Novel ; rr:objectMap [ rr:column "Novel" ] ] .

