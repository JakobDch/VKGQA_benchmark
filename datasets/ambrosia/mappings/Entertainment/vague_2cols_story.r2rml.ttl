<#tm_vague_2cols_story_5_Book_Authors_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookID\", \"AuthorID\" FROM \"Book_Authors\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Book_Authors/{BookID}/{AuthorID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthor ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Author/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_story_6_Book_Authors_BookID_fk> a rr:TriplesMap ;
