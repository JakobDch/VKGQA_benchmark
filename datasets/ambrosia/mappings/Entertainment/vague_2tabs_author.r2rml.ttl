@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_author_0_Filmmaker_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"birth_year\" FROM \"Filmmaker\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Filmmaker/{id}" ; rr:class :Filmmaker ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birth_year ; rr:objectMap [ rr:column "birth_year" ] ] .

<#tm_vague_2tabs_author_1_Screenwriter_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"birth_year\" FROM \"Screenwriter\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Screenwriter/{id}" ; rr:class :Screenwriter ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birth_year ; rr:objectMap [ rr:column "birth_year" ] ] .

<#tm_vague_2tabs_author_2_Movie_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_date\", \"filmmaker_id\", \"screenwriter_id\" FROM \"Movie\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ; rr:class :Movie ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:filmmaker_id ; rr:objectMap [ rr:column "filmmaker_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:screenwriter_id ; rr:objectMap [ rr:column "screenwriter_id" ] ] .

<#tm_vague_2tabs_author_3_Movie_screenwriter_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"screenwriter_id\" FROM \"Movie\" WHERE \"screenwriter_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasScreenwriter ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Screenwriter/{screenwriter_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_author_4_Movie_filmmaker_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"filmmaker_id\" FROM \"Movie\" WHERE \"filmmaker_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilmmaker ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Filmmaker/{filmmaker_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_author_5_Genre_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"genre_name\" FROM \"Genre\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Genre/{id}" ; rr:class :Genre ] ;
