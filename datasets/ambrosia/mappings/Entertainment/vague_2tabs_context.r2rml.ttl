<#tm_vague_2tabs_context_4_Play_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"summary\", \"year_of_creation\", \"epoch_id\", \"society_id\", \"author_id\", \"genre_id\" FROM \"Play\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Play/{id}" ; rr:class :Play ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:summary ; rr:objectMap [ rr:column "summary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:year_of_creation ; rr:objectMap [ rr:column "year_of_creation" ] ] ;
