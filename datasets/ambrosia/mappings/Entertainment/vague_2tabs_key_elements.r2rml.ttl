@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_key_elements_0_Color_Palette_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"color_id\", \"color_name\" FROM \"Color_Palette\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Color_Palette/{color_id}" ; rr:class :Color_Palette ] ;
  rr:predicateObjectMap [ rr:predicate p:color_id ; rr:objectMap [ rr:column "color_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:color_name ; rr:objectMap [ rr:column "color_name" ] ] .

<#tm_vague_2tabs_key_elements_1_Fabric_Choice_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"fabric_id\", \"fabric_type\" FROM \"Fabric_Choice\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Fabric_Choice/{fabric_id}" ; rr:class :Fabric_Choice ] ;
  rr:predicateObjectMap [ rr:predicate p:fabric_id ; rr:objectMap [ rr:column "fabric_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fabric_type ; rr:objectMap [ rr:column "fabric_type" ] ] .

<#tm_vague_2tabs_key_elements_2_Fashion_Design_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"design_id\", \"design_name\", \"color_id\", \"fabric_id\" FROM \"Fashion_Design\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Fashion_Design/{design_id}" ; rr:class :Fashion_Design ] ;
  rr:predicateObjectMap [ rr:predicate p:design_id ; rr:objectMap [ rr:column "design_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:design_name ; rr:objectMap [ rr:column "design_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:color_id ; rr:objectMap [ rr:column "color_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fabric_id ; rr:objectMap [ rr:column "fabric_id" ] ] .

<#tm_vague_2tabs_key_elements_3_Fashion_Design_fabric_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"design_id\", \"fabric_id\" FROM \"Fashion_Design\" WHERE \"fabric_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Fashion_Design/{design_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFabric_Choice ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Fabric_Choice/{fabric_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_key_elements_4_Fashion_Design_color_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"design_id\", \"color_id\" FROM \"Fashion_Design\" WHERE \"color_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Fashion_Design/{design_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasColor_Palette ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Color_Palette/{color_id}" ; rr:termType rr:IRI ] ] .

