  rr:predicateObjectMap [ rr:predicate p:dance_name ; rr:objectMap [ rr:column "dance_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:culture_id ; rr:objectMap [ rr:column "culture_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:geographical_area_id ; rr:objectMap [ rr:column "geographical_area_id" ] ] .

<#tm_vague_2tabs_origin_3_Dance_geographical_area_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"geographical_area_id\" FROM \"Dance\" WHERE \"geographical_area_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Dance/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGeographical_Area ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Geographical_Area/{geographical_area_id}" ; rr:termType rr:IRI ] ] .

