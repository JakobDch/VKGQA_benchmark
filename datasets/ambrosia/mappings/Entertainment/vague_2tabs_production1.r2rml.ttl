  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDocumentary ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Documentary/{foreign_key}" ; rr:termType rr:IRI ] ] .

