  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"rating\", \"reviewer_name\", \"comment\", \"movie_id\", \"documentary_id\" FROM \"Review\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Review/{id}" ; rr:class :Review ] ;
