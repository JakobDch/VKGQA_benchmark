  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_date\", \"budget\", \"box_office\", \"foreign_key\" FROM \"Movie\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Movie/{id}" ; rr:class :Movie ] ;
