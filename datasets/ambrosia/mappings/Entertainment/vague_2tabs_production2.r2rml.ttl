<#tm_vague_2tabs_production2_3_Stage_Play_producer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"producer_id\" FROM \"Stage_Play\" WHERE \"producer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Stage_Play/{id}" ] ;
