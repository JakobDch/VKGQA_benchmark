<#tm_vague_2tabs_sale_date_3_Events_venue_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"event_id\", \"venue_id\" FROM \"Events\" WHERE \"venue_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Events/{event_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVenue ; rr:objectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Venue/{venue_id}" ; rr:termType rr:IRI ] ] .

