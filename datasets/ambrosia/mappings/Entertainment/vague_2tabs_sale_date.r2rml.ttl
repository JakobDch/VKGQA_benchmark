@prefix : <http://ambrosia.example.org/entertainment#> .
@prefix p: <http://ambrosia.example.org/entertainment/prop#> .
@prefix ex: <http://ambrosia.example.org/entertainment/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_sale_date_0_Artists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"artist_id\", \"name\", \"genre\" FROM \"Artists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/entertainment/id/Artist/{artist_id}" ; rr:class :Artist ] ;
  rr:predicateObjectMap [ rr:predicate p:artist_id ; rr:objectMap [ rr:column "artist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] .

