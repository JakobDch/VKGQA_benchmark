<#tm_attachment_1tab_ref_animation_studio_0_AnimationStudios_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"studioName\" FROM \"AnimationStudios\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/AnimationStudios/{id}" ; rr:class :AnimationStudios ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:studioName ; rr:objectMap [ rr:column "studioName" ] ] .

