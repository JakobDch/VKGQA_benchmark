  rr:predicateObjectMap [ rr:predicate p:hasAnimationStudios ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/AnimationStudios/{animationStudioId}" ; rr:termType rr:IRI ] ] .

