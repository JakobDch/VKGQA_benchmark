  rr:predicateObjectMap [ rr:predicate p:animationStudioId ; rr:objectMap [ rr:column "animationStudioId" ] ] .

<#tm_attachment_1tab_ref_animation_studio_2_MovieDetails_animationStudioId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"animationStudioId\" FROM \"MovieDetails\" WHERE \"animationStudioId\" IS NOT NULL""" ] ;
