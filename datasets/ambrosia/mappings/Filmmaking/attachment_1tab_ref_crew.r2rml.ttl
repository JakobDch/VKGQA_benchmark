@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_crew_0_Actors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Actor_ID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"Height\" FROM \"Actors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{Actor_ID}" ; rr:class :Actors ] ;
  rr:predicateObjectMap [ rr:predicate p:Actor_ID ; rr:objectMap [ rr:column "Actor_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Height ; rr:objectMap [ rr:column "Height" ] ] .

<#tm_attachment_1tab_ref_crew_1_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Role_ID\", \"CharacterName\", \"Movie_ID\", \"Actor_ID\" FROM \"Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{Role_ID}" ; rr:class :Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:Role_ID ; rr:objectMap [ rr:column "Role_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CharacterName ; rr:objectMap [ rr:column "CharacterName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Movie_ID ; rr:objectMap [ rr:column "Movie_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Actor_ID ; rr:objectMap [ rr:column "Actor_ID" ] ] .

<#tm_attachment_1tab_ref_crew_2_Roles_Actor_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Role_ID\", \"Actor_ID\" FROM \"Roles\" WHERE \"Actor_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{Role_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{Actor_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_crew_3_Roles_Movie_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Role_ID\", \"Movie_ID\" FROM \"Roles\" WHERE \"Movie_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{Role_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovies ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{Movie_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_crew_4_Episodes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Episode_ID\", \"SeasonNumber\", \"EpisodeTitle\", \"EpisodeLength\", \"AirDate\", \"Crew_ID\" FROM \"Episodes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Episodes/{Episode_ID}" ; rr:class :Episodes ] ;
  rr:predicateObjectMap [ rr:predicate p:Episode_ID ; rr:objectMap [ rr:column "Episode_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SeasonNumber ; rr:objectMap [ rr:column "SeasonNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EpisodeTitle ; rr:objectMap [ rr:column "EpisodeTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EpisodeLength ; rr:objectMap [ rr:column "EpisodeLength" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AirDate ; rr:objectMap [ rr:column "AirDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Crew_ID ; rr:objectMap [ rr:column "Crew_ID" ] ] .

<#tm_attachment_1tab_ref_crew_5_Crew_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Crew_ID\", \"Position\", \"Name\", \"Experience\", \"Episode_ID\" FROM \"Crew\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Crew/{Crew_ID}" ; rr:class :Crew ] ;
  rr:predicateObjectMap [ rr:predicate p:Crew_ID ; rr:objectMap [ rr:column "Crew_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Position ; rr:objectMap [ rr:column "Position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience ; rr:objectMap [ rr:column "Experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Episode_ID ; rr:objectMap [ rr:column "Episode_ID" ] ] .

<#tm_attachment_1tab_ref_crew_6_Crew_Episode_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Crew_ID\", \"Episode_ID\" FROM \"Crew\" WHERE \"Episode_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Crew/{Crew_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEpisodes ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Episodes/{Episode_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_crew_7_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Movie_ID\", \"Title\", \"ReleaseDate\", \"Genre\", \"BoxOffice\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{Movie_ID}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:Movie_ID ; rr:objectMap [ rr:column "Movie_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BoxOffice ; rr:objectMap [ rr:column "BoxOffice" ] ] .

