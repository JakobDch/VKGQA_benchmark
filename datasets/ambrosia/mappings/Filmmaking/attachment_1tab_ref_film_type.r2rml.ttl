<#tm_attachment_1tab_ref_film_type_3_film_details_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"filmmakingId\", \"film_typeId\", \"budgetId\" FROM \"film_details\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/film_details/{id}" ; rr:class :film_details ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:filmmakingId ; rr:objectMap [ rr:column "filmmakingId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:film_typeId ; rr:objectMap [ rr:column "film_typeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:budgetId ; rr:objectMap [ rr:column "budgetId" ] ] .

<#tm_attachment_1tab_ref_film_type_4_film_details_budgetId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"budgetId\" FROM \"film_details\" WHERE \"budgetId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/film_details/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasbudget ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/budget/{budgetId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_film_type_5_film_details_film_typeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"film_typeId\" FROM \"film_details\" WHERE \"film_typeId\" IS NOT NULL""" ] ;
