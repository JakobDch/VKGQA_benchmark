@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_genre1_0_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Genres/{id}" ; rr:class :Genres ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_genre1_1_Directors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\" FROM \"Directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{id}" ; rr:class :Directors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] .

<#tm_attachment_1tab_ref_genre1_2_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_year\", \"genre_id\", \"director_id\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{id}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_year ; rr:objectMap [ rr:column "release_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre_id ; rr:objectMap [ rr:column "genre_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:director_id ; rr:objectMap [ rr:column "director_id" ] ] .

<#tm_attachment_1tab_ref_genre1_3_Movies_director_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"director_id\" FROM \"Movies\" WHERE \"director_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{director_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_genre1_4_Movies_genre_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"genre_id\" FROM \"Movies\" WHERE \"genre_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenres ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Genres/{genre_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_genre1_5_Durations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"minutes\" FROM \"Durations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Durations/{id}" ; rr:class :Durations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:minutes ; rr:objectMap [ rr:column "minutes" ] ] .

<#tm_attachment_1tab_ref_genre1_6_MovieDurations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"duration_id\" FROM \"MovieDurations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/MovieDurations/{movie_id}/{duration_id}" ; rr:class :MovieDurations ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration_id ; rr:objectMap [ rr:column "duration_id" ] ] .

<#tm_attachment_1tab_ref_genre1_7_MovieDurations_duration_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"duration_id\" FROM \"MovieDurations\" WHERE \"duration_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/MovieDurations/{movie_id}/{duration_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDurations ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Durations/{duration_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_genre1_8_MovieDurations_movie_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"duration_id\" FROM \"MovieDurations\" WHERE \"movie_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/MovieDurations/{movie_id}/{duration_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovies ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movie_id}" ; rr:termType rr:IRI ] ] .

