<#tm_attachment_1tab_ref_genre2_8_Film_Stars_film_star_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"film_star_id\" FROM \"Film_Stars\" WHERE \"film_star_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Stars/{_amb_rowid}" ] ;
