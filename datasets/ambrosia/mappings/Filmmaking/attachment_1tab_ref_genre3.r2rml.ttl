  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birth_year ; rr:objectMap [ rr:column "birth_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:nationality ; rr:objectMap [ rr:column "nationality" ] ] .

<#tm_attachment_1tab_ref_genre3_3_Film_Director_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"director_id\" FROM \"Film_Director\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Director/{film_id}/{director_id}" ; rr:class :Film_Director ] ;
  rr:predicateObjectMap [ rr:predicate p:film_id ; rr:objectMap [ rr:column "film_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:director_id ; rr:objectMap [ rr:column "director_id" ] ] .

<#tm_attachment_1tab_ref_genre3_4_Film_Director_director_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"director_id\" FROM \"Film_Director\" WHERE \"director_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Director/{film_id}/{director_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{director_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_genre3_5_Film_Director_film_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"director_id\" FROM \"Film_Director\" WHERE \"film_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Director/{film_id}/{director_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilms ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{film_id}" ; rr:termType rr:IRI ] ] .

