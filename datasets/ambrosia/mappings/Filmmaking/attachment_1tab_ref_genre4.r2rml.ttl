  rr:predicateObjectMap [ rr:predicate p:genreName ; rr:objectMap [ rr:column "genreName" ] ] .

<#tm_attachment_1tab_ref_genre4_5_Films_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"releaseDate\", \"directorId\", \"genreId\", \"filmingLocation\" FROM \"Films\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ; rr:class :Films ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:releaseDate ; rr:objectMap [ rr:column "releaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:directorId ; rr:objectMap [ rr:column "directorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genreId ; rr:objectMap [ rr:column "genreId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:filmingLocation ; rr:objectMap [ rr:column "filmingLocation" ] ] .

<#tm_attachment_1tab_ref_genre4_6_Films_genreId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"genreId\" FROM \"Films\" WHERE \"genreId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenres ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Genres/{genreId}" ; rr:termType rr:IRI ] ] .

