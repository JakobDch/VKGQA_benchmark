@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_soundtrack_0_Director_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Director\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{id}" ; rr:class :Directors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_soundtrack_1_Film_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_date\", \"director_id\" FROM \"Film\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ; rr:class :Films ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:director_id ; rr:objectMap [ rr:column "director_id" ] ] .

<#tm_attachment_1tab_ref_soundtrack_2_Film_director_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"director_id\" FROM \"Film\" WHERE \"director_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{director_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_soundtrack_3_Movie_Elements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"element_type\", \"movie_title\", \"composer_id\", \"duration\" FROM \"Movie_Elements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_Elements/{_amb_rowid}" ; rr:class :Movie_Elements ] ;
  rr:predicateObjectMap [ rr:predicate p:element_type ; rr:objectMap [ rr:column "element_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_title ; rr:objectMap [ rr:column "movie_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:composer_id ; rr:objectMap [ rr:column "composer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration ; rr:objectMap [ rr:column "duration" ] ] .

<#tm_attachment_1tab_ref_soundtrack_4_Movie_Elements_composer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"composer_id\" FROM \"Movie_Elements\" WHERE \"composer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_Elements/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasComposer ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Composer/{composer_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_soundtrack_5_Composer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"creator\", \"birth_year\", \"death_year\" FROM \"Composer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Composer/{id}" ; rr:class :Composer ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:creator ; rr:objectMap [ rr:column "creator" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birth_year ; rr:objectMap [ rr:column "birth_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:death_year ; rr:objectMap [ rr:column "death_year" ] ] .

