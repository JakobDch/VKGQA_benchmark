<#tm_attachment_1tab_val_animation_studio_5_FilmDirectors_directorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"filmID\", \"directorID\" FROM \"FilmDirectors\" WHERE \"directorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/DirectorFilms/{filmID}/{directorID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{directorID}" ; rr:termType rr:IRI ] ] .

