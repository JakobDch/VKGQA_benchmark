[PrefixDeclaration]
:	http://ambrosia.example.org/filmmaking#
p:	http://ambrosia.example.org/filmmaking/prop#
ex:	http://ambrosia.example.org/filmmaking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Festival_base
target		ex:Festival/{id} a :Festival ; p:id {id} ; p:name {name} ; p:event {event} ; p:committee_members {committee_members} .
source		SELECT `id`, `name`, `event`, `committee_members` FROM `Festival`

mappingId	Movie_base
target		ex:Movies/{id} a :Movies ; p:id {id} ; p:title {title} ; p:release_year {release_year} ; p:festival_id {festival_id} .
source		SELECT `id`, `title`, `release_year`, `festival_id` FROM `Movie`

mappingId	Movie_festival_id_fk
target		ex:Movies/{id} p:hasFestival ex:Festival/{festival_id} .
source		SELECT `id`, `festival_id` FROM `Movie` WHERE `festival_id` IS NOT NULL

mappingId	Director_base
target		ex:Directors/{id} a :Directors ; p:id {id} ; p:name {name} .
source		SELECT `id`, `name` FROM `Director`

mappingId	Actor_base
target		ex:Actors/{id} a :Actors ; p:id {id} ; p:name {name} ; p:director_id {director_id} .
source		SELECT `id`, `name`, `director_id` FROM `Actor`

mappingId	Actor_director_id_fk
target		ex:Actors/{id} p:hasDirectors ex:Directors/{director_id} .
source		SELECT `id`, `director_id` FROM `Actor` WHERE `director_id` IS NOT NULL

mappingId	Character_base
target		ex:Character/{id} a :Character ; p:id {id} ; p:name {name} ; p:actor_id {actor_id} ; p:movie_id {movie_id} .
source		SELECT `id`, `name`, `actor_id`, `movie_id` FROM `Character`

mappingId	Character_movie_id_fk
target		ex:Character/{id} p:hasMovies ex:Movies/{movie_id} .
source		SELECT `id`, `movie_id` FROM `Character` WHERE `movie_id` IS NOT NULL

mappingId	Character_actor_id_fk
target		ex:Character/{id} p:hasActors ex:Actors/{actor_id} .
source		SELECT `id`, `actor_id` FROM `Character` WHERE `actor_id` IS NOT NULL

]]
