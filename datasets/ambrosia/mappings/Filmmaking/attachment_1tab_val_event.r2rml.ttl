  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:director_id ; rr:objectMap [ rr:column "director_id" ] ] .

<#tm_attachment_1tab_val_event_5_Actor_director_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"director_id\" FROM \"Actor\" WHERE \"director_id\" IS NOT NULL""" ] ;
