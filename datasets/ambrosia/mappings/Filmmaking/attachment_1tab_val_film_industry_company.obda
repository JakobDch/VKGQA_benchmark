[PrefixDeclaration]
:	http://ambrosia.example.org/filmmaking#
p:	http://ambrosia.example.org/filmmaking/prop#
ex:	http://ambrosia.example.org/filmmaking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Companies_base
target		ex:Companies/{id} a :Companies ; p:id {id} ; p:name {Name} ; p:Film_Industry_Type {Film_Industry_Type} ; p:Number_Of_Employees {Number_Of_Employees} ; p:Annual_Revenue {Annual_Revenue} ; p:Founded {Founded} .
source		SELECT `id`, `Name`, `Film_Industry_Type`, `Number_Of_Employees`, `Annual_Revenue`, `Founded` FROM `Companies`

mappingId	Films_base
target		ex:Films/{id} a :Films ; p:id {id} ; p:Title {Title} ; p:Director_Name {Director_Name} ; p:Production_Companies {Production_Companies} ; p:Distribution_Companies {Distribution_Companies} ; p:Release_Date {Release_Date} ; p:Running_Time {Running_Time} ; p:Genre {Genre} ; p:Box_Office_Earnings {Box_Office_Earnings} .
source		SELECT `id`, `Title`, `Director_Name`, `Production_Companies`, `Distribution_Companies`, `Release_Date`, `Running_Time`, `Genre`, `Box_Office_Earnings` FROM `Films`

mappingId	Directors_base
target		ex:Directors/{id} a :Directors ; p:id {id} ; p:name {Name} ; p:Birth_Place {Birth_Place} ; p:Years_Experience {Years_Experience} .
source		SELECT `id`, `Name`, `Birth_Place`, `Years_Experience` FROM `Directors`

mappingId	Producers_base
target		ex:Producers/{id} a :Producers ; p:id {id} ; p:name {Name} ; p:Birth_Place {Birth_Place} ; p:Total_Movies_Produced {Total_Movies_Produced} .
source		SELECT `id`, `Name`, `Birth_Place`, `Total_Movies_Produced` FROM `Producers`

mappingId	Actors_base
target		ex:Actors/{id} a :Actors ; p:id {id} ; p:First_Name {First_Name} ; p:Last_Name {Last_Name} ; p:Date_of_Birth {Date_of_Birth} ; p:Nationality {Nationality} .
source		SELECT `id`, `First_Name`, `Last_Name`, `Date_of_Birth`, `Nationality` FROM `Actors`

]]
