@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_film_industry_company_0_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Film_Industry_Type\", \"Number_Of_Employees\", \"Annual_Revenue\", \"Founded\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Film_Industry_Type ; rr:objectMap [ rr:column "Film_Industry_Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_Of_Employees ; rr:objectMap [ rr:column "Number_Of_Employees" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Annual_Revenue ; rr:objectMap [ rr:column "Annual_Revenue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Founded ; rr:objectMap [ rr:column "Founded" ] ] .

<#tm_attachment_1tab_val_film_industry_company_1_Films_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Director_Name\", \"Production_Companies\", \"Distribution_Companies\", \"Release_Date\", \"Running_Time\", \"Genre\", \"Box_Office_Earnings\" FROM \"Films\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ; rr:class :Films ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Director_Name ; rr:objectMap [ rr:column "Director_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Production_Companies ; rr:objectMap [ rr:column "Production_Companies" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Distribution_Companies ; rr:objectMap [ rr:column "Distribution_Companies" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Release_Date ; rr:objectMap [ rr:column "Release_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Running_Time ; rr:objectMap [ rr:column "Running_Time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Box_Office_Earnings ; rr:objectMap [ rr:column "Box_Office_Earnings" ] ] .

