[PrefixDeclaration]
:	http://ambrosia.example.org/filmmaking#
p:	http://ambrosia.example.org/filmmaking/prop#
ex:	http://ambrosia.example.org/filmmaking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Directors_base
target		ex:Directors/{DirectorID} a :Directors ; p:DirectorID {DirectorID} ; p:name {Name} ; p:BirthDate {BirthDate} ; p:Nationality {Nationality} .
source		SELECT `DirectorID`, `Name`, `BirthDate`, `Nationality` FROM `Directors`

mappingId	Producers_base
target		ex:Producers/{ProducerID} a :Producers ; p:ProducerID {ProducerID} ; p:name {Name} ; p:ContactNumber {ContactNumber} ; p:email {Email} ; p:AssociatedDirector {AssociatedDirector} .
source		SELECT `ProducerID`, `Name`, `ContactNumber`, `Email`, `AssociatedDirector` FROM `Producers`

mappingId	Producers_AssociatedDirector_fk
target		ex:Producers/{ProducerID} p:hasDirectors ex:Directors/{AssociatedDirector} .
source		SELECT `ProducerID`, `AssociatedDirector` FROM `Producers` WHERE `AssociatedDirector` IS NOT NULL

mappingId	Films_base
target		ex:Films/{FilmID} a :Films ; p:FilmID {FilmID} ; p:Title {Title} ; p:ReleaseYear {ReleaseYear} ; p:FilmType {FilmType} ; p:Budget {Budget} ; p:ProductionCompanyID {ProductionCompanyID} .
source		SELECT `FilmID`, `Title`, `ReleaseYear`, `FilmType`, `Budget`, `ProductionCompanyID` FROM `Films`

mappingId	Films_ProductionCompanyID_fk
target		ex:Films/{FilmID} p:hasCompanies ex:Companies/{ProductionCompanyID} .
source		SELECT `FilmID`, `ProductionCompanyID` FROM `Films` WHERE `ProductionCompanyID` IS NOT NULL

mappingId	Actors_base
target		ex:Actors/{ActorID} a :Actors ; p:ActorID {ActorID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:DateOfBirth {DateOfBirth} .
source		SELECT `ActorID`, `FirstName`, `LastName`, `DateOfBirth` FROM `Actors`

mappingId	Casts_base
target		ex:FilmActors/{RoleID} a :FilmActors ; p:RoleID {RoleID} ; p:FilmID {FilmID} ; p:ActorID {ActorID} ; p:CharacterName {CharacterName} ; p:AppearanceFee {AppearanceFee} .
source		SELECT `RoleID`, `FilmID`, `ActorID`, `CharacterName`, `AppearanceFee` FROM `Casts`

mappingId	Casts_FilmID_fk
target		ex:FilmActors/{RoleID} p:hasFilms ex:Films/{FilmID} .
source		SELECT `RoleID`, `FilmID` FROM `Casts` WHERE `FilmID` IS NOT NULL

mappingId	Casts_ActorID_fk
target		ex:FilmActors/{RoleID} p:hasActors ex:Actors/{ActorID} .
source		SELECT `RoleID`, `ActorID` FROM `Casts` WHERE `ActorID` IS NOT NULL

mappingId	Companies_base
target		ex:Companies/{CompanyID} a :Companies ; p:CompanyID {CompanyID} ; p:CompanyName {CompanyName} ; p:AddressLine1 {AddressLine1} ; p:AddressLine2 {AddressLine2} ; p:City {City} ; p:StateOrRegion {StateOrRegion} ; p:PostalCode {PostalCode} ; p:Country {Country} .
source		SELECT `CompanyID`, `CompanyName`, `AddressLine1`, `AddressLine2`, `City`, `StateOrRegion`, `PostalCode`, `Country` FROM `Companies`

]]
