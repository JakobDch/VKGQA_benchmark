  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StateOrRegion ; rr:objectMap [ rr:column "StateOrRegion" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PostalCode ; rr:objectMap [ rr:column "PostalCode" ] ] ;
