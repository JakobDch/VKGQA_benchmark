@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_genre1_0_Production_houses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"houseID\", \"name\" FROM \"Production_houses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/ProductionHouses/{houseID}" ; rr:class :ProductionHouses ] ;
  rr:predicateObjectMap [ rr:predicate p:houseID ; rr:objectMap [ rr:column "houseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_val_genre1_1_Directors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"directorID\", \"firstName\", \"lastName\" FROM \"Directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{directorID}" ; rr:class :Directors ] ;
  rr:predicateObjectMap [ rr:predicate p:directorID ; rr:objectMap [ rr:column "directorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] .

<#tm_attachment_1tab_val_genre1_2_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movieID\", \"title\", \"genre\", \"duration\", \"productionHouseID\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movieID}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:movieID ; rr:objectMap [ rr:column "movieID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration ; rr:objectMap [ rr:column "duration" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:productionHouseID ; rr:objectMap [ rr:column "productionHouseID" ] ] .

<#tm_attachment_1tab_val_genre1_3_Movies_productionHouseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movieID\", \"productionHouseID\" FROM \"Movies\" WHERE \"productionHouseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movieID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProductionHouses ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/ProductionHouses/{productionHouseID}" ; rr:termType rr:IRI ] ] .

