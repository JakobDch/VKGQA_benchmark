@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_genre3_0_Directors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorID\", \"Name\", \"BirthDate\" FROM \"Directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{DirectorID}" ; rr:class :Directors ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorID ; rr:objectMap [ rr:column "DirectorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] .

<#tm_attachment_1tab_val_genre3_1_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MovieID\", \"Title\", \"Genre\", \"Budget\", \"ReleaseYear\", \"DirectorID\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{MovieID}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieID ; rr:objectMap [ rr:column "MovieID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Budget ; rr:objectMap [ rr:column "Budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorID ; rr:objectMap [ rr:column "DirectorID" ] ] .

<#tm_attachment_1tab_val_genre3_2_Movies_DirectorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MovieID\", \"DirectorID\" FROM \"Movies\" WHERE \"DirectorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{MovieID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{DirectorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_genre3_3_Actors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ActorID\", \"FirstName\", \"LastName\", \"BirthDate\" FROM \"Actors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{ActorID}" ; rr:class :Actors ] ;
  rr:predicateObjectMap [ rr:predicate p:ActorID ; rr:objectMap [ rr:column "ActorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] .

<#tm_attachment_1tab_val_genre3_4_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoleID\", \"MovieID\", \"ActorID\", \"CharacterName\" FROM \"Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{RoleID}" ; rr:class :Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:RoleID ; rr:objectMap [ rr:column "RoleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieID ; rr:objectMap [ rr:column "MovieID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ActorID ; rr:objectMap [ rr:column "ActorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CharacterName ; rr:objectMap [ rr:column "CharacterName" ] ] .

<#tm_attachment_1tab_val_genre3_5_Roles_ActorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoleID\", \"ActorID\" FROM \"Roles\" WHERE \"ActorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{RoleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{ActorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_genre3_6_Roles_MovieID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoleID\", \"MovieID\" FROM \"Roles\" WHERE \"MovieID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{RoleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovies ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{MovieID}" ; rr:termType rr:IRI ] ] .

