@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_genre4_0_Directors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorID\", \"Name\", \"BirthDate\", \"Country\" FROM \"Directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{DirectorID}" ; rr:class :Directors ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorID ; rr:objectMap [ rr:column "DirectorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_val_genre4_1_Actors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ActorID\", \"Name\", \"DateOfBirth\", \"Nationality\" FROM \"Actors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{ActorID}" ; rr:class :Actors ] ;
  rr:predicateObjectMap [ rr:predicate p:ActorID ; rr:objectMap [ rr:column "ActorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Nationality ; rr:objectMap [ rr:column "Nationality" ] ] .

<#tm_attachment_1tab_val_genre4_2_Producers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProducerID\", \"Name\", \"CompanyName\", \"ContactInfo\" FROM \"Producers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Producers/{ProducerID}" ; rr:class :Producers ] ;
  rr:predicateObjectMap [ rr:predicate p:ProducerID ; rr:objectMap [ rr:column "ProducerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyName ; rr:objectMap [ rr:column "CompanyName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ContactInfo ; rr:objectMap [ rr:column "ContactInfo" ] ] .

<#tm_attachment_1tab_val_genre4_3_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoleID\", \"MovieTitle\", \"CharacterName\", \"DirectorID\", \"ProducerID\" FROM \"Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{RoleID}" ; rr:class :Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:RoleID ; rr:objectMap [ rr:column "RoleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieTitle ; rr:objectMap [ rr:column "MovieTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CharacterName ; rr:objectMap [ rr:column "CharacterName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorID ; rr:objectMap [ rr:column "DirectorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProducerID ; rr:objectMap [ rr:column "ProducerID" ] ] .

<#tm_attachment_1tab_val_genre4_4_Roles_ProducerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoleID\", \"ProducerID\" FROM \"Roles\" WHERE \"ProducerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{RoleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProducers ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Producers/{ProducerID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_genre4_5_Roles_DirectorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoleID\", \"DirectorID\" FROM \"Roles\" WHERE \"DirectorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{RoleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{DirectorID}" ; rr:termType rr:IRI ] ] .

