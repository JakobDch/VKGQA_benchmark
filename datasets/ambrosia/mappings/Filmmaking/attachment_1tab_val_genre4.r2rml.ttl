  rr:logicalTable [ rr:sqlQuery """SELECT \"MovieID\", \"Title\", \"ReleaseYear\", \"Genre\", \"Rating\", \"FilmFestival\", \"Budget\", \"BoxOffice\", \"DirectorID\", \"ProducerID\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{MovieID}" ; rr:class :Movies ] ;
