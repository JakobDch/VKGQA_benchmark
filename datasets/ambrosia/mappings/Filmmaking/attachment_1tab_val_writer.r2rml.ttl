@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_writer_0_Writer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Type\", \"Education\" FROM \"Writer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Writer/{id}" ; rr:class :Writer ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Education ; rr:objectMap [ rr:column "Education" ] ] .

<#tm_attachment_1tab_val_writer_1_Film_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"ReleaseYear\", \"Genre\" FROM \"Film\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ; rr:class :Films ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] .

<#tm_attachment_1tab_val_writer_2_Director_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"BirthDate\" FROM \"Director\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{id}" ; rr:class :Directors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] .

<#tm_attachment_1tab_val_writer_3_Director_Film_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"directorId\", \"filmId\" FROM \"Director_Film\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/DirectorFilms/{directorId}/{filmId}" ; rr:class :DirectorFilms ] ;
  rr:predicateObjectMap [ rr:predicate p:directorId ; rr:objectMap [ rr:column "directorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:filmId ; rr:objectMap [ rr:column "filmId" ] ] .

<#tm_attachment_1tab_val_writer_4_Director_Film_filmId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"directorId\", \"filmId\" FROM \"Director_Film\" WHERE \"filmId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/DirectorFilms/{directorId}/{filmId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilms ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{filmId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_writer_5_Director_Film_directorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"directorId\", \"filmId\" FROM \"Director_Film\" WHERE \"directorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/DirectorFilms/{directorId}/{filmId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{directorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_writer_6_Screenplay_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Year\" FROM \"Screenplay\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Screenplay/{id}" ; rr:class :Screenplay ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] .

<#tm_attachment_1tab_val_writer_7_Film_Screenplay_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"filmId\", \"scriptId\" FROM \"Film_Screenplay\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Screenplay/{filmId}/{scriptId}" ; rr:class :Film_Screenplay ] ;
  rr:predicateObjectMap [ rr:predicate p:filmId ; rr:objectMap [ rr:column "filmId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:scriptId ; rr:objectMap [ rr:column "scriptId" ] ] .

<#tm_attachment_1tab_val_writer_8_Film_Screenplay_filmId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"filmId\", \"scriptId\" FROM \"Film_Screenplay\" WHERE \"filmId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Screenplay/{filmId}/{scriptId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilms ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{filmId}" ; rr:termType rr:IRI ] ] .

