<#tm_attachment_2tab_ref_crew_member_3_Film_cinematographer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"cinematographer_id\" FROM \"Film\" WHERE \"cinematographer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCinematographers ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographers/{cinematographer_id}" ; rr:termType rr:IRI ] ] .

