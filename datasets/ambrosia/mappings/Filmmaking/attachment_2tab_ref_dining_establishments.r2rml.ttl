<#tm_attachment_2tab_ref_dining_establishments_4_Restaurant_Menus_menu_option_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"restaurant_id\", \"menu_option_id\" FROM \"Restaurant_Menus\" WHERE \"menu_option_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Restaurant_Menus/{restaurant_id}/{menu_option_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMenu_Options ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Menu_Options/{menu_option_id}" ; rr:termType rr:IRI ] ] .

