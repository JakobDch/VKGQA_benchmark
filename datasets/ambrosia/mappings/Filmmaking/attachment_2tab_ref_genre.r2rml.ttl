@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_genre_0_Blockbusters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"releaseYear\", \"director\", \"budget\", \"boxOffice\", \"film_festival_id\" FROM \"Blockbusters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Blockbusters/{id}" ; rr:class :Blockbusters ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:releaseYear ; rr:objectMap [ rr:column "releaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:director ; rr:objectMap [ rr:column "director" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:budget ; rr:objectMap [ rr:column "budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:boxOffice ; rr:objectMap [ rr:column "boxOffice" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:film_festival_id ; rr:objectMap [ rr:column "film_festival_id" ] ] .

<#tm_attachment_2tab_ref_genre_1_Blockbusters_film_festival_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"film_festival_id\" FROM \"Blockbusters\" WHERE \"film_festival_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Blockbusters/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFestival ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Festival/{film_festival_id}" ; rr:termType rr:IRI ] ] .

