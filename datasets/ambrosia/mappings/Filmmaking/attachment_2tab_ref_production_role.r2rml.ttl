@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_production_role_0_Scriptwriters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Birthdate\" FROM \"Scriptwriters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Scriptwriters/{ID}" ; rr:class :Scriptwriters ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Birthdate ; rr:objectMap [ rr:column "Birthdate" ] ] .

<#tm_attachment_2tab_ref_production_role_1_Editors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"HireDate\" FROM \"Editors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Editors/{ID}" ; rr:class :Editors ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HireDate ; rr:objectMap [ rr:column "HireDate" ] ] .

<#tm_attachment_2tab_ref_production_role_2_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Deadline\", \"Budget\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Projects/{ID}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Deadline ; rr:objectMap [ rr:column "Deadline" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Budget ; rr:objectMap [ rr:column "Budget" ] ] .

<#tm_attachment_2tab_ref_production_role_3_Assignments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ScriptwriterID\", \"EditorID\", \"ProjectID\" FROM \"Assignments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Assignments/{ScriptwriterID}/{EditorID}/{ProjectID}" ; rr:class :Assignments ] ;
  rr:predicateObjectMap [ rr:predicate p:ScriptwriterID ; rr:objectMap [ rr:column "ScriptwriterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EditorID ; rr:objectMap [ rr:column "EditorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProjectID ; rr:objectMap [ rr:column "ProjectID" ] ] .

<#tm_attachment_2tab_ref_production_role_4_Assignments_ProjectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ScriptwriterID\", \"EditorID\", \"ProjectID\" FROM \"Assignments\" WHERE \"ProjectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Assignments/{ScriptwriterID}/{EditorID}/{ProjectID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Projects/{ProjectID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_production_role_5_Assignments_EditorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ScriptwriterID\", \"EditorID\", \"ProjectID\" FROM \"Assignments\" WHERE \"EditorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Assignments/{ScriptwriterID}/{EditorID}/{ProjectID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEditors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Editors/{EditorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_production_role_6_Assignments_ScriptwriterID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ScriptwriterID\", \"EditorID\", \"ProjectID\" FROM \"Assignments\" WHERE \"ScriptwriterID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Assignments/{ScriptwriterID}/{EditorID}/{ProjectID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasScriptwriters ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Scriptwriters/{ScriptwriterID}" ; rr:termType rr:IRI ] ] .

