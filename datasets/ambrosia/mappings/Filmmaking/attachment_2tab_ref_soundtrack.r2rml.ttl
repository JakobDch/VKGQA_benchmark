@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_soundtrack_0_Creators_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Creators\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Creators/{id}" ; rr:class :Creators ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_soundtrack_1_Films_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"releaseDate\", \"soundDesign\", \"musicScore\" FROM \"Films\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ; rr:class :Films ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:releaseDate ; rr:objectMap [ rr:column "releaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:soundDesign ; rr:objectMap [ rr:column "soundDesign" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:musicScore ; rr:objectMap [ rr:column "musicScore" ] ] .

<#tm_attachment_2tab_ref_soundtrack_2_Films_musicScore_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"musicScore\" FROM \"Films\" WHERE \"musicScore\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSoundDesigns ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/SoundDesigns/{musicScore}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_soundtrack_3_Films_soundDesign_fk> a rr:TriplesMap ;
