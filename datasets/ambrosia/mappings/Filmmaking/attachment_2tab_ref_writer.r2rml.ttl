@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_writer_0_Education_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"institution\" FROM \"Education\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Education/{id}" ; rr:class :Education ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:institution ; rr:objectMap [ rr:column "institution" ] ] .

<#tm_attachment_2tab_ref_writer_1_Screenwriter_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"birthdate\", \"nationality\", \"educationId\" FROM \"Screenwriter\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Screenwriters/{id}" ; rr:class :Screenwriters ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthdate ; rr:objectMap [ rr:column "birthdate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:nationality ; rr:objectMap [ rr:column "nationality" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:educationId ; rr:objectMap [ rr:column "educationId" ] ] .

<#tm_attachment_2tab_ref_writer_2_Screenwriter_educationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"educationId\" FROM \"Screenwriter\" WHERE \"educationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Screenwriters/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEducation ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Education/{educationId}" ; rr:termType rr:IRI ] ] .

