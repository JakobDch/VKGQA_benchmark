[PrefixDeclaration]
:	http://ambrosia.example.org/filmmaking#
p:	http://ambrosia.example.org/filmmaking/prop#
ex:	http://ambrosia.example.org/filmmaking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Screenwriters_base
target		ex:Screenwriters/{ID} a :Screenwriters ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Country {Country} ; p:Number_Of_Projects_Completed {Number_Of_Projects_Completed} .
source		SELECT `ID`, `Name`, `Age`, `Country`, `Number_Of_Projects_Completed` FROM `Screenwriters`

mappingId	Directors_base
target		ex:Directors/{ID} a :Directors ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Country {Country} ; p:Number_Of_Movies_Directed {Number_Of_Movies_Directed} .
source		SELECT `ID`, `Name`, `Age`, `Country`, `Number_Of_Movies_Directed` FROM `Directors`

mappingId	Actors_base
target		ex:Actors/{ID} a :Actors ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Country {Country} ; p:Number_Of_Roles {Number_Of_Roles} .
source		SELECT `ID`, `Name`, `Age`, `Country`, `Number_Of_Roles` FROM `Actors`

mappingId	Producers_base
target		ex:Producers/{ID} a :Producers ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Country {Country} ; p:Number_Of_Productions {Number_Of_Productions} .
source		SELECT `ID`, `Name`, `Age`, `Country`, `Number_Of_Productions` FROM `Producers`

mappingId	Cinematographers_base
target		ex:Cinematographers/{ID} a :Cinematographers ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Country {Country} ; p:Number_Of_Films_Cinematographed {Number_Of_Films_Cinematographed} .
source		SELECT `ID`, `Name`, `Age`, `Country`, `Number_Of_Films_Cinematographed` FROM `Cinematographers`

mappingId	Editors_base
target		ex:Editors/{ID} a :Editors ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Country {Country} ; p:Number_Of_Projects_Completed {Number_Of_Projects_Completed} .
source		SELECT `ID`, `Name`, `Age`, `Country`, `Number_Of_Projects_Completed` FROM `Editors`

]]
