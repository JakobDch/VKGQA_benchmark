  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/ActorsInFilms/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilmsDirectedBy ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/FilmsDirectedBy/{FilmID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_film_type_8_ActorsInFilms_ActorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ActorID\" FROM \"ActorsInFilms\" WHERE \"ActorID\" IS NOT NULL""" ] ;
