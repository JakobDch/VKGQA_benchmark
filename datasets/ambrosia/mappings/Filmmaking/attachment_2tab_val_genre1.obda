[PrefixDeclaration]
:	http://ambrosia.example.org/filmmaking#
p:	http://ambrosia.example.org/filmmaking/prop#
ex:	http://ambrosia.example.org/filmmaking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Action_Movies_base
target		ex:Action_Movies/{id} a :Action_Movies ; p:id {id} ; p:Title {Title} ; p:Director {Director} ; p:ReleaseYear {ReleaseYear} ; p:Stars {Stars} .
source		SELECT `id`, `Title`, `Director`, `ReleaseYear`, `Stars` FROM `Action_Movies`

mappingId	Adventure_Movies_base
target		ex:Adventure_Movies/{id} a :Adventure_Movies ; p:id {id} ; p:Title {Title} ; p:Director {Director} ; p:ReleaseYear {ReleaseYear} ; p:Stars {Stars} .
source		SELECT `id`, `Title`, `Director`, `ReleaseYear`, `Stars` FROM `Adventure_Movies`

mappingId	SciFi_Movies_base
target		ex:SciFi_Movies/{id} a :SciFi_Movies ; p:id {id} ; p:Title {Title} ; p:Director {Director} ; p:ReleaseYear {ReleaseYear} ; p:Stars {Stars} .
source		SELECT `id`, `Title`, `Director`, `ReleaseYear`, `Stars` FROM `SciFi_Movies`

mappingId	Animated_Movies_base
target		ex:Animated_Movies/{id} a :Animated_Movies ; p:id {id} ; p:Title {Title} ; p:Studio {Studio} ; p:ReleaseYear {ReleaseYear} ; p:Stars {Stars} .
source		SELECT `id`, `Title`, `Studio`, `ReleaseYear`, `Stars` FROM `Animated_Movies`

mappingId	Horror_Movies_base
target		ex:Horror_Movies/{id} a :Horror_Movies ; p:id {id} ; p:Title {Title} ; p:Director {Director} ; p:ReleaseYear {ReleaseYear} ; p:Stars {Stars} .
source		SELECT `id`, `Title`, `Director`, `ReleaseYear`, `Stars` FROM `Horror_Movies`

mappingId	Comedy_Movies_base
target		ex:Comedy_Movies/{id} a :Comedy_Movies ; p:id {id} ; p:Title {Title} ; p:Director {Director} ; p:ReleaseYear {ReleaseYear} ; p:Stars {Stars} .
source		SELECT `id`, `Title`, `Director`, `ReleaseYear`, `Stars` FROM `Comedy_Movies`

]]
