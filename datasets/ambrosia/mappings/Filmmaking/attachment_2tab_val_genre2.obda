[PrefixDeclaration]
:	http://ambrosia.example.org/filmmaking#
p:	http://ambrosia.example.org/filmmaking/prop#
ex:	http://ambrosia.example.org/filmmaking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	SciFiMovies_base
target		ex:SciFi_Movies/{id} a :SciFi_Movies ; p:id {id} ; p:title {title} ; p:director {director} ; p:releaseYear {releaseYear} ; p:sciFi {sciFi} ; p:filmingLocation {filmingLocation} .
source		SELECT `id`, `title`, `director`, `releaseYear`, `sciFi`, `filmingLocation` FROM `SciFiMovies`

mappingId	FantasyMovies_base
target		ex:FantasyMovies/{id} a :FantasyMovies ; p:id {id} ; p:title {title} ; p:director {director} ; p:releaseYear {releaseYear} ; p:fantasy {fantasy} ; p:filmingLocation {filmingLocation} .
source		SELECT `id`, `title`, `director`, `releaseYear`, `fantasy`, `filmingLocation` FROM `FantasyMovies`

mappingId	Actors_base
target		ex:Actors/{id} a :Actors ; p:id {id} ; p:name {name} ; p:birthDate {birthDate} ; p:nationality {nationality} .
source		SELECT `id`, `name`, `birthDate`, `nationality` FROM `Actors`

mappingId	Roles_base
target		ex:Roles/{movieId}/{actorId} a :Roles ; p:movieId {movieId} ; p:actorId {actorId} ; p:roleName {roleName} .
source		SELECT `movieId`, `actorId`, `roleName` FROM `Roles`

mappingId	Roles_actorId_fk
target		ex:Roles/{movieId}/{actorId} p:hasActors ex:Actors/{actorId} .
source		SELECT `movieId`, `actorId` FROM `Roles` WHERE `actorId` IS NOT NULL

mappingId	Directors_base
target		ex:Directors/{id} a :Directors ; p:id {id} ; p:name {name} ; p:birthDate {birthDate} ; p:nationality {nationality} .
source		SELECT `id`, `name`, `birthDate`, `nationality` FROM `Directors`

mappingId	Productions_base
target		ex:Productions/{id} a :Productions ; p:id {id} ; p:movieTitle {movieTitle} ; p:productionCompany {productionCompany} ; p:budget {budget} ; p:startDate {startDate} ; p:endDate {endDate} .
source		SELECT `id`, `movieTitle`, `productionCompany`, `budget`, `startDate`, `endDate` FROM `Productions`

]]
