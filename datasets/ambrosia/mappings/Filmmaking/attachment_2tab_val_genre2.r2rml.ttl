<#tm_attachment_2tab_val_genre2_3_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movieId\", \"actorId\", \"roleName\" FROM \"Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{movieId}/{actorId}" ; rr:class :Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:movieId ; rr:objectMap [ rr:column "movieId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:actorId ; rr:objectMap [ rr:column "actorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roleName ; rr:objectMap [ rr:column "roleName" ] ] .

<#tm_attachment_2tab_val_genre2_4_Roles_actorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movieId\", \"actorId\" FROM \"Roles\" WHERE \"actorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{movieId}/{actorId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{actorId}" ; rr:termType rr:IRI ] ] .

