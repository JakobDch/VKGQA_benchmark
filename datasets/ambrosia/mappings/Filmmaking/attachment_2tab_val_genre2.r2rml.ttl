@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_genre2_0_SciFiMovies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"director\", \"releaseYear\", \"sciFi\", \"filmingLocation\" FROM \"SciFiMovies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/SciFi_Movies/{id}" ; rr:class :SciFi_Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:director ; rr:objectMap [ rr:column "director" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:releaseYear ; rr:objectMap [ rr:column "releaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:sciFi ; rr:objectMap [ rr:column "sciFi" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:filmingLocation ; rr:objectMap [ rr:column "filmingLocation" ] ] .

