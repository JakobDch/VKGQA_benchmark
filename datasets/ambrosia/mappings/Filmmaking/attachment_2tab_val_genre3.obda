[PrefixDeclaration]
:	http://ambrosia.example.org/filmmaking#
p:	http://ambrosia.example.org/filmmaking/prop#
ex:	http://ambrosia.example.org/filmmaking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Action_Movies_base
target		ex:Action_Movies/{id} a :Action_Movies ; p:id {id} ; p:Title {Title} ; p:Director {Director} ; p:ReleaseYear {ReleaseYear} ; p:Duration {Duration} .
source		SELECT `id`, `Title`, `Director`, `ReleaseYear`, `Duration` FROM `Action_Movies`

mappingId	Romantic_Comedies_base
target		ex:Romantic_Comedies/{id} a :Romantic_Comedies ; p:id {id} ; p:Title {Title} ; p:Director {Director} ; p:ReleaseYear {ReleaseYear} ; p:Duration {Duration} .
source		SELECT `id`, `Title`, `Director`, `ReleaseYear`, `Duration` FROM `Romantic_Comedies`

mappingId	Actors_base
target		ex:Actors/{id} a :Actors ; p:id {id} ; p:name {Name} ; p:BirthDate {BirthDate} ; p:Nationality {Nationality} .
source		SELECT `id`, `Name`, `BirthDate`, `Nationality` FROM `Actors`

mappingId	Directors_base
target		ex:Directors/{id} a :Directors ; p:id {id} ; p:name {Name} ; p:BirthDate {BirthDate} ; p:Nationality {Nationality} .
source		SELECT `id`, `Name`, `BirthDate`, `Nationality` FROM `Directors`

mappingId	Movie_Ratings_base
target		ex:Movie_Ratings/{id} a :Movie_Ratings ; p:id {id} ; p:Rating {Rating} ; p:ReviewerName {ReviewerName} .
source		SELECT `id`, `Rating`, `ReviewerName` FROM `Movie_Ratings`

mappingId	Awards_base
target		ex:Awards/{id} a :Awards ; p:id {id} ; p:AwardType {AwardType} ; p:RecipientId {RecipientId} .
source		SELECT `id`, `AwardType`, `RecipientId` FROM `Awards`

mappingId	Awards_RecipientId_fk
target		ex:Awards/{id} p:hasActors ex:Actors/{RecipientId} .
source		SELECT `id`, `RecipientId` FROM `Awards` WHERE `RecipientId` IS NOT NULL

]]
