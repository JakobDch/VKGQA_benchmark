<#tm_attachment_2tab_val_genre3_6_Awards_RecipientId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"RecipientId\" FROM \"Awards\" WHERE \"RecipientId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Awards/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{RecipientId}" ; rr:termType rr:IRI ] ] .

