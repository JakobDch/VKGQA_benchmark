<#tm_attachment_2tab_val_production_role1_6_MovieCrew_HouseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"HouseID\" FROM \"MovieCrew\" WHERE \"HouseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/MovieCrew/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProductionHouses ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/ProductionHouses/{HouseID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_production_role1_7_MovieCrew_PersonID_fk> a rr:TriplesMap ;
