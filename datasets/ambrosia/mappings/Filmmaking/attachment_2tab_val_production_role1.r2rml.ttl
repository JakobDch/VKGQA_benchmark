  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/MovieCrew/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{PersonID}" ; rr:termType rr:IRI ] ] .

