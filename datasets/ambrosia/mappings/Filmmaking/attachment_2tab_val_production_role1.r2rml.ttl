<#tm_attachment_2tab_val_production_role1_5_MovieCrew_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Position\", \"PersonID\", \"HouseID\" FROM \"MovieCrew\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/MovieCrew/{ID}" ; rr:class :MovieCrew ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Position ; rr:objectMap [ rr:column "Position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PersonID ; rr:objectMap [ rr:column "PersonID" ] ] ;
