[PrefixDeclaration]
:	http://ambrosia.example.org/filmmaking#
p:	http://ambrosia.example.org/filmmaking/prop#
ex:	http://ambrosia.example.org/filmmaking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Casting_Directors_base
target		ex:Casting_Directors/{ID} a :Casting_Directors ; p:ID {ID} ; p:name {Name} ; p:Salary {Salary} ; p:Experience {Experience} ; p:Awards {Awards} .
source		SELECT `ID`, `Name`, `Salary`, `Experience`, `Awards` FROM `Casting_Directors`

mappingId	Location_Scouts_base
target		ex:Location_Scouts/{ID} a :Location_Scouts ; p:ID {ID} ; p:name {Name} ; p:Salary {Salary} ; p:YearsExperience {YearsExperience} ; p:NotableLocations {NotableLocations} .
source		SELECT `ID`, `Name`, `Salary`, `YearsExperience`, `NotableLocations` FROM `Location_Scouts`

mappingId	Producers_base
target		ex:Producers/{ID} a :Producers ; p:ID {ID} ; p:name {Name} ; p:Budget {Budget} ; p:Projects {Projects} ; p:FamousFor {FamousFor} .
source		SELECT `ID`, `Name`, `Budget`, `Projects`, `FamousFor` FROM `Producers`

mappingId	Cinematographers_base
target		ex:Cinematographers/{ID} a :Cinematographers ; p:ID {ID} ; p:name {Name} ; p:EquipmentUsed {EquipmentUsed} ; p:Style {Style} ; p:FilmsShot {FilmsShot} .
source		SELECT `ID`, `Name`, `EquipmentUsed`, `Style`, `FilmsShot` FROM `Cinematographers`

mappingId	Screenwriters_base
target		ex:Screenwriters/{ID} a :Screenwriters ; p:ID {ID} ; p:name {Name} ; p:Genre {Genre} ; p:ScriptsWritten {ScriptsWritten} ; p:Nominations {Nominations} .
source		SELECT `ID`, `Name`, `Genre`, `ScriptsWritten`, `Nominations` FROM `Screenwriters`

mappingId	Actors_base
target		ex:Actors/{ID} a :Actors ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:RolesPlayed {RolesPlayed} ; p:KnownFor {KnownFor} .
source		SELECT `ID`, `Name`, `Age`, `RolesPlayed`, `KnownFor` FROM `Actors`

]]
