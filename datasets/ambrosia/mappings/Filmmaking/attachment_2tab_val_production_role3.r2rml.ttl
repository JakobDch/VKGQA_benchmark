<#tm_attachment_2tab_val_production_role3_0_ProductionHouse_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"HouseID\", \"Name\" FROM \"ProductionHouse\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/ProductionHouses/{HouseID}" ; rr:class :ProductionHouses ] ;
  rr:predicateObjectMap [ rr:predicate p:HouseID ; rr:objectMap [ rr:column "HouseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_val_production_role3_1_Film_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FilmID\", \"Title\", \"ReleaseYear\", \"Budget\", \"BoxOffice\", \"HouseID\" FROM \"Film\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{FilmID}" ; rr:class :Films ] ;
  rr:predicateObjectMap [ rr:predicate p:FilmID ; rr:objectMap [ rr:column "FilmID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Budget ; rr:objectMap [ rr:column "Budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BoxOffice ; rr:objectMap [ rr:column "BoxOffice" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HouseID ; rr:objectMap [ rr:column "HouseID" ] ] .

<#tm_attachment_2tab_val_production_role3_2_Film_HouseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FilmID\", \"HouseID\" FROM \"Film\" WHERE \"HouseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{FilmID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProductionHouses ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/ProductionHouses/{HouseID}" ; rr:termType rr:IRI ] ] .

