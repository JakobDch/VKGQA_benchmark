[PrefixDeclaration]
:	http://ambrosia.example.org/filmmaking#
p:	http://ambrosia.example.org/filmmaking/prop#
ex:	http://ambrosia.example.org/filmmaking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Script_Supervisors_base
target		ex:Script_Supervisors/{ID} a :Script_Supervisors ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Experience {Experience} ; p:Awards {Awards} .
source		SELECT `ID`, `Name`, `Age`, `Experience`, `Awards` FROM `Script_Supervisors`

mappingId	Costume_Designers_base
target		ex:Costume_Designers/{ID} a :Costume_Designers ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Experience {Experience} ; p:Famous_For {Famous_For} .
source		SELECT `ID`, `Name`, `Age`, `Experience`, `Famous_For` FROM `Costume_Designers`

mappingId	Directors_base
target		ex:Directors/{ID} a :Directors ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Films_Directed {Films_Directed} ; p:Genre {Genre} .
source		SELECT `ID`, `Name`, `Age`, `Films_Directed`, `Genre` FROM `Directors`

mappingId	Producers_base
target		ex:Producers/{ID} a :Producers ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Budget {Budget} ; p:Projects_Produced {Projects_Produced} .
source		SELECT `ID`, `Name`, `Age`, `Budget`, `Projects_Produced` FROM `Producers`

mappingId	Actors_base
target		ex:Actors/{ID} a :Actors ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Roles {Roles} ; p:Nominations {Nominations} .
source		SELECT `ID`, `Name`, `Age`, `Roles`, `Nominations` FROM `Actors`

mappingId	Cinematographers_base
target		ex:Cinematographers/{ID} a :Cinematographers ; p:ID {ID} ; p:name {Name} ; p:Age {Age} ; p:Movies_Cinematographer {Movies_Cinematographer} ; p:Techniques {Techniques} .
source		SELECT `ID`, `Name`, `Age`, `Movies_Cinematographer`, `Techniques` FROM `Cinematographers`

]]
