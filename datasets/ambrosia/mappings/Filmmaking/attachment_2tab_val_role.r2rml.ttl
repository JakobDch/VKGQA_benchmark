<#tm_attachment_2tab_val_role_0_Script_Supervisors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Age\", \"Experience\", \"Awards\" FROM \"Script_Supervisors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Script_Supervisors/{ID}" ; rr:class :Script_Supervisors ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience ; rr:objectMap [ rr:column "Experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Awards ; rr:objectMap [ rr:column "Awards" ] ] .

