[PrefixDeclaration]
:	http://ambrosia.example.org/filmmaking#
p:	http://ambrosia.example.org/filmmaking/prop#
ex:	http://ambrosia.example.org/filmmaking/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Screenwriters_base
target		ex:Screenwriters/{id} a :Screenwriters ; p:id {id} ; p:name {Name} ; p:BirthDate {BirthDate} ; p:Nationality {Nationality} ; p:Education {Education} .
source		SELECT `id`, `Name`, `BirthDate`, `Nationality`, `Education` FROM `Screenwriters`

mappingId	Playwrights_base
target		ex:Playwrights/{id} a :Playwrights ; p:id {id} ; p:name {Name} ; p:BirthDate {BirthDate} ; p:Nationality {Nationality} ; p:Education {Education} .
source		SELECT `id`, `Name`, `BirthDate`, `Nationality`, `Education` FROM `Playwrights`

mappingId	Directors_base
target		ex:Directors/{id} a :Directors ; p:id {id} ; p:name {Name} ; p:BirthDate {BirthDate} ; p:Nationality {Nationality} ; p:FavoriteGenre {FavoriteGenre} .
source		SELECT `id`, `Name`, `BirthDate`, `Nationality`, `FavoriteGenre` FROM `Directors`

mappingId	Actors_base
target		ex:Actors/{id} a :Actors ; p:id {id} ; p:name {Name} ; p:BirthDate {BirthDate} ; p:Nationality {Nationality} ; p:FamousFor {FamousFor} .
source		SELECT `id`, `Name`, `BirthDate`, `Nationality`, `FamousFor` FROM `Actors`

mappingId	FilmProductions_base
target		ex:FilmProductions/{id} a :FilmProductions ; p:id {id} ; p:Title {Title} ; p:ReleaseYear {ReleaseYear} ; p:Budget {Budget} ; p:BoxOffice {BoxOffice} .
source		SELECT `id`, `Title`, `ReleaseYear`, `Budget`, `BoxOffice` FROM `FilmProductions`

]]
