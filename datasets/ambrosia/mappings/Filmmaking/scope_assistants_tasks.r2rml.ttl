@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_assistants_tasks_0_Assistants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Assistants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Assistants/{id}" ; rr:class :Assistants ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_assistants_tasks_1_Tasks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"task_name\", \"description\" FROM \"Tasks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Tasks/{id}" ; rr:class :Tasks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:task_name ; rr:objectMap [ rr:column "task_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_assistants_tasks_2_Assistants_Tasks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assistant_id\", \"task_id\" FROM \"Assistants_Tasks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Assistants_Tasks/{assistant_id}/{task_id}" ; rr:class :Assistants_Tasks ] ;
  rr:predicateObjectMap [ rr:predicate p:assistant_id ; rr:objectMap [ rr:column "assistant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:task_id ; rr:objectMap [ rr:column "task_id" ] ] .

<#tm_scope_assistants_tasks_3_Assistants_Tasks_task_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assistant_id\", \"task_id\" FROM \"Assistants_Tasks\" WHERE \"task_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Assistants_Tasks/{assistant_id}/{task_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTasks ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Tasks/{task_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_assistants_tasks_4_Assistants_Tasks_assistant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assistant_id\", \"task_id\" FROM \"Assistants_Tasks\" WHERE \"assistant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Assistants_Tasks/{assistant_id}/{task_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAssistants ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Assistants/{assistant_id}" ; rr:termType rr:IRI ] ] .

