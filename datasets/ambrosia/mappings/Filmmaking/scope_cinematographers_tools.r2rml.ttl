@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_cinematographers_tools_0_Cinematographers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"birthdate\" FROM \"Cinematographers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographers/{id}" ; rr:class :Cinematographers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthdate ; rr:objectMap [ rr:column "birthdate" ] ] .

<#tm_scope_cinematographers_tools_1_Tools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"toolName\" FROM \"Tools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Tools/{id}" ; rr:class :Tools ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:toolName ; rr:objectMap [ rr:column "toolName" ] ] .

<#tm_scope_cinematographers_tools_2_Cinematographers_Tools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cinematographerId\", \"toolId\" FROM \"Cinematographers_Tools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographers_Tools/{cinematographerId}/{toolId}" ; rr:class :Cinematographers_Tools ] ;
  rr:predicateObjectMap [ rr:predicate p:cinematographerId ; rr:objectMap [ rr:column "cinematographerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:toolId ; rr:objectMap [ rr:column "toolId" ] ] .

<#tm_scope_cinematographers_tools_3_Cinematographers_Tools_toolId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cinematographerId\", \"toolId\" FROM \"Cinematographers_Tools\" WHERE \"toolId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographers_Tools/{cinematographerId}/{toolId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTools ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Tools/{toolId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_cinematographers_tools_4_Cinematographers_Tools_cinematographerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cinematographerId\", \"toolId\" FROM \"Cinematographers_Tools\" WHERE \"cinematographerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographers_Tools/{cinematographerId}/{toolId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCinematographers ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographers/{cinematographerId}" ; rr:termType rr:IRI ] ] .

