@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_cinematographies_techniques_0_Cinematographies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"release_year\" FROM \"Cinematographies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographies/{id}" ; rr:class :Cinematographies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_year ; rr:objectMap [ rr:column "release_year" ] ] .

<#tm_scope_cinematographies_techniques_1_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"technique_name\" FROM \"Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Techniques/{id}" ; rr:class :Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_name ; rr:objectMap [ rr:column "technique_name" ] ] .

<#tm_scope_cinematographies_techniques_2_Cinematographies_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cinematography_id\", \"technique_id\" FROM \"Cinematographies_Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographies_Techniques/{cinematography_id}/{technique_id}" ; rr:class :Cinematographies_Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:cinematography_id ; rr:objectMap [ rr:column "cinematography_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_id ; rr:objectMap [ rr:column "technique_id" ] ] .

<#tm_scope_cinematographies_techniques_3_Cinematographies_Techniques_technique_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cinematography_id\", \"technique_id\" FROM \"Cinematographies_Techniques\" WHERE \"technique_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographies_Techniques/{cinematography_id}/{technique_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTechniques ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Techniques/{technique_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_cinematographies_techniques_4_Cinematographies_Techniques_cinematography_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cinematography_id\", \"technique_id\" FROM \"Cinematographies_Techniques\" WHERE \"cinematography_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographies_Techniques/{cinematography_id}/{technique_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCinematographies ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographies/{cinematography_id}" ; rr:termType rr:IRI ] ] .

