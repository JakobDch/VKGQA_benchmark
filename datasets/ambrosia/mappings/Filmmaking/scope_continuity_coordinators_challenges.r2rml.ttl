@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_continuity_coordinators_challenges_0_Continuity_Coordinators_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Experience\" FROM \"Continuity_Coordinators\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Continuity_Coordinators/{ID}" ; rr:class :Continuity_Coordinators ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience ; rr:objectMap [ rr:column "Experience" ] ] .

<#tm_scope_continuity_coordinators_challenges_1_Challenges_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ChallengeID\", \"ChallengeName\" FROM \"Challenges\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Challenges/{ChallengeID}" ; rr:class :Challenges ] ;
  rr:predicateObjectMap [ rr:predicate p:ChallengeID ; rr:objectMap [ rr:column "ChallengeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ChallengeName ; rr:objectMap [ rr:column "ChallengeName" ] ] .

<#tm_scope_continuity_coordinators_challenges_2_Continuity_Coordinators_Challenges_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"CoordinatorID\", \"ChallengeID\" FROM \"Continuity_Coordinators_Challenges\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Continuity_Coordinators_Challenges/{_amb_rowid}" ; rr:class :Continuity_Coordinators_Challenges ] ;
  rr:predicateObjectMap [ rr:predicate p:CoordinatorID ; rr:objectMap [ rr:column "CoordinatorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ChallengeID ; rr:objectMap [ rr:column "ChallengeID" ] ] .

<#tm_scope_continuity_coordinators_challenges_3_Continuity_Coordinators_Challenges_ChallengeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ChallengeID\" FROM \"Continuity_Coordinators_Challenges\" WHERE \"ChallengeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Continuity_Coordinators_Challenges/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasChallenges ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Challenges/{ChallengeID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_continuity_coordinators_challenges_4_Continuity_Coordinators_Challenges_CoordinatorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"CoordinatorID\" FROM \"Continuity_Coordinators_Challenges\" WHERE \"CoordinatorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Continuity_Coordinators_Challenges/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasContinuity_Coordinators ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Continuity_Coordinators/{CoordinatorID}" ; rr:termType rr:IRI ] ] .

