  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"director_id\" FROM \"Films_and_Directors\" WHERE \"director_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films_and_Directors/{film_id}/{director_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{director_id}" ; rr:termType rr:IRI ] ] .

