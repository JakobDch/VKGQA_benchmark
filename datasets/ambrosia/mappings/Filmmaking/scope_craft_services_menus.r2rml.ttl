@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_craft_services_menus_0_Menus_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MenuID\", \"Name\" FROM \"Menus\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Menus/{MenuID}" ; rr:class :Menus ] ;
  rr:predicateObjectMap [ rr:predicate p:MenuID ; rr:objectMap [ rr:column "MenuID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_scope_craft_services_menus_1_Craft_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ServiceID\", \"Description\", \"Price\" FROM \"Craft_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Craft_Services/{ServiceID}" ; rr:class :Craft_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:ServiceID ; rr:objectMap [ rr:column "ServiceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_scope_craft_services_menus_2_Craft_Services_Menus_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"ServiceID\", \"MenuID\" FROM \"Craft_Services_Menus\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Craft_Services_Menus/{ID}" ; rr:class :Craft_Services_Menus ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ServiceID ; rr:objectMap [ rr:column "ServiceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MenuID ; rr:objectMap [ rr:column "MenuID" ] ] .

<#tm_scope_craft_services_menus_3_Craft_Services_Menus_MenuID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"MenuID\" FROM \"Craft_Services_Menus\" WHERE \"MenuID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Craft_Services_Menus/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMenus ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Menus/{MenuID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_craft_services_menus_4_Craft_Services_Menus_ServiceID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"ServiceID\" FROM \"Craft_Services_Menus\" WHERE \"ServiceID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Craft_Services_Menus/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCraft_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Craft_Services/{ServiceID}" ; rr:termType rr:IRI ] ] .

