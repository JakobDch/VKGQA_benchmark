@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_directors_additional_roles_0_Directors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorID\", \"Name\", \"BirthDate\" FROM \"Directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{DirectorID}" ; rr:class :Directors ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorID ; rr:objectMap [ rr:column "DirectorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] .

<#tm_scope_directors_additional_roles_1_Films_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FilmID\", \"Title\", \"ReleaseYear\" FROM \"Films\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{FilmID}" ; rr:class :Films ] ;
  rr:predicateObjectMap [ rr:predicate p:FilmID ; rr:objectMap [ rr:column "FilmID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] .

<#tm_scope_directors_additional_roles_2_DirectorFilms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorFilmID\", \"DirectorID\", \"FilmID\" FROM \"DirectorFilms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/DirectorFilms/{DirectorFilmID}" ; rr:class :DirectorFilms ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorFilmID ; rr:objectMap [ rr:column "DirectorFilmID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorID ; rr:objectMap [ rr:column "DirectorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FilmID ; rr:objectMap [ rr:column "FilmID" ] ] .

<#tm_scope_directors_additional_roles_3_DirectorFilms_FilmID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorFilmID\", \"FilmID\" FROM \"DirectorFilms\" WHERE \"FilmID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/DirectorFilms/{DirectorFilmID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilms ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{FilmID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_directors_additional_roles_4_DirectorFilms_DirectorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorFilmID\", \"DirectorID\" FROM \"DirectorFilms\" WHERE \"DirectorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/DirectorFilms/{DirectorFilmID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{DirectorID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_directors_additional_roles_5_Additional_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AdditionalRoleID\", \"Role\", \"Fee\" FROM \"Additional_Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Additional_Roles/{AdditionalRoleID}" ; rr:class :Additional_Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:AdditionalRoleID ; rr:objectMap [ rr:column "AdditionalRoleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Role ; rr:objectMap [ rr:column "Role" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Fee ; rr:objectMap [ rr:column "Fee" ] ] .

<#tm_scope_directors_additional_roles_6_Directors_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorRoleID\", \"DirectorID\", \"AdditionalRoleID\" FROM \"Directors_Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors_Roles/{DirectorRoleID}" ; rr:class :Directors_Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorRoleID ; rr:objectMap [ rr:column "DirectorRoleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorID ; rr:objectMap [ rr:column "DirectorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AdditionalRoleID ; rr:objectMap [ rr:column "AdditionalRoleID" ] ] .

<#tm_scope_directors_additional_roles_7_Directors_Roles_AdditionalRoleID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorRoleID\", \"AdditionalRoleID\" FROM \"Directors_Roles\" WHERE \"AdditionalRoleID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors_Roles/{DirectorRoleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAdditional_Roles ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Additional_Roles/{AdditionalRoleID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_directors_additional_roles_8_Directors_Roles_DirectorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DirectorRoleID\", \"DirectorID\" FROM \"Directors_Roles\" WHERE \"DirectorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors_Roles/{DirectorRoleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{DirectorID}" ; rr:termType rr:IRI ] ] .

