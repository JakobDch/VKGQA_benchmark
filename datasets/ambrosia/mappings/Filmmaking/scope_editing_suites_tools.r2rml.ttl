@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_editing_suites_tools_0_Editing_Suites_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SuiteID\", \"Name\", \"Location\" FROM \"Editing_Suites\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Editing_Suites/{SuiteID}" ; rr:class :Editing_Suites ] ;
  rr:predicateObjectMap [ rr:predicate p:SuiteID ; rr:objectMap [ rr:column "SuiteID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_scope_editing_suites_tools_1_Tools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ToolID\", \"Type\" FROM \"Tools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Tools/{ToolID}" ; rr:class :Tools ] ;
  rr:predicateObjectMap [ rr:predicate p:ToolID ; rr:objectMap [ rr:column "ToolID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] .

<#tm_scope_editing_suites_tools_2_Editing_Suites_Tools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SuiteID\", \"ToolID\" FROM \"Editing_Suites_Tools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Editing_Suites_Tools/{SuiteID}/{ToolID}" ; rr:class :Editing_Suites_Tools ] ;
  rr:predicateObjectMap [ rr:predicate p:SuiteID ; rr:objectMap [ rr:column "SuiteID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ToolID ; rr:objectMap [ rr:column "ToolID" ] ] .

<#tm_scope_editing_suites_tools_3_Editing_Suites_Tools_ToolID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SuiteID\", \"ToolID\" FROM \"Editing_Suites_Tools\" WHERE \"ToolID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Editing_Suites_Tools/{SuiteID}/{ToolID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTools ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Tools/{ToolID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_editing_suites_tools_4_Editing_Suites_Tools_SuiteID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SuiteID\", \"ToolID\" FROM \"Editing_Suites_Tools\" WHERE \"SuiteID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Editing_Suites_Tools/{SuiteID}/{ToolID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEditing_Suites ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Editing_Suites/{SuiteID}" ; rr:termType rr:IRI ] ] .

