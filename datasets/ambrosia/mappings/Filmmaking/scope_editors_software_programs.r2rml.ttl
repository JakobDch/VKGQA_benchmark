<#tm_scope_editors_software_programs_6_EditorDirectorRelationship_editor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"relationship_id\", \"editor_id\" FROM \"EditorDirectorRelationship\" WHERE \"editor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/EditorDirectorRelationship/{relationship_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEditors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Editors/{editor_id}" ; rr:termType rr:IRI ] ] .

