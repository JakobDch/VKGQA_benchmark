@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_editors_software_programs_0_Editors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"editor_id\", \"full_name\" FROM \"Editors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Editors/{editor_id}" ; rr:class :Editors ] ;
  rr:predicateObjectMap [ rr:predicate p:editor_id ; rr:objectMap [ rr:column "editor_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_scope_editors_software_programs_1_Software_Programs_base> a rr:TriplesMap ;
