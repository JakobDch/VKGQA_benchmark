<#tm_scope_film_archivists_preservation_methods_3_Archived_Films_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"film_id\", \"archiver_id\", \"preservation_method_id\" FROM \"Archived_Films\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Archived_Films/{_amb_rowid}" ; rr:class :Archived_Films ] ;
  rr:predicateObjectMap [ rr:predicate p:film_id ; rr:objectMap [ rr:column "film_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:archiver_id ; rr:objectMap [ rr:column "archiver_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:preservation_method_id ; rr:objectMap [ rr:column "preservation_method_id" ] ] .

<#tm_scope_film_archivists_preservation_methods_4_Archived_Films_preservation_method_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"preservation_method_id\" FROM \"Archived_Films\" WHERE \"preservation_method_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Archived_Films/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPreservation_Methods ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Preservation_Methods/{preservation_method_id}" ; rr:termType rr:IRI ] ] .

