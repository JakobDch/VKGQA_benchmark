@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_film_archivists_preservation_methods_0_Film_Archivists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Film_Archivists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Archivists/{id}" ; rr:class :Film_Archivists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_film_archivists_preservation_methods_1_Preservation_Methods_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"method\", \"description\" FROM \"Preservation_Methods\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Preservation_Methods/{id}" ; rr:class :Preservation_Methods ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:method ; rr:objectMap [ rr:column "method" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

