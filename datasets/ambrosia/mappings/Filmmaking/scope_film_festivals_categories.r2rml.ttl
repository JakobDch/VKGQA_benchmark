  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:director ; rr:objectMap [ rr:column "director" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:yearReleased ; rr:objectMap [ rr:column "yearReleased" ] ] .

<#tm_scope_film_festivals_categories_3_Film_Festival_Entries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"festivalId\", \"filmId\", \"entryDate\" FROM \"Film_Festival_Entries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Festival_Entries/{_amb_rowid}" ; rr:class :Film_Festival_Entries ] ;
  rr:predicateObjectMap [ rr:predicate p:festivalId ; rr:objectMap [ rr:column "festivalId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:filmId ; rr:objectMap [ rr:column "filmId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:entryDate ; rr:objectMap [ rr:column "entryDate" ] ] .

<#tm_scope_film_festivals_categories_4_Film_Festival_Entries_filmId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"filmId\" FROM \"Film_Festival_Entries\" WHERE \"filmId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Festival_Entries/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilms ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{filmId}" ; rr:termType rr:IRI ] ] .

