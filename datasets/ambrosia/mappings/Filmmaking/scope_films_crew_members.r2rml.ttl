  rr:predicateObjectMap [ rr:predicate p:member_id ; rr:objectMap [ rr:column "member_id" ] ] .

<#tm_scope_films_crew_members_3_Films_Crew_Members_member_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"member_id\" FROM \"Films_Crew_Members\" WHERE \"member_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films_Crew_Members/{film_id}/{member_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCrew_Members ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Crew_Members/{member_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_films_crew_members_4_Films_Crew_Members_film_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"member_id\" FROM \"Films_Crew_Members\" WHERE \"film_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films_Crew_Members/{film_id}/{member_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilms ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{film_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_films_crew_members_5_Film_Genres_base> a rr:TriplesMap ;
