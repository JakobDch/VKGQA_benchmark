@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_films_crew_members_0_Films_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"title\", \"release_year\" FROM \"Films\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{film_id}" ; rr:class :Films ] ;
  rr:predicateObjectMap [ rr:predicate p:film_id ; rr:objectMap [ rr:column "film_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_year ; rr:objectMap [ rr:column "release_year" ] ] .

<#tm_scope_films_crew_members_1_Crew_Members_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"member_id\", \"role\", \"name\" FROM \"Crew_Members\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Crew_Members/{member_id}" ; rr:class :Crew_Members ] ;
  rr:predicateObjectMap [ rr:predicate p:member_id ; rr:objectMap [ rr:column "member_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role ; rr:objectMap [ rr:column "role" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_films_crew_members_2_Films_Crew_Members_base> a rr:TriplesMap ;
