@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_hair_stylists_styles_0_Hair_Stylists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"experience\" FROM \"Hair_Stylists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Hair_Stylists/{id}" ; rr:class :Hair_Stylists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] .

<#tm_scope_hair_stylists_styles_1_Styles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"style_id\", \"style_name\", \"description\" FROM \"Styles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Styles/{style_id}" ; rr:class :Styles ] ;
  rr:predicateObjectMap [ rr:predicate p:style_id ; rr:objectMap [ rr:column "style_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:style_name ; rr:objectMap [ rr:column "style_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_hair_stylists_styles_2_Hair_Stylists_Styles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"hairdresser_id\", \"style_id\" FROM \"Hair_Stylists_Styles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Hair_Stylists_Styles/{_amb_rowid}" ; rr:class :Hair_Stylists_Styles ] ;
  rr:predicateObjectMap [ rr:predicate p:hairdresser_id ; rr:objectMap [ rr:column "hairdresser_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:style_id ; rr:objectMap [ rr:column "style_id" ] ] .

<#tm_scope_hair_stylists_styles_3_Hair_Stylists_Styles_style_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"style_id\" FROM \"Hair_Stylists_Styles\" WHERE \"style_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Hair_Stylists_Styles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStyles ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Styles/{style_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_hair_stylists_styles_4_Hair_Stylists_Styles_hairdresser_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"hairdresser_id\" FROM \"Hair_Stylists_Styles\" WHERE \"hairdresser_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Hair_Stylists_Styles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHair_Stylists ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Hair_Stylists/{hairdresser_id}" ; rr:termType rr:IRI ] ] .

