<#tm_scope_lighting_technicians_fixtures_10_Lighting_Technicians_Fixtures_fixtureType_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"fixtureType\" FROM \"Lighting_Technicians_Fixtures\" WHERE \"fixtureType\" IS NOT NULL""" ] ;
