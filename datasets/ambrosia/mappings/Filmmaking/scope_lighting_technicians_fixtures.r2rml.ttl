  rr:logicalTable [ rr:sqlQuery """SELECT \"fixtureType\", \"description\" FROM \"Fixtures\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Fixtures/{fixtureType}" ; rr:class :Fixtures ] ;
  rr:predicateObjectMap [ rr:predicate p:fixtureType ; rr:objectMap [ rr:column "fixtureType" ] ] ;
