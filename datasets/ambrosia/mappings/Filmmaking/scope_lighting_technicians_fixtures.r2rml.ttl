  rr:predicateObjectMap [ rr:predicate p:hasFixtures ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Fixtures/{fixtureType}" ; rr:termType rr:IRI ] ] .

<#tm_scope_lighting_technicians_fixtures_11_Lighting_Technicians_Fixtures_technicianID_fk> a rr:TriplesMap ;
