  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cinematographers/{cinematographerID}" ; rr:class :Cinematographers ] ;
  rr:predicateObjectMap [ rr:predicate p:cinematographerID ; rr:objectMap [ rr:column "cinematographerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] .

<#tm_scope_lighting_technicians_fixtures_3_Actors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"actorID\", \"name\", \"age\" FROM \"Actors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{actorID}" ; rr:class :Actors ] ;
  rr:predicateObjectMap [ rr:predicate p:actorID ; rr:objectMap [ rr:column "actorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:age ; rr:objectMap [ rr:column "age" ] ] .

<#tm_scope_lighting_technicians_fixtures_4_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"roleID\", \"filmProjectID\", \"actorID\" FROM \"Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{roleID}" ; rr:class :Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:roleID ; rr:objectMap [ rr:column "roleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:filmProjectID ; rr:objectMap [ rr:column "filmProjectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:actorID ; rr:objectMap [ rr:column "actorID" ] ] .

<#tm_scope_lighting_technicians_fixtures_5_Roles_actorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"roleID\", \"actorID\" FROM \"Roles\" WHERE \"actorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{roleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{actorID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_lighting_technicians_fixtures_6_Roles_filmProjectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"roleID\", \"filmProjectID\" FROM \"Roles\" WHERE \"filmProjectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Roles/{roleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilm_Projects ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Projects/{filmProjectID}" ; rr:termType rr:IRI ] ] .

