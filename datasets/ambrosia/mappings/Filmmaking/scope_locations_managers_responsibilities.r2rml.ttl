@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_locations_managers_responsibilities_0_Locations_Managers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"contact_info\" FROM \"Locations_Managers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Locations_Managers/{id}" ; rr:class :Locations_Managers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contact_info ; rr:objectMap [ rr:column "contact_info" ] ] .

<#tm_scope_locations_managers_responsibilities_1_Responsibilities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"description\" FROM \"Responsibilities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Responsibilities/{id}" ; rr:class :Responsibilities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_locations_managers_responsibilities_2_Locations_Managers_Responsibilities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"locations_manager_id\", \"responsibility_id\" FROM \"Locations_Managers_Responsibilities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Locations_Managers_Responsibilities/{_amb_rowid}" ; rr:class :Locations_Managers_Responsibilities ] ;
  rr:predicateObjectMap [ rr:predicate p:locations_manager_id ; rr:objectMap [ rr:column "locations_manager_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:responsibility_id ; rr:objectMap [ rr:column "responsibility_id" ] ] .

<#tm_scope_locations_managers_responsibilities_3_Locations_Managers_Responsibilities_responsibility_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"responsibility_id\" FROM \"Locations_Managers_Responsibilities\" WHERE \"responsibility_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Locations_Managers_Responsibilities/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasResponsibilities ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Responsibilities/{responsibility_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_locations_managers_responsibilities_4_Locations_Managers_Responsibilities_locations_manager_id_fk> a rr:TriplesMap ;
