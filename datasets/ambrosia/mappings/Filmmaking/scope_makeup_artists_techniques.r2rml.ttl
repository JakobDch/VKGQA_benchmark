@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_makeup_artists_techniques_0_Makeup_Artists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"artist_id\", \"full_name\" FROM \"Makeup_Artists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Makeup_Artists/{artist_id}" ; rr:class :Makeup_Artists ] ;
  rr:predicateObjectMap [ rr:predicate p:artist_id ; rr:objectMap [ rr:column "artist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_scope_makeup_artists_techniques_1_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"technique_id\", \"name\" FROM \"Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Techniques/{technique_id}" ; rr:class :Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_id ; rr:objectMap [ rr:column "technique_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_makeup_artists_techniques_2_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"title\", \"release_date\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movie_id}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] .

<#tm_scope_makeup_artists_techniques_3_Movie_Makeup_Artists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"movie_id\", \"artist_id\" FROM \"Movie_Makeup_Artists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_Makeup_Artists/{_amb_rowid}" ; rr:class :Movie_Makeup_Artists ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:artist_id ; rr:objectMap [ rr:column "artist_id" ] ] .

<#tm_scope_makeup_artists_techniques_4_Movie_Makeup_Artists_artist_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"artist_id\" FROM \"Movie_Makeup_Artists\" WHERE \"artist_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_Makeup_Artists/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMakeup_Artists ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Makeup_Artists/{artist_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_makeup_artists_techniques_5_Movie_Makeup_Artists_movie_id_fk> a rr:TriplesMap ;
