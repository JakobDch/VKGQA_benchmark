  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_Makeup_Artists/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovies ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movie_id}" ; rr:termType rr:IRI ] ] .

