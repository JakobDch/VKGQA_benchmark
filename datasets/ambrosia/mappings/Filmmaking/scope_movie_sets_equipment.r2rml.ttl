@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_movie_sets_equipment_0_Movie_sets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"director\", \"release_date\" FROM \"Movie_sets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_sets/{id}" ; rr:class :Movie_sets ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:director ; rr:objectMap [ rr:column "director" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] .

<#tm_scope_movie_sets_equipment_1_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"type\" FROM \"Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Equipment/{id}" ; rr:class :Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_scope_movie_sets_equipment_2_Movie_sets_equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"movie_set_id\", \"equipment_id\", \"quantity\" FROM \"Movie_sets_equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_sets_equipment/{_amb_rowid}" ; rr:class :Movie_sets_equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_set_id ; rr:objectMap [ rr:column "movie_set_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:equipment_id ; rr:objectMap [ rr:column "equipment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "quantity" ] ] .

<#tm_scope_movie_sets_equipment_3_Movie_sets_equipment_equipment_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"equipment_id\" FROM \"Movie_sets_equipment\" WHERE \"equipment_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_sets_equipment/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEquipment ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Equipment/{equipment_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_movie_sets_equipment_4_Movie_sets_equipment_movie_set_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"movie_set_id\" FROM \"Movie_sets_equipment\" WHERE \"movie_set_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_sets_equipment/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovie_sets ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_sets/{movie_set_id}" ; rr:termType rr:IRI ] ] .

