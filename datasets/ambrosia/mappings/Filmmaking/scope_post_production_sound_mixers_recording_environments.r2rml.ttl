@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_post_production_sound_mixers_recording_environments_0_Post_Production_Sound_Mixers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"years_of_experience\" FROM \"Post_Production_Sound_Mixers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Post_Production_Sound_Mixers/{id}" ; rr:class :Post_Production_Sound_Mixers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_of_experience ; rr:objectMap [ rr:column "years_of_experience" ] ] .

<#tm_scope_post_production_sound_mixers_recording_environments_1_Recording_Environments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"environment_name\" FROM \"Recording_Environments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Recording_Environments/{id}" ; rr:class :Recording_Environments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:environment_name ; rr:objectMap [ rr:column "environment_name" ] ] .

<#tm_scope_post_production_sound_mixers_recording_environments_2_FilmProjects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_date\" FROM \"FilmProjects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Projects/{id}" ; rr:class :Film_Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] .

<#tm_scope_post_production_sound_mixers_recording_environments_3_Films_with_Sound_Mixing_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"mixer_id\" FROM \"Films_with_Sound_Mixing\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films_with_Sound_Mixing/{film_id}/{mixer_id}" ; rr:class :Films_with_Sound_Mixing ] ;
  rr:predicateObjectMap [ rr:predicate p:film_id ; rr:objectMap [ rr:column "film_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:mixer_id ; rr:objectMap [ rr:column "mixer_id" ] ] .

<#tm_scope_post_production_sound_mixers_recording_environments_4_Films_with_Sound_Mixing_mixer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"mixer_id\" FROM \"Films_with_Sound_Mixing\" WHERE \"mixer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films_with_Sound_Mixing/{film_id}/{mixer_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPost_Production_Sound_Mixers ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Post_Production_Sound_Mixers/{mixer_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_post_production_sound_mixers_recording_environments_5_Films_with_Sound_Mixing_film_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"mixer_id\" FROM \"Films_with_Sound_Mixing\" WHERE \"film_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films_with_Sound_Mixing/{film_id}/{mixer_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilm_Projects ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Projects/{film_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_post_production_sound_mixers_recording_environments_6_Sound_Mixer_Environment_History_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"sound_mixer_id\", \"environment_id\", \"start_year\", \"end_year\" FROM \"Sound_Mixer_Environment_History\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Sound_Mixer_Environment_History/{_amb_rowid}" ; rr:class :Sound_Mixer_Environment_History ] ;
  rr:predicateObjectMap [ rr:predicate p:sound_mixer_id ; rr:objectMap [ rr:column "sound_mixer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:environment_id ; rr:objectMap [ rr:column "environment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_year ; rr:objectMap [ rr:column "start_year" ] ] ;
