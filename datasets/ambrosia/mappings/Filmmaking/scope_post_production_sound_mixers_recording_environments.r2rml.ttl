  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"environment_id\" FROM \"Sound_Mixer_Environment_History\" WHERE \"environment_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Sound_Mixer_Environment_History/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRecording_Environments ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Recording_Environments/{environment_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_post_production_sound_mixers_recording_environments_8_Sound_Mixer_Environment_History_sound_mixer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"sound_mixer_id\" FROM \"Sound_Mixer_Environment_History\" WHERE \"sound_mixer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Sound_Mixer_Environment_History/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPost_Production_Sound_Mixers ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Post_Production_Sound_Mixers/{sound_mixer_id}" ; rr:termType rr:IRI ] ] .

