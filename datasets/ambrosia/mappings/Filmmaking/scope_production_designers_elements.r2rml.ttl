@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_production_designers_elements_0_Production_Designers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Production_Designers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Production_Designers/{id}" ; rr:class :Production_Designers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_production_designers_elements_1_Elements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"element_type\", \"description\" FROM \"Elements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Elements/{id}" ; rr:class :Elements ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:element_type ; rr:objectMap [ rr:column "element_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_production_designers_elements_2_Production_Designers_Elements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"production_designer_id\", \"element_id\" FROM \"Production_Designers_Elements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Production_Designers_Elements/{production_designer_id}/{element_id}" ; rr:class :Production_Designers_Elements ] ;
  rr:predicateObjectMap [ rr:predicate p:production_designer_id ; rr:objectMap [ rr:column "production_designer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:element_id ; rr:objectMap [ rr:column "element_id" ] ] .

<#tm_scope_production_designers_elements_3_Production_Designers_Elements_element_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"production_designer_id\", \"element_id\" FROM \"Production_Designers_Elements\" WHERE \"element_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Production_Designers_Elements/{production_designer_id}/{element_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasElements ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Elements/{element_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_production_designers_elements_4_Production_Designers_Elements_production_designer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"production_designer_id\", \"element_id\" FROM \"Production_Designers_Elements\" WHERE \"production_designer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Production_Designers_Elements/{production_designer_id}/{element_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProduction_Designers ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Production_Designers/{production_designer_id}" ; rr:termType rr:IRI ] ] .

