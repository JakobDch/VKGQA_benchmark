  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Cast/{ProductionID}/{ActorID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProductions ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Productions/{ProductionID}" ; rr:termType rr:IRI ] ] .

