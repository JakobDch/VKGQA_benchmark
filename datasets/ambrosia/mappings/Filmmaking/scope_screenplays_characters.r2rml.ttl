  rr:logicalTable [ rr:sqlQuery """SELECT \"filmID\", \"actorID\" FROM \"Film_Actors\" WHERE \"actorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/FilmActors/{filmID}/{actorID}" ] ;
