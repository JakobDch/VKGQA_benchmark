@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_screenplays_characters_0_Screenplays_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"screenplayID\", \"title\", \"director\" FROM \"Screenplays\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Screenplay/{screenplayID}" ; rr:class :Screenplay ] ;
  rr:predicateObjectMap [ rr:predicate p:screenplayID ; rr:objectMap [ rr:column "screenplayID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:director ; rr:objectMap [ rr:column "director" ] ] .

<#tm_scope_screenplays_characters_1_Characters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"characterID\", \"roleType\" FROM \"Characters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Character/{characterID}" ; rr:class :Character ] ;
  rr:predicateObjectMap [ rr:predicate p:characterID ; rr:objectMap [ rr:column "characterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roleType ; rr:objectMap [ rr:column "roleType" ] ] .

<#tm_scope_screenplays_characters_2_Screenplays_Characters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"screenplayID\", \"characterID\" FROM \"Screenplays_Characters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Screenplays_Characters/{screenplayID}/{characterID}" ; rr:class :Screenplays_Characters ] ;
  rr:predicateObjectMap [ rr:predicate p:screenplayID ; rr:objectMap [ rr:column "screenplayID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:characterID ; rr:objectMap [ rr:column "characterID" ] ] .

<#tm_scope_screenplays_characters_3_Screenplays_Characters_characterID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"screenplayID\", \"characterID\" FROM \"Screenplays_Characters\" WHERE \"characterID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Screenplays_Characters/{screenplayID}/{characterID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCharacter ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Character/{characterID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_screenplays_characters_4_Screenplays_Characters_screenplayID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"screenplayID\", \"characterID\" FROM \"Screenplays_Characters\" WHERE \"screenplayID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Screenplays_Characters/{screenplayID}/{characterID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasScreenplay ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Screenplay/{screenplayID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_screenplays_characters_5_Directors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"directorID\", \"firstName\", \"lastName\" FROM \"Directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{directorID}" ; rr:class :Directors ] ;
  rr:predicateObjectMap [ rr:predicate p:directorID ; rr:objectMap [ rr:column "directorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] .

