<#tm_scope_sound_designers_techniques_5_Movie_Director_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"MovieID\", \"DirectorID\" FROM \"Movie_Director\"""" ] ;
