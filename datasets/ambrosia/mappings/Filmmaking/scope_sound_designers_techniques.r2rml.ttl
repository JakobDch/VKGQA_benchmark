<#tm_scope_sound_designers_techniques_6_Movie_Director_DirectorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"DirectorID\" FROM \"Movie_Director\" WHERE \"DirectorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_Director/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{DirectorID}" ; rr:termType rr:IRI ] ] .

