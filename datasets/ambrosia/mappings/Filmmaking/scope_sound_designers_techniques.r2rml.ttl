@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_sound_designers_techniques_0_Sound_Designers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Email\" FROM \"Sound_Designers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Sound_Designers/{ID}" ; rr:class :Sound_Designers ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

