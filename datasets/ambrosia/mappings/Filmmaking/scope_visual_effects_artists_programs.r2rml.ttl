@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_visual_effects_artists_programs_0_Visual_Effects_Artists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"artist_id\", \"name\", \"email\" FROM \"Visual_Effects_Artists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Visual_Effects_Artists/{artist_id}" ; rr:class :Visual_Effects_Artists ] ;
  rr:predicateObjectMap [ rr:predicate p:artist_id ; rr:objectMap [ rr:column "artist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_visual_effects_artists_programs_1_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"program_id\", \"name\", \"version\" FROM \"Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Programs/{program_id}" ; rr:class :Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:program_id ; rr:objectMap [ rr:column "program_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:version ; rr:objectMap [ rr:column "version" ] ] .

<#tm_scope_visual_effects_artists_programs_2_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"title\", \"release_date\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movie_id}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] .

<#tm_scope_visual_effects_artists_programs_3_Film_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"movie_id\" FROM \"Film_Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Movies/{film_id}/{movie_id}" ; rr:class :Film_Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:film_id ; rr:objectMap [ rr:column "film_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] .

<#tm_scope_visual_effects_artists_programs_4_Film_Movies_movie_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"film_id\", \"movie_id\" FROM \"Film_Movies\" WHERE \"movie_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Film_Movies/{film_id}/{movie_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovies ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movie_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_visual_effects_artists_programs_5_Visual_Effects_Artists_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"visual_effects_artist_id\", \"program_id\" FROM \"Visual_Effects_Artists_Programs\"""" ] ;
