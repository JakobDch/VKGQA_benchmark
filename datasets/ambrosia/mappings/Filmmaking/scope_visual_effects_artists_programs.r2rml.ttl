<#tm_scope_visual_effects_artists_programs_6_Visual_Effects_Artists_Programs_program_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"visual_effects_artist_id\", \"program_id\" FROM \"Visual_Effects_Artists_Programs\" WHERE \"program_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Visual_Effects_Artists_Programs/{visual_effects_artist_id}/{program_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPrograms ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Programs/{program_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_visual_effects_artists_programs_7_Visual_Effects_Artists_Programs_visual_effects_artist_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"visual_effects_artist_id\", \"program_id\" FROM \"Visual_Effects_Artists_Programs\" WHERE \"visual_effects_artist_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Visual_Effects_Artists_Programs/{visual_effects_artist_id}/{program_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVisual_Effects_Artists ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Visual_Effects_Artists/{visual_effects_artist_id}" ; rr:termType rr:IRI ] ] .

