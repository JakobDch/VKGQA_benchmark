<#tm_vague_2cols_actor_9_Rating_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"roleId\", \"score\" FROM \"Rating\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Rating/{id}" ; rr:class :Rating ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roleId ; rr:objectMap [ rr:column "roleId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:score ; rr:objectMap [ rr:column "score" ] ] .

<#tm_vague_2cols_actor_10_Rating_roleId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"roleId\" FROM \"Rating\" WHERE \"roleId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Rating/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRole ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Role/{roleId}" ; rr:termType rr:IRI ] ] .

