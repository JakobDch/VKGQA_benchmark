@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_actor_0_Director_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"birthDate\" FROM \"Director\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{id}" ; rr:class :Directors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthDate ; rr:objectMap [ rr:column "birthDate" ] ] .

<#tm_vague_2cols_actor_1_Actor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"fullName\", \"birthDate\" FROM \"Actor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{id}" ; rr:class :Actors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "fullName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthDate ; rr:objectMap [ rr:column "birthDate" ] ] .

<#tm_vague_2cols_actor_2_Movie_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"releaseYear\", \"directorId\" FROM \"Movie\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{id}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:releaseYear ; rr:objectMap [ rr:column "releaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:directorId ; rr:objectMap [ rr:column "directorId" ] ] .

<#tm_vague_2cols_actor_3_Movie_directorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"directorId\" FROM \"Movie\" WHERE \"directorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirectors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{directorId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_actor_4_Role_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"movieId\", \"leadRole\", \"supportingRole\", \"actorId\", \"genreId\", \"rating\" FROM \"Role\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Role/{id}" ; rr:class :Role ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:movieId ; rr:objectMap [ rr:column "movieId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:leadRole ; rr:objectMap [ rr:column "leadRole" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:supportingRole ; rr:objectMap [ rr:column "supportingRole" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:actorId ; rr:objectMap [ rr:column "actorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genreId ; rr:objectMap [ rr:column "genreId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rating ; rr:objectMap [ rr:column "rating" ] ] .

<#tm_vague_2cols_actor_5_Role_genreId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"genreId\" FROM \"Role\" WHERE \"genreId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Role/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenres ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Genres/{genreId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_actor_6_Role_actorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"actorId\" FROM \"Role\" WHERE \"actorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Role/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{actorId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_actor_7_Role_movieId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"movieId\" FROM \"Role\" WHERE \"movieId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Role/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovies ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movieId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_actor_8_Genre_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Genre\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Genres/{id}" ; rr:class :Genres ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
