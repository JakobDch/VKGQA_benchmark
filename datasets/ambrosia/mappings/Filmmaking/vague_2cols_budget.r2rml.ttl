@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_budget_0_Directors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"birthdate\", \"nationality\" FROM \"Directors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Directors/{id}" ; rr:class :Directors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthdate ; rr:objectMap [ rr:column "birthdate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:nationality ; rr:objectMap [ rr:column "nationality" ] ] .

<#tm_vague_2cols_budget_1_Producers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"company\", \"networth\" FROM \"Producers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Producers/{id}" ; rr:class :Producers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company ; rr:objectMap [ rr:column "company" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:networth ; rr:objectMap [ rr:column "networth" ] ] .

<#tm_vague_2cols_budget_2_Films_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"releaseyear\", \"Production_Cost\", \"Marketing_Expense\", \"genre\", \"directorId\", \"producerId\" FROM \"Films\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ; rr:class :Films ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:releaseyear ; rr:objectMap [ rr:column "releaseyear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Production_Cost ; rr:objectMap [ rr:column "Production_Cost" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Marketing_Expense ; rr:objectMap [ rr:column "Marketing_Expense" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:directorId ; rr:objectMap [ rr:column "directorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:producerId ; rr:objectMap [ rr:column "producerId" ] ] .

<#tm_vague_2cols_budget_3_Films_producerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"producerId\" FROM \"Films\" WHERE \"producerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProducers ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Producers/{producerId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_budget_4_Films_directorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"directorId\" FROM \"Films\" WHERE \"directorId\" IS NOT NULL""" ] ;
