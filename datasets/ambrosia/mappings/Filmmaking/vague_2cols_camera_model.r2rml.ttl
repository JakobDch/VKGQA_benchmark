@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_camera_model_0_Camera_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Brand_Name\", \"Camera_Type\", \"Cinematographer\", \"Purchase_Year\", \"Currently_In_Use\" FROM \"Camera\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Camera/{ID}" ; rr:class :Camera ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Brand_Name ; rr:objectMap [ rr:column "Brand_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Camera_Type ; rr:objectMap [ rr:column "Camera_Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Cinematographer ; rr:objectMap [ rr:column "Cinematographer" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Purchase_Year ; rr:objectMap [ rr:column "Purchase_Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Currently_In_Use ; rr:objectMap [ rr:column "Currently_In_Use" ] ] .

