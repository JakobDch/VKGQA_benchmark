<#tm_vague_2cols_costumier_4_Costumes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CostumeID\", \"Costume_Designer\", \"Costume_Supervisor\", \"Costumes\", \"Budget\" FROM \"Costumes\"""" ] ;
