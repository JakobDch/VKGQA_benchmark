<#tm_vague_2cols_costumier_5_FilmActors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FilmID\", \"ActorID\", \"Role\" FROM \"FilmActors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/FilmActors/{FilmID}/{ActorID}" ; rr:class :FilmActors ] ;
  rr:predicateObjectMap [ rr:predicate p:FilmID ; rr:objectMap [ rr:column "FilmID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ActorID ; rr:objectMap [ rr:column "ActorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Role ; rr:objectMap [ rr:column "Role" ] ] .

<#tm_vague_2cols_costumier_6_FilmActors_ActorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FilmID\", \"ActorID\" FROM \"FilmActors\" WHERE \"ActorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/FilmActors/{FilmID}/{ActorID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{ActorID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_costumier_7_FilmActors_FilmID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FilmID\", \"ActorID\" FROM \"FilmActors\" WHERE \"FilmID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/FilmActors/{FilmID}/{ActorID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilms ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{FilmID}" ; rr:termType rr:IRI ] ] .

