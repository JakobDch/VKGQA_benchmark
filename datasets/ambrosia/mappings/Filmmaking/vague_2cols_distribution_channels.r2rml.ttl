<#tm_vague_2cols_distribution_channels_9_StreamingDetails_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DetailsID\", \"Platforms\", \"Countries\", \"Movies\", \"AvailableSince\" FROM \"StreamingDetails\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/StreamingDetails/{DetailsID}" ; rr:class :StreamingDetails ] ;
  rr:predicateObjectMap [ rr:predicate p:DetailsID ; rr:objectMap [ rr:column "DetailsID" ] ] ;
