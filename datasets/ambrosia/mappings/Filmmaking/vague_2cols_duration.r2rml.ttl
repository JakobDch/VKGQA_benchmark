  rr:logicalTable [ rr:sqlQuery """SELECT \"MovieID\", \"GenreID\" FROM \"Movie_Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movie_Genres/{MovieID}/{GenreID}" ; rr:class :Movie_Genres ] ;
  rr:predicateObjectMap [ rr:predicate p:MovieID ; rr:objectMap [ rr:column "MovieID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GenreID ; rr:objectMap [ rr:column "GenreID" ] ] .

