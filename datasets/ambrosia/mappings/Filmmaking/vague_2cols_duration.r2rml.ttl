<#tm_vague_2cols_duration_6_Movie_Genres_MovieID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MovieID\", \"GenreID\" FROM \"Movie_Genres\" WHERE \"MovieID\" IS NOT NULL""" ] ;
