  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Genres/{GenreID}" ; rr:class :Genres ] ;
  rr:predicateObjectMap [ rr:predicate p:GenreID ; rr:objectMap [ rr:column "GenreID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] .

