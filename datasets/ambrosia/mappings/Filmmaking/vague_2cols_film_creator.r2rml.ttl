  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date_of_birth ; rr:objectMap [ rr:column "date_of_birth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:gender ; rr:objectMap [ rr:column "gender" ] ] .

<#tm_vague_2cols_film_creator_6_Role_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"actor_id\", \"character\" FROM \"Role\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Role/{movie_id}/{actor_id}" ; rr:class :Role ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:actor_id ; rr:objectMap [ rr:column "actor_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:character ; rr:objectMap [ rr:column "character" ] ] .

<#tm_vague_2cols_film_creator_7_Role_actor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"actor_id\" FROM \"Role\" WHERE \"actor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Role/{movie_id}/{actor_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActors ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actors/{actor_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_film_creator_8_Role_movie_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"actor_id\" FROM \"Role\" WHERE \"movie_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Role/{movie_id}/{actor_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovies ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movie_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_film_creator_9_Award_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"award_name\", \"category\" FROM \"Award\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Awards/{award_name}" ; rr:class :Awards ] ;
  rr:predicateObjectMap [ rr:predicate p:award_name ; rr:objectMap [ rr:column "award_name" ] ] ;
