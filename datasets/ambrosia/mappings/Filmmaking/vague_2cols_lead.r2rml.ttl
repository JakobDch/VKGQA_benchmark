@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_lead_0_Movie_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Genre\", \"ReleaseDate\", \"DirectorId\", \"LeadActorId\", \"LeadActressId\" FROM \"Movie\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{id}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Genre ; rr:objectMap [ rr:column "Genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DirectorId ; rr:objectMap [ rr:column "DirectorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LeadActorId ; rr:objectMap [ rr:column "LeadActorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LeadActressId ; rr:objectMap [ rr:column "LeadActressId" ] ] .

<#tm_vague_2cols_lead_1_Movie_LeadActressId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"LeadActressId\" FROM \"Movie\" WHERE \"LeadActressId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActress ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Actress/{LeadActressId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_lead_2_Movie_LeadActorId_fk> a rr:TriplesMap ;
