@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_production_0_Studio_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address_line1\", \"address_line2\", \"phone_number\" FROM \"Studio\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Studio/{id}" ; rr:class :Studio ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address_line1 ; rr:objectMap [ rr:column "address_line1" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address_line2 ; rr:objectMap [ rr:column "address_line2" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_vague_2cols_production_1_Producer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"email\", \"birthdate\", \"full_name\" FROM \"Producer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Producers/{id}" ; rr:class :Producers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthdate ; rr:objectMap [ rr:column "birthdate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_vague_2cols_production_2_Movie_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_year\", \"genre\", \"studio_id\", \"producer_id\" FROM \"Movie\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{id}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_year ; rr:objectMap [ rr:column "release_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:studio_id ; rr:objectMap [ rr:column "studio_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:producer_id ; rr:objectMap [ rr:column "producer_id" ] ] .

<#tm_vague_2cols_production_3_Movie_producer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"producer_id\" FROM \"Movie\" WHERE \"producer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProducers ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Producers/{producer_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_production_4_Movie_studio_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"studio_id\" FROM \"Movie\" WHERE \"studio_id\" IS NOT NULL""" ] ;
