  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Role/{id}" ; rr:class :Role ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:actor_id ; rr:objectMap [ rr:column "actor_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role_name ; rr:objectMap [ rr:column "role_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:film_id ; rr:objectMap [ rr:column "film_id" ] ] .

<#tm_vague_2cols_rating_3_Role_film_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"film_id\" FROM \"Role\" WHERE \"film_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Role/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilms ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Films/{film_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_rating_4_Role_actor_id_fk> a rr:TriplesMap ;
