@prefix : <http://ambrosia.example.org/filmmaking#> .
@prefix p: <http://ambrosia.example.org/filmmaking/prop#> .
@prefix ex: <http://ambrosia.example.org/filmmaking/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_production_0_Studio_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studio_id\", \"name\", \"location\" FROM \"Studio\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Studio/{studio_id}" ; rr:class :Studio ] ;
  rr:predicateObjectMap [ rr:predicate p:studio_id ; rr:objectMap [ rr:column "studio_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_vague_2tabs_production_1_Producer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"producer_id\", \"birthdate\", \"full_name\" FROM \"Producer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Producers/{producer_id}" ; rr:class :Producers ] ;
  rr:predicateObjectMap [ rr:predicate p:producer_id ; rr:objectMap [ rr:column "producer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthdate ; rr:objectMap [ rr:column "birthdate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_vague_2tabs_production_2_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"title\", \"release_year\", \"genre\", \"studio_id\", \"producer_id\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movie_id}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_year ; rr:objectMap [ rr:column "release_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:studio_id ; rr:objectMap [ rr:column "studio_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:producer_id ; rr:objectMap [ rr:column "producer_id" ] ] .

<#tm_vague_2tabs_production_3_Movies_producer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"producer_id\" FROM \"Movies\" WHERE \"producer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Movies/{movie_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProducers ; rr:objectMap [ rr:template "http://ambrosia.example.org/filmmaking/id/Producers/{producer_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_production_4_Movies_studio_id_fk> a rr:TriplesMap ;
