@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_clinics_services_0_Clinics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"clinic_id\", \"name\", \"address\" FROM \"Clinics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Clinics/{clinic_id}" ; rr:class :Clinics ] ;
  rr:predicateObjectMap [ rr:predicate p:clinic_id ; rr:objectMap [ rr:column "clinic_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_scope_clinics_services_1_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"service_id\", \"service_name\" FROM \"Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Services/{service_id}" ; rr:class :Services ] ;
  rr:predicateObjectMap [ rr:predicate p:service_id ; rr:objectMap [ rr:column "service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_name ; rr:objectMap [ rr:column "service_name" ] ] .

<#tm_scope_clinics_services_2_Clinics_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"clinics_services_id\", \"clinic_id\", \"service_id\" FROM \"Clinics_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Clinics_Services/{clinics_services_id}" ; rr:class :Clinics_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:clinics_services_id ; rr:objectMap [ rr:column "clinics_services_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:clinic_id ; rr:objectMap [ rr:column "clinic_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_id ; rr:objectMap [ rr:column "service_id" ] ] .

<#tm_scope_clinics_services_3_Clinics_Services_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"clinics_services_id\", \"service_id\" FROM \"Clinics_Services\" WHERE \"service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Clinics_Services/{clinics_services_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasServices ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Services/{service_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_clinics_services_4_Clinics_Services_clinic_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"clinics_services_id\", \"clinic_id\" FROM \"Clinics_Services\" WHERE \"clinic_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Clinics_Services/{clinics_services_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClinics ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Clinics/{clinic_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_clinics_services_5_Patients_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"patient_id\", \"first_name\", \"last_name\", \"date_of_birth\", \"phone_number\" FROM \"Patients\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{patient_id}" ; rr:class :Patients ] ;
  rr:predicateObjectMap [ rr:predicate p:patient_id ; rr:objectMap [ rr:column "patient_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date_of_birth ; rr:objectMap [ rr:column "date_of_birth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_scope_clinics_services_6_Appointments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"appointment_id\", \"patient_id\", \"clinic_id\", \"service_id\", \"appointment_date\" FROM \"Appointments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Appointments/{appointment_id}" ; rr:class :Appointments ] ;
  rr:predicateObjectMap [ rr:predicate p:appointment_id ; rr:objectMap [ rr:column "appointment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:patient_id ; rr:objectMap [ rr:column "patient_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:clinic_id ; rr:objectMap [ rr:column "clinic_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_id ; rr:objectMap [ rr:column "service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:appointment_date ; rr:objectMap [ rr:column "appointment_date" ] ] .

<#tm_scope_clinics_services_7_Appointments_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"appointment_id\", \"service_id\" FROM \"Appointments\" WHERE \"service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Appointments/{appointment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasServices ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Services/{service_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_clinics_services_8_Appointments_clinic_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"appointment_id\", \"clinic_id\" FROM \"Appointments\" WHERE \"clinic_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Appointments/{appointment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClinics ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Clinics/{clinic_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_clinics_services_9_Appointments_patient_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"appointment_id\", \"patient_id\" FROM \"Appointments\" WHERE \"patient_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Appointments/{appointment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPatients ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{patient_id}" ; rr:termType rr:IRI ] ] .

