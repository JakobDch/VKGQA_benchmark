@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_epidemiological_study_methods_0_Epidemiological_Study_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"study_id\", \"name\", \"start_date\", \"end_date\" FROM \"Epidemiological_Study\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Epidemiological_Study/{study_id}" ; rr:class :Epidemiological_Study ] ;
  rr:predicateObjectMap [ rr:predicate p:study_id ; rr:objectMap [ rr:column "study_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] .

<#tm_scope_epidemiological_study_methods_1_Methods_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"method_id\", \"method_name\" FROM \"Methods\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Methods/{method_id}" ; rr:class :Methods ] ;
  rr:predicateObjectMap [ rr:predicate p:method_id ; rr:objectMap [ rr:column "method_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:method_name ; rr:objectMap [ rr:column "method_name" ] ] .

<#tm_scope_epidemiological_study_methods_2_Study_Participants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"participant_id\", \"epidemiological_study_id\", \"first_name\", \"last_name\", \"age\" FROM \"Study_Participants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Study_Participants/{participant_id}" ; rr:class :Study_Participants ] ;
  rr:predicateObjectMap [ rr:predicate p:participant_id ; rr:objectMap [ rr:column "participant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:epidemiological_study_id ; rr:objectMap [ rr:column "epidemiological_study_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:age ; rr:objectMap [ rr:column "age" ] ] .

<#tm_scope_epidemiological_study_methods_3_Study_Participants_epidemiological_study_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"participant_id\", \"epidemiological_study_id\" FROM \"Study_Participants\" WHERE \"epidemiological_study_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Study_Participants/{participant_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEpidemiological_Study ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Epidemiological_Study/{epidemiological_study_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_epidemiological_study_methods_4_Diseases_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"disease_id\", \"disease_name\" FROM \"Diseases\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Diseases/{disease_id}" ; rr:class :Diseases ] ;
  rr:predicateObjectMap [ rr:predicate p:disease_id ; rr:objectMap [ rr:column "disease_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:disease_name ; rr:objectMap [ rr:column "disease_name" ] ] .

<#tm_scope_epidemiological_study_methods_5_Diagnoses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"diagnosis_id\", \"participant_id\", \"disease_id\", \"date_of_diagnosis\" FROM \"Diagnoses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Diagnoses/{diagnosis_id}" ; rr:class :Diagnoses ] ;
  rr:predicateObjectMap [ rr:predicate p:diagnosis_id ; rr:objectMap [ rr:column "diagnosis_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:participant_id ; rr:objectMap [ rr:column "participant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:disease_id ; rr:objectMap [ rr:column "disease_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date_of_diagnosis ; rr:objectMap [ rr:column "date_of_diagnosis" ] ] .

<#tm_scope_epidemiological_study_methods_6_Diagnoses_disease_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"diagnosis_id\", \"disease_id\" FROM \"Diagnoses\" WHERE \"disease_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Diagnoses/{diagnosis_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDiseases ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Diseases/{disease_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_epidemiological_study_methods_7_Diagnoses_participant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"diagnosis_id\", \"participant_id\" FROM \"Diagnoses\" WHERE \"participant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Diagnoses/{diagnosis_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudy_Participants ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Study_Participants/{participant_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_epidemiological_study_methods_8_Epidemiological_Study_Methods_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"epidemiological_study_id\", \"method_id\" FROM \"Epidemiological_Study_Methods\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Epidemiological_Study_Methods/{_amb_rowid}" ; rr:class :Epidemiological_Study_Methods ] ;
  rr:predicateObjectMap [ rr:predicate p:epidemiological_study_id ; rr:objectMap [ rr:column "epidemiological_study_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:method_id ; rr:objectMap [ rr:column "method_id" ] ] .

<#tm_scope_epidemiological_study_methods_9_Epidemiological_Study_Methods_method_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"method_id\" FROM \"Epidemiological_Study_Methods\" WHERE \"method_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Epidemiological_Study_Methods/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMethods ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Methods/{method_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_epidemiological_study_methods_10_Epidemiological_Study_Methods_epidemiological_study_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"epidemiological_study_id\" FROM \"Epidemiological_Study_Methods\" WHERE \"epidemiological_study_id\" IS NOT NULL""" ] ;
