@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_health_apps_functions_0_Users_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"userID\", \"username\", \"email\", \"password\" FROM \"Users\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Users/{userID}" ; rr:class :Users ] ;
  rr:predicateObjectMap [ rr:predicate p:userID ; rr:objectMap [ rr:column "userID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:username ; rr:objectMap [ rr:column "username" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:password ; rr:objectMap [ rr:column "password" ] ] .

<#tm_scope_health_apps_functions_1_Health_Apps_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"appID\", \"name\", \"description\", \"price\" FROM \"Health_Apps\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Apps/{appID}" ; rr:class :Health_Apps ] ;
  rr:predicateObjectMap [ rr:predicate p:appID ; rr:objectMap [ rr:column "appID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_health_apps_functions_2_Functions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"functionID\", \"value\" FROM \"Functions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Functions/{functionID}" ; rr:class :Functions ] ;
  rr:predicateObjectMap [ rr:predicate p:functionID ; rr:objectMap [ rr:column "functionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:value ; rr:objectMap [ rr:column "value" ] ] .

<#tm_scope_health_apps_functions_3_Health_Apps_Functions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"healthAppID\", \"functionID\" FROM \"Health_Apps_Functions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Apps_Functions/{healthAppID}/{functionID}" ; rr:class :Health_Apps_Functions ] ;
  rr:predicateObjectMap [ rr:predicate p:healthAppID ; rr:objectMap [ rr:column "healthAppID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:functionID ; rr:objectMap [ rr:column "functionID" ] ] .

<#tm_scope_health_apps_functions_4_Health_Apps_Functions_functionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"healthAppID\", \"functionID\" FROM \"Health_Apps_Functions\" WHERE \"functionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Apps_Functions/{healthAppID}/{functionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFunctions ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Functions/{functionID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_health_apps_functions_5_Health_Apps_Functions_healthAppID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"healthAppID\", \"functionID\" FROM \"Health_Apps_Functions\" WHERE \"healthAppID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Apps_Functions/{healthAppID}/{functionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHealth_Apps ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Apps/{healthAppID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_health_apps_functions_6_Reviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reviewID\", \"rating\", \"comment\", \"appID\", \"userID\" FROM \"Reviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Reviews/{reviewID}" ; rr:class :Reviews ] ;
  rr:predicateObjectMap [ rr:predicate p:reviewID ; rr:objectMap [ rr:column "reviewID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rating ; rr:objectMap [ rr:column "rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:comment ; rr:objectMap [ rr:column "comment" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:appID ; rr:objectMap [ rr:column "appID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:userID ; rr:objectMap [ rr:column "userID" ] ] .

<#tm_scope_health_apps_functions_7_Reviews_userID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reviewID\", \"userID\" FROM \"Reviews\" WHERE \"userID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Reviews/{reviewID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUsers ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Users/{userID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_health_apps_functions_8_Reviews_appID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reviewID\", \"appID\" FROM \"Reviews\" WHERE \"appID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Reviews/{reviewID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHealth_Apps ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Apps/{appID}" ; rr:termType rr:IRI ] ] .

