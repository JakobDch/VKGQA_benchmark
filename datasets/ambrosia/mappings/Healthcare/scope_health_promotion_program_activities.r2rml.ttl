@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_health_promotion_program_activities_0_Health_Promotion_Program_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"program_id\", \"name\", \"description\" FROM \"Health_Promotion_Program\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Promotion_Program/{program_id}" ; rr:class :Health_Promotion_Program ] ;
  rr:predicateObjectMap [ rr:predicate p:program_id ; rr:objectMap [ rr:column "program_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_health_promotion_program_activities_1_Activities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"activity_id\", \"activity_name\", \"description\" FROM \"Activities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Activities/{activity_id}" ; rr:class :Activities ] ;
  rr:predicateObjectMap [ rr:predicate p:activity_id ; rr:objectMap [ rr:column "activity_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:activity_name ; rr:objectMap [ rr:column "activity_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_health_promotion_program_activities_2_Health_Promotion_Program_Activities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"program_id\", \"activity_id\" FROM \"Health_Promotion_Program_Activities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Promotion_Program_Activities/{id}" ; rr:class :Health_Promotion_Program_Activities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:program_id ; rr:objectMap [ rr:column "program_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:activity_id ; rr:objectMap [ rr:column "activity_id" ] ] .

<#tm_scope_health_promotion_program_activities_3_Health_Promotion_Program_Activities_activity_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"activity_id\" FROM \"Health_Promotion_Program_Activities\" WHERE \"activity_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Promotion_Program_Activities/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActivities ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Activities/{activity_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_health_promotion_program_activities_4_Health_Promotion_Program_Activities_program_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"program_id\" FROM \"Health_Promotion_Program_Activities\" WHERE \"program_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Promotion_Program_Activities/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHealth_Promotion_Program ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Promotion_Program/{program_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_health_promotion_program_activities_5_Participants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"participant_id\", \"first_name\", \"last_name\", \"email\", \"phone_number\" FROM \"Participants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Participants/{participant_id}" ; rr:class :Participants ] ;
  rr:predicateObjectMap [ rr:predicate p:participant_id ; rr:objectMap [ rr:column "participant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

