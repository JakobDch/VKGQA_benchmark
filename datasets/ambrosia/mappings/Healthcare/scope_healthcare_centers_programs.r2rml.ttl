@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_healthcare_centers_programs_0_Healthcare_Centers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CenterID\", \"CenterName\", \"Address\" FROM \"Healthcare_Centers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Healthcare_Centers/{CenterID}" ; rr:class :Healthcare_Centers ] ;
  rr:predicateObjectMap [ rr:predicate p:CenterID ; rr:objectMap [ rr:column "CenterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CenterName ; rr:objectMap [ rr:column "CenterName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] .

<#tm_scope_healthcare_centers_programs_1_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProgramID\", \"ProgramType\" FROM \"Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Programs/{ProgramID}" ; rr:class :Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:ProgramID ; rr:objectMap [ rr:column "ProgramID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProgramType ; rr:objectMap [ rr:column "ProgramType" ] ] .

<#tm_scope_healthcare_centers_programs_2_Patients_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PatientID\", \"FirstName\", \"LastName\", \"Age\", \"CenterID\" FROM \"Patients\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{PatientID}" ; rr:class :Patients ] ;
  rr:predicateObjectMap [ rr:predicate p:PatientID ; rr:objectMap [ rr:column "PatientID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CenterID ; rr:objectMap [ rr:column "CenterID" ] ] .

<#tm_scope_healthcare_centers_programs_3_Patients_CenterID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PatientID\", \"CenterID\" FROM \"Patients\" WHERE \"CenterID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{PatientID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHealthcare_Centers ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Healthcare_Centers/{CenterID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_healthcare_centers_programs_4_Doctors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DoctorID\", \"Name\", \"Specialization\", \"CenterID\" FROM \"Doctors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Doctors/{DoctorID}" ; rr:class :Doctors ] ;
  rr:predicateObjectMap [ rr:predicate p:DoctorID ; rr:objectMap [ rr:column "DoctorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Specialization ; rr:objectMap [ rr:column "Specialization" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CenterID ; rr:objectMap [ rr:column "CenterID" ] ] .

<#tm_scope_healthcare_centers_programs_5_Doctors_CenterID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DoctorID\", \"CenterID\" FROM \"Doctors\" WHERE \"CenterID\" IS NOT NULL""" ] ;
