<#tm_scope_hospitals_departments_11_Hospitals_Departments_hospitalId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"hospitalId\", \"departmentId\" FROM \"Hospitals_Departments\" WHERE \"hospitalId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Hospitals_Departments/{hospitalId}/{departmentId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHospitals ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Hospitals/{hospitalId}" ; rr:termType rr:IRI ] ] .

