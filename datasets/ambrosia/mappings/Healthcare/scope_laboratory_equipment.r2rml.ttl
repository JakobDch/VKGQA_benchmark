@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_laboratory_equipment_0_Laboratory_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\" FROM \"Laboratory\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Laboratory/{id}" ; rr:class :Laboratory ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_scope_laboratory_equipment_1_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\", \"description\" FROM \"Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Equipment/{id}" ; rr:class :Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_laboratory_equipment_2_Laboratory_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"laboratory_id\", \"equipment_type_id\" FROM \"Laboratory_Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Laboratory_Equipment/{laboratory_id}/{equipment_type_id}" ; rr:class :Laboratory_Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:laboratory_id ; rr:objectMap [ rr:column "laboratory_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:equipment_type_id ; rr:objectMap [ rr:column "equipment_type_id" ] ] .

<#tm_scope_laboratory_equipment_3_Laboratory_Equipment_equipment_type_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"laboratory_id\", \"equipment_type_id\" FROM \"Laboratory_Equipment\" WHERE \"equipment_type_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Laboratory_Equipment/{laboratory_id}/{equipment_type_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEquipment ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Equipment/{equipment_type_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_laboratory_equipment_4_Laboratory_Equipment_laboratory_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"laboratory_id\", \"equipment_type_id\" FROM \"Laboratory_Equipment\" WHERE \"laboratory_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Laboratory_Equipment/{laboratory_id}/{equipment_type_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLaboratory ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Laboratory/{laboratory_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_laboratory_equipment_5_Doctors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"specialization\" FROM \"Doctors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Doctors/{id}" ; rr:class :Doctors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specialization ; rr:objectMap [ rr:column "specialization" ] ] .

<#tm_scope_laboratory_equipment_6_Patients_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"age\", \"gender\" FROM \"Patients\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{id}" ; rr:class :Patients ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:age ; rr:objectMap [ rr:column "age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:gender ; rr:objectMap [ rr:column "gender" ] ] .

<#tm_scope_laboratory_equipment_7_Appointments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"appointment_id\", \"doctor_id\", \"patient_id\", \"date\", \"time\" FROM \"Appointments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Appointments/{appointment_id}" ; rr:class :Appointments ] ;
  rr:predicateObjectMap [ rr:predicate p:appointment_id ; rr:objectMap [ rr:column "appointment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:doctor_id ; rr:objectMap [ rr:column "doctor_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:patient_id ; rr:objectMap [ rr:column "patient_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:time ; rr:objectMap [ rr:column "time" ] ] .

<#tm_scope_laboratory_equipment_8_Appointments_patient_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"appointment_id\", \"patient_id\" FROM \"Appointments\" WHERE \"patient_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Appointments/{appointment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPatients ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{patient_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_laboratory_equipment_9_Appointments_doctor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"appointment_id\", \"doctor_id\" FROM \"Appointments\" WHERE \"doctor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Appointments/{appointment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDoctors ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Doctors/{doctor_id}" ; rr:termType rr:IRI ] ] .

