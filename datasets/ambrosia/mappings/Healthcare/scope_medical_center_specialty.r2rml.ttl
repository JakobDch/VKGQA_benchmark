<#tm_scope_medical_center_specialty_7_Appointment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Patient_ID\", \"Doctor_ID\", \"StartTime\", \"EndTime\" FROM \"Appointment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Appointments/{ID}" ; rr:class :Appointments ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Patient_ID ; rr:objectMap [ rr:column "Patient_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Doctor_ID ; rr:objectMap [ rr:column "Doctor_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartTime ; rr:objectMap [ rr:column "StartTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndTime ; rr:objectMap [ rr:column "EndTime" ] ] .

<#tm_scope_medical_center_specialty_8_Appointment_Doctor_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Doctor_ID\" FROM \"Appointment\" WHERE \"Doctor_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Appointments/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDoctors ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Doctors/{Doctor_ID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_medical_center_specialty_9_Appointment_Patient_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Patient_ID\" FROM \"Appointment\" WHERE \"Patient_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Appointments/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPatients ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{Patient_ID}" ; rr:termType rr:IRI ] ] .

