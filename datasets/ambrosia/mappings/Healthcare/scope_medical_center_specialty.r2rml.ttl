@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_medical_center_specialty_0_Medical_Center_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Location\" FROM \"Medical_Center\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Medical_Center/{ID}" ; rr:class :Medical_Center ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_scope_medical_center_specialty_1_Specialty_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Type\" FROM \"Specialty\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Specialty/{ID}" ; rr:class :Specialty ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] .

<#tm_scope_medical_center_specialty_2_Medical_Center_Specialty_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Medical_Center_ID\", \"Specialty_ID\" FROM \"Medical_Center_Specialty\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Medical_Center_Specialty/{_amb_rowid}" ; rr:class :Medical_Center_Specialty ] ;
  rr:predicateObjectMap [ rr:predicate p:Medical_Center_ID ; rr:objectMap [ rr:column "Medical_Center_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Specialty_ID ; rr:objectMap [ rr:column "Specialty_ID" ] ] .

<#tm_scope_medical_center_specialty_3_Medical_Center_Specialty_Specialty_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Specialty_ID\" FROM \"Medical_Center_Specialty\" WHERE \"Specialty_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Medical_Center_Specialty/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSpecialty ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Specialty/{Specialty_ID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_medical_center_specialty_4_Medical_Center_Specialty_Medical_Center_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Medical_Center_ID\" FROM \"Medical_Center_Specialty\" WHERE \"Medical_Center_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Medical_Center_Specialty/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMedical_Center ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Medical_Center/{Medical_Center_ID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_medical_center_specialty_5_Doctor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FirstName\", \"LastName\", \"LicenseNumber\" FROM \"Doctor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Doctors/{ID}" ; rr:class :Doctors ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LicenseNumber ; rr:objectMap [ rr:column "LicenseNumber" ] ] .

<#tm_scope_medical_center_specialty_6_Patient_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"PhoneNumber\" FROM \"Patient\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{ID}" ; rr:class :Patients ] ;
