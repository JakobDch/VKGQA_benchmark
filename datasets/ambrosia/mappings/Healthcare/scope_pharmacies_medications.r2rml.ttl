<#tm_scope_pharmacies_medications_6_Pharmacy_Prescriptions_pharmacy_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"pharmacy_prescription_id\", \"pharmacy_id\" FROM \"Pharmacy_Prescriptions\" WHERE \"pharmacy_id\" IS NOT NULL""" ] ;
