@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_research_institutes_projects_0_Research_Institutes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InstituteID\", \"Name\", \"Location\" FROM \"Research_Institutes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Research_Institutes/{InstituteID}" ; rr:class :Research_Institutes ] ;
  rr:predicateObjectMap [ rr:predicate p:InstituteID ; rr:objectMap [ rr:column "InstituteID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_scope_research_institutes_projects_1_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProjectID\", \"Name\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Projects/{ProjectID}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:ProjectID ; rr:objectMap [ rr:column "ProjectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_scope_research_institutes_projects_2_Research_Institutes_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"InstituteID\", \"ProjectID\" FROM \"Research_Institutes_Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Research_Institutes_Projects/{_amb_rowid}" ; rr:class :Research_Institutes_Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:InstituteID ; rr:objectMap [ rr:column "InstituteID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProjectID ; rr:objectMap [ rr:column "ProjectID" ] ] .

<#tm_scope_research_institutes_projects_3_Research_Institutes_Projects_ProjectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ProjectID\" FROM \"Research_Institutes_Projects\" WHERE \"ProjectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Research_Institutes_Projects/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Projects/{ProjectID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_research_institutes_projects_4_Research_Institutes_Projects_InstituteID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"InstituteID\" FROM \"Research_Institutes_Projects\" WHERE \"InstituteID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Research_Institutes_Projects/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasResearch_Institutes ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Research_Institutes/{InstituteID}" ; rr:termType rr:IRI ] ] .

