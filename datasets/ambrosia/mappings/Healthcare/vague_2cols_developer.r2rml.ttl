@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_developer_0_Scientists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"birthDate\", \"fullname\" FROM \"Scientists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Scientists/{id}" ; rr:class :Scientists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthDate ; rr:objectMap [ rr:column "birthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "fullname" ] ] .

<#tm_vague_2cols_developer_1_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_vague_2cols_developer_2_MedicalDevices_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"deviceName\", \"description\", \"price\" FROM \"MedicalDevices\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/MedicalDevices/{id}" ; rr:class :MedicalDevices ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:deviceName ; rr:objectMap [ rr:column "deviceName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_vague_2cols_developer_3_DeviceDevelopment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"scientistId\", \"companyId\", \"medicalDeviceId\", \"startDate\", \"endDate\" FROM \"DeviceDevelopment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/DeviceDevelopment/{scientistId}/{companyId}/{medicalDeviceId}" ; rr:class :DeviceDevelopment ] ;
  rr:predicateObjectMap [ rr:predicate p:scientistId ; rr:objectMap [ rr:column "scientistId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:companyId ; rr:objectMap [ rr:column "companyId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:medicalDeviceId ; rr:objectMap [ rr:column "medicalDeviceId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] .

<#tm_vague_2cols_developer_4_DeviceDevelopment_medicalDeviceId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"scientistId\", \"companyId\", \"medicalDeviceId\" FROM \"DeviceDevelopment\" WHERE \"medicalDeviceId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/DeviceDevelopment/{scientistId}/{companyId}/{medicalDeviceId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMedicalDevices ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/MedicalDevices/{medicalDeviceId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_developer_5_DeviceDevelopment_companyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"scientistId\", \"companyId\", \"medicalDeviceId\" FROM \"DeviceDevelopment\" WHERE \"companyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/DeviceDevelopment/{scientistId}/{companyId}/{medicalDeviceId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Companies/{companyId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_developer_6_DeviceDevelopment_scientistId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"scientistId\", \"companyId\", \"medicalDeviceId\" FROM \"DeviceDevelopment\" WHERE \"scientistId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/DeviceDevelopment/{scientistId}/{companyId}/{medicalDeviceId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasScientists ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Scientists/{scientistId}" ; rr:termType rr:IRI ] ] .

