@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_geographical_location_0_Doctors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"specialty\", \"hospital_id\" FROM \"Doctors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Doctors/{id}" ; rr:class :Doctors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specialty ; rr:objectMap [ rr:column "specialty" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hospital_id ; rr:objectMap [ rr:column "hospital_id" ] ] .

<#tm_vague_2cols_geographical_location_1_Doctors_hospital_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"hospital_id\" FROM \"Doctors\" WHERE \"hospital_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Doctors/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHospitals ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Hospitals/{hospital_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_geographical_location_2_Hospitals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"city\", \"neighborhood\", \"phone_number\" FROM \"Hospitals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Hospitals/{id}" ; rr:class :Hospitals ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:neighborhood ; rr:objectMap [ rr:column "neighborhood" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_vague_2cols_geographical_location_3_InsurancePlans_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"plan_name\", \"premium\", \"coverage_details\", \"provider_id\" FROM \"InsurancePlans\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/InsurancePlans/{id}" ; rr:class :InsurancePlans ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:plan_name ; rr:objectMap [ rr:column "plan_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:premium ; rr:objectMap [ rr:column "premium" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:coverage_details ; rr:objectMap [ rr:column "coverage_details" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:provider_id ; rr:objectMap [ rr:column "provider_id" ] ] .

<#tm_vague_2cols_geographical_location_4_Patients_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\", \"birthdate\", \"insurance_plan_id\" FROM \"Patients\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{id}" ; rr:class :Patients ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthdate ; rr:objectMap [ rr:column "birthdate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:insurance_plan_id ; rr:objectMap [ rr:column "insurance_plan_id" ] ] .

<#tm_vague_2cols_geographical_location_5_Patients_insurance_plan_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"insurance_plan_id\" FROM \"Patients\" WHERE \"insurance_plan_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInsurancePlans ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/InsurancePlans/{insurance_plan_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_geographical_location_6_Prescriptions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"patient_id\", \"doctor_id\", \"medication\", \"dosage\", \"quantity\", \"refillable\", \"prescription_date\" FROM \"Prescriptions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Prescriptions/{id}" ; rr:class :Prescriptions ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:patient_id ; rr:objectMap [ rr:column "patient_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:doctor_id ; rr:objectMap [ rr:column "doctor_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:medication ; rr:objectMap [ rr:column "medication" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dosage ; rr:objectMap [ rr:column "dosage" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quantity ; rr:objectMap [ rr:column "quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:refillable ; rr:objectMap [ rr:column "refillable" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:prescription_date ; rr:objectMap [ rr:column "prescription_date" ] ] .

<#tm_vague_2cols_geographical_location_7_Prescriptions_doctor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"doctor_id\" FROM \"Prescriptions\" WHERE \"doctor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Prescriptions/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDoctors ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Doctors/{doctor_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_geographical_location_8_Prescriptions_patient_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"patient_id\" FROM \"Prescriptions\" WHERE \"patient_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Prescriptions/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPatients ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{patient_id}" ; rr:termType rr:IRI ] ] .

