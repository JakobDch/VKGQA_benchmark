  rr:predicateObjectMap [ rr:predicate p:MedicineName ; rr:objectMap [ rr:column "MedicineName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DrugClass ; rr:objectMap [ rr:column "DrugClass" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Instructions ; rr:objectMap [ rr:column "Instructions" ] ] .

<#tm_vague_2cols_hospital_history_6_Prescriptions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PrescriptionID\", \"PatientID\", \"MedicationID\", \"IssueDate\", \"ExpiryDate\", \"Quantity\" FROM \"Prescriptions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Prescriptions/{PrescriptionID}" ; rr:class :Prescriptions ] ;
