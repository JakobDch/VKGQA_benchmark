<#tm_vague_2cols_hospital_history_9_Insurances_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InsuranceID\", \"PolicyNumber\", \"Provider\", \"CoverageAmount\", \"StartDate\", \"EndDate\", \"PatientID\" FROM \"Insurances\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Insurances/{InsuranceID}" ; rr:class :Insurances ] ;
  rr:predicateObjectMap [ rr:predicate p:InsuranceID ; rr:objectMap [ rr:column "InsuranceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PolicyNumber ; rr:objectMap [ rr:column "PolicyNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Provider ; rr:objectMap [ rr:column "Provider" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CoverageAmount ; rr:objectMap [ rr:column "CoverageAmount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PatientID ; rr:objectMap [ rr:column "PatientID" ] ] .

<#tm_vague_2cols_hospital_history_10_Insurances_PatientID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InsuranceID\", \"PatientID\" FROM \"Insurances\" WHERE \"PatientID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Insurances/{InsuranceID}" ] ;
