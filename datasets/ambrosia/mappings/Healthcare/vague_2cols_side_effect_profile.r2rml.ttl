  rr:logicalTable [ rr:sqlQuery """SELECT \"doctor_patient_id\", \"doctor_id\", \"patient_id\", \"relationship\" FROM \"DoctorPatient\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/DoctorPatient/{doctor_patient_id}" ; rr:class :DoctorPatient ] ;
  rr:predicateObjectMap [ rr:predicate p:doctor_patient_id ; rr:objectMap [ rr:column "doctor_patient_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:doctor_id ; rr:objectMap [ rr:column "doctor_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:patient_id ; rr:objectMap [ rr:column "patient_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:relationship ; rr:objectMap [ rr:column "relationship" ] ] .

<#tm_vague_2cols_side_effect_profile_8_DoctorPatient_patient_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"doctor_patient_id\", \"patient_id\" FROM \"DoctorPatient\" WHERE \"patient_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/DoctorPatient/{doctor_patient_id}" ] ;
