<#tm_vague_2cols_side_effect_profile_10_Diagnosis_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"diagnosis_id\", \"patient_id\", \"diagnosis_text\", \"diagnosis_code\" FROM \"Diagnosis\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Diagnoses/{diagnosis_id}" ; rr:class :Diagnoses ] ;
  rr:predicateObjectMap [ rr:predicate p:diagnosis_id ; rr:objectMap [ rr:column "diagnosis_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:patient_id ; rr:objectMap [ rr:column "patient_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:diagnosis_text ; rr:objectMap [ rr:column "diagnosis_text" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:diagnosis_code ; rr:objectMap [ rr:column "diagnosis_code" ] ] .

<#tm_vague_2cols_side_effect_profile_11_Diagnosis_patient_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"diagnosis_id\", \"patient_id\" FROM \"Diagnosis\" WHERE \"patient_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Diagnoses/{diagnosis_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPatients ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{patient_id}" ; rr:termType rr:IRI ] ] .

