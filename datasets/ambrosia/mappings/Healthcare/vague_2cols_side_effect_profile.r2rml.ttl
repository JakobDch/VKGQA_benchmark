<#tm_vague_2cols_side_effect_profile_9_DoctorPatient_doctor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"doctor_patient_id\", \"doctor_id\" FROM \"DoctorPatient\" WHERE \"doctor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/DoctorPatient/{doctor_patient_id}" ] ;
