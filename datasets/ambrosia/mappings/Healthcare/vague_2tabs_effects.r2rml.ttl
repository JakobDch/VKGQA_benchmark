<#tm_vague_2tabs_effects_11_Effectiveness_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"effectivenessID\", \"percentage\" FROM \"Effectiveness\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Effectiveness/{effectivenessID}" ; rr:class :Effectiveness ] ;
  rr:predicateObjectMap [ rr:predicate p:effectivenessID ; rr:objectMap [ rr:column "effectivenessID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:percentage ; rr:objectMap [ rr:column "percentage" ] ] .

