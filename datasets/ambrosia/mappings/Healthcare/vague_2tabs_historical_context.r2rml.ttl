  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"treatment_name\", \"start_date\", \"end_date\", \"patient_id\", \"healthcare_facility_id\" FROM \"Treatments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Treatments/{id}" ; rr:class :Treatments ] ;
