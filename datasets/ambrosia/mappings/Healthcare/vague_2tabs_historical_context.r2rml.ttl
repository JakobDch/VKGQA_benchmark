  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Treatments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHealthcare_Facilities ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Healthcare_Facilities/{healthcare_facility_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_historical_context_11_Treatments_patient_id_fk> a rr:TriplesMap ;
