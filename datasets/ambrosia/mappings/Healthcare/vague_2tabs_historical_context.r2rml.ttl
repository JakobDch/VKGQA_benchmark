@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_historical_context_0_Founding_Year_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"year\" FROM \"Founding_Year\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Founding_Year/{id}" ; rr:class :Founding_Year ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:year ; rr:objectMap [ rr:column "year" ] ] .

<#tm_vague_2tabs_historical_context_1_Past_Owners_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"owner_name\", \"acquisition_year\" FROM \"Past_Owners\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Past_Owners/{id}" ; rr:class :Past_Owners ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:owner_name ; rr:objectMap [ rr:column "owner_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:acquisition_year ; rr:objectMap [ rr:column "acquisition_year" ] ] .

<#tm_vague_2tabs_historical_context_2_Healthcare_Facilities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"founding_id\", \"past_owner_id\" FROM \"Healthcare_Facilities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Healthcare_Facilities/{id}" ; rr:class :Healthcare_Facilities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:founding_id ; rr:objectMap [ rr:column "founding_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:past_owner_id ; rr:objectMap [ rr:column "past_owner_id" ] ] .

<#tm_vague_2tabs_historical_context_3_Healthcare_Facilities_past_owner_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"past_owner_id\" FROM \"Healthcare_Facilities\" WHERE \"past_owner_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Healthcare_Facilities/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPast_Owners ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Past_Owners/{past_owner_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_historical_context_4_Healthcare_Facilities_founding_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"founding_id\" FROM \"Healthcare_Facilities\" WHERE \"founding_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Healthcare_Facilities/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFounding_Year ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Founding_Year/{founding_id}" ; rr:termType rr:IRI ] ] .

