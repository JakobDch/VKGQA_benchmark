@prefix : <http://ambrosia.example.org/healthcare#> .
@prefix p: <http://ambrosia.example.org/healthcare/prop#> .
@prefix ex: <http://ambrosia.example.org/healthcare/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_side_effect_profile_0_Patient_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"patientID\", \"firstName\", \"lastName\" FROM \"Patient\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{patientID}" ; rr:class :Patients ] ;
  rr:predicateObjectMap [ rr:predicate p:patientID ; rr:objectMap [ rr:column "patientID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] .

<#tm_vague_2tabs_side_effect_profile_1_Doctor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"doctorID\", \"firstName\", \"lastName\" FROM \"Doctor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Doctors/{doctorID}" ; rr:class :Doctors ] ;
  rr:predicateObjectMap [ rr:predicate p:doctorID ; rr:objectMap [ rr:column "doctorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] .

<#tm_vague_2tabs_side_effect_profile_2_Prescription_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"prescriptionID\", \"antibioticID\", \"patientID\", \"doctorID\", \"datePrescribed\" FROM \"Prescription\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Prescriptions/{prescriptionID}" ; rr:class :Prescriptions ] ;
  rr:predicateObjectMap [ rr:predicate p:prescriptionID ; rr:objectMap [ rr:column "prescriptionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:antibioticID ; rr:objectMap [ rr:column "antibioticID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:patientID ; rr:objectMap [ rr:column "patientID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:doctorID ; rr:objectMap [ rr:column "doctorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:datePrescribed ; rr:objectMap [ rr:column "datePrescribed" ] ] .

<#tm_vague_2tabs_side_effect_profile_3_Prescription_doctorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"prescriptionID\", \"doctorID\" FROM \"Prescription\" WHERE \"doctorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Prescriptions/{prescriptionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDoctors ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Doctors/{doctorID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_side_effect_profile_4_Prescription_patientID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"prescriptionID\", \"patientID\" FROM \"Prescription\" WHERE \"patientID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Prescriptions/{prescriptionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPatients ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Patients/{patientID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_side_effect_profile_5_Prescription_antibioticID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"prescriptionID\", \"antibioticID\" FROM \"Prescription\" WHERE \"antibioticID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Prescriptions/{prescriptionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAntibiotic ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Antibiotic/{antibioticID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_side_effect_profile_6_Common_Side_Effects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"sideEffectID\", \"description\" FROM \"Common_Side_Effects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Common_Side_Effects/{sideEffectID}" ; rr:class :Common_Side_Effects ] ;
  rr:predicateObjectMap [ rr:predicate p:sideEffectID ; rr:objectMap [ rr:column "sideEffectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2tabs_side_effect_profile_7_Serious_Side_Effects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"seriousSideEffectID\", \"description\" FROM \"Serious_Side_Effects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Serious_Side_Effects/{seriousSideEffectID}" ; rr:class :Serious_Side_Effects ] ;
  rr:predicateObjectMap [ rr:predicate p:seriousSideEffectID ; rr:objectMap [ rr:column "seriousSideEffectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2tabs_side_effect_profile_8_Antibiotic_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"antibioticID\", \"name\", \"commonSideEffects\", \"seriousSideEffects\" FROM \"Antibiotic\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Antibiotic/{antibioticID}" ; rr:class :Antibiotic ] ;
  rr:predicateObjectMap [ rr:predicate p:antibioticID ; rr:objectMap [ rr:column "antibioticID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:commonSideEffects ; rr:objectMap [ rr:column "commonSideEffects" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:seriousSideEffects ; rr:objectMap [ rr:column "seriousSideEffects" ] ] .

<#tm_vague_2tabs_side_effect_profile_9_Antibiotic_seriousSideEffects_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"antibioticID\", \"seriousSideEffects\" FROM \"Antibiotic\" WHERE \"seriousSideEffects\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Antibiotic/{antibioticID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSerious_Side_Effects ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Serious_Side_Effects/{seriousSideEffects}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_side_effect_profile_10_Antibiotic_commonSideEffects_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"antibioticID\", \"commonSideEffects\" FROM \"Antibiotic\" WHERE \"commonSideEffects\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Antibiotic/{antibioticID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCommon_Side_Effects ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Common_Side_Effects/{commonSideEffects}" ; rr:termType rr:IRI ] ] .

