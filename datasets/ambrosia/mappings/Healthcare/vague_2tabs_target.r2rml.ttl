  rr:predicateObjectMap [ rr:predicate p:age_group_id ; rr:objectMap [ rr:column "age_group_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:health_condition_id ; rr:objectMap [ rr:column "health_condition_id" ] ] .

<#tm_vague_2tabs_target_3_Vaccine_health_condition_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"health_condition_id\" FROM \"Vaccine\" WHERE \"health_condition_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Vaccine/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHealth_Condition ; rr:objectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Health_Condition/{health_condition_id}" ; rr:termType rr:IRI ] ] .

