  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"vaccine_name\", \"age_group_id\", \"health_condition_id\" FROM \"Vaccine\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/healthcare/id/Vaccine/{id}" ; rr:class :Vaccine ] ;
