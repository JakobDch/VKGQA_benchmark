@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_accommodation2_0_Accomodations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"type\" FROM \"Accomodations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Accommodations/{id}" ; rr:class :Accommodations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_attachment_1tab_ref_accommodation2_1_Prices_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"accommodationId\", \"price_per_night\" FROM \"Prices\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Prices/{_amb_rowid}" ; rr:class :Prices ] ;
  rr:predicateObjectMap [ rr:predicate p:accommodationId ; rr:objectMap [ rr:column "accommodationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price_per_night ; rr:objectMap [ rr:column "price_per_night" ] ] .

<#tm_attachment_1tab_ref_accommodation2_2_Prices_accommodationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"accommodationId\" FROM \"Prices\" WHERE \"accommodationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Prices/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccommodations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Accommodations/{accommodationId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_accommodation2_3_Guests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"emailAddress\" FROM \"Guests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{id}" ; rr:class :Guests ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "emailAddress" ] ] .

<#tm_attachment_1tab_ref_accommodation2_4_Reservations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reservationId\", \"guestId\", \"accommodationId\", \"checkInDate\", \"checkOutDate\", \"totalCost\" FROM \"Reservations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{reservationId}" ; rr:class :Reservations ] ;
  rr:predicateObjectMap [ rr:predicate p:reservationId ; rr:objectMap [ rr:column "reservationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:guestId ; rr:objectMap [ rr:column "guestId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:accommodationId ; rr:objectMap [ rr:column "accommodationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkInDate ; rr:objectMap [ rr:column "checkInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkOutDate ; rr:objectMap [ rr:column "checkOutDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:totalCost ; rr:objectMap [ rr:column "totalCost" ] ] .

<#tm_attachment_1tab_ref_accommodation2_5_Reservations_accommodationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reservationId\", \"accommodationId\" FROM \"Reservations\" WHERE \"accommodationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{reservationId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccommodations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Accommodations/{accommodationId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_accommodation2_6_Reservations_guestId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reservationId\", \"guestId\" FROM \"Reservations\" WHERE \"guestId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{reservationId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuests ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{guestId}" ; rr:termType rr:IRI ] ] .

