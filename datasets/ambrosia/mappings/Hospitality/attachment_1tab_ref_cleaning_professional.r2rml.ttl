@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_cleaning_professional_0_CleaningProfessionals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"type\", \"hotel_id\" FROM \"CleaningProfessionals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/CleaningProfessionals/{id}" ; rr:class :CleaningProfessionals ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hotel_id ; rr:objectMap [ rr:column "hotel_id" ] ] .

<#tm_attachment_1tab_ref_cleaning_professional_1_CleaningProfessionals_hotel_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"hotel_id\" FROM \"CleaningProfessionals\" WHERE \"hotel_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/CleaningProfessionals/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHotels ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Hotels/{hotel_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_cleaning_professional_2_Hotels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Hotels\"""" ] ;
