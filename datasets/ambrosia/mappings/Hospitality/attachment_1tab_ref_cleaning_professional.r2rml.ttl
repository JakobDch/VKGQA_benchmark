<#tm_attachment_1tab_ref_cleaning_professional_5_Reservations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"checkin\", \"checkout\", \"room_id\", \"customer_name\" FROM \"Reservations\"""" ] ;
