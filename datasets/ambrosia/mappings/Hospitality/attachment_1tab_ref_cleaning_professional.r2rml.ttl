<#tm_attachment_1tab_ref_cleaning_professional_6_Reservations_room_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"room_id\" FROM \"Reservations\" WHERE \"room_id\" IS NOT NULL""" ] ;
