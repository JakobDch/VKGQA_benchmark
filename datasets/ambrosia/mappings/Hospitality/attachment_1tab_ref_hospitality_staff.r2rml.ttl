  rr:logicalTable [ rr:sqlQuery """SELECT \"StaffID\", \"RoomID\" FROM \"StaffRooms\" WHERE \"RoomID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/StaffRooms/{StaffID}/{RoomID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{RoomID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_hospitality_staff_7_StaffRooms_StaffID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StaffID\", \"RoomID\" FROM \"StaffRooms\" WHERE \"StaffID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/StaffRooms/{StaffID}/{RoomID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStaff ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Staff/{StaffID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_hospitality_staff_8_Languages_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Language\" FROM \"Languages\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Languages/{ID}" ; rr:class :Languages ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
