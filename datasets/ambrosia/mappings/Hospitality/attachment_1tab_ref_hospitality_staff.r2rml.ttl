  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomNumber ; rr:objectMap [ rr:column "RoomNumber" ] ] .

<#tm_attachment_1tab_ref_hospitality_staff_3_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"GuestName\", \"CheckInDate\", \"CheckOutDate\", \"RoomID\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{ID}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GuestName ; rr:objectMap [ rr:column "GuestName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckInDate ; rr:objectMap [ rr:column "CheckInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckOutDate ; rr:objectMap [ rr:column "CheckOutDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomID ; rr:objectMap [ rr:column "RoomID" ] ] .

<#tm_attachment_1tab_ref_hospitality_staff_4_Bookings_RoomID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"RoomID\" FROM \"Bookings\" WHERE \"RoomID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{RoomID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_hospitality_staff_5_StaffRooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StaffID\", \"RoomID\", \"WorkDays\" FROM \"StaffRooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/StaffRooms/{StaffID}/{RoomID}" ; rr:class :StaffRooms ] ;
  rr:predicateObjectMap [ rr:predicate p:StaffID ; rr:objectMap [ rr:column "StaffID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomID ; rr:objectMap [ rr:column "RoomID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:WorkDays ; rr:objectMap [ rr:column "WorkDays" ] ] .

