  rr:predicateObjectMap [ rr:predicate p:hasRoomTypes ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/RoomTypes/{roomtype_id}" ; rr:termType rr:IRI ] ] .

