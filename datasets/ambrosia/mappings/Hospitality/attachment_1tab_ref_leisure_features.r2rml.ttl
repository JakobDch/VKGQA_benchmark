  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"checkin_date\", \"checkout_date\", \"roomtype_id\", \"customer_name\", \"guest_count\" FROM \"Reservation\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{id}" ; rr:class :Reservations ] ;
