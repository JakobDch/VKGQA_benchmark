@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_overnight_stay_0_Guests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"EmailAddress\", \"PhoneNumber\", \"FullName\" FROM \"Guests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{ID}" ; rr:class :Guests ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_ref_overnight_stay_1_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoomID\", \"TypeOfRoom\", \"ServiceID\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{RoomID}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomID ; rr:objectMap [ rr:column "RoomID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeOfRoom ; rr:objectMap [ rr:column "TypeOfRoom" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ServiceID ; rr:objectMap [ rr:column "ServiceID" ] ] .

<#tm_attachment_1tab_ref_overnight_stay_2_Rooms_ServiceID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoomID\", \"ServiceID\" FROM \"Rooms\" WHERE \"ServiceID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{RoomID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasServices ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Services/{ServiceID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_overnight_stay_3_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"CheckInDate\", \"CheckOutDate\", \"NumberOfAdults\", \"NumberOfChildren\", \"GuestID\", \"ROOMID\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:BookingID ; rr:objectMap [ rr:column "BookingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckInDate ; rr:objectMap [ rr:column "CheckInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckOutDate ; rr:objectMap [ rr:column "CheckOutDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfAdults ; rr:objectMap [ rr:column "NumberOfAdults" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfChildren ; rr:objectMap [ rr:column "NumberOfChildren" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GuestID ; rr:objectMap [ rr:column "GuestID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ROOMID ; rr:objectMap [ rr:column "ROOMID" ] ] .

<#tm_attachment_1tab_ref_overnight_stay_4_Bookings_ROOMID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"ROOMID\" FROM \"Bookings\" WHERE \"ROOMID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{ROOMID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_overnight_stay_5_Bookings_GuestID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"GuestID\" FROM \"Bookings\" WHERE \"GuestID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuests ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{GuestID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_overnight_stay_6_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ServiceID\", \"Amenity\", \"Description\" FROM \"Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Services/{ServiceID}" ; rr:class :Services ] ;
  rr:predicateObjectMap [ rr:predicate p:ServiceID ; rr:objectMap [ rr:column "ServiceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Amenity ; rr:objectMap [ rr:column "Amenity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

