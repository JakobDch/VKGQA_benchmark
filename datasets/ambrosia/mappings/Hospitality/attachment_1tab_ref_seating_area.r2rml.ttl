<#tm_attachment_1tab_ref_seating_area_9_FoodOrders_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OrderID\", \"ReservationID\", \"MenuItem\", \"Quantity\", \"SpecialInstructions\", \"TotalPrice\", \"PaymentStatus\" FROM \"FoodOrders\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/FoodOrders/{OrderID}" ; rr:class :FoodOrders ] ;
  rr:predicateObjectMap [ rr:predicate p:OrderID ; rr:objectMap [ rr:column "OrderID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReservationID ; rr:objectMap [ rr:column "ReservationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MenuItem ; rr:objectMap [ rr:column "MenuItem" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SpecialInstructions ; rr:objectMap [ rr:column "SpecialInstructions" ] ] ;
