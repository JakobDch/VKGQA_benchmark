@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_seating_area_0_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CustomerID\", \"PhoneNumber\", \"EmailAddress\", \"FullName\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{CustomerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_ref_seating_area_1_Tables_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TableID\", \"SeatingArea\", \"Capacity\" FROM \"Tables\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Tables/{TableID}" ; rr:class :Tables ] ;
  rr:predicateObjectMap [ rr:predicate p:TableID ; rr:objectMap [ rr:column "TableID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SeatingArea ; rr:objectMap [ rr:column "SeatingArea" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] .

<#tm_attachment_1tab_ref_seating_area_2_FloorPlan_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FloorplanID\", \"NumberOfSeats\", \"TableId\" FROM \"FloorPlan\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/FloorPlan/{FloorplanID}" ; rr:class :FloorPlan ] ;
  rr:predicateObjectMap [ rr:predicate p:FloorplanID ; rr:objectMap [ rr:column "FloorplanID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfSeats ; rr:objectMap [ rr:column "NumberOfSeats" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TableId ; rr:objectMap [ rr:column "TableId" ] ] .

<#tm_attachment_1tab_ref_seating_area_3_FloorPlan_TableId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FloorplanID\", \"TableId\" FROM \"FloorPlan\" WHERE \"TableId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/FloorPlan/{FloorplanID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTables ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Tables/{TableId}" ; rr:termType rr:IRI ] ] .

