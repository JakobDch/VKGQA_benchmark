<#tm_attachment_1tab_ref_seating_area_10_FoodOrders_ReservationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OrderID\", \"ReservationID\" FROM \"FoodOrders\" WHERE \"ReservationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/FoodOrders/{OrderID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReservations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{ReservationID}" ; rr:termType rr:IRI ] ] .

