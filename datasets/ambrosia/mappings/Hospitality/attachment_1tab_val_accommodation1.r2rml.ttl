@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_accommodation1_0_Accommodations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Type_of_Accommodation\", \"Price\" FROM \"Accommodations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Accommodations/{ID}" ; rr:class :Accommodations ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type_of_Accommodation ; rr:objectMap [ rr:column "Type_of_Accommodation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_attachment_1tab_val_accommodation1_1_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CustomerID\", \"FirstName\", \"LastName\", \"Email\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{CustomerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

<#tm_attachment_1tab_val_accommodation1_2_Booking_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"CustomerID\", \"AccommodationID\", \"CheckInDate\", \"CheckOutDate\" FROM \"Booking\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:BookingID ; rr:objectMap [ rr:column "BookingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccommodationID ; rr:objectMap [ rr:column "AccommodationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckInDate ; rr:objectMap [ rr:column "CheckInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckOutDate ; rr:objectMap [ rr:column "CheckOutDate" ] ] .

<#tm_attachment_1tab_val_accommodation1_3_Booking_AccommodationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"AccommodationID\" FROM \"Booking\" WHERE \"AccommodationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccommodations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Accommodations/{AccommodationID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_accommodation1_4_Booking_CustomerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"CustomerID\" FROM \"Booking\" WHERE \"CustomerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{CustomerID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_accommodation1_5_Reviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReviewID\", \"AccommodationID\", \"Rating\", \"Comment\" FROM \"Reviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reviews/{ReviewID}" ; rr:class :Reviews ] ;
  rr:predicateObjectMap [ rr:predicate p:ReviewID ; rr:objectMap [ rr:column "ReviewID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccommodationID ; rr:objectMap [ rr:column "AccommodationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Comment ; rr:objectMap [ rr:column "Comment" ] ] .

<#tm_attachment_1tab_val_accommodation1_6_Reviews_AccommodationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReviewID\", \"AccommodationID\" FROM \"Reviews\" WHERE \"AccommodationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reviews/{ReviewID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccommodations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Accommodations/{AccommodationID}" ; rr:termType rr:IRI ] ] .

