[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Hotels_base
target		ex:Hotels/{HotelID} a :Hotels ; p:HotelID {HotelID} ; p:name {Name} ; p:Address {Address} ; p:City {City} ; p:Country {Country} .
source		SELECT `HotelID`, `Name`, `Address`, `City`, `Country` FROM `Hotels`

mappingId	Guests_base
target		ex:Guests/{GuestID} a :Guests ; p:GuestID {GuestID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:email {Email} .
source		SELECT `GuestID`, `FirstName`, `LastName`, `Email` FROM `Guests`

mappingId	Bookings_base
target		ex:Bookings/{BookingID} a :Bookings ; p:BookingID {BookingID} ; p:CheckInDate {CheckInDate} ; p:CheckOutDate {CheckOutDate} ; p:AccommodationID {AccommodationID} ; p:GuestID {GuestID} ; p:TotalCost {TotalCost} .
source		SELECT `BookingID`, `CheckInDate`, `CheckOutDate`, `AccommodationID`, `GuestID`, `TotalCost` FROM `Bookings`

mappingId	Bookings_GuestID_fk
target		ex:Bookings/{BookingID} p:hasGuests ex:Guests/{GuestID} .
source		SELECT `BookingID`, `GuestID` FROM `Bookings` WHERE `GuestID` IS NOT NULL

mappingId	Bookings_AccommodationID_fk
target		ex:Bookings/{BookingID} p:hasAccommodations ex:Accommodations/{AccommodationID} .
source		SELECT `BookingID`, `AccommodationID` FROM `Bookings` WHERE `AccommodationID` IS NOT NULL

mappingId	Accommodations_base
target		ex:Accommodations/{AccommodationID} a :Accommodations ; p:AccommodationID {AccommodationID} ; p:RoomNumber {RoomNumber} ; p:TypeOfAccomodation {TypeOfAccomodation} ; p:PricePerNight {PricePerNight} ; p:NumberGuests {NumberGuests} ; p:HotelID {HotelID} .
source		SELECT `AccommodationID`, `RoomNumber`, `TypeOfAccomodation`, `PricePerNight`, `NumberGuests`, `HotelID` FROM `Accommodations`

mappingId	Accommodations_HotelID_fk
target		ex:Accommodations/{AccommodationID} p:hasHotels ex:Hotels/{HotelID} .
source		SELECT `AccommodationID`, `HotelID` FROM `Accommodations` WHERE `HotelID` IS NOT NULL

]]
