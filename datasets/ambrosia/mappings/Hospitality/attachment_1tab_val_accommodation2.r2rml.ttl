@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_accommodation2_0_Hotels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"HotelID\", \"Name\", \"Address\", \"City\", \"Country\" FROM \"Hotels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Hotels/{HotelID}" ; rr:class :Hotels ] ;
  rr:predicateObjectMap [ rr:predicate p:HotelID ; rr:objectMap [ rr:column "HotelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_val_accommodation2_1_Guests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GuestID\", \"FirstName\", \"LastName\", \"Email\" FROM \"Guests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{GuestID}" ; rr:class :Guests ] ;
  rr:predicateObjectMap [ rr:predicate p:GuestID ; rr:objectMap [ rr:column "GuestID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

<#tm_attachment_1tab_val_accommodation2_2_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"CheckInDate\", \"CheckOutDate\", \"AccommodationID\", \"GuestID\", \"TotalCost\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:BookingID ; rr:objectMap [ rr:column "BookingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckInDate ; rr:objectMap [ rr:column "CheckInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckOutDate ; rr:objectMap [ rr:column "CheckOutDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AccommodationID ; rr:objectMap [ rr:column "AccommodationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GuestID ; rr:objectMap [ rr:column "GuestID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalCost ; rr:objectMap [ rr:column "TotalCost" ] ] .

<#tm_attachment_1tab_val_accommodation2_3_Bookings_GuestID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"GuestID\" FROM \"Bookings\" WHERE \"GuestID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuests ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{GuestID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_accommodation2_4_Bookings_AccommodationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"AccommodationID\" FROM \"Bookings\" WHERE \"AccommodationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccommodations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Accommodations/{AccommodationID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_accommodation2_5_Accommodations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccommodationID\", \"RoomNumber\", \"TypeOfAccomodation\", \"PricePerNight\", \"NumberGuests\", \"HotelID\" FROM \"Accommodations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Accommodations/{AccommodationID}" ; rr:class :Accommodations ] ;
  rr:predicateObjectMap [ rr:predicate p:AccommodationID ; rr:objectMap [ rr:column "AccommodationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomNumber ; rr:objectMap [ rr:column "RoomNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeOfAccomodation ; rr:objectMap [ rr:column "TypeOfAccomodation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PricePerNight ; rr:objectMap [ rr:column "PricePerNight" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberGuests ; rr:objectMap [ rr:column "NumberGuests" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HotelID ; rr:objectMap [ rr:column "HotelID" ] ] .

<#tm_attachment_1tab_val_accommodation2_6_Accommodations_HotelID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccommodationID\", \"HotelID\" FROM \"Accommodations\" WHERE \"HotelID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Accommodations/{AccommodationID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHotels ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Hotels/{HotelID}" ; rr:termType rr:IRI ] ] .

