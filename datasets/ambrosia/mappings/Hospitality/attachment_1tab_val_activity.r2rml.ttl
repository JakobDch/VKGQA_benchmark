<#tm_attachment_1tab_val_activity_5_VisitRecords_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"VisitorID\", \"TouristAttractionID\", \"LocalMarketID\" FROM \"VisitRecords\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/VisitRecords/{ID}" ; rr:class :VisitRecords ] ;
