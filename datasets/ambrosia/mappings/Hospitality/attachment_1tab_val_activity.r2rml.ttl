<#tm_attachment_1tab_val_activity_6_VisitRecords_LocalMarketID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"LocalMarketID\" FROM \"VisitRecords\" WHERE \"LocalMarketID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/VisitRecords/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMarkets ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Markets/{LocalMarketID}" ; rr:termType rr:IRI ] ] .

