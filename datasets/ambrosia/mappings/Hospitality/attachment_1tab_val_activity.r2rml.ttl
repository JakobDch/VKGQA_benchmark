  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"VisitorID\" FROM \"VisitRecords\" WHERE \"VisitorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/VisitRecords/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVisitors ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Visitors/{VisitorID}" ; rr:termType rr:IRI ] ] .

