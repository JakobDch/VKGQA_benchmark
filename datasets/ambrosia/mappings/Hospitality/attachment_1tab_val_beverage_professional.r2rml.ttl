<#tm_attachment_1tab_val_beverage_professional_7_Orders_Ordered_by_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Ordered_by\" FROM \"Orders\" WHERE \"Ordered_by\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReservations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{Ordered_by}" ; rr:termType rr:IRI ] ] .

