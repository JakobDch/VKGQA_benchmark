  rr:predicateObjectMap [ rr:predicate p:Ordered_by ; rr:objectMap [ rr:column "Ordered_by" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Item_name ; rr:objectMap [ rr:column "Item_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date_ordered ; rr:objectMap [ rr:column "Date_ordered" ] ] ;
