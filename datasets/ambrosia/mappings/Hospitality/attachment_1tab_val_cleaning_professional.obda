[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Cleaning_Professionals_base
target		ex:CleaningProfessionals/{ID} a :CleaningProfessionals ; p:ID {ID} ; p:name {Name} ; p:Position {Position} ; p:Hotel_ID {Hotel_ID} .
source		SELECT `ID`, `Name`, `Position`, `Hotel_ID` FROM `Cleaning_Professionals`

mappingId	Rooms_base
target		ex:Rooms/{ID} a :Rooms ; p:ID {ID} ; p:Number {Number} ; p:Type {Type} ; p:Floor {Floor} ; p:Hotel_ID {Hotel_ID} .
source		SELECT `ID`, `Number`, `Type`, `Floor`, `Hotel_ID` FROM `Rooms`

mappingId	Hotels_base
target		ex:Hotels/{ID} a :Hotels ; p:ID {ID} ; p:name {Name} ; p:location {Location} ; p:Manager_Name {Manager_Name} .
source		SELECT `ID`, `Name`, `Location`, `Manager_Name` FROM `Hotels`

mappingId	Services_base
target		ex:Services/{ID} a :Services ; p:ID {ID} ; p:Service_Type {Service_Type} ; p:Description {Description} ; p:Price {Price} .
source		SELECT `ID`, `Service_Type`, `Description`, `Price` FROM `Services`

]]
