<#tm_attachment_1tab_val_cleaning_professional_3_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Service_Type\", \"Description\", \"Price\" FROM \"Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Services/{ID}" ; rr:class :Services ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
