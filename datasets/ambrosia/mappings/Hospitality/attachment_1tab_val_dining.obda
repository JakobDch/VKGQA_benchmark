[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Customers_base
target		ex:Customers/{CustomerID} a :Customers ; p:CustomerID {CustomerID} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:email {Email} ; p:PhoneNumber {PhoneNumber} .
source		SELECT `CustomerID`, `FirstName`, `LastName`, `Email`, `PhoneNumber` FROM `Customers`

mappingId	Restaurants_base
target		ex:Restaurants/{RestaurantID} a :Restaurants ; p:RestaurantID {RestaurantID} ; p:name {Name} ; p:Address {Address} ; p:OpeningTime {OpeningTime} ; p:ClosingTime {ClosingTime} .
source		SELECT `RestaurantID`, `Name`, `Address`, `OpeningTime`, `ClosingTime` FROM `Restaurants`

mappingId	Meals_base
target		ex:Meals/{MealID} a :Meals ; p:MealID {MealID} ; p:MealType {MealType} ; p:BestBefore {BestBefore} ; p:Description {Description} ; p:Price {Price} .
source		SELECT `MealID`, `MealType`, `BestBefore`, `Description`, `Price` FROM `Meals`

mappingId	Orders_base
target		ex:Orders/{OrderID} a :Orders ; p:OrderID {OrderID} ; p:CustomerID {CustomerID} ; p:MealID {MealID} ; p:Quantity {Quantity} ; p:OrderDate {OrderDate} .
source		SELECT `OrderID`, `CustomerID`, `MealID`, `Quantity`, `OrderDate` FROM `Orders`

mappingId	Orders_MealID_fk
target		ex:Orders/{OrderID} p:hasMeals ex:Meals/{MealID} .
source		SELECT `OrderID`, `MealID` FROM `Orders` WHERE `MealID` IS NOT NULL

mappingId	Orders_CustomerID_fk
target		ex:Orders/{OrderID} p:hasCustomers ex:Customers/{CustomerID} .
source		SELECT `OrderID`, `CustomerID` FROM `Orders` WHERE `CustomerID` IS NOT NULL

]]
