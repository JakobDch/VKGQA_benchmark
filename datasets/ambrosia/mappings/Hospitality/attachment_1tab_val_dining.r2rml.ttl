@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_dining_0_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CustomerID\", \"FirstName\", \"LastName\", \"Email\", \"PhoneNumber\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{CustomerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_attachment_1tab_val_dining_1_Restaurants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RestaurantID\", \"Name\", \"Address\", \"OpeningTime\", \"ClosingTime\" FROM \"Restaurants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{RestaurantID}" ; rr:class :Restaurants ] ;
  rr:predicateObjectMap [ rr:predicate p:RestaurantID ; rr:objectMap [ rr:column "RestaurantID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OpeningTime ; rr:objectMap [ rr:column "OpeningTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClosingTime ; rr:objectMap [ rr:column "ClosingTime" ] ] .

<#tm_attachment_1tab_val_dining_2_Meals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MealID\", \"MealType\", \"BestBefore\", \"Description\", \"Price\" FROM \"Meals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Meals/{MealID}" ; rr:class :Meals ] ;
  rr:predicateObjectMap [ rr:predicate p:MealID ; rr:objectMap [ rr:column "MealID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MealType ; rr:objectMap [ rr:column "MealType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BestBefore ; rr:objectMap [ rr:column "BestBefore" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_attachment_1tab_val_dining_3_Orders_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OrderID\", \"CustomerID\", \"MealID\", \"Quantity\", \"OrderDate\" FROM \"Orders\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{OrderID}" ; rr:class :Orders ] ;
  rr:predicateObjectMap [ rr:predicate p:OrderID ; rr:objectMap [ rr:column "OrderID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MealID ; rr:objectMap [ rr:column "MealID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OrderDate ; rr:objectMap [ rr:column "OrderDate" ] ] .

<#tm_attachment_1tab_val_dining_4_Orders_MealID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OrderID\", \"MealID\" FROM \"Orders\" WHERE \"MealID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{OrderID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMeals ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Meals/{MealID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_dining_5_Orders_CustomerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OrderID\", \"CustomerID\" FROM \"Orders\" WHERE \"CustomerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{OrderID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{CustomerID}" ; rr:termType rr:IRI ] ] .

