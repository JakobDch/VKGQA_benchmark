@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_event_space_0_EventSpaces_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Event_Space\", \"Capacity\", \"Address\", \"ContactInfo\" FROM \"EventSpaces\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/EventSpaces/{id}" ; rr:class :EventSpaces ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Event_Space ; rr:objectMap [ rr:column "Event_Space" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ContactInfo ; rr:objectMap [ rr:column "ContactInfo" ] ] .

<#tm_attachment_1tab_val_event_space_1_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"EventSpaceId\", \"Date\", \"Time\", \"NumberOfGuests\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{id}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EventSpaceId ; rr:objectMap [ rr:column "EventSpaceId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Time ; rr:objectMap [ rr:column "Time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfGuests ; rr:objectMap [ rr:column "NumberOfGuests" ] ] .

<#tm_attachment_1tab_val_event_space_2_Bookings_EventSpaceId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"EventSpaceId\" FROM \"Bookings\" WHERE \"EventSpaceId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEventSpaces ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/EventSpaces/{EventSpaceId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_event_space_3_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"FirstName\", \"LastName\", \"Email\", \"PhoneNumber\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_attachment_1tab_val_event_space_4_Payments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"BookingId\", \"Amount\", \"PaymentDate\", \"CustomerId\" FROM \"Payments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Payments/{id}" ; rr:class :Payments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BookingId ; rr:objectMap [ rr:column "BookingId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Amount ; rr:objectMap [ rr:column "Amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PaymentDate ; rr:objectMap [ rr:column "PaymentDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerId ; rr:objectMap [ rr:column "CustomerId" ] ] .

<#tm_attachment_1tab_val_event_space_5_Payments_CustomerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"CustomerId\" FROM \"Payments\" WHERE \"CustomerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Payments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{CustomerId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_event_space_6_Payments_BookingId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"BookingId\" FROM \"Payments\" WHERE \"BookingId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Payments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBookings ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingId}" ; rr:termType rr:IRI ] ] .

