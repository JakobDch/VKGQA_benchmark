@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_food_service_0_Restaurants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Address\", \"Food_Service\", \"Cuisine\" FROM \"Restaurants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{ID}" ; rr:class :Restaurants ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Food_Service ; rr:objectMap [ rr:column "Food_Service" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Cuisine ; rr:objectMap [ rr:column "Cuisine" ] ] .

<#tm_attachment_1tab_val_food_service_1_Tables_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Number\", \"Status\", \"RestaurantID\" FROM \"Tables\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Tables/{ID}" ; rr:class :Tables ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number ; rr:objectMap [ rr:column "Number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Status ; rr:objectMap [ rr:column "Status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RestaurantID ; rr:objectMap [ rr:column "RestaurantID" ] ] .

<#tm_attachment_1tab_val_food_service_2_Tables_RestaurantID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"RestaurantID\" FROM \"Tables\" WHERE \"RestaurantID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Tables/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRestaurants ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{RestaurantID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_food_service_3_Reservations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Date\", \"Time\", \"TableNumber\", \"Guests\", \"TotalCost\", \"CustomerName\", \"TableID\" FROM \"Reservations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{ID}" ; rr:class :Reservations ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Time ; rr:objectMap [ rr:column "Time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TableNumber ; rr:objectMap [ rr:column "TableNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Guests ; rr:objectMap [ rr:column "Guests" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalCost ; rr:objectMap [ rr:column "TotalCost" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerName ; rr:objectMap [ rr:column "CustomerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TableID ; rr:objectMap [ rr:column "TableID" ] ] .

<#tm_attachment_1tab_val_food_service_4_Reservations_TableID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"TableID\" FROM \"Reservations\" WHERE \"TableID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTables ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Tables/{TableID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_food_service_5_Orders_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"OrderDate\", \"Item\", \"Quantity\", \"Price\", \"ReservationID\" FROM \"Orders\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{ID}" ; rr:class :Orders ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OrderDate ; rr:objectMap [ rr:column "OrderDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Item ; rr:objectMap [ rr:column "Item" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReservationID ; rr:objectMap [ rr:column "ReservationID" ] ] .

<#tm_attachment_1tab_val_food_service_6_Orders_ReservationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"ReservationID\" FROM \"Orders\" WHERE \"ReservationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReservations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{ReservationID}" ; rr:termType rr:IRI ] ] .

