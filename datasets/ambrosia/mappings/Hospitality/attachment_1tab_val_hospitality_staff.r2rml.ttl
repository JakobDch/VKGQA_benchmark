  rr:predicateObjectMap [ rr:predicate p:hasGuests ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{GuestId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_hospitality_staff_6_Bookings_RoomId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"RoomId\" FROM \"Bookings\" WHERE \"RoomId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{Id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{RoomId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_hospitality_staff_7_Staff_base> a rr:TriplesMap ;
