@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_hospitality_staff_0_RoomTypes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"TypeName\" FROM \"RoomTypes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/RoomTypes/{Id}" ; rr:class :RoomTypes ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeName ; rr:objectMap [ rr:column "TypeName" ] ] .

<#tm_attachment_1tab_val_hospitality_staff_1_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"RoomTypeId\", \"FloorNumber\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{Id}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomTypeId ; rr:objectMap [ rr:column "RoomTypeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FloorNumber ; rr:objectMap [ rr:column "FloorNumber" ] ] .

<#tm_attachment_1tab_val_hospitality_staff_2_Rooms_RoomTypeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"RoomTypeId\" FROM \"Rooms\" WHERE \"RoomTypeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{Id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRoomTypes ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/RoomTypes/{RoomTypeId}" ; rr:termType rr:IRI ] ] .

