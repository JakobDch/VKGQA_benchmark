  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_attachment_1tab_val_hospitality_staff_4_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"CheckInDate\", \"CheckOutDate\", \"RoomId\", \"GuestId\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{Id}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
