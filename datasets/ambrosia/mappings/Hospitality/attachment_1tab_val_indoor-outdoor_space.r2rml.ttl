@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_indoor_outdoor_space_0_Room_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Indoor_Outdoor_Space\", \"Size\", \"Price\" FROM \"Room\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{id}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Indoor_Outdoor_Space ; rr:objectMap [ rr:column "Indoor_Outdoor_Space" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Size ; rr:objectMap [ rr:column "Size" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_attachment_1tab_val_indoor_outdoor_space_1_Amenities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"amenityName\", \"available\" FROM \"Amenities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Amenities/{id}" ; rr:class :Amenities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amenityName ; rr:objectMap [ rr:column "amenityName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:available ; rr:objectMap [ rr:column "available" ] ] .

<#tm_attachment_1tab_val_indoor_outdoor_space_2_Booking_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bookingID\", \"roomId\", \"customerId\", \"startDate\", \"endDate\", \"totalPrice\" FROM \"Booking\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{bookingID}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:bookingID ; rr:objectMap [ rr:column "bookingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roomId ; rr:objectMap [ rr:column "roomId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customerId ; rr:objectMap [ rr:column "customerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:totalPrice ; rr:objectMap [ rr:column "totalPrice" ] ] .

<#tm_attachment_1tab_val_indoor_outdoor_space_3_Booking_customerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bookingID\", \"customerId\" FROM \"Booking\" WHERE \"customerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{bookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customerId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_indoor_outdoor_space_4_Booking_roomId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bookingID\", \"roomId\" FROM \"Booking\" WHERE \"roomId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{bookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{roomId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_indoor_outdoor_space_5_Customer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customerID\", \"firstName\", \"lastName\", \"email\", \"phoneNumber\" FROM \"Customer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:customerID ; rr:objectMap [ rr:column "customerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] .

