[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Guests_base
target		ex:Guests/{id} a :Guests ; p:id {id} ; p:firstName {firstName} ; p:lastName {lastName} ; p:phoneNumber {phoneNumber} .
source		SELECT `id`, `firstName`, `lastName`, `phoneNumber` FROM `Guests`

mappingId	Rooms_base
target		ex:Rooms/{id} a :Rooms ; p:id {id} ; p:roomNumber {roomNumber} ; p:capacity {capacity} ; p:pricePerNight {pricePerNight} .
source		SELECT `id`, `roomNumber`, `capacity`, `pricePerNight` FROM `Rooms`

mappingId	Reservations_base
target		ex:Reservations/{id} a :Reservations ; p:id {id} ; p:guestId {guestId} ; p:roomId {roomId} ; p:checkInDate {checkInDate} ; p:checkOutDate {checkOutDate} .
source		SELECT `id`, `guestId`, `roomId`, `checkInDate`, `checkOutDate` FROM `Reservations`

mappingId	Reservations_guestId_fk
target		ex:Reservations/{id} p:hasGuests ex:Guests/{guestId} .
source		SELECT `id`, `guestId` FROM `Reservations` WHERE `guestId` IS NOT NULL

mappingId	Relaxation_spot_base
target		ex:Relaxation_spot/{id} a :Relaxation_spot ; p:id {id} ; p:name {name} ; p:type {type} ; p:price {price} .
source		SELECT `id`, `name`, `type`, `price` FROM `Relaxation_spot`

]]
