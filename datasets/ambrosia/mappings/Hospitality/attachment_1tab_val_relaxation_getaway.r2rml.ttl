@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_relaxation_getaway_0_Guests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"phoneNumber\" FROM \"Guests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{id}" ; rr:class :Guests ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] .

<#tm_attachment_1tab_val_relaxation_getaway_1_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"roomNumber\", \"capacity\", \"pricePerNight\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{id}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roomNumber ; rr:objectMap [ rr:column "roomNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:pricePerNight ; rr:objectMap [ rr:column "pricePerNight" ] ] .

<#tm_attachment_1tab_val_relaxation_getaway_2_Reservations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"guestId\", \"roomId\", \"checkInDate\", \"checkOutDate\" FROM \"Reservations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{id}" ; rr:class :Reservations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:guestId ; rr:objectMap [ rr:column "guestId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roomId ; rr:objectMap [ rr:column "roomId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkInDate ; rr:objectMap [ rr:column "checkInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkOutDate ; rr:objectMap [ rr:column "checkOutDate" ] ] .

<#tm_attachment_1tab_val_relaxation_getaway_3_Reservations_guestId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"guestId\" FROM \"Reservations\" WHERE \"guestId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuests ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{guestId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_relaxation_getaway_4_Relaxation_spot_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"type\", \"price\" FROM \"Relaxation_spot\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Relaxation_spot/{id}" ; rr:class :Relaxation_spot ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

