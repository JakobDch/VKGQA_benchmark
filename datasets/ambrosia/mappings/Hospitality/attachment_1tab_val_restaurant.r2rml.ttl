  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"RestaurantId\" FROM \"MenuItems\" WHERE \"RestaurantId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/MenuItems/{id}" ] ;
