@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_seating_area_0_Seating_Areas_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AreaID\", \"Name\", \"Number_Of_Seats\", \"Type_of_Food\" FROM \"Seating_Areas\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Seating_Areas/{AreaID}" ; rr:class :Seating_Areas ] ;
  rr:predicateObjectMap [ rr:predicate p:AreaID ; rr:objectMap [ rr:column "AreaID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_Of_Seats ; rr:objectMap [ rr:column "Number_Of_Seats" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type_of_Food ; rr:objectMap [ rr:column "Type_of_Food" ] ] .

<#tm_attachment_1tab_val_seating_area_1_Restaurant_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RestID\", \"Name\", \"Address\", \"Contact_No\", \"Seating_Area_ID\" FROM \"Restaurant\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{RestID}" ; rr:class :Restaurants ] ;
  rr:predicateObjectMap [ rr:predicate p:RestID ; rr:objectMap [ rr:column "RestID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Contact_No ; rr:objectMap [ rr:column "Contact_No" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Seating_Area_ID ; rr:objectMap [ rr:column "Seating_Area_ID" ] ] .

<#tm_attachment_1tab_val_seating_area_2_Restaurant_Seating_Area_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RestID\", \"Seating_Area_ID\" FROM \"Restaurant\" WHERE \"Seating_Area_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{RestID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSeating_Areas ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Seating_Areas/{Seating_Area_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_seating_area_3_MenuItems_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ItemID\", \"Name\", \"Category\", \"Price\", \"Description\", \"Restaurant_ID\" FROM \"MenuItems\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/MenuItems/{ItemID}" ; rr:class :MenuItems ] ;
  rr:predicateObjectMap [ rr:predicate p:ItemID ; rr:objectMap [ rr:column "ItemID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Category ; rr:objectMap [ rr:column "Category" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Restaurant_ID ; rr:objectMap [ rr:column "Restaurant_ID" ] ] .

<#tm_attachment_1tab_val_seating_area_4_MenuItems_Restaurant_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ItemID\", \"Restaurant_ID\" FROM \"MenuItems\" WHERE \"Restaurant_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/MenuItems/{ItemID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRestaurants ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{Restaurant_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_seating_area_5_Reservations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReservationID\", \"Date\", \"Time\", \"No_Of_Guests\", \"Customer_Name\", \"TableID\" FROM \"Reservations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{ReservationID}" ; rr:class :Reservations ] ;
  rr:predicateObjectMap [ rr:predicate p:ReservationID ; rr:objectMap [ rr:column "ReservationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Time ; rr:objectMap [ rr:column "Time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:No_Of_Guests ; rr:objectMap [ rr:column "No_Of_Guests" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Customer_Name ; rr:objectMap [ rr:column "Customer_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TableID ; rr:objectMap [ rr:column "TableID" ] ] .

<#tm_attachment_1tab_val_seating_area_6_Reservations_TableID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReservationID\", \"TableID\" FROM \"Reservations\" WHERE \"TableID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{ReservationID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSeating_Areas ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Seating_Areas/{TableID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_seating_area_7_Reviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReviewID\", \"Rating\", \"Comment\", \"Reservation_ID\" FROM \"Reviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reviews/{ReviewID}" ; rr:class :Reviews ] ;
  rr:predicateObjectMap [ rr:predicate p:ReviewID ; rr:objectMap [ rr:column "ReviewID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Comment ; rr:objectMap [ rr:column "Comment" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Reservation_ID ; rr:objectMap [ rr:column "Reservation_ID" ] ] .

<#tm_attachment_1tab_val_seating_area_8_Reviews_Reservation_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReviewID\", \"Reservation_ID\" FROM \"Reviews\" WHERE \"Reservation_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reviews/{ReviewID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReservations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{Reservation_ID}" ; rr:termType rr:IRI ] ] .

