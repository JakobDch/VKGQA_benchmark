[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Restaurant_base
target		ex:Restaurants/{id} a :Restaurants ; p:id {id} ; p:name {name} ; p:address {address} ; p:Service_format {Service_format} ; p:Hours {Hours} .
source		SELECT `id`, `name`, `address`, `Service_format`, `Hours` FROM `Restaurant`

mappingId	MenuItems_base
target		ex:MenuItems/{id} a :MenuItems ; p:id {id} ; p:restaurant_id {restaurant_id} ; p:item_name {item_name} ; p:price {price} .
source		SELECT `id`, `restaurant_id`, `item_name`, `price` FROM `MenuItems`

mappingId	MenuItems_restaurant_id_fk
target		ex:MenuItems/{id} p:hasRestaurants ex:Restaurants/{restaurant_id} .
source		SELECT `id`, `restaurant_id` FROM `MenuItems` WHERE `restaurant_id` IS NOT NULL

mappingId	Customers_base
target		ex:Customers/{id} a :Customers ; p:id {id} ; p:name {name} ; p:email {email} ; p:phone {phone} ; p:preferred_language {preferred_language} .
source		SELECT `id`, `name`, `email`, `phone`, `preferred_language` FROM `Customers`

mappingId	Orders_base
target		ex:Orders/{id} a :Orders ; p:id {id} ; p:customer_id {customer_id} ; p:order_date {order_date} ; p:total_price {total_price} ; p:paid {paid} .
source		SELECT `id`, `customer_id`, `order_date`, `total_price`, `paid` FROM `Orders`

mappingId	Orders_customer_id_fk
target		ex:Orders/{id} p:hasCustomers ex:Customers/{customer_id} .
source		SELECT `id`, `customer_id` FROM `Orders` WHERE `customer_id` IS NOT NULL

]]
