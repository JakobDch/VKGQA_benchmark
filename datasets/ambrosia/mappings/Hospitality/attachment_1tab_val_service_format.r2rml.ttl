@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_service_format_0_Restaurant_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"Service_format\", \"Hours\" FROM \"Restaurant\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{id}" ; rr:class :Restaurants ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Service_format ; rr:objectMap [ rr:column "Service_format" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Hours ; rr:objectMap [ rr:column "Hours" ] ] .

<#tm_attachment_1tab_val_service_format_1_MenuItems_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"restaurant_id\", \"item_name\", \"price\" FROM \"MenuItems\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/MenuItems/{id}" ; rr:class :MenuItems ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:restaurant_id ; rr:objectMap [ rr:column "restaurant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:item_name ; rr:objectMap [ rr:column "item_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_attachment_1tab_val_service_format_2_MenuItems_restaurant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"restaurant_id\" FROM \"MenuItems\" WHERE \"restaurant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/MenuItems/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRestaurants ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{restaurant_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_service_format_3_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\", \"phone\", \"preferred_language\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone ; rr:objectMap [ rr:column "phone" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:preferred_language ; rr:objectMap [ rr:column "preferred_language" ] ] .

<#tm_attachment_1tab_val_service_format_4_Orders_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"customer_id\", \"order_date\", \"total_price\", \"paid\" FROM \"Orders\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{id}" ; rr:class :Orders ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:order_date ; rr:objectMap [ rr:column "order_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:total_price ; rr:objectMap [ rr:column "total_price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:paid ; rr:objectMap [ rr:column "paid" ] ] .

<#tm_attachment_1tab_val_service_format_5_Orders_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"customer_id\" FROM \"Orders\" WHERE \"customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customer_id}" ; rr:termType rr:IRI ] ] .

