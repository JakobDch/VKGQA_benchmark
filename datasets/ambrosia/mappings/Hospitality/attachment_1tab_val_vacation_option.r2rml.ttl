@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_vacation_option_0_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\", \"phoneNumber\", \"Vacation_Option\", \"Activities\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Vacation_Option ; rr:objectMap [ rr:column "Vacation_Option" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Activities ; rr:objectMap [ rr:column "Activities" ] ] .

<#tm_attachment_1tab_val_vacation_option_1_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\", \"capacity\", \"price\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{id}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_attachment_1tab_val_vacation_option_2_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"checkInDate\", \"checkOutDate\", \"totalPrice\", \"roomId\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{id}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkInDate ; rr:objectMap [ rr:column "checkInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkOutDate ; rr:objectMap [ rr:column "checkOutDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:totalPrice ; rr:objectMap [ rr:column "totalPrice" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roomId ; rr:objectMap [ rr:column "roomId" ] ] .

<#tm_attachment_1tab_val_vacation_option_3_Bookings_roomId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"roomId\" FROM \"Bookings\" WHERE \"roomId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{roomId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_vacation_option_4_Customer_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"customerId\", \"bookingId\" FROM \"Customer_Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customer_Bookings/{id}" ; rr:class :Customer_Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customerId ; rr:objectMap [ rr:column "customerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bookingId ; rr:objectMap [ rr:column "bookingId" ] ] .

<#tm_attachment_1tab_val_vacation_option_5_Customer_Bookings_bookingId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"bookingId\" FROM \"Customer_Bookings\" WHERE \"bookingId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customer_Bookings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBookings ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{bookingId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_vacation_option_6_Customer_Bookings_customerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"customerId\" FROM \"Customer_Bookings\" WHERE \"customerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customer_Bookings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customerId}" ; rr:termType rr:IRI ] ] .

