  rr:predicateObjectMap [ rr:predicate p:pod ; rr:objectMap [ rr:column "pod" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationId ; rr:objectMap [ rr:column "locationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:accommodationTypeId ; rr:objectMap [ rr:column "accommodationTypeId" ] ] .

<#tm_attachment_2tab_ref_accommodation_3_GlampingPod_accommodationTypeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"accommodationTypeId\" FROM \"GlampingPod\" WHERE \"accommodationTypeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GlampingPod/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccommodationType ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/AccommodationType/{accommodationTypeId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_accommodation_4_GlampingPod_locationId_fk> a rr:TriplesMap ;
