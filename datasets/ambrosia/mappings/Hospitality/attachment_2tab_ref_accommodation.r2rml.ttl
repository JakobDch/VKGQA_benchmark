  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GlampingPod/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Locations/{locationId}" ; rr:termType rr:IRI ] ] .

