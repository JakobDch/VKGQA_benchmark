@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_beverage_professional_0_Restaurants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"phoneNumber\" FROM \"Restaurants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{id}" ; rr:class :Restaurants ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] .

<#tm_attachment_2tab_ref_beverage_professional_1_Sommeliers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"restaurantId\", \"FullName\" FROM \"Sommeliers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Sommeliers/{id}" ; rr:class :Sommeliers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:restaurantId ; rr:objectMap [ rr:column "restaurantId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_2tab_ref_beverage_professional_2_Sommeliers_restaurantId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"restaurantId\" FROM \"Sommeliers\" WHERE \"restaurantId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Sommeliers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRestaurants ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{restaurantId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_beverage_professional_3_Bartenders_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"restaurantId\", \"FullName\" FROM \"Bartenders\"""" ] ;
