@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_hospitality_staff_0_Languages_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LanguageID\", \"LanguageName\" FROM \"Languages\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Languages/{LanguageID}" ; rr:class :Languages ] ;
  rr:predicateObjectMap [ rr:predicate p:LanguageID ; rr:objectMap [ rr:column "LanguageID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LanguageName ; rr:objectMap [ rr:column "LanguageName" ] ] .

<#tm_attachment_2tab_ref_hospitality_staff_1_Chefs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ChefID\", \"FirstName\", \"LastName\", \"LanguageID\" FROM \"Chefs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Chefs/{ChefID}" ; rr:class :Chefs ] ;
  rr:predicateObjectMap [ rr:predicate p:ChefID ; rr:objectMap [ rr:column "ChefID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LanguageID ; rr:objectMap [ rr:column "LanguageID" ] ] .

<#tm_attachment_2tab_ref_hospitality_staff_2_Chefs_LanguageID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ChefID\", \"LanguageID\" FROM \"Chefs\" WHERE \"LanguageID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Chefs/{ChefID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLanguages ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Languages/{LanguageID}" ; rr:termType rr:IRI ] ] .

