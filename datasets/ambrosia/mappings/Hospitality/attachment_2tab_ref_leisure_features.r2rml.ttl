  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"HotelID\", \"AmenityID\", \"Available\" FROM \"HotelAmenities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/HotelAmenities/{_amb_rowid}" ; rr:class :HotelAmenities ] ;
  rr:predicateObjectMap [ rr:predicate p:HotelID ; rr:objectMap [ rr:column "HotelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AmenityID ; rr:objectMap [ rr:column "AmenityID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Available ; rr:objectMap [ rr:column "Available" ] ] .

