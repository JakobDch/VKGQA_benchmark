@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_accommodation1_0_FamilySuites_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SuiteID\", \"Room\", \"OccupancyLimit\", \"Amenities\", \"Price_per_night\" FROM \"FamilySuites\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/FamilySuites/{SuiteID}" ; rr:class :FamilySuites ] ;
  rr:predicateObjectMap [ rr:predicate p:SuiteID ; rr:objectMap [ rr:column "SuiteID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Room ; rr:objectMap [ rr:column "Room" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OccupancyLimit ; rr:objectMap [ rr:column "OccupancyLimit" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Amenities ; rr:objectMap [ rr:column "Amenities" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price_per_night ; rr:objectMap [ rr:column "Price_per_night" ] ] .

<#tm_attachment_2tab_val_accommodation1_1_Guests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GuestID\", \"FullName\", \"PhoneNumber\", \"EmailAddress\" FROM \"Guests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{GuestID}" ; rr:class :Guests ] ;
  rr:predicateObjectMap [ rr:predicate p:GuestID ; rr:objectMap [ rr:column "GuestID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] .

<#tm_attachment_2tab_val_accommodation1_2_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"CheckInDate\", \"CheckOutDate\", \"TotalCost\", \"GuestID\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:BookingID ; rr:objectMap [ rr:column "BookingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckInDate ; rr:objectMap [ rr:column "CheckInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckOutDate ; rr:objectMap [ rr:column "CheckOutDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalCost ; rr:objectMap [ rr:column "TotalCost" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GuestID ; rr:objectMap [ rr:column "GuestID" ] ] .

<#tm_attachment_2tab_val_accommodation1_3_Bookings_GuestID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"GuestID\" FROM \"Bookings\" WHERE \"GuestID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuests ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{GuestID}" ; rr:termType rr:IRI ] ] .

