  rr:predicateObjectMap [ rr:predicate p:chaletId ; rr:objectMap [ rr:column "chaletId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rating ; rr:objectMap [ rr:column "rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:comment ; rr:objectMap [ rr:column "comment" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:reviewDate ; rr:objectMap [ rr:column "reviewDate" ] ] .

<#tm_attachment_2tab_val_accommodation2_7_Reviews_chaletId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"chaletId\" FROM \"Reviews\" WHERE \"chaletId\" IS NOT NULL""" ] ;
