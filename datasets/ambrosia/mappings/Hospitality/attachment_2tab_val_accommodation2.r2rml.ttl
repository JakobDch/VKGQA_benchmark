  rr:predicateObjectMap [ rr:predicate p:pricePerNight ; rr:objectMap [ rr:column "pricePerNight" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

<#tm_attachment_2tab_val_accommodation2_2_Guests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstname\", \"lastname\", \"email\", \"phoneNumber\", \"checkIn\", \"checkOut\" FROM \"Guests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{id}" ; rr:class :Guests ] ;
