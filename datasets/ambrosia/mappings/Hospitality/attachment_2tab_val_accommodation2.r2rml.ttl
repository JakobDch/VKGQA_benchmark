  rr:predicateObjectMap [ rr:predicate p:firstname ; rr:objectMap [ rr:column "firstname" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastname ; rr:objectMap [ rr:column "lastname" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkIn ; rr:objectMap [ rr:column "checkIn" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkOut ; rr:objectMap [ rr:column "checkOut" ] ] .

<#tm_attachment_2tab_val_accommodation2_3_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"guestId\", \"chaletId\", \"bookingDate\", \"totalCost\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{id}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:guestId ; rr:objectMap [ rr:column "guestId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:chaletId ; rr:objectMap [ rr:column "chaletId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bookingDate ; rr:objectMap [ rr:column "bookingDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:totalCost ; rr:objectMap [ rr:column "totalCost" ] ] .

<#tm_attachment_2tab_val_accommodation2_4_Bookings_chaletId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"chaletId\" FROM \"Bookings\" WHERE \"chaletId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasChalets ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Chalets/{chaletId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_accommodation2_5_Bookings_guestId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"guestId\" FROM \"Bookings\" WHERE \"guestId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuests ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{guestId}" ; rr:termType rr:IRI ] ] .

