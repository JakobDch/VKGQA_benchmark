[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Tourist_Attractions_base
target		ex:Tourist_Attractions/{AttractionID} a :Tourist_Attractions ; p:AttractionID {AttractionID} ; p:name {Name} ; p:location {Location} ; p:EntranceFee {EntranceFee} ; p:OpeningHours {OpeningHours} .
source		SELECT `AttractionID`, `Name`, `Location`, `EntranceFee`, `OpeningHours` FROM `Tourist_Attractions`

mappingId	Local_Markets_base
target		ex:Local_Markets/{MarketID} a :Local_Markets ; p:MarketID {MarketID} ; p:name {Name} ; p:location {Location} ; p:OperatingDays {OperatingDays} ; p:ProductsSold {ProductsSold} .
source		SELECT `MarketID`, `Name`, `Location`, `OperatingDays`, `ProductsSold` FROM `Local_Markets`

mappingId	Accommodations_base
target		ex:Accommodations/{AccomodationID} a :Accommodations ; p:AccomodationID {AccomodationID} ; p:name {Name} ; p:Address {Address} ; p:StarRating {StarRating} ; p:PricePerNight {PricePerNight} .
source		SELECT `AccomodationID`, `Name`, `Address`, `StarRating`, `PricePerNight` FROM `Accommodations`

mappingId	Restaurants_base
target		ex:Restaurants/{RestaurantID} a :Restaurants ; p:RestaurantID {RestaurantID} ; p:name {Name} ; p:TypeOfCuisine {TypeOfCuisine} ; p:location {Location} ; p:AveragePriceForMeal {AveragePriceForMeal} .
source		SELECT `RestaurantID`, `Name`, `TypeOfCuisine`, `Location`, `AveragePriceForMeal` FROM `Restaurants`

mappingId	Tours_base
target		ex:Tours/{TourID} a :Tours ; p:TourID {TourID} ; p:name {Name} ; p:Duration {Duration} ; p:StartingLocation {StartingLocation} ; p:Cost {Cost} .
source		SELECT `TourID`, `Name`, `Duration`, `StartingLocation`, `Cost` FROM `Tours`

mappingId	Events_base
target		ex:Events/{EventID} a :Events ; p:EventID {EventID} ; p:name {Name} ; p:Date {Date} ; p:Time {Time} ; p:Venue {Venue} ; p:Description {Description} .
source		SELECT `EventID`, `Name`, `Date`, `Time`, `Venue`, `Description` FROM `Events`

]]
