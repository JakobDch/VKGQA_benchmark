@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_activity_0_Tourist_Attractions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AttractionID\", \"Name\", \"Location\", \"EntranceFee\", \"OpeningHours\" FROM \"Tourist_Attractions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Tourist_Attractions/{AttractionID}" ; rr:class :Tourist_Attractions ] ;
  rr:predicateObjectMap [ rr:predicate p:AttractionID ; rr:objectMap [ rr:column "AttractionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EntranceFee ; rr:objectMap [ rr:column "EntranceFee" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OpeningHours ; rr:objectMap [ rr:column "OpeningHours" ] ] .

