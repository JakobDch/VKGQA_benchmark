[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Beaches_base
target		ex:Beaches/{id} a :Beaches ; p:id {id} ; p:name {Name} ; p:Address {Address} ; p:PhoneNumber {PhoneNumber} ; p:email {Email} .
source		SELECT `id`, `Name`, `Address`, `PhoneNumber`, `Email` FROM `Beaches`

mappingId	Beach_Clubs_base
target		ex:Beach_Clubs/{id} a :Beach_Clubs ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:OpeningHours {OpeningHours} ; p:PriceRange {PriceRange} ; p:Beach_id {Beach_id} .
source		SELECT `id`, `Name`, `Location`, `OpeningHours`, `PriceRange`, `Beach_id` FROM `Beach_Clubs`

mappingId	Beach_Clubs_Beach_id_fk
target		ex:Beach_Clubs/{id} p:hasBeaches ex:Beaches/{Beach_id} .
source		SELECT `id`, `Beach_id` FROM `Beach_Clubs` WHERE `Beach_id` IS NOT NULL

mappingId	Restaurants_base
target		ex:Restaurants/{id} a :Restaurants ; p:id {id} ; p:name {Name} ; p:Cuisine {Cuisine} ; p:Rating {Rating} ; p:Beach_id {Beach_id} .
source		SELECT `id`, `Name`, `Cuisine`, `Rating`, `Beach_id` FROM `Restaurants`

mappingId	Restaurants_Beach_id_fk
target		ex:Restaurants/{id} p:hasBeaches ex:Beaches/{Beach_id} .
source		SELECT `id`, `Beach_id` FROM `Restaurants` WHERE `Beach_id` IS NOT NULL

mappingId	Hotels_base
target		ex:Hotels/{id} a :Hotels ; p:id {id} ; p:name {Name} ; p:Star_rating {Star_rating} ; p:PriceRange {PriceRange} ; p:Beach_id {Beach_id} .
source		SELECT `id`, `Name`, `Star_rating`, `PriceRange`, `Beach_id` FROM `Hotels`

mappingId	Hotels_Beach_id_fk
target		ex:Hotels/{id} p:hasBeaches ex:Beaches/{Beach_id} .
source		SELECT `id`, `Beach_id` FROM `Hotels` WHERE `Beach_id` IS NOT NULL

mappingId	Accommodations_base
target		ex:Accommodations/{id} a :Accommodations ; p:id {id} ; p:Type {Type} ; p:Capacity {Capacity} ; p:Amenities {Amenities} ; p:Beach_id {Beach_id} .
source		SELECT `id`, `Type`, `Capacity`, `Amenities`, `Beach_id` FROM `Accommodations`

mappingId	Accommodations_Beach_id_fk
target		ex:Accommodations/{id} p:hasBeaches ex:Beaches/{Beach_id} .
source		SELECT `id`, `Beach_id` FROM `Accommodations` WHERE `Beach_id` IS NOT NULL

mappingId	Watersports_Rentals_base
target		ex:Watersports_Rentals/{id} a :Watersports_Rentals ; p:id {id} ; p:name {name} ; p:Item {Item} ; p:RentalRate {RentalRate} ; p:AvailableDays {AvailableDays} ; p:Beach_id {Beach_id} .
source		SELECT `id`, `name`, `Item`, `RentalRate`, `AvailableDays`, `Beach_id` FROM `Watersports_Rentals`

mappingId	Watersports_Rentals_Beach_id_fk
target		ex:Watersports_Rentals/{id} p:hasBeaches ex:Beaches/{Beach_id} .
source		SELECT `id`, `Beach_id` FROM `Watersports_Rentals` WHERE `Beach_id` IS NOT NULL

]]
