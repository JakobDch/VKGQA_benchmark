@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_amenity_0_Beaches_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Address\", \"PhoneNumber\", \"Email\" FROM \"Beaches\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Beaches/{id}" ; rr:class :Beaches ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

<#tm_attachment_2tab_val_amenity_1_Beach_Clubs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Location\", \"OpeningHours\", \"PriceRange\", \"Beach_id\" FROM \"Beach_Clubs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Beach_Clubs/{id}" ; rr:class :Beach_Clubs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OpeningHours ; rr:objectMap [ rr:column "OpeningHours" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PriceRange ; rr:objectMap [ rr:column "PriceRange" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Beach_id ; rr:objectMap [ rr:column "Beach_id" ] ] .

<#tm_attachment_2tab_val_amenity_2_Beach_Clubs_Beach_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Beach_id\" FROM \"Beach_Clubs\" WHERE \"Beach_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Beach_Clubs/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBeaches ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Beaches/{Beach_id}" ; rr:termType rr:IRI ] ] .

