[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Salads_base
target		ex:Salads/{id} a :Salads ; p:id {id} ; p:name {Name} ; p:Price {Price} ; p:Quantity {Quantity} ; p:BuffetName {BuffetName} .
source		SELECT `id`, `Name`, `Price`, `Quantity`, `BuffetName` FROM `Salads`

mappingId	Soups_base
target		ex:Soups/{id} a :Soups ; p:id {id} ; p:name {Name} ; p:Price {Price} ; p:Quantity {Quantity} ; p:BuffetName {BuffetName} .
source		SELECT `id`, `Name`, `Price`, `Quantity`, `BuffetName` FROM `Soups`

mappingId	Desserts_base
target		ex:Desserts/{id} a :Desserts ; p:id {id} ; p:name {Name} ; p:Price {Price} ; p:Quantity {Quantity} ; p:BuffetName {BuffetName} .
source		SELECT `id`, `Name`, `Price`, `Quantity`, `BuffetName` FROM `Desserts`

mappingId	Beverages_base
target		ex:Beverages/{id} a :Beverages ; p:id {id} ; p:name {Name} ; p:Price {Price} ; p:Quantity {Quantity} ; p:BuffetName {BuffetName} .
source		SELECT `id`, `Name`, `Price`, `Quantity`, `BuffetName` FROM `Beverages`

mappingId	Staffs_base
target		ex:Staff/{id} a :Staff ; p:id {id} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:Position {Position} ; p:HireDate {HireDate} .
source		SELECT `id`, `FirstName`, `LastName`, `Position`, `HireDate` FROM `Staffs`

mappingId	Customers_base
target		ex:Customers/{id} a :Customers ; p:id {id} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:ContactNumber {ContactNumber} ; p:email {Email} .
source		SELECT `id`, `FirstName`, `LastName`, `ContactNumber`, `Email` FROM `Customers`

]]
