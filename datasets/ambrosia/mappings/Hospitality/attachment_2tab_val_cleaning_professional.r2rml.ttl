@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_cleaning_professional_0_Housekeeping_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"housekeeper\", \"hotel\", \"shift_start\", \"shift_end\" FROM \"Housekeeping\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Housekeeping/{id}" ; rr:class :Housekeeping ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:housekeeper ; rr:objectMap [ rr:column "housekeeper" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hotel ; rr:objectMap [ rr:column "hotel" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:shift_start ; rr:objectMap [ rr:column "shift_start" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:shift_end ; rr:objectMap [ rr:column "shift_end" ] ] .

<#tm_attachment_2tab_val_cleaning_professional_1_LaundryService_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"laundry_attendant\", \"hotel\", \"shift_start\", \"shift_end\" FROM \"LaundryService\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/LaundryService/{id}" ; rr:class :LaundryService ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:laundry_attendant ; rr:objectMap [ rr:column "laundry_attendant" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hotel ; rr:objectMap [ rr:column "hotel" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:shift_start ; rr:objectMap [ rr:column "shift_start" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:shift_end ; rr:objectMap [ rr:column "shift_end" ] ] .

<#tm_attachment_2tab_val_cleaning_professional_2_GuestRooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"room_id\", \"hotel_name\", \"room_number\", \"capacity\", \"amenities\" FROM \"GuestRooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GuestRooms/{room_id}" ; rr:class :GuestRooms ] ;
  rr:predicateObjectMap [ rr:predicate p:room_id ; rr:objectMap [ rr:column "room_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hotel_name ; rr:objectMap [ rr:column "hotel_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:room_number ; rr:objectMap [ rr:column "room_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amenities ; rr:objectMap [ rr:column "amenities" ] ] .

<#tm_attachment_2tab_val_cleaning_professional_3_Reservations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reservation_id\", \"guest_name\", \"email\", \"phone_number\", \"checkin_date\", \"checkout_date\", \"room_id\" FROM \"Reservations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{reservation_id}" ; rr:class :Reservations ] ;
  rr:predicateObjectMap [ rr:predicate p:reservation_id ; rr:objectMap [ rr:column "reservation_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:guest_name ; rr:objectMap [ rr:column "guest_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkin_date ; rr:objectMap [ rr:column "checkin_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkout_date ; rr:objectMap [ rr:column "checkout_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:room_id ; rr:objectMap [ rr:column "room_id" ] ] .

<#tm_attachment_2tab_val_cleaning_professional_4_Reservations_room_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reservation_id\", \"room_id\" FROM \"Reservations\" WHERE \"room_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{reservation_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuestRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GuestRooms/{room_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_cleaning_professional_5_MaintenanceRequests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"request_id\", \"description\", \"requested_at\", \"resolved_at\", \"status\" FROM \"MaintenanceRequests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/MaintenanceRequests/{request_id}" ; rr:class :MaintenanceRequests ] ;
  rr:predicateObjectMap [ rr:predicate p:request_id ; rr:objectMap [ rr:column "request_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:requested_at ; rr:objectMap [ rr:column "requested_at" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:resolved_at ; rr:objectMap [ rr:column "resolved_at" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] .

