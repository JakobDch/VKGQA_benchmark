[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Apartments_base
target		ex:Apartments/{id} a :Apartments ; p:id {id} ; p:name {name} ; p:type {type} ; p:city {city} .
source		SELECT `id`, `name`, `type`, `city` FROM `Apartments`

mappingId	Rooms_base
target		ex:Rooms/{id} a :Rooms ; p:id {id} ; p:apartment_id {apartment_id} ; p:number {number} ; p:floor_number {floor_number} .
source		SELECT `id`, `apartment_id`, `number`, `floor_number` FROM `Rooms`

mappingId	Rooms_apartment_id_fk
target		ex:Rooms/{id} p:hasApartments ex:Apartments/{apartment_id} .
source		SELECT `id`, `apartment_id` FROM `Rooms` WHERE `apartment_id` IS NOT NULL

mappingId	Guests_base
target		ex:Guests/{id} a :Guests ; p:id {id} ; p:first_name {first_name} ; p:last_name {last_name} ; p:email {email} ; p:phone_number {phone_number} .
source		SELECT `id`, `first_name`, `last_name`, `email`, `phone_number` FROM `Guests`

mappingId	Orders_base
target		ex:Orders/{order_id} a :Orders ; p:order_id {order_id} ; p:guest_id {guest_id} ; p:room_id {room_id} ; p:order_date {order_date} ; p:total_amount {total_amount} ; p:status {status} .
source		SELECT `order_id`, `guest_id`, `room_id`, `order_date`, `total_amount`, `status` FROM `Orders`

mappingId	Orders_room_id_fk
target		ex:Orders/{order_id} p:hasRooms ex:Rooms/{room_id} .
source		SELECT `order_id`, `room_id` FROM `Orders` WHERE `room_id` IS NOT NULL

mappingId	Orders_guest_id_fk
target		ex:Orders/{order_id} p:hasGuests ex:Guests/{guest_id} .
source		SELECT `order_id`, `guest_id` FROM `Orders` WHERE `guest_id` IS NOT NULL

mappingId	Espresso_Machine_base
target		ex:Espresso_Machine/{id} a :Espresso_Machine ; p:id {id} ; p:apartment_id {apartment_id} ; p:model {model} ; p:price {price} .
source		SELECT `id`, `apartment_id`, `model`, `price` FROM `Espresso_Machine`

mappingId	Espresso_Machine_apartment_id_fk
target		ex:Espresso_Machine/{id} p:hasApartments ex:Apartments/{apartment_id} .
source		SELECT `id`, `apartment_id` FROM `Espresso_Machine` WHERE `apartment_id` IS NOT NULL

mappingId	Blender_base
target		ex:Blender/{id} a :Blender ; p:id {id} ; p:apartment_id {apartment_id} ; p:model {model} ; p:price {price} .
source		SELECT `id`, `apartment_id`, `model`, `price` FROM `Blender`

mappingId	Blender_apartment_id_fk
target		ex:Blender/{id} p:hasApartments ex:Apartments/{apartment_id} .
source		SELECT `id`, `apartment_id` FROM `Blender` WHERE `apartment_id` IS NOT NULL

]]
