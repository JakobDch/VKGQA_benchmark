@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_commercial_appliances_0_Apartments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"type\", \"city\" FROM \"Apartments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Apartments/{id}" ; rr:class :Apartments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] .

<#tm_attachment_2tab_val_commercial_appliances_1_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"apartment_id\", \"number\", \"floor_number\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{id}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:apartment_id ; rr:objectMap [ rr:column "apartment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number ; rr:objectMap [ rr:column "number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:floor_number ; rr:objectMap [ rr:column "floor_number" ] ] .

<#tm_attachment_2tab_val_commercial_appliances_2_Rooms_apartment_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"apartment_id\" FROM \"Rooms\" WHERE \"apartment_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Apartments/{apartment_id}" ; rr:termType rr:IRI ] ] .

