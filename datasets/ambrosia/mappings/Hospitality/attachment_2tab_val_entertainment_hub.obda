[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	cocktail_lounges_base
target		ex:cocktail_lounges/{id} a :cocktail_lounges ; p:id {id} ; p:name {name} ; p:address {address} ; p:phone_number {phone_number} ; p:hours {hours} .
source		SELECT `id`, `name`, `address`, `phone_number`, `hours` FROM `cocktail_lounges`

mappingId	sports_bars_base
target		ex:sports_bars/{id} a :sports_bars ; p:id {id} ; p:name {name} ; p:address {address} ; p:phone_number {phone_number} ; p:hours {hours} .
source		SELECT `id`, `name`, `address`, `phone_number`, `hours` FROM `sports_bars`

mappingId	restaurants_base
target		ex:Restaurants/{id} a :Restaurants ; p:id {id} ; p:name {name} ; p:address {address} ; p:phone_number {phone_number} ; p:cuisine {cuisine} .
source		SELECT `id`, `name`, `address`, `phone_number`, `cuisine` FROM `restaurants`

mappingId	rooms_base
target		ex:Rooms/{id} a :Rooms ; p:id {id} ; p:hotel_name {hotel_name} ; p:room_type {room_type} ; p:price {price} ; p:capacity {capacity} .
source		SELECT `id`, `hotel_name`, `room_type`, `price`, `capacity` FROM `rooms`

mappingId	employees_base
target		ex:Employees/{id} a :Employees ; p:id {id} ; p:first_name {first_name} ; p:last_name {last_name} ; p:position {position} ; p:salary {salary} .
source		SELECT `id`, `first_name`, `last_name`, `position`, `salary` FROM `employees`

]]
