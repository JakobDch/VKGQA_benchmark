[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Ballrooms_base
target		ex:Ballrooms/{id} a :Ballrooms ; p:id {id} ; p:name {name} ; p:seating_capacity {seating_capacity} ; p:price {price} ; p:availability {availability} .
source		SELECT `id`, `name`, `seating_capacity`, `price`, `availability` FROM `Ballrooms`

mappingId	GreenRooms_base
target		ex:GreenRooms/{id} a :GreenRooms ; p:id {id} ; p:name {name} ; p:seating_capacity {seating_capacity} ; p:price {price} ; p:availability {availability} .
source		SELECT `id`, `name`, `seating_capacity`, `price`, `availability` FROM `GreenRooms`

mappingId	Events_base
target		ex:Events/{event_id} a :Events ; p:event_id {event_id} ; p:ballroom_id {ballroom_id} ; p:greenroom_id {greenroom_id} ; p:event_name {event_name} ; p:date {date} .
source		SELECT `event_id`, `ballroom_id`, `greenroom_id`, `event_name`, `date` FROM `Events`

mappingId	Events_greenroom_id_fk
target		ex:Events/{event_id} p:hasGreenRooms ex:GreenRooms/{greenroom_id} .
source		SELECT `event_id`, `greenroom_id` FROM `Events` WHERE `greenroom_id` IS NOT NULL

mappingId	Events_ballroom_id_fk
target		ex:Events/{event_id} p:hasBallrooms ex:Ballrooms/{ballroom_id} .
source		SELECT `event_id`, `ballroom_id` FROM `Events` WHERE `ballroom_id` IS NOT NULL

mappingId	Guests_base
target		ex:Guests/{guest_id} a :Guests ; p:guest_id {guest_id} ; p:first_name {first_name} ; p:last_name {last_name} ; p:email {email} ; p:phone_number {phone_number} ; p:event_id {event_id} .
source		SELECT `guest_id`, `first_name`, `last_name`, `email`, `phone_number`, `event_id` FROM `Guests`

mappingId	Guests_event_id_fk
target		ex:Guests/{guest_id} p:hasEvents ex:Events/{event_id} .
source		SELECT `guest_id`, `event_id` FROM `Guests` WHERE `event_id` IS NOT NULL

mappingId	Bookings_base
target		ex:Bookings/{booking_id} a :Bookings ; p:booking_id {booking_id} ; p:guest_id {guest_id} ; p:event_date {event_date} ; p:special_requests {special_requests} .
source		SELECT `booking_id`, `guest_id`, `event_date`, `special_requests` FROM `Bookings`

mappingId	Bookings_guest_id_fk
target		ex:Bookings/{booking_id} p:hasGuests ex:Guests/{guest_id} .
source		SELECT `booking_id`, `guest_id` FROM `Bookings` WHERE `guest_id` IS NOT NULL

]]
