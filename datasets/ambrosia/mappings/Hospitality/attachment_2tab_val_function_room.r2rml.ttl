@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_function_room_0_Ballrooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"seating_capacity\", \"price\", \"availability\" FROM \"Ballrooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Ballrooms/{id}" ; rr:class :Ballrooms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:seating_capacity ; rr:objectMap [ rr:column "seating_capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:availability ; rr:objectMap [ rr:column "availability" ] ] .

<#tm_attachment_2tab_val_function_room_1_GreenRooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"seating_capacity\", \"price\", \"availability\" FROM \"GreenRooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GreenRooms/{id}" ; rr:class :GreenRooms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:seating_capacity ; rr:objectMap [ rr:column "seating_capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:availability ; rr:objectMap [ rr:column "availability" ] ] .

<#tm_attachment_2tab_val_function_room_2_Events_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"event_id\", \"ballroom_id\", \"greenroom_id\", \"event_name\", \"date\" FROM \"Events\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Events/{event_id}" ; rr:class :Events ] ;
  rr:predicateObjectMap [ rr:predicate p:event_id ; rr:objectMap [ rr:column "event_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ballroom_id ; rr:objectMap [ rr:column "ballroom_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:greenroom_id ; rr:objectMap [ rr:column "greenroom_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:event_name ; rr:objectMap [ rr:column "event_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] .

<#tm_attachment_2tab_val_function_room_3_Events_greenroom_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"event_id\", \"greenroom_id\" FROM \"Events\" WHERE \"greenroom_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Events/{event_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGreenRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GreenRooms/{greenroom_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_function_room_4_Events_ballroom_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"event_id\", \"ballroom_id\" FROM \"Events\" WHERE \"ballroom_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Events/{event_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBallrooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Ballrooms/{ballroom_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_function_room_5_Guests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"guest_id\", \"first_name\", \"last_name\", \"email\", \"phone_number\", \"event_id\" FROM \"Guests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{guest_id}" ; rr:class :Guests ] ;
  rr:predicateObjectMap [ rr:predicate p:guest_id ; rr:objectMap [ rr:column "guest_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:event_id ; rr:objectMap [ rr:column "event_id" ] ] .

<#tm_attachment_2tab_val_function_room_6_Guests_event_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"guest_id\", \"event_id\" FROM \"Guests\" WHERE \"event_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{guest_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEvents ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Events/{event_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_function_room_7_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"booking_id\", \"guest_id\", \"event_date\", \"special_requests\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{booking_id}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:booking_id ; rr:objectMap [ rr:column "booking_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:guest_id ; rr:objectMap [ rr:column "guest_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:event_date ; rr:objectMap [ rr:column "event_date" ] ] ;
