  rr:logicalTable [ rr:sqlQuery """SELECT \"booking_id\", \"guest_id\" FROM \"Bookings\" WHERE \"guest_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{booking_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuests ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{guest_id}" ; rr:termType rr:IRI ] ] .

