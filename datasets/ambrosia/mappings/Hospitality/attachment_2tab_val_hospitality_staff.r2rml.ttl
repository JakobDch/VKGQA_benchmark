  rr:logicalTable [ rr:sqlQuery """SELECT \"order_id\", \"restaurant_id\" FROM \"Orders\" WHERE \"restaurant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{order_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRestaurants ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{restaurant_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_hospitality_staff_9_Orders_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"order_id\", \"customer_id\" FROM \"Orders\" WHERE \"customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{order_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customer_id}" ; rr:termType rr:IRI ] ] .

