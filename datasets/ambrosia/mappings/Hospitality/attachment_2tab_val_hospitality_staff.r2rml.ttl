@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_hospitality_staff_0_Chefs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"chef_id\", \"name\", \"language\", \"experience_years\" FROM \"Chefs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Chefs/{chef_id}" ; rr:class :Chefs ] ;
  rr:predicateObjectMap [ rr:predicate p:chef_id ; rr:objectMap [ rr:column "chef_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:language ; rr:objectMap [ rr:column "language" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience_years ; rr:objectMap [ rr:column "experience_years" ] ] .

<#tm_attachment_2tab_val_hospitality_staff_1_Servers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"server_id\", \"name\", \"language\", \"years_of_service\" FROM \"Servers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Servers/{server_id}" ; rr:class :Servers ] ;
  rr:predicateObjectMap [ rr:predicate p:server_id ; rr:objectMap [ rr:column "server_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:language ; rr:objectMap [ rr:column "language" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_of_service ; rr:objectMap [ rr:column "years_of_service" ] ] .

<#tm_attachment_2tab_val_hospitality_staff_2_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"name\", \"phone_number\", \"preferred_server_id\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customer_id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:preferred_server_id ; rr:objectMap [ rr:column "preferred_server_id" ] ] .

<#tm_attachment_2tab_val_hospitality_staff_3_Customers_preferred_server_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"preferred_server_id\" FROM \"Customers\" WHERE \"preferred_server_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customer_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasServers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Servers/{preferred_server_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_hospitality_staff_4_Restaurants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"restaurant_id\", \"name\", \"address\", \"cuisine\" FROM \"Restaurants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{restaurant_id}" ; rr:class :Restaurants ] ;
  rr:predicateObjectMap [ rr:predicate p:restaurant_id ; rr:objectMap [ rr:column "restaurant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cuisine ; rr:objectMap [ rr:column "cuisine" ] ] .

<#tm_attachment_2tab_val_hospitality_staff_5_Menus_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"menu_id\", \"restaurant_id\", \"dish\", \"price\" FROM \"Menus\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Menus/{menu_id}" ; rr:class :Menus ] ;
  rr:predicateObjectMap [ rr:predicate p:menu_id ; rr:objectMap [ rr:column "menu_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:restaurant_id ; rr:objectMap [ rr:column "restaurant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dish ; rr:objectMap [ rr:column "dish" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_attachment_2tab_val_hospitality_staff_6_Menus_restaurant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"menu_id\", \"restaurant_id\" FROM \"Menus\" WHERE \"restaurant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Menus/{menu_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRestaurants ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{restaurant_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_hospitality_staff_7_Orders_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"order_id\", \"customer_id\", \"restaurant_id\", \"total_price\" FROM \"Orders\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Orders/{order_id}" ; rr:class :Orders ] ;
  rr:predicateObjectMap [ rr:predicate p:order_id ; rr:objectMap [ rr:column "order_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:restaurant_id ; rr:objectMap [ rr:column "restaurant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:total_price ; rr:objectMap [ rr:column "total_price" ] ] .

