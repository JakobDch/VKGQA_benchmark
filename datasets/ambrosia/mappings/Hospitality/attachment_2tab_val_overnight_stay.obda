[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Guestrooms_base
target		ex:GuestRooms/{id} a :GuestRooms ; p:id {id} ; p:room {room} ; p:floor_no {floor_no} ; p:capacity {capacity} ; p:amenities {amenities} .
source		SELECT `id`, `room`, `floor_no`, `capacity`, `amenities` FROM `Guestrooms`

mappingId	Suites_base
target		ex:Suites/{id} a :Suites ; p:id {id} ; p:suite_name {suite_name} ; p:area_sqft {area_sqft} ; p:occupancy {occupancy} ; p:amenities {amenities} .
source		SELECT `id`, `suite_name`, `area_sqft`, `occupancy`, `amenities` FROM `Suites`

mappingId	Reservations_base
target		ex:Reservations/{reservation_id} a :Reservations ; p:reservation_id {reservation_id} ; p:guest_name {guest_name} ; p:checkin {checkin} ; p:checkout {checkout} ; p:room_type {room_type} ; p:total_cost {total_cost} .
source		SELECT `reservation_id`, `guest_name`, `checkin`, `checkout`, `room_type`, `total_cost` FROM `Reservations`

mappingId	Employees_base
target		ex:Employees/{employee_id} a :Employees ; p:employee_id {employee_id} ; p:name {name} ; p:role {role} ; p:department {department} ; p:hire_date {hire_date} .
source		SELECT `employee_id`, `name`, `role`, `department`, `hire_date` FROM `Employees`

mappingId	GuestReviews_base
target		ex:GuestReviews/{review_id} a :GuestReviews ; p:review_id {review_id} ; p:guest_name {guest_name} ; p:rating {rating} ; p:comments {comments} .
source		SELECT `review_id`, `guest_name`, `rating`, `comments` FROM `GuestReviews`

mappingId	FoodMenu_base
target		ex:MenuItems/{menu_item_id} a :MenuItems ; p:menu_item_id {menu_item_id} ; p:item_name {item_name} ; p:description {description} ; p:price {price} .
source		SELECT `menu_item_id`, `item_name`, `description`, `price` FROM `FoodMenu`

]]
