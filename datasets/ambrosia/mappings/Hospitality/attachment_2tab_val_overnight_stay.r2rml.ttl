@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_overnight_stay_0_Guestrooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"room\", \"floor_no\", \"capacity\", \"amenities\" FROM \"Guestrooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GuestRooms/{id}" ; rr:class :GuestRooms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:room ; rr:objectMap [ rr:column "room" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:floor_no ; rr:objectMap [ rr:column "floor_no" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amenities ; rr:objectMap [ rr:column "amenities" ] ] .

