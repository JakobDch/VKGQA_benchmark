[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Day_Spa_base
target		ex:Day_Spa/{id} a :Day_Spa ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Services {Services} ; p:Price {Price} .
source		SELECT `id`, `Name`, `Location`, `Services`, `Price` FROM `Day_Spa`

mappingId	Wellness_Retreat_base
target		ex:Wellness_Retreat/{id} a :Wellness_Retreat ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Activities {Activities} ; p:Price {Price} .
source		SELECT `id`, `Name`, `Location`, `Activities`, `Price` FROM `Wellness_Retreat`

mappingId	Hotel_base
target		ex:Hotels/{id} a :Hotels ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Rooms {Rooms} ; p:Amenities {Amenities} .
source		SELECT `id`, `Name`, `Location`, `Rooms`, `Amenities` FROM `Hotel`

mappingId	Restaurant_base
target		ex:Restaurants/{id} a :Restaurants ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Cuisine {Cuisine} ; p:Menu {Menu} .
source		SELECT `id`, `Name`, `Location`, `Cuisine`, `Menu` FROM `Restaurant`

mappingId	Spa_Therapist_base
target		ex:Spa_Therapist/{id} a :Spa_Therapist ; p:id {id} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:Specialty {Specialty} ; p:Experience {Experience} .
source		SELECT `id`, `FirstName`, `LastName`, `Specialty`, `Experience` FROM `Spa_Therapist`

mappingId	Guest_base
target		ex:Guests/{id} a :Guests ; p:id {id} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:email {Email} ; p:PhoneNumber {PhoneNumber} .
source		SELECT `id`, `FirstName`, `LastName`, `Email`, `PhoneNumber` FROM `Guest`

]]
