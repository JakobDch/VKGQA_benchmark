[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	SteakHouses_base
target		ex:SteakHouses/{id} a :SteakHouses ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Year_of_establishment {Year_of_establishment} ; p:Number_of_employees {Number_of_employees} ; p:Average_meal_price {Average_meal_price} .
source		SELECT `id`, `Name`, `Location`, `Year_of_establishment`, `Number_of_employees`, `Average_meal_price` FROM `SteakHouses`

mappingId	SeaFoodRestaurants_base
target		ex:SeaFoodRestaurants/{id} a :SeaFoodRestaurants ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Year_of_establishment {Year_of_establishment} ; p:Number_of_employees {Number_of_employees} ; p:Specialty_dish {Specialty_dish} .
source		SELECT `id`, `Name`, `Location`, `Year_of_establishment`, `Number_of_employees`, `Specialty_dish` FROM `SeaFoodRestaurants`

mappingId	Hotels_base
target		ex:Hotels/{id} a :Hotels ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Year_of_establishment {Year_of_establishment} ; p:Number_of_rooms {Number_of_rooms} ; p:Star_rating {Star_rating} .
source		SELECT `id`, `Name`, `Location`, `Year_of_establishment`, `Number_of_rooms`, `Star_rating` FROM `Hotels`

mappingId	Bars_base
target		ex:Bars/{id} a :Bars ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Year_of_establishment {Year_of_establishment} ; p:Type_of_bar {Type_of_bar} ; p:Capacity {Capacity} .
source		SELECT `id`, `Name`, `Location`, `Year_of_establishment`, `Type_of_bar`, `Capacity` FROM `Bars`

mappingId	EventVenues_base
target		ex:EventVenues/{id} a :EventVenues ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Year_of_establishment {Year_of_establishment} ; p:Maximum_capacity {Maximum_capacity} ; p:Types_of_events {Types_of_events} .
source		SELECT `id`, `Name`, `Location`, `Year_of_establishment`, `Maximum_capacity`, `Types_of_events` FROM `EventVenues`

]]
