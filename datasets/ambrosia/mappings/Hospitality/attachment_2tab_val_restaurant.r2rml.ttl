@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_restaurant_0_SteakHouses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Location\", \"Year_of_establishment\", \"Number_of_employees\", \"Average_meal_price\" FROM \"SteakHouses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/SteakHouses/{id}" ; rr:class :SteakHouses ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year_of_establishment ; rr:objectMap [ rr:column "Year_of_establishment" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Number_of_employees ; rr:objectMap [ rr:column "Number_of_employees" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Average_meal_price ; rr:objectMap [ rr:column "Average_meal_price" ] ] .

