[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Patios_base
target		ex:Patios/{Id} a :Patios ; p:Id {Id} ; p:name {Name} ; p:Address {Address} ; p:Phone {Phone} ; p:Number_of_Seats {Number_of_Seats} .
source		SELECT `Id`, `Name`, `Address`, `Phone`, `Number_of_Seats` FROM `Patios`

mappingId	Verandas_base
target		ex:Verandas/{Id} a :Verandas ; p:Id {Id} ; p:name {Name} ; p:Address {Address} ; p:Phone {Phone} ; p:Number_of_Seats {Number_of_Seats} .
source		SELECT `Id`, `Name`, `Address`, `Phone`, `Number_of_Seats` FROM `Verandas`

mappingId	Rooms_base
target		ex:Rooms/{Id} a :Rooms ; p:Id {Id} ; p:RoomNo {RoomNo} ; p:Capacity {Capacity} ; p:Amenities {Amenities} ; p:FloorType {FloorType} .
source		SELECT `Id`, `RoomNo`, `Capacity`, `Amenities`, `FloorType` FROM `Rooms`

mappingId	Staffs_base
target		ex:Staff/{Id} a :Staff ; p:Id {Id} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:Position {Position} ; p:Salary {Salary} .
source		SELECT `Id`, `FirstName`, `LastName`, `Position`, `Salary` FROM `Staffs`

mappingId	Customers_base
target		ex:Customers/{Id} a :Customers ; p:Id {Id} ; p:CustomerID {CustomerID} ; p:name {Fullname} ; p:Contact {Contact} ; p:ReservationDate {ReservationDate} .
source		SELECT `Id`, `CustomerID`, `Fullname`, `Contact`, `ReservationDate` FROM `Customers`

mappingId	Bookings_base
target		ex:Bookings/{Id} a :Bookings ; p:Id {Id} ; p:BookingId {BookingId} ; p:RoomNo {RoomNo} ; p:CheckInTime {CheckInTime} ; p:CheckOutTime {CheckOutTime} ; p:TotalStayDays {TotalStayDays} ; p:Price {Price} .
source		SELECT `Id`, `BookingId`, `RoomNo`, `CheckInTime`, `CheckOutTime`, `TotalStayDays`, `Price` FROM `Bookings`

]]
