[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Buffet_base
target		ex:Buffet/{id} a :Buffet ; p:id {id} ; p:name {Name} ; p:Address {Address} ; p:Capacity {Capacity} ; p:Hours {Hours} .
source		SELECT `id`, `Name`, `Address`, `Capacity`, `Hours` FROM `Buffet`

mappingId	Coffee_Shop_base
target		ex:Coffee_Shop/{id} a :Coffee_Shop ; p:id {id} ; p:name {Name} ; p:Address {Address} ; p:SeatingCapacity {SeatingCapacity} ; p:Hours {Hours} .
source		SELECT `id`, `Name`, `Address`, `SeatingCapacity`, `Hours` FROM `Coffee_Shop`

mappingId	Restaurant_base
target		ex:Restaurants/{id} a :Restaurants ; p:id {id} ; p:name {Name} ; p:Address {Address} ; p:Cuisine {Cuisine} ; p:OperatingTime {OperatingTime} .
source		SELECT `id`, `Name`, `Address`, `Cuisine`, `OperatingTime` FROM `Restaurant`

mappingId	Bar_base
target		ex:Bars/{id} a :Bars ; p:id {id} ; p:name {Name} ; p:Address {Address} ; p:DrinkSelection {DrinkSelection} ; p:OpeningTime {OpeningTime} .
source		SELECT `id`, `Name`, `Address`, `DrinkSelection`, `OpeningTime` FROM `Bar`

mappingId	Event_base
target		ex:Events/{id} a :Events ; p:id {id} ; p:name {Name} ; p:Venue {Venue} ; p:Date {Date} ; p:Time {Time} .
source		SELECT `id`, `Name`, `Venue`, `Date`, `Time` FROM `Event`

]]
