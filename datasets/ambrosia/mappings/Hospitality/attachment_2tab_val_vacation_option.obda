[PrefixDeclaration]
:	http://ambrosia.example.org/hospitality#
p:	http://ambrosia.example.org/hospitality/prop#
ex:	http://ambrosia.example.org/hospitality/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Cruise_Ship_base
target		ex:Cruise_Ships/{id} a :Cruise_Ships ; p:id {id} ; p:name {name} ; p:capacity {capacity} ; p:destination {destination} ; p:cruise_start_date {cruise_start_date} ; p:cruise_end_date {cruise_end_date} ; p:activities {activities} .
source		SELECT `id`, `name`, `capacity`, `destination`, `cruise_start_date`, `cruise_end_date`, `activities` FROM `Cruise_Ship`

mappingId	All_Inclusive_Resort_base
target		ex:All_Inclusive_Resort/{id} a :All_Inclusive_Resort ; p:id {id} ; p:name {name} ; p:location {location} ; p:star_rating {star_rating} ; p:number_of_rooms {number_of_rooms} ; p:activities {activities} .
source		SELECT `id`, `name`, `location`, `star_rating`, `number_of_rooms`, `activities` FROM `All_Inclusive_Resort`

mappingId	Customer_base
target		ex:Customers/{id} a :Customers ; p:id {id} ; p:firstName {firstName} ; p:lastName {lastName} ; p:email {email} ; p:phoneNumber {phoneNumber} ; p:preferredLanguage {preferredLanguage} .
source		SELECT `id`, `firstName`, `lastName`, `email`, `phoneNumber`, `preferredLanguage` FROM `Customer`

mappingId	Employee_base
target		ex:Employees/{id} a :Employees ; p:id {id} ; p:firstName {firstName} ; p:lastName {lastName} ; p:position {position} ; p:yearsOfExperience {yearsOfExperience} ; p:skill {skill} .
source		SELECT `id`, `firstName`, `lastName`, `position`, `yearsOfExperience`, `skill` FROM `Employee`

mappingId	Booking_base
target		ex:Bookings/{bookingId} a :Bookings ; p:bookingId {bookingId} ; p:customerId {customerId} ; p:cruiseOrResort {cruiseOrResort} ; p:checkinDate {checkinDate} ; p:checkoutDate {checkoutDate} .
source		SELECT `bookingId`, `customerId`, `cruiseOrResort`, `checkinDate`, `checkoutDate` FROM `Booking`

mappingId	Booking_customerId_fk
target		ex:Bookings/{bookingId} p:hasCustomers ex:Customers/{customerId} .
source		SELECT `bookingId`, `customerId` FROM `Booking` WHERE `customerId` IS NOT NULL

]]
