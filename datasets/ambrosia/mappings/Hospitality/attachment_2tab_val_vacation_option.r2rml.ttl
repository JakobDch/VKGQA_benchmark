@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_vacation_option_0_Cruise_Ship_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"capacity\", \"destination\", \"cruise_start_date\", \"cruise_end_date\", \"activities\" FROM \"Cruise_Ship\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cruise_Ships/{id}" ; rr:class :Cruise_Ships ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destination ; rr:objectMap [ rr:column "destination" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cruise_start_date ; rr:objectMap [ rr:column "cruise_start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cruise_end_date ; rr:objectMap [ rr:column "cruise_end_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:activities ; rr:objectMap [ rr:column "activities" ] ] .

<#tm_attachment_2tab_val_vacation_option_1_All_Inclusive_Resort_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\", \"star_rating\", \"number_of_rooms\", \"activities\" FROM \"All_Inclusive_Resort\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/All_Inclusive_Resort/{id}" ; rr:class :All_Inclusive_Resort ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:star_rating ; rr:objectMap [ rr:column "star_rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number_of_rooms ; rr:objectMap [ rr:column "number_of_rooms" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:activities ; rr:objectMap [ rr:column "activities" ] ] .

<#tm_attachment_2tab_val_vacation_option_2_Customer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"email\", \"phoneNumber\", \"preferredLanguage\" FROM \"Customer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:preferredLanguage ; rr:objectMap [ rr:column "preferredLanguage" ] ] .

<#tm_attachment_2tab_val_vacation_option_3_Employee_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"position\", \"yearsOfExperience\", \"skill\" FROM \"Employee\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Employees/{id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position ; rr:objectMap [ rr:column "position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:yearsOfExperience ; rr:objectMap [ rr:column "yearsOfExperience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skill ; rr:objectMap [ rr:column "skill" ] ] .

<#tm_attachment_2tab_val_vacation_option_4_Booking_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bookingId\", \"customerId\", \"cruiseOrResort\", \"checkinDate\", \"checkoutDate\" FROM \"Booking\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{bookingId}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:bookingId ; rr:objectMap [ rr:column "bookingId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customerId ; rr:objectMap [ rr:column "customerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cruiseOrResort ; rr:objectMap [ rr:column "cruiseOrResort" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkinDate ; rr:objectMap [ rr:column "checkinDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkoutDate ; rr:objectMap [ rr:column "checkoutDate" ] ] .

<#tm_attachment_2tab_val_vacation_option_5_Booking_customerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bookingId\", \"customerId\" FROM \"Booking\" WHERE \"customerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{bookingId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customerId}" ; rr:termType rr:IRI ] ] .

