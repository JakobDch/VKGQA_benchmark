@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_adventure_tour_operators_activities_0_Adventure_Tour_Operators_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Adventure_Tour_Operators\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Adventure_Tour_Operators/{id}" ; rr:class :Adventure_Tour_Operators ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_adventure_tour_operators_activities_1_Activities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"activity_name\", \"description\" FROM \"Activities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Activities/{id}" ; rr:class :Activities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:activity_name ; rr:objectMap [ rr:column "activity_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_adventure_tour_operators_activities_2_Adventure_Tour_Operators_Activities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"adventure_tour_operator_id\", \"activity_id\" FROM \"Adventure_Tour_Operators_Activities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Adventure_Tour_Operators_Activities/{_amb_rowid}" ; rr:class :Adventure_Tour_Operators_Activities ] ;
  rr:predicateObjectMap [ rr:predicate p:adventure_tour_operator_id ; rr:objectMap [ rr:column "adventure_tour_operator_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:activity_id ; rr:objectMap [ rr:column "activity_id" ] ] .

<#tm_scope_adventure_tour_operators_activities_3_Adventure_Tour_Operators_Activities_activity_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"activity_id\" FROM \"Adventure_Tour_Operators_Activities\" WHERE \"activity_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Adventure_Tour_Operators_Activities/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActivities ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Activities/{activity_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_adventure_tour_operators_activities_4_Adventure_Tour_Operators_Activities_adventure_tour_operator_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"adventure_tour_operator_id\" FROM \"Adventure_Tour_Operators_Activities\" WHERE \"adventure_tour_operator_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Adventure_Tour_Operators_Activities/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAdventure_Tour_Operators ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Adventure_Tour_Operators/{adventure_tour_operator_id}" ; rr:termType rr:IRI ] ] .

