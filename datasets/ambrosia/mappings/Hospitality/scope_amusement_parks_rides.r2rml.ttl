@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_amusement_parks_rides_0_Amusement_Parks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Amusement_Parks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Amusement_Parks/{id}" ; rr:class :Amusement_Parks ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_amusement_parks_rides_1_Rides_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"ride_name\", \"ride_type\" FROM \"Rides\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rides/{id}" ; rr:class :Rides ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ride_name ; rr:objectMap [ rr:column "ride_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ride_type ; rr:objectMap [ rr:column "ride_type" ] ] .

<#tm_scope_amusement_parks_rides_2_Amusement_Parks_Rides_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"amusement_park_id\", \"rides_id\" FROM \"Amusement_Parks_Rides\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Amusement_Parks_Rides/{_amb_rowid}" ; rr:class :Amusement_Parks_Rides ] ;
  rr:predicateObjectMap [ rr:predicate p:amusement_park_id ; rr:objectMap [ rr:column "amusement_park_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rides_id ; rr:objectMap [ rr:column "rides_id" ] ] .

<#tm_scope_amusement_parks_rides_3_Amusement_Parks_Rides_rides_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"rides_id\" FROM \"Amusement_Parks_Rides\" WHERE \"rides_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Amusement_Parks_Rides/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRides ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rides/{rides_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_amusement_parks_rides_4_Amusement_Parks_Rides_amusement_park_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"amusement_park_id\" FROM \"Amusement_Parks_Rides\" WHERE \"amusement_park_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Amusement_Parks_Rides/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAmusement_Parks ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Amusement_Parks/{amusement_park_id}" ; rr:termType rr:IRI ] ] .

