@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_art_galleries_exhibitions_0_Art_Galleries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GalleryID\", \"Name\", \"Location\" FROM \"Art_Galleries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Art_Galleries/{GalleryID}" ; rr:class :Art_Galleries ] ;
  rr:predicateObjectMap [ rr:predicate p:GalleryID ; rr:objectMap [ rr:column "GalleryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_scope_art_galleries_exhibitions_1_Exhibitions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ExhibitionID\", \"Type\", \"Description\" FROM \"Exhibitions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Exhibitions/{ExhibitionID}" ; rr:class :Exhibitions ] ;
  rr:predicateObjectMap [ rr:predicate p:ExhibitionID ; rr:objectMap [ rr:column "ExhibitionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_scope_art_galleries_exhibitions_2_Art_Galleries_Exhibitions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GalleryID\", \"ExhibitionID\" FROM \"Art_Galleries_Exhibitions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Art_Galleries_Exhibitions/{GalleryID}/{ExhibitionID}" ; rr:class :Art_Galleries_Exhibitions ] ;
  rr:predicateObjectMap [ rr:predicate p:GalleryID ; rr:objectMap [ rr:column "GalleryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ExhibitionID ; rr:objectMap [ rr:column "ExhibitionID" ] ] .

<#tm_scope_art_galleries_exhibitions_3_Art_Galleries_Exhibitions_ExhibitionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GalleryID\", \"ExhibitionID\" FROM \"Art_Galleries_Exhibitions\" WHERE \"ExhibitionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Art_Galleries_Exhibitions/{GalleryID}/{ExhibitionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasExhibitions ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Exhibitions/{ExhibitionID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_art_galleries_exhibitions_4_Art_Galleries_Exhibitions_GalleryID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GalleryID\", \"ExhibitionID\" FROM \"Art_Galleries_Exhibitions\" WHERE \"GalleryID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Art_Galleries_Exhibitions/{GalleryID}/{ExhibitionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArt_Galleries ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Art_Galleries/{GalleryID}" ; rr:termType rr:IRI ] ] .

