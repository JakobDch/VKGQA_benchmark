@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_beach_resorts_water_sports_0_Beach_Resorts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ResortID\", \"Name\", \"Location\" FROM \"Beach_Resorts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Beach_Resorts/{ResortID}" ; rr:class :Beach_Resorts ] ;
  rr:predicateObjectMap [ rr:predicate p:ResortID ; rr:objectMap [ rr:column "ResortID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_scope_beach_resorts_water_sports_1_Water_Sports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SportID\", \"Name\", \"Description\" FROM \"Water_Sports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Water_Sports/{SportID}" ; rr:class :Water_Sports ] ;
  rr:predicateObjectMap [ rr:predicate p:SportID ; rr:objectMap [ rr:column "SportID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_scope_beach_resorts_water_sports_2_Beach_Resorts_Water_Sports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ResortID\", \"SportID\" FROM \"Beach_Resorts_Water_Sports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Beach_Resorts_Water_Sports/{ResortID}/{SportID}" ; rr:class :Beach_Resorts_Water_Sports ] ;
  rr:predicateObjectMap [ rr:predicate p:ResortID ; rr:objectMap [ rr:column "ResortID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SportID ; rr:objectMap [ rr:column "SportID" ] ] .

<#tm_scope_beach_resorts_water_sports_3_Beach_Resorts_Water_Sports_SportID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ResortID\", \"SportID\" FROM \"Beach_Resorts_Water_Sports\" WHERE \"SportID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Beach_Resorts_Water_Sports/{ResortID}/{SportID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWater_Sports ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Water_Sports/{SportID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_beach_resorts_water_sports_4_Beach_Resorts_Water_Sports_ResortID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ResortID\", \"SportID\" FROM \"Beach_Resorts_Water_Sports\" WHERE \"ResortID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Beach_Resorts_Water_Sports/{ResortID}/{SportID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBeach_Resorts ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Beach_Resorts/{ResortID}" ; rr:termType rr:IRI ] ] .

