@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_bed_and_breakfast_rooms_0_Bed_and_breakfast_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"rating\" FROM \"Bed_and_breakfast\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bed_and_breakfast/{id}" ; rr:class :Bed_and_breakfast ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rating ; rr:objectMap [ rr:column "rating" ] ] .

<#tm_scope_bed_and_breakfast_rooms_1_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"room_type\", \"price\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{room_type}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:room_type ; rr:objectMap [ rr:column "room_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_bed_and_breakfast_rooms_2_Bed_and_breakfast_rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"bed_id\", \"room_id\" FROM \"Bed_and_breakfast_rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bed_and_breakfast_rooms/{_amb_rowid}" ; rr:class :Bed_and_breakfast_rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:bed_id ; rr:objectMap [ rr:column "bed_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:room_id ; rr:objectMap [ rr:column "room_id" ] ] .

<#tm_scope_bed_and_breakfast_rooms_3_Bed_and_breakfast_rooms_room_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"room_id\" FROM \"Bed_and_breakfast_rooms\" WHERE \"room_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bed_and_breakfast_rooms/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{room_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_bed_and_breakfast_rooms_4_Bed_and_breakfast_rooms_bed_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"bed_id\" FROM \"Bed_and_breakfast_rooms\" WHERE \"bed_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bed_and_breakfast_rooms/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBed_and_breakfast ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bed_and_breakfast/{bed_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_bed_and_breakfast_rooms_5_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"first_name\", \"last_name\", \"email\", \"phone_number\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customer_id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_scope_bed_and_breakfast_rooms_6_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"booking_id\", \"bed_id\", \"customer_id\", \"checkin\", \"checkout\", \"total_price\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{booking_id}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:booking_id ; rr:objectMap [ rr:column "booking_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bed_id ; rr:objectMap [ rr:column "bed_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkin ; rr:objectMap [ rr:column "checkin" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkout ; rr:objectMap [ rr:column "checkout" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:total_price ; rr:objectMap [ rr:column "total_price" ] ] .

<#tm_scope_bed_and_breakfast_rooms_7_Bookings_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"booking_id\", \"customer_id\" FROM \"Bookings\" WHERE \"customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{booking_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customer_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_bed_and_breakfast_rooms_8_Bookings_bed_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"booking_id\", \"bed_id\" FROM \"Bookings\" WHERE \"bed_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{booking_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBed_and_breakfast_rooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bed_and_breakfast_rooms/{bed_id}" ; rr:termType rr:IRI ] ] .

