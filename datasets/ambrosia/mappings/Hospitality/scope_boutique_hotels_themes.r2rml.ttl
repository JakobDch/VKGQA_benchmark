@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_boutique_hotels_themes_0_Boutique_Hotels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"hotel_id\", \"name\", \"location\" FROM \"Boutique_Hotels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Boutique_Hotels/{hotel_id}" ; rr:class :Boutique_Hotels ] ;
  rr:predicateObjectMap [ rr:predicate p:hotel_id ; rr:objectMap [ rr:column "hotel_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_boutique_hotels_themes_1_Themes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"theme_id\", \"theme_name\" FROM \"Themes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Themes/{theme_id}" ; rr:class :Themes ] ;
  rr:predicateObjectMap [ rr:predicate p:theme_id ; rr:objectMap [ rr:column "theme_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:theme_name ; rr:objectMap [ rr:column "theme_name" ] ] .

<#tm_scope_boutique_hotels_themes_2_Boutique_Hotels_Themes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"boutique_hotel_id\", \"theme_id\" FROM \"Boutique_Hotels_Themes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Boutique_Hotels_Themes/{_amb_rowid}" ; rr:class :Boutique_Hotels_Themes ] ;
  rr:predicateObjectMap [ rr:predicate p:boutique_hotel_id ; rr:objectMap [ rr:column "boutique_hotel_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:theme_id ; rr:objectMap [ rr:column "theme_id" ] ] .

<#tm_scope_boutique_hotels_themes_3_Boutique_Hotels_Themes_theme_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"theme_id\" FROM \"Boutique_Hotels_Themes\" WHERE \"theme_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Boutique_Hotels_Themes/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasThemes ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Themes/{theme_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_boutique_hotels_themes_4_Boutique_Hotels_Themes_boutique_hotel_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"boutique_hotel_id\" FROM \"Boutique_Hotels_Themes\" WHERE \"boutique_hotel_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Boutique_Hotels_Themes/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBoutique_Hotels ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Boutique_Hotels/{boutique_hotel_id}" ; rr:termType rr:IRI ] ] .

