@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_casinos_games_0_Casinos_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Casinos\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Casinos/{id}" ; rr:class :Casinos ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_casinos_games_1_Games_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"game_name\", \"description\" FROM \"Games\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Games/{id}" ; rr:class :Games ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:game_name ; rr:objectMap [ rr:column "game_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_casinos_games_2_Casinos_Games_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"casino_id\", \"game_id\" FROM \"Casinos_Games\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Casinos_Games/{casino_id}/{game_id}" ; rr:class :Casinos_Games ] ;
  rr:predicateObjectMap [ rr:predicate p:casino_id ; rr:objectMap [ rr:column "casino_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:game_id ; rr:objectMap [ rr:column "game_id" ] ] .

<#tm_scope_casinos_games_3_Casinos_Games_game_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"casino_id\", \"game_id\" FROM \"Casinos_Games\" WHERE \"game_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Casinos_Games/{casino_id}/{game_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGames ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Games/{game_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_casinos_games_4_Casinos_Games_casino_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"casino_id\", \"game_id\" FROM \"Casinos_Games\" WHERE \"casino_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Casinos_Games/{casino_id}/{game_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCasinos ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Casinos/{casino_id}" ; rr:termType rr:IRI ] ] .

