<#tm_scope_convention_centers_event_spaces_4_Reservations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"guest_id\", \"event_space_id\", \"checkin\", \"checkout\" FROM \"Reservations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{id}" ; rr:class :Reservations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:guest_id ; rr:objectMap [ rr:column "guest_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:event_space_id ; rr:objectMap [ rr:column "event_space_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkin ; rr:objectMap [ rr:column "checkin" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkout ; rr:objectMap [ rr:column "checkout" ] ] .

<#tm_scope_convention_centers_event_spaces_5_Reservations_event_space_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"event_space_id\" FROM \"Reservations\" WHERE \"event_space_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEventSpaces ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/EventSpaces/{event_space_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_convention_centers_event_spaces_6_Reservations_guest_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"guest_id\" FROM \"Reservations\" WHERE \"guest_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuests ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{guest_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_convention_centers_event_spaces_7_Convention_Centers_Event_Spaces_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"convention_center_id\", \"event_space_id\" FROM \"Convention_Centers_Event_Spaces\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Convention_Centers_Event_Spaces/{_amb_rowid}" ; rr:class :Convention_Centers_Event_Spaces ] ;
  rr:predicateObjectMap [ rr:predicate p:convention_center_id ; rr:objectMap [ rr:column "convention_center_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:event_space_id ; rr:objectMap [ rr:column "event_space_id" ] ] .

