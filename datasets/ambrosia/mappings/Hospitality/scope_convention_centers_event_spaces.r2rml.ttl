  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"room_number\", \"floor_no\", \"capacity\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{id}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:room_number ; rr:objectMap [ rr:column "room_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:floor_no ; rr:objectMap [ rr:column "floor_no" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

