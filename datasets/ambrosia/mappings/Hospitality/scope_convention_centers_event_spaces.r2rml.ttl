  rr:predicateObjectMap [ rr:predicate p:hasEventSpaces ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/EventSpaces/{event_space_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_convention_centers_event_spaces_9_Convention_Centers_Event_Spaces_convention_center_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"convention_center_id\" FROM \"Convention_Centers_Event_Spaces\" WHERE \"convention_center_id\" IS NOT NULL""" ] ;
