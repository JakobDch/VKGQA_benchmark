@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_craft_fairs_vendors_0_Craft_Fairs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\", \"date\" FROM \"Craft_Fairs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Craft_Fairs/{id}" ; rr:class :Craft_Fairs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] .

<#tm_scope_craft_fairs_vendors_1_Vendors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\" FROM \"Vendors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Vendors/{id}" ; rr:class :Vendors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_scope_craft_fairs_vendors_2_Craft_Fairs_Vendors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"craft_fair_id\", \"vendor_type_id\" FROM \"Craft_Fairs_Vendors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Craft_Fairs_Vendors/{_amb_rowid}" ; rr:class :Craft_Fairs_Vendors ] ;
  rr:predicateObjectMap [ rr:predicate p:craft_fair_id ; rr:objectMap [ rr:column "craft_fair_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:vendor_type_id ; rr:objectMap [ rr:column "vendor_type_id" ] ] .

<#tm_scope_craft_fairs_vendors_3_Craft_Fairs_Vendors_vendor_type_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"vendor_type_id\" FROM \"Craft_Fairs_Vendors\" WHERE \"vendor_type_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Craft_Fairs_Vendors/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVendors ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Vendors/{vendor_type_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_craft_fairs_vendors_4_Craft_Fairs_Vendors_craft_fair_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"craft_fair_id\" FROM \"Craft_Fairs_Vendors\" WHERE \"craft_fair_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Craft_Fairs_Vendors/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCraft_Fairs ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Craft_Fairs/{craft_fair_id}" ; rr:termType rr:IRI ] ] .

