@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_cruise_ships_facilities_0_Cruise_Ships_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"capacity\" FROM \"Cruise_Ships\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cruise_Ships/{id}" ; rr:class :Cruise_Ships ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

<#tm_scope_cruise_ships_facilities_1_Facilities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"facilityName\", \"isAvailable\" FROM \"Facilities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Facilities/{id}" ; rr:class :Facilities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:facilityName ; rr:objectMap [ rr:column "facilityName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:isAvailable ; rr:objectMap [ rr:column "isAvailable" ] ] .

<#tm_scope_cruise_ships_facilities_2_Cruise_Ships_Facilities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cruiseShipId\", \"facilityId\" FROM \"Cruise_Ships_Facilities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cruise_Ships_Facilities/{cruiseShipId}/{facilityId}" ; rr:class :Cruise_Ships_Facilities ] ;
  rr:predicateObjectMap [ rr:predicate p:cruiseShipId ; rr:objectMap [ rr:column "cruiseShipId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:facilityId ; rr:objectMap [ rr:column "facilityId" ] ] .

<#tm_scope_cruise_ships_facilities_3_Cruise_Ships_Facilities_facilityId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cruiseShipId\", \"facilityId\" FROM \"Cruise_Ships_Facilities\" WHERE \"facilityId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cruise_Ships_Facilities/{cruiseShipId}/{facilityId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFacilities ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Facilities/{facilityId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_cruise_ships_facilities_4_Cruise_Ships_Facilities_cruiseShipId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cruiseShipId\", \"facilityId\" FROM \"Cruise_Ships_Facilities\" WHERE \"cruiseShipId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cruise_Ships_Facilities/{cruiseShipId}/{facilityId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCruise_Ships ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cruise_Ships/{cruiseShipId}" ; rr:termType rr:IRI ] ] .

