@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_culinary_schools_cuisine_types_0_Culinary_Schools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Culinary_Schools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Culinary_Schools/{id}" ; rr:class :Culinary_Schools ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_culinary_schools_cuisine_types_1_Cuisine_Types_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cuisine_id\", \"type\" FROM \"Cuisine_Types\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cuisine_Types/{cuisine_id}" ; rr:class :Cuisine_Types ] ;
  rr:predicateObjectMap [ rr:predicate p:cuisine_id ; rr:objectMap [ rr:column "cuisine_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_scope_culinary_schools_cuisine_types_2_Culinary_Schools_Cuisine_Types_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"culinary_school_id\", \"cuisine_type_id\" FROM \"Culinary_Schools_Cuisine_Types\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Culinary_Schools_Cuisine_Types/{_amb_rowid}" ; rr:class :Culinary_Schools_Cuisine_Types ] ;
  rr:predicateObjectMap [ rr:predicate p:culinary_school_id ; rr:objectMap [ rr:column "culinary_school_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cuisine_type_id ; rr:objectMap [ rr:column "cuisine_type_id" ] ] .

<#tm_scope_culinary_schools_cuisine_types_3_Culinary_Schools_Cuisine_Types_cuisine_type_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"cuisine_type_id\" FROM \"Culinary_Schools_Cuisine_Types\" WHERE \"cuisine_type_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Culinary_Schools_Cuisine_Types/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCuisine_Types ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cuisine_Types/{cuisine_type_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_culinary_schools_cuisine_types_4_Culinary_Schools_Cuisine_Types_culinary_school_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"culinary_school_id\" FROM \"Culinary_Schools_Cuisine_Types\" WHERE \"culinary_school_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Culinary_Schools_Cuisine_Types/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCulinary_Schools ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Culinary_Schools/{culinary_school_id}" ; rr:termType rr:IRI ] ] .

