@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_cultural_centers_performances_0_Cultural_Centers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"centerID\", \"name\", \"location\" FROM \"Cultural_Centers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cultural_Centers/{centerID}" ; rr:class :Cultural_Centers ] ;
  rr:predicateObjectMap [ rr:predicate p:centerID ; rr:objectMap [ rr:column "centerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_cultural_centers_performances_1_Performances_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"performanceID\", \"type\" FROM \"Performances\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Performances/{performanceID}" ; rr:class :Performances ] ;
  rr:predicateObjectMap [ rr:predicate p:performanceID ; rr:objectMap [ rr:column "performanceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_scope_cultural_centers_performances_2_Cultural_Centers_Performances_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"culturalCenterID\", \"performanceID\" FROM \"Cultural_Centers_Performances\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cultural_Centers_Performances/{_amb_rowid}" ; rr:class :Cultural_Centers_Performances ] ;
  rr:predicateObjectMap [ rr:predicate p:culturalCenterID ; rr:objectMap [ rr:column "culturalCenterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:performanceID ; rr:objectMap [ rr:column "performanceID" ] ] .

<#tm_scope_cultural_centers_performances_3_Cultural_Centers_Performances_performanceID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"performanceID\" FROM \"Cultural_Centers_Performances\" WHERE \"performanceID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cultural_Centers_Performances/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPerformances ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Performances/{performanceID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_cultural_centers_performances_4_Cultural_Centers_Performances_culturalCenterID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"culturalCenterID\" FROM \"Cultural_Centers_Performances\" WHERE \"culturalCenterID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cultural_Centers_Performances/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCultural_Centers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Cultural_Centers/{culturalCenterID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_cultural_centers_performances_5_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employeeID\", \"firstName\", \"lastName\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Employees/{employeeID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:employeeID ; rr:objectMap [ rr:column "employeeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] .

<#tm_scope_cultural_centers_performances_6_Managers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"managerID\", \"employeeID\" FROM \"Managers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Managers/{managerID}" ; rr:class :Managers ] ;
  rr:predicateObjectMap [ rr:predicate p:managerID ; rr:objectMap [ rr:column "managerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:employeeID ; rr:objectMap [ rr:column "employeeID" ] ] .

<#tm_scope_cultural_centers_performances_7_Managers_employeeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"managerID\", \"employeeID\" FROM \"Managers\" WHERE \"employeeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Managers/{managerID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployees ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Employees/{employeeID}" ; rr:termType rr:IRI ] ] .

