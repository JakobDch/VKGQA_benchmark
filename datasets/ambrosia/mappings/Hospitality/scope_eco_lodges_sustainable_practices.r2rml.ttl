@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_eco_lodges_sustainable_practices_0_Eco_Lodges_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Eco_Lodges\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Eco_Lodges/{id}" ; rr:class :Eco_Lodges ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_eco_lodges_sustainable_practices_1_Sustainable_Practices_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"practice_id\", \"practice_name\" FROM \"Sustainable_Practices\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Sustainable_Practices/{practice_id}" ; rr:class :Sustainable_Practices ] ;
  rr:predicateObjectMap [ rr:predicate p:practice_id ; rr:objectMap [ rr:column "practice_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:practice_name ; rr:objectMap [ rr:column "practice_name" ] ] .

<#tm_scope_eco_lodges_sustainable_practices_2_Eco_Lodges_Sustainable_Practices_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"eco_lodge_id\", \"practice_id\" FROM \"Eco_Lodges_Sustainable_Practices\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Eco_Lodges_Sustainable_Practices/{_amb_rowid}" ; rr:class :Eco_Lodges_Sustainable_Practices ] ;
  rr:predicateObjectMap [ rr:predicate p:eco_lodge_id ; rr:objectMap [ rr:column "eco_lodge_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:practice_id ; rr:objectMap [ rr:column "practice_id" ] ] .

<#tm_scope_eco_lodges_sustainable_practices_3_Eco_Lodges_Sustainable_Practices_practice_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"practice_id\" FROM \"Eco_Lodges_Sustainable_Practices\" WHERE \"practice_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Eco_Lodges_Sustainable_Practices/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSustainable_Practices ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Sustainable_Practices/{practice_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_eco_lodges_sustainable_practices_4_Eco_Lodges_Sustainable_Practices_eco_lodge_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"eco_lodge_id\" FROM \"Eco_Lodges_Sustainable_Practices\" WHERE \"eco_lodge_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Eco_Lodges_Sustainable_Practices/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEco_Lodges ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Eco_Lodges/{eco_lodge_id}" ; rr:termType rr:IRI ] ] .

