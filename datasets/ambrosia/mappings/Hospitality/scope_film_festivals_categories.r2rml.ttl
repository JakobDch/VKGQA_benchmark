@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_film_festivals_categories_0_Film_Festivals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Film_Festivals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Film_Festivals/{id}" ; rr:class :Film_Festivals ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_film_festivals_categories_1_Categories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"category_name\" FROM \"Categories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Categories/{id}" ; rr:class :Categories ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:category_name ; rr:objectMap [ rr:column "category_name" ] ] .

<#tm_scope_film_festivals_categories_2_Film_Festivals_Categories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"film_festival_id\", \"category_id\" FROM \"Film_Festivals_Categories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Film_Festivals_Categories/{_amb_rowid}" ; rr:class :Film_Festivals_Categories ] ;
  rr:predicateObjectMap [ rr:predicate p:film_festival_id ; rr:objectMap [ rr:column "film_festival_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:category_id ; rr:objectMap [ rr:column "category_id" ] ] .

<#tm_scope_film_festivals_categories_3_Film_Festivals_Categories_category_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"category_id\" FROM \"Film_Festivals_Categories\" WHERE \"category_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Film_Festivals_Categories/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCategories ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Categories/{category_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_film_festivals_categories_4_Film_Festivals_Categories_film_festival_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"film_festival_id\" FROM \"Film_Festivals_Categories\" WHERE \"film_festival_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Film_Festivals_Categories/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFilm_Festivals ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Film_Festivals/{film_festival_id}" ; rr:termType rr:IRI ] ] .

