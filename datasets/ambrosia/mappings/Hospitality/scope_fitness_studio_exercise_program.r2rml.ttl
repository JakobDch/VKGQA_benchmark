@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_fitness_studio_exercise_program_0_Fitness_Studio_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudioID\", \"Name\", \"Location\" FROM \"Fitness_Studio\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Fitness_Studio/{StudioID}" ; rr:class :Fitness_Studio ] ;
  rr:predicateObjectMap [ rr:predicate p:StudioID ; rr:objectMap [ rr:column "StudioID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_scope_fitness_studio_exercise_program_1_Exercise_Program_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProgramID\", \"Type\" FROM \"Exercise_Program\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Exercise_Program/{ProgramID}" ; rr:class :Exercise_Program ] ;
  rr:predicateObjectMap [ rr:predicate p:ProgramID ; rr:objectMap [ rr:column "ProgramID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] .

<#tm_scope_fitness_studio_exercise_program_2_Fitness_Studio_Exercise_Program_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FitnessStudioID\", \"ExerciseProgramID\" FROM \"Fitness_Studio_Exercise_Program\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Fitness_Studio_Exercise_Program/{ID}" ; rr:class :Fitness_Studio_Exercise_Program ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FitnessStudioID ; rr:objectMap [ rr:column "FitnessStudioID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ExerciseProgramID ; rr:objectMap [ rr:column "ExerciseProgramID" ] ] .

<#tm_scope_fitness_studio_exercise_program_3_Fitness_Studio_Exercise_Program_ExerciseProgramID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"ExerciseProgramID\" FROM \"Fitness_Studio_Exercise_Program\" WHERE \"ExerciseProgramID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Fitness_Studio_Exercise_Program/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasExercise_Program ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Exercise_Program/{ExerciseProgramID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_fitness_studio_exercise_program_4_Fitness_Studio_Exercise_Program_FitnessStudioID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FitnessStudioID\" FROM \"Fitness_Studio_Exercise_Program\" WHERE \"FitnessStudioID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Fitness_Studio_Exercise_Program/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFitness_Studio ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Fitness_Studio/{FitnessStudioID}" ; rr:termType rr:IRI ] ] .

