@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_guesthouses_suites_0_RoomAmenities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"amenID\", \"amenName\", \"amenCost\" FROM \"RoomAmenities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/RoomAmenities/{amenID}" ; rr:class :RoomAmenities ] ;
  rr:predicateObjectMap [ rr:predicate p:amenID ; rr:objectMap [ rr:column "amenID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amenName ; rr:objectMap [ rr:column "amenName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amenCost ; rr:objectMap [ rr:column "amenCost" ] ] .

<#tm_scope_guesthouses_suites_1_Guests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"guestID\", \"firstName\", \"lastName\", \"email\", \"phoneNumber\" FROM \"Guests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{guestID}" ; rr:class :Guests ] ;
  rr:predicateObjectMap [ rr:predicate p:guestID ; rr:objectMap [ rr:column "guestID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] .

<#tm_scope_guesthouses_suites_2_GuestHouses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"houseID\", \"houseName\", \"location\", \"capacity\", \"pricePerNight\" FROM \"GuestHouses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GuestHouses/{houseID}" ; rr:class :GuestHouses ] ;
  rr:predicateObjectMap [ rr:predicate p:houseID ; rr:objectMap [ rr:column "houseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:houseName ; rr:objectMap [ rr:column "houseName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:pricePerNight ; rr:objectMap [ rr:column "pricePerNight" ] ] .

<#tm_scope_guesthouses_suites_3_Suites_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"suiteType\" FROM \"Suites\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Suites/{suiteType}" ; rr:class :Suites ] ;
  rr:predicateObjectMap [ rr:predicate p:suiteType ; rr:objectMap [ rr:column "suiteType" ] ] .

<#tm_scope_guesthouses_suites_4_GuestHouseSuites_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"guesthouseID\", \"suiteType\" FROM \"GuestHouseSuites\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GuestHouseSuites/{_amb_rowid}" ; rr:class :GuestHouseSuites ] ;
  rr:predicateObjectMap [ rr:predicate p:guesthouseID ; rr:objectMap [ rr:column "guesthouseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:suiteType ; rr:objectMap [ rr:column "suiteType" ] ] .

<#tm_scope_guesthouses_suites_5_GuestHouseSuites_suiteType_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"suiteType\" FROM \"GuestHouseSuites\" WHERE \"suiteType\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GuestHouseSuites/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSuites ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Suites/{suiteType}" ; rr:termType rr:IRI ] ] .

<#tm_scope_guesthouses_suites_6_GuestHouseSuites_guesthouseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"guesthouseID\" FROM \"GuestHouseSuites\" WHERE \"guesthouseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GuestHouseSuites/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuestHouses ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/GuestHouses/{guesthouseID}" ; rr:termType rr:IRI ] ] .

