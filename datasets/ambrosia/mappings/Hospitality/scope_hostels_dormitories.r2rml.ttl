@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_hostels_dormitories_0_Hostels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\" FROM \"Hostels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Hostels/{id}" ; rr:class :Hostels ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_scope_hostels_dormitories_1_Dormitories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"dormitory_id\", \"type\", \"capacity\" FROM \"Dormitories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Dormitories/{dormitory_id}" ; rr:class :Dormitories ] ;
  rr:predicateObjectMap [ rr:predicate p:dormitory_id ; rr:objectMap [ rr:column "dormitory_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] .

<#tm_scope_hostels_dormitories_2_Hostels_Dormitories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"hostel_dormitory_id\", \"hostel_id\", \"dormitory_id\" FROM \"Hostels_Dormitories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Hostels_Dormitories/{hostel_dormitory_id}" ; rr:class :Hostels_Dormitories ] ;
  rr:predicateObjectMap [ rr:predicate p:hostel_dormitory_id ; rr:objectMap [ rr:column "hostel_dormitory_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hostel_id ; rr:objectMap [ rr:column "hostel_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dormitory_id ; rr:objectMap [ rr:column "dormitory_id" ] ] .

<#tm_scope_hostels_dormitories_3_Hostels_Dormitories_dormitory_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"hostel_dormitory_id\", \"dormitory_id\" FROM \"Hostels_Dormitories\" WHERE \"dormitory_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Hostels_Dormitories/{hostel_dormitory_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDormitories ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Dormitories/{dormitory_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_hostels_dormitories_4_Hostels_Dormitories_hostel_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"hostel_dormitory_id\", \"hostel_id\" FROM \"Hostels_Dormitories\" WHERE \"hostel_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Hostels_Dormitories/{hostel_dormitory_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHostels ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Hostels/{hostel_id}" ; rr:termType rr:IRI ] ] .

