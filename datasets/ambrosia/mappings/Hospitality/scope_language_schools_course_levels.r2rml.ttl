@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_language_schools_course_levels_0_Language_Schools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Language_Schools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Language_Schools/{id}" ; rr:class :Language_Schools ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_language_schools_course_levels_1_Course_Levels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"level\" FROM \"Course_Levels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Course_Levels/{id}" ; rr:class :Course_Levels ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:level ; rr:objectMap [ rr:column "level" ] ] .

<#tm_scope_language_schools_course_levels_2_Language_Schools_Course_Levels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"language_schools_id\", \"course_levels_id\" FROM \"Language_Schools_Course_Levels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Language_Schools_Course_Levels/{language_schools_id}/{course_levels_id}" ; rr:class :Language_Schools_Course_Levels ] ;
  rr:predicateObjectMap [ rr:predicate p:language_schools_id ; rr:objectMap [ rr:column "language_schools_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:course_levels_id ; rr:objectMap [ rr:column "course_levels_id" ] ] .

<#tm_scope_language_schools_course_levels_3_Language_Schools_Course_Levels_course_levels_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"language_schools_id\", \"course_levels_id\" FROM \"Language_Schools_Course_Levels\" WHERE \"course_levels_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Language_Schools_Course_Levels/{language_schools_id}/{course_levels_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourse_Levels ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Course_Levels/{course_levels_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_language_schools_course_levels_4_Language_Schools_Course_Levels_language_schools_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"language_schools_id\", \"course_levels_id\" FROM \"Language_Schools_Course_Levels\" WHERE \"language_schools_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Language_Schools_Course_Levels/{language_schools_id}/{course_levels_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLanguage_Schools ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Language_Schools/{language_schools_id}" ; rr:termType rr:IRI ] ] .

