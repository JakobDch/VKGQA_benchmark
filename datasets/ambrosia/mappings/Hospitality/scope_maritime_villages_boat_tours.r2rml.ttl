@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_maritime_villages_boat_tours_0_Maritime_Villages_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Maritime_Villages\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Maritime_Villages/{id}" ; rr:class :Maritime_Villages ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_maritime_villages_boat_tours_1_Boat_Tours_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"tour_name\", \"description\" FROM \"Boat_Tours\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Boat_Tours/{id}" ; rr:class :Boat_Tours ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:tour_name ; rr:objectMap [ rr:column "tour_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_maritime_villages_boat_tours_2_Maritime_Villages_Boat_Tours_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"maritime_village_id\", \"boat_tour_id\" FROM \"Maritime_Villages_Boat_Tours\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Maritime_Villages_Boat_Tours/{_amb_rowid}" ; rr:class :Maritime_Villages_Boat_Tours ] ;
  rr:predicateObjectMap [ rr:predicate p:maritime_village_id ; rr:objectMap [ rr:column "maritime_village_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:boat_tour_id ; rr:objectMap [ rr:column "boat_tour_id" ] ] .

<#tm_scope_maritime_villages_boat_tours_3_Maritime_Villages_Boat_Tours_boat_tour_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"boat_tour_id\" FROM \"Maritime_Villages_Boat_Tours\" WHERE \"boat_tour_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Maritime_Villages_Boat_Tours/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBoat_Tours ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Boat_Tours/{boat_tour_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_maritime_villages_boat_tours_4_Maritime_Villages_Boat_Tours_maritime_village_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"maritime_village_id\" FROM \"Maritime_Villages_Boat_Tours\" WHERE \"maritime_village_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Maritime_Villages_Boat_Tours/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMaritime_Villages ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Maritime_Villages/{maritime_village_id}" ; rr:termType rr:IRI ] ] .

