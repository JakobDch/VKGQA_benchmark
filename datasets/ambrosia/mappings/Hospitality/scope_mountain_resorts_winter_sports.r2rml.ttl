@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_mountain_resorts_winter_sports_0_Mountain_Resorts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ResortID\", \"Name\", \"Location\", \"NumOfRooms\" FROM \"Mountain_Resorts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Mountain_Resorts/{ResortID}" ; rr:class :Mountain_Resorts ] ;
  rr:predicateObjectMap [ rr:predicate p:ResortID ; rr:objectMap [ rr:column "ResortID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumOfRooms ; rr:objectMap [ rr:column "NumOfRooms" ] ] .

<#tm_scope_mountain_resorts_winter_sports_1_Winter_Sports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SportID\", \"Name\", \"Description\" FROM \"Winter_Sports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Winter_Sports/{SportID}" ; rr:class :Winter_Sports ] ;
  rr:predicateObjectMap [ rr:predicate p:SportID ; rr:objectMap [ rr:column "SportID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_scope_mountain_resorts_winter_sports_2_Mountain_Resorts_Winter_Sports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ResortID\", \"SportID\" FROM \"Mountain_Resorts_Winter_Sports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Mountain_Resorts_Winter_Sports/{_amb_rowid}" ; rr:class :Mountain_Resorts_Winter_Sports ] ;
  rr:predicateObjectMap [ rr:predicate p:ResortID ; rr:objectMap [ rr:column "ResortID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SportID ; rr:objectMap [ rr:column "SportID" ] ] .

<#tm_scope_mountain_resorts_winter_sports_3_Mountain_Resorts_Winter_Sports_SportID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"SportID\" FROM \"Mountain_Resorts_Winter_Sports\" WHERE \"SportID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Mountain_Resorts_Winter_Sports/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWinter_Sports ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Winter_Sports/{SportID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_mountain_resorts_winter_sports_4_Mountain_Resorts_Winter_Sports_ResortID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ResortID\" FROM \"Mountain_Resorts_Winter_Sports\" WHERE \"ResortID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Mountain_Resorts_Winter_Sports/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMountain_Resorts ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Mountain_Resorts/{ResortID}" ; rr:termType rr:IRI ] ] .

