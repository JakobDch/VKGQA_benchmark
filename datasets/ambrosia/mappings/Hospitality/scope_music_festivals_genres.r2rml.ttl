@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_music_festivals_genres_0_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"genre_id\", \"genre_name\" FROM \"Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Genres/{genre_id}" ; rr:class :Genres ] ;
  rr:predicateObjectMap [ rr:predicate p:genre_id ; rr:objectMap [ rr:column "genre_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre_name ; rr:objectMap [ rr:column "genre_name" ] ] .

<#tm_scope_music_festivals_genres_1_Music_Festivals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"festival_id\", \"festival_name\", \"location\" FROM \"Music_Festivals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Music_Festivals/{festival_id}" ; rr:class :Music_Festivals ] ;
  rr:predicateObjectMap [ rr:predicate p:festival_id ; rr:objectMap [ rr:column "festival_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:festival_name ; rr:objectMap [ rr:column "festival_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_music_festivals_genres_2_Music_Festivals_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"music_festival_id\", \"genre_id\" FROM \"Music_Festivals_Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Music_Festivals_Genres/{_amb_rowid}" ; rr:class :Music_Festivals_Genres ] ;
  rr:predicateObjectMap [ rr:predicate p:music_festival_id ; rr:objectMap [ rr:column "music_festival_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre_id ; rr:objectMap [ rr:column "genre_id" ] ] .

<#tm_scope_music_festivals_genres_3_Music_Festivals_Genres_genre_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"genre_id\" FROM \"Music_Festivals_Genres\" WHERE \"genre_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Music_Festivals_Genres/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenres ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Genres/{genre_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_music_festivals_genres_4_Music_Festivals_Genres_music_festival_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"music_festival_id\" FROM \"Music_Festivals_Genres\" WHERE \"music_festival_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Music_Festivals_Genres/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMusic_Festivals ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Music_Festivals/{music_festival_id}" ; rr:termType rr:IRI ] ] .

