@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_national_parks_trails_0_National_Parks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"park_id\", \"name\", \"location\" FROM \"National_Parks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/National_Parks/{park_id}" ; rr:class :National_Parks ] ;
  rr:predicateObjectMap [ rr:predicate p:park_id ; rr:objectMap [ rr:column "park_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_national_parks_trails_1_Trails_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"trail_id\", \"difficulty\", \"length\" FROM \"Trails\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Trails/{trail_id}" ; rr:class :Trails ] ;
  rr:predicateObjectMap [ rr:predicate p:trail_id ; rr:objectMap [ rr:column "trail_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:difficulty ; rr:objectMap [ rr:column "difficulty" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:length ; rr:objectMap [ rr:column "length" ] ] .

<#tm_scope_national_parks_trails_2_National_Parks_Trails_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"national_park_id\", \"trail_id\" FROM \"National_Parks_Trails\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/National_Parks_Trails/{national_park_id}/{trail_id}" ; rr:class :National_Parks_Trails ] ;
  rr:predicateObjectMap [ rr:predicate p:national_park_id ; rr:objectMap [ rr:column "national_park_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:trail_id ; rr:objectMap [ rr:column "trail_id" ] ] .

<#tm_scope_national_parks_trails_3_National_Parks_Trails_trail_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"national_park_id\", \"trail_id\" FROM \"National_Parks_Trails\" WHERE \"trail_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/National_Parks_Trails/{national_park_id}/{trail_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTrails ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Trails/{trail_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_national_parks_trails_4_National_Parks_Trails_national_park_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"national_park_id\", \"trail_id\" FROM \"National_Parks_Trails\" WHERE \"national_park_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/National_Parks_Trails/{national_park_id}/{trail_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNational_Parks ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/National_Parks/{national_park_id}" ; rr:termType rr:IRI ] ] .

