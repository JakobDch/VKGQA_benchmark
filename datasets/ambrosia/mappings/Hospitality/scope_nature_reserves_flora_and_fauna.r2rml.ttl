@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_nature_reserves_flora_and_fauna_0_Nature_Reserves_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReserveID\", \"Name\", \"Location\" FROM \"Nature_Reserves\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Nature_Reserves/{ReserveID}" ; rr:class :Nature_Reserves ] ;
  rr:predicateObjectMap [ rr:predicate p:ReserveID ; rr:objectMap [ rr:column "ReserveID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_scope_nature_reserves_flora_and_fauna_1_Flora_and_fauna_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FaunaID\", \"SpeciesName\" FROM \"Flora_and_fauna\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Flora_and_fauna/{FaunaID}" ; rr:class :Flora_and_fauna ] ;
  rr:predicateObjectMap [ rr:predicate p:FaunaID ; rr:objectMap [ rr:column "FaunaID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SpeciesName ; rr:objectMap [ rr:column "SpeciesName" ] ] .

<#tm_scope_nature_reserves_flora_and_fauna_2_Nature_reserves_flora_and_fauna_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"NatureReserveId\", \"FaunaId\" FROM \"Nature_reserves_flora_and_fauna\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Nature_reserves_flora_and_fauna/{ID}" ; rr:class :Nature_reserves_flora_and_fauna ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NatureReserveId ; rr:objectMap [ rr:column "NatureReserveId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FaunaId ; rr:objectMap [ rr:column "FaunaId" ] ] .

<#tm_scope_nature_reserves_flora_and_fauna_3_Nature_reserves_flora_and_fauna_FaunaId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FaunaId\" FROM \"Nature_reserves_flora_and_fauna\" WHERE \"FaunaId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Nature_reserves_flora_and_fauna/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFlora_and_fauna ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Flora_and_fauna/{FaunaId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_nature_reserves_flora_and_fauna_4_Nature_reserves_flora_and_fauna_NatureReserveId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"NatureReserveId\" FROM \"Nature_reserves_flora_and_fauna\" WHERE \"NatureReserveId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Nature_reserves_flora_and_fauna/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNature_Reserves ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Nature_Reserves/{NatureReserveId}" ; rr:termType rr:IRI ] ] .

