  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Enrollments/{enrollment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWorkshop_Sessions ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Workshop_Sessions/{workshop_session_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_photography_workshops_techniques_9_Enrollments_participant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"participant_id\" FROM \"Enrollments\" WHERE \"participant_id\" IS NOT NULL""" ] ;
