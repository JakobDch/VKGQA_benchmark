<#tm_scope_photography_workshops_techniques_11_Photography_Workshops_workshop_leader_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"workshop_id\", \"workshop_leader_id\" FROM \"Photography_Workshops\" WHERE \"workshop_leader_id\" IS NOT NULL""" ] ;
