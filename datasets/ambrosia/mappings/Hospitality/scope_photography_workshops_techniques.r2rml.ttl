@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_photography_workshops_techniques_0_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"technique_id\", \"technique_name\" FROM \"Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Techniques/{technique_id}" ; rr:class :Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_id ; rr:objectMap [ rr:column "technique_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_name ; rr:objectMap [ rr:column "technique_name" ] ] .

<#tm_scope_photography_workshops_techniques_1_Photographers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"photographer_id\", \"name\", \"experience\" FROM \"Photographers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Photographers/{photographer_id}" ; rr:class :Photographers ] ;
  rr:predicateObjectMap [ rr:predicate p:photographer_id ; rr:objectMap [ rr:column "photographer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] .

<#tm_scope_photography_workshops_techniques_2_Workshop_Sessions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"session_id\", \"workshop_title\", \"start_time\", \"end_time\" FROM \"Workshop_Sessions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Workshop_Sessions/{session_id}" ; rr:class :Workshop_Sessions ] ;
  rr:predicateObjectMap [ rr:predicate p:session_id ; rr:objectMap [ rr:column "session_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:workshop_title ; rr:objectMap [ rr:column "workshop_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_time ; rr:objectMap [ rr:column "start_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_time ; rr:objectMap [ rr:column "end_time" ] ] .

<#tm_scope_photography_workshops_techniques_3_Photography_Workshops_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"photography_workshop_id\", \"technique_id\" FROM \"Photography_Workshops_Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Photography_Workshops_Techniques/{id}" ; rr:class :Photography_Workshops_Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:photography_workshop_id ; rr:objectMap [ rr:column "photography_workshop_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_id ; rr:objectMap [ rr:column "technique_id" ] ] .

<#tm_scope_photography_workshops_techniques_4_Photography_Workshops_Techniques_technique_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"technique_id\" FROM \"Photography_Workshops_Techniques\" WHERE \"technique_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Photography_Workshops_Techniques/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTechniques ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Techniques/{technique_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_photography_workshops_techniques_5_Photography_Workshops_Techniques_photography_workshop_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"photography_workshop_id\" FROM \"Photography_Workshops_Techniques\" WHERE \"photography_workshop_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Photography_Workshops_Techniques/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPhotography_Workshops ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Photography_Workshops/{photography_workshop_id}" ; rr:termType rr:IRI ] ] .

