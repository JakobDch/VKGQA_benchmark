@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_resorts_activities_0_Resorts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Resorts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Resorts/{id}" ; rr:class :Resorts ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_resorts_activities_1_Activities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"activityID\", \"activityName\" FROM \"Activities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Activities/{activityID}" ; rr:class :Activities ] ;
  rr:predicateObjectMap [ rr:predicate p:activityID ; rr:objectMap [ rr:column "activityID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:activityName ; rr:objectMap [ rr:column "activityName" ] ] .

<#tm_scope_resorts_activities_2_Resorts_Activities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"resortID\", \"activityID\" FROM \"Resorts_Activities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Resorts_Activities/{_amb_rowid}" ; rr:class :Resorts_Activities ] ;
  rr:predicateObjectMap [ rr:predicate p:resortID ; rr:objectMap [ rr:column "resortID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:activityID ; rr:objectMap [ rr:column "activityID" ] ] .

<#tm_scope_resorts_activities_3_Resorts_Activities_activityID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"activityID\" FROM \"Resorts_Activities\" WHERE \"activityID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Resorts_Activities/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasActivities ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Activities/{activityID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_resorts_activities_4_Resorts_Activities_resortID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"resortID\" FROM \"Resorts_Activities\" WHERE \"resortID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Resorts_Activities/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasResorts ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Resorts/{resortID}" ; rr:termType rr:IRI ] ] .

