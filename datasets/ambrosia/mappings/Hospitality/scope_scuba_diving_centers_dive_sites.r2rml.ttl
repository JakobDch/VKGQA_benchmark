@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_scuba_diving_centers_dive_sites_0_Scuba_Diving_Centers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Scuba_Diving_Centers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Scuba_Diving_Centers/{id}" ; rr:class :Scuba_Diving_Centers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_scuba_diving_centers_dive_sites_1_Dive_Sites_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"site_name\", \"type\" FROM \"Dive_Sites\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Dive_Sites/{id}" ; rr:class :Dive_Sites ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:site_name ; rr:objectMap [ rr:column "site_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_scope_scuba_diving_centers_dive_sites_2_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\", \"email\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_scuba_diving_centers_dive_sites_3_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"booking_id\", \"customer_id\", \"scuba_center_id\", \"dive_site_id\", \"date\", \"time\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{booking_id}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:booking_id ; rr:objectMap [ rr:column "booking_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:scuba_center_id ; rr:objectMap [ rr:column "scuba_center_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dive_site_id ; rr:objectMap [ rr:column "dive_site_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:time ; rr:objectMap [ rr:column "time" ] ] .

<#tm_scope_scuba_diving_centers_dive_sites_4_Bookings_dive_site_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"booking_id\", \"dive_site_id\" FROM \"Bookings\" WHERE \"dive_site_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{booking_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDive_Sites ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Dive_Sites/{dive_site_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_scuba_diving_centers_dive_sites_5_Bookings_scuba_center_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"booking_id\", \"scuba_center_id\" FROM \"Bookings\" WHERE \"scuba_center_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{booking_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasScuba_Diving_Centers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Scuba_Diving_Centers/{scuba_center_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_scuba_diving_centers_dive_sites_6_Bookings_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"booking_id\", \"customer_id\" FROM \"Bookings\" WHERE \"customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{booking_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customer_id}" ; rr:termType rr:IRI ] ] .

