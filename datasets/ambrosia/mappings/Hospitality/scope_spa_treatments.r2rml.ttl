@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_spa_treatments_0_Spa_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"spa_id\", \"name\", \"address\", \"phone_number\" FROM \"Spa\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Spa/{spa_id}" ; rr:class :Spa ] ;
  rr:predicateObjectMap [ rr:predicate p:spa_id ; rr:objectMap [ rr:column "spa_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_scope_spa_treatments_1_Treatments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"treatment_id\", \"name\", \"description\" FROM \"Treatments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Treatments/{treatment_id}" ; rr:class :Treatments ] ;
  rr:predicateObjectMap [ rr:predicate p:treatment_id ; rr:objectMap [ rr:column "treatment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_spa_treatments_2_Spa_Treatments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"spa_treatment_id\", \"spa_id\", \"treatment_id\" FROM \"Spa_Treatments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Spa_Treatments/{spa_treatment_id}" ; rr:class :Spa_Treatments ] ;
  rr:predicateObjectMap [ rr:predicate p:spa_treatment_id ; rr:objectMap [ rr:column "spa_treatment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:spa_id ; rr:objectMap [ rr:column "spa_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:treatment_id ; rr:objectMap [ rr:column "treatment_id" ] ] .

<#tm_scope_spa_treatments_3_Spa_Treatments_treatment_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"spa_treatment_id\", \"treatment_id\" FROM \"Spa_Treatments\" WHERE \"treatment_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Spa_Treatments/{spa_treatment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTreatments ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Treatments/{treatment_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_spa_treatments_4_Spa_Treatments_spa_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"spa_treatment_id\", \"spa_id\" FROM \"Spa_Treatments\" WHERE \"spa_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Spa_Treatments/{spa_treatment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSpa ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Spa/{spa_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_spa_treatments_5_Customers_base> a rr:TriplesMap ;
