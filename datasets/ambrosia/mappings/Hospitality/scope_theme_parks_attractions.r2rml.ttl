@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_theme_parks_attractions_0_Theme_Parks_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"park_id\", \"name\", \"location\" FROM \"Theme_Parks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Theme_Parks/{park_id}" ; rr:class :Theme_Parks ] ;
  rr:predicateObjectMap [ rr:predicate p:park_id ; rr:objectMap [ rr:column "park_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_theme_parks_attractions_1_Attractions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"attraction_id\", \"type\", \"description\" FROM \"Attractions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Attractions/{attraction_id}" ; rr:class :Attractions ] ;
  rr:predicateObjectMap [ rr:predicate p:attraction_id ; rr:objectMap [ rr:column "attraction_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_theme_parks_attractions_2_Theme_Parks_Attractions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"theme_park_id\", \"attraction_id\" FROM \"Theme_Parks_Attractions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Theme_Parks_Attractions/{_amb_rowid}" ; rr:class :Theme_Parks_Attractions ] ;
  rr:predicateObjectMap [ rr:predicate p:theme_park_id ; rr:objectMap [ rr:column "theme_park_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:attraction_id ; rr:objectMap [ rr:column "attraction_id" ] ] .

<#tm_scope_theme_parks_attractions_3_Theme_Parks_Attractions_attraction_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"attraction_id\" FROM \"Theme_Parks_Attractions\" WHERE \"attraction_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Theme_Parks_Attractions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAttractions ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Attractions/{attraction_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_theme_parks_attractions_4_Theme_Parks_Attractions_theme_park_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"theme_park_id\" FROM \"Theme_Parks_Attractions\" WHERE \"theme_park_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Theme_Parks_Attractions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTheme_Parks ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Theme_Parks/{theme_park_id}" ; rr:termType rr:IRI ] ] .

