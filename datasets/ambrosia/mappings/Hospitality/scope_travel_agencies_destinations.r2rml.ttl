<#tm_scope_travel_agencies_destinations_5_Bookings_tour_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"tour_id\" FROM \"Bookings\" WHERE \"tour_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTours ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Tours/{tour_id}" ; rr:termType rr:IRI ] ] .

