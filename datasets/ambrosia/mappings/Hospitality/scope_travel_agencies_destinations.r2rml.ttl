<#tm_scope_travel_agencies_destinations_4_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"travel_agency_id\", \"destination_id\", \"accommodation_id\", \"tour_id\", \"date\", \"price\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{id}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:travel_agency_id ; rr:objectMap [ rr:column "travel_agency_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:destination_id ; rr:objectMap [ rr:column "destination_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:accommodation_id ; rr:objectMap [ rr:column "accommodation_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:tour_id ; rr:objectMap [ rr:column "tour_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
