@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_wine_regions_winery_tours_0_Wine_Regions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RegionID\", \"Name\", \"Description\" FROM \"Wine_Regions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Wine_Regions/{RegionID}" ; rr:class :Wine_Regions ] ;
  rr:predicateObjectMap [ rr:predicate p:RegionID ; rr:objectMap [ rr:column "RegionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_scope_wine_regions_winery_tours_1_Winery_Tours_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TourID\", \"Type\", \"Duration\" FROM \"Winery_Tours\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Winery_Tours/{TourID}" ; rr:class :Winery_Tours ] ;
  rr:predicateObjectMap [ rr:predicate p:TourID ; rr:objectMap [ rr:column "TourID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Duration ; rr:objectMap [ rr:column "Duration" ] ] .

<#tm_scope_wine_regions_winery_tours_2_Wine_Regions_Winery_Tours_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"WineRegionID\", \"TourType\" FROM \"Wine_Regions_Winery_Tours\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Wine_Regions_Winery_Tours/{_amb_rowid}" ; rr:class :Wine_Regions_Winery_Tours ] ;
  rr:predicateObjectMap [ rr:predicate p:WineRegionID ; rr:objectMap [ rr:column "WineRegionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TourType ; rr:objectMap [ rr:column "TourType" ] ] .

<#tm_scope_wine_regions_winery_tours_3_Wine_Regions_Winery_Tours_TourType_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"TourType\" FROM \"Wine_Regions_Winery_Tours\" WHERE \"TourType\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Wine_Regions_Winery_Tours/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWinery_Tours ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Winery_Tours/{TourType}" ; rr:termType rr:IRI ] ] .

<#tm_scope_wine_regions_winery_tours_4_Wine_Regions_Winery_Tours_WineRegionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"WineRegionID\" FROM \"Wine_Regions_Winery_Tours\" WHERE \"WineRegionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Wine_Regions_Winery_Tours/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWine_Regions ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Wine_Regions/{WineRegionID}" ; rr:termType rr:IRI ] ] .

