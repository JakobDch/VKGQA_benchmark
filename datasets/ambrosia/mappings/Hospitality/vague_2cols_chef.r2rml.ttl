@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_chef_0_Reservations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reservation_id\", \"customer_name\", \"phone_number\", \"date\", \"time\" FROM \"Reservations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{reservation_id}" ; rr:class :Reservations ] ;
  rr:predicateObjectMap [ rr:predicate p:reservation_id ; rr:objectMap [ rr:column "reservation_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_name ; rr:objectMap [ rr:column "customer_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:time ; rr:objectMap [ rr:column "time" ] ] .

<#tm_vague_2cols_chef_1_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"name\", \"email\", \"address\", \"phone_number\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customer_id}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_vague_2cols_chef_2_MenuItems_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"item_id\", \"restaurant_id\", \"item_name\", \"description\", \"price\" FROM \"MenuItems\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/MenuItems/{item_id}" ; rr:class :MenuItems ] ;
  rr:predicateObjectMap [ rr:predicate p:item_id ; rr:objectMap [ rr:column "item_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:restaurant_id ; rr:objectMap [ rr:column "restaurant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:item_name ; rr:objectMap [ rr:column "item_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_vague_2cols_chef_3_MenuItems_restaurant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"item_id\", \"restaurant_id\" FROM \"MenuItems\" WHERE \"restaurant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/MenuItems/{item_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRestaurants ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{restaurant_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_chef_4_Restaurants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"restaurant_id\", \"name\", \"location\", \"executive_chef\", \"sous_chef\", \"cuisine\" FROM \"Restaurants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{restaurant_id}" ; rr:class :Restaurants ] ;
  rr:predicateObjectMap [ rr:predicate p:restaurant_id ; rr:objectMap [ rr:column "restaurant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:executive_chef ; rr:objectMap [ rr:column "executive_chef" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:sous_chef ; rr:objectMap [ rr:column "sous_chef" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cuisine ; rr:objectMap [ rr:column "cuisine" ] ] .

<#tm_vague_2cols_chef_5_Reviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"review_id\", \"customer_id\", \"rating\", \"comments\" FROM \"Reviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reviews/{review_id}" ; rr:class :Reviews ] ;
  rr:predicateObjectMap [ rr:predicate p:review_id ; rr:objectMap [ rr:column "review_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rating ; rr:objectMap [ rr:column "rating" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:comments ; rr:objectMap [ rr:column "comments" ] ] .

<#tm_vague_2cols_chef_6_Reviews_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"review_id\", \"customer_id\" FROM \"Reviews\" WHERE \"customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reviews/{review_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{customer_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_chef_7_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employee_id\", \"first_name\", \"last_name\", \"position\", \"hire_date\", \"wage\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Employees/{employee_id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:employee_id ; rr:objectMap [ rr:column "employee_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position ; rr:objectMap [ rr:column "position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hire_date ; rr:objectMap [ rr:column "hire_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:wage ; rr:objectMap [ rr:column "wage" ] ] .

