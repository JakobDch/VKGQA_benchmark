@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_location_0_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoomID\", \"Building\", \"Area\", \"Spa\", \"Occupied\", \"Rate\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{RoomID}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomID ; rr:objectMap [ rr:column "RoomID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Building ; rr:objectMap [ rr:column "Building" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Area ; rr:objectMap [ rr:column "Area" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Spa ; rr:objectMap [ rr:column "Spa" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Occupied ; rr:objectMap [ rr:column "Occupied" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rate ; rr:objectMap [ rr:column "Rate" ] ] .

<#tm_vague_2cols_location_1_Customers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CustomerID\", \"FirstName\", \"LastName\", \"Email\", \"PhoneNumber\" FROM \"Customers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{CustomerID}" ; rr:class :Customers ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_vague_2cols_location_2_Reservations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReservationID\", \"CustomerID\", \"CheckInDate\", \"CheckOutDate\", \"TotalAmount\" FROM \"Reservations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{ReservationID}" ; rr:class :Reservations ] ;
  rr:predicateObjectMap [ rr:predicate p:ReservationID ; rr:objectMap [ rr:column "ReservationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CustomerID ; rr:objectMap [ rr:column "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckInDate ; rr:objectMap [ rr:column "CheckInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckOutDate ; rr:objectMap [ rr:column "CheckOutDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalAmount ; rr:objectMap [ rr:column "TotalAmount" ] ] .

<#tm_vague_2cols_location_3_Reservations_CustomerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReservationID\", \"CustomerID\" FROM \"Reservations\" WHERE \"CustomerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{ReservationID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomers ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Customers/{CustomerID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_4_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ServiceID\", \"Description\", \"Price\" FROM \"Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Services/{ServiceID}" ; rr:class :Services ] ;
  rr:predicateObjectMap [ rr:predicate p:ServiceID ; rr:objectMap [ rr:column "ServiceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_vague_2cols_location_5_BookedServices_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"ReservationID\", \"ServiceID\", \"Quantity\", \"TotalAmount\" FROM \"BookedServices\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/BookedServices/{BookingID}" ; rr:class :BookedServices ] ;
  rr:predicateObjectMap [ rr:predicate p:BookingID ; rr:objectMap [ rr:column "BookingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReservationID ; rr:objectMap [ rr:column "ReservationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ServiceID ; rr:objectMap [ rr:column "ServiceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalAmount ; rr:objectMap [ rr:column "TotalAmount" ] ] .

<#tm_vague_2cols_location_6_BookedServices_ServiceID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"ServiceID\" FROM \"BookedServices\" WHERE \"ServiceID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/BookedServices/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasServices ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Services/{ServiceID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_7_BookedServices_ReservationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"ReservationID\" FROM \"BookedServices\" WHERE \"ReservationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/BookedServices/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReservations ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{ReservationID}" ; rr:termType rr:IRI ] ] .

