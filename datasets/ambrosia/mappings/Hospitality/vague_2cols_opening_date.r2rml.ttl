@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_opening_date_0_Hotels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"HotelID\", \"Opening_Year\", \"Opening_Month\", \"Name\", \"Address\", \"City\", \"Country\" FROM \"Hotels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Hotels/{HotelID}" ; rr:class :Hotels ] ;
  rr:predicateObjectMap [ rr:predicate p:HotelID ; rr:objectMap [ rr:column "HotelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Opening_Year ; rr:objectMap [ rr:column "Opening_Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Opening_Month ; rr:objectMap [ rr:column "Opening_Month" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_vague_2cols_opening_date_1_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoomID\", \"HotelID\", \"Type\", \"Capacity\", \"Rate\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{RoomID}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomID ; rr:objectMap [ rr:column "RoomID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HotelID ; rr:objectMap [ rr:column "HotelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rate ; rr:objectMap [ rr:column "Rate" ] ] .

<#tm_vague_2cols_opening_date_2_Rooms_HotelID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoomID\", \"HotelID\" FROM \"Rooms\" WHERE \"HotelID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{RoomID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHotels ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Hotels/{HotelID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_opening_date_3_Bookings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"GuestID\", \"RoomID\", \"CheckInDate\", \"CheckOutDate\", \"TotalCost\" FROM \"Bookings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ; rr:class :Bookings ] ;
  rr:predicateObjectMap [ rr:predicate p:BookingID ; rr:objectMap [ rr:column "BookingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GuestID ; rr:objectMap [ rr:column "GuestID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomID ; rr:objectMap [ rr:column "RoomID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckInDate ; rr:objectMap [ rr:column "CheckInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CheckOutDate ; rr:objectMap [ rr:column "CheckOutDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalCost ; rr:objectMap [ rr:column "TotalCost" ] ] .

<#tm_vague_2cols_opening_date_4_Bookings_RoomID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"RoomID\" FROM \"Bookings\" WHERE \"RoomID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Rooms/{RoomID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_opening_date_5_Bookings_GuestID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BookingID\", \"GuestID\" FROM \"Bookings\" WHERE \"GuestID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Bookings/{BookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuests ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Guests/{GuestID}" ; rr:termType rr:IRI ] ] .

