@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_chef_0_Executive_chef_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"chef_id\", \"full_name\" FROM \"Executive_chef\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Executive_chef/{chef_id}" ; rr:class :Executive_chef ] ;
  rr:predicateObjectMap [ rr:predicate p:chef_id ; rr:objectMap [ rr:column "chef_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_vague_2tabs_chef_1_Sous_chef_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"sous_id\", \"executive_chef_id\", \"full_name\" FROM \"Sous_chef\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Sous_chef/{sous_id}" ; rr:class :Sous_chef ] ;
  rr:predicateObjectMap [ rr:predicate p:sous_id ; rr:objectMap [ rr:column "sous_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:executive_chef_id ; rr:objectMap [ rr:column "executive_chef_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_vague_2tabs_chef_2_Sous_chef_executive_chef_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"sous_id\", \"executive_chef_id\" FROM \"Sous_chef\" WHERE \"executive_chef_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Sous_chef/{sous_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasExecutive_chef ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Executive_chef/{executive_chef_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_chef_3_Restaurant_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"restaurant_id\", \"name\", \"address\", \"executive_chef_id\", \"SOUS_CHEF_ID\" FROM \"Restaurant\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Restaurants/{restaurant_id}" ; rr:class :Restaurants ] ;
