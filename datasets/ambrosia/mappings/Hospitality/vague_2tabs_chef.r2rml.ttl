  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:executive_chef_id ; rr:objectMap [ rr:column "executive_chef_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SOUS_CHEF_ID ; rr:objectMap [ rr:column "SOUS_CHEF_ID" ] ] .

