  rr:predicateObjectMap [ rr:predicate p:customerId ; rr:objectMap [ rr:column "customerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roomTypeId ; rr:objectMap [ rr:column "roomTypeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkInDate ; rr:objectMap [ rr:column "checkInDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:checkOutDate ; rr:objectMap [ rr:column "checkOutDate" ] ] .

<#tm_vague_2tabs_docking_location_2_Reservations_roomTypeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"roomTypeId\" FROM \"Reservations\" WHERE \"roomTypeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRoomTypes ; rr:objectMap [ rr:template "http://ambrosia.example.org/hospitality/id/RoomTypes/{roomTypeId}" ; rr:termType rr:IRI ] ] .

