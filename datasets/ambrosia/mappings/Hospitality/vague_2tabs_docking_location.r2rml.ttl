  rr:predicateObjectMap [ rr:predicate p:amountPaid ; rr:objectMap [ rr:column "amountPaid" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:paymentMethod ; rr:objectMap [ rr:column "paymentMethod" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:transactionTime ; rr:objectMap [ rr:column "transactionTime" ] ] .

