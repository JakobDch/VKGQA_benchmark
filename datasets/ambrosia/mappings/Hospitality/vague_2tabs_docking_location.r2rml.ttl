@prefix : <http://ambrosia.example.org/hospitality#> .
@prefix p: <http://ambrosia.example.org/hospitality/prop#> .
@prefix ex: <http://ambrosia.example.org/hospitality/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_docking_location_0_RoomTypes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"typeName\", \"capacity\", \"pricePerNight\" FROM \"RoomTypes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/RoomTypes/{id}" ; rr:class :RoomTypes ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:typeName ; rr:objectMap [ rr:column "typeName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:capacity ; rr:objectMap [ rr:column "capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:pricePerNight ; rr:objectMap [ rr:column "pricePerNight" ] ] .

<#tm_vague_2tabs_docking_location_1_Reservations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"customerId\", \"roomTypeId\", \"checkInDate\", \"checkOutDate\" FROM \"Reservations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/hospitality/id/Reservations/{id}" ; rr:class :Reservations ] ;
