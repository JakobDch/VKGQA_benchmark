@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_affordable_housing_projects_financing_sources_0_Affordable_Housing_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"project_id\", \"project_name\", \"location\" FROM \"Affordable_Housing_Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Affordable_Housing_Projects/{project_id}" ; rr:class :Affordable_Housing_Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:project_id ; rr:objectMap [ rr:column "project_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:project_name ; rr:objectMap [ rr:column "project_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_affordable_housing_projects_financing_sources_1_Financing_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"source_id\", \"source_value\" FROM \"Financing_Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Financing_Sources/{source_id}" ; rr:class :Financing_Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:source_id ; rr:objectMap [ rr:column "source_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:source_value ; rr:objectMap [ rr:column "source_value" ] ] .

<#tm_scope_affordable_housing_projects_financing_sources_2_Affordable_Housing_Projects_Financing_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"housing_project_id\", \"financing_source_id\" FROM \"Affordable_Housing_Projects_Financing_Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Affordable_Housing_Projects_Financing_Sources/{id}" ; rr:class :Affordable_Housing_Projects_Financing_Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:housing_project_id ; rr:objectMap [ rr:column "housing_project_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:financing_source_id ; rr:objectMap [ rr:column "financing_source_id" ] ] .

<#tm_scope_affordable_housing_projects_financing_sources_3_Affordable_Housing_Projects_Financing_Sources_financing_source_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"financing_source_id\" FROM \"Affordable_Housing_Projects_Financing_Sources\" WHERE \"financing_source_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Affordable_Housing_Projects_Financing_Sources/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFinancing_Sources ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Financing_Sources/{financing_source_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_affordable_housing_projects_financing_sources_4_Affordable_Housing_Projects_Financing_Sources_housing_project_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"housing_project_id\" FROM \"Affordable_Housing_Projects_Financing_Sources\" WHERE \"housing_project_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Affordable_Housing_Projects_Financing_Sources/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAffordable_Housing_Projects ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Affordable_Housing_Projects/{housing_project_id}" ; rr:termType rr:IRI ] ] .

