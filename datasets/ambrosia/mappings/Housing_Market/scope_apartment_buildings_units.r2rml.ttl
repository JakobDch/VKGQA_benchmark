@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_apartment_buildings_units_0_Apartment_Buildings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"city\", \"state\", \"zipcode\", \"num_units\" FROM \"Apartment_Buildings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Apartment_Buildings/{id}" ; rr:class :Apartment_Buildings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:state ; rr:objectMap [ rr:column "state" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:zipcode ; rr:objectMap [ rr:column "zipcode" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:num_units ; rr:objectMap [ rr:column "num_units" ] ] .

<#tm_scope_apartment_buildings_units_1_Units_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"unit_type\", \"description\" FROM \"Units\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Units/{id}" ; rr:class :Units ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:unit_type ; rr:objectMap [ rr:column "unit_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_apartment_buildings_units_2_Apartment_Buildings_Units_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"building_id\", \"unit_id\" FROM \"Apartment_Buildings_Units\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Apartment_Buildings_Units/{_amb_rowid}" ; rr:class :Apartment_Buildings_Units ] ;
  rr:predicateObjectMap [ rr:predicate p:building_id ; rr:objectMap [ rr:column "building_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:unit_id ; rr:objectMap [ rr:column "unit_id" ] ] .

<#tm_scope_apartment_buildings_units_3_Apartment_Buildings_Units_unit_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"unit_id\" FROM \"Apartment_Buildings_Units\" WHERE \"unit_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Apartment_Buildings_Units/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUnits ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Units/{unit_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_apartment_buildings_units_4_Apartment_Buildings_Units_building_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"building_id\" FROM \"Apartment_Buildings_Units\" WHERE \"building_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Apartment_Buildings_Units/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApartment_Buildings ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Apartment_Buildings/{building_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_apartment_buildings_units_5_Tenants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"tenant_id\", \"firstname\", \"lastname\", \"email\", \"phone\" FROM \"Tenants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Tenants/{tenant_id}" ; rr:class :Tenants ] ;
  rr:predicateObjectMap [ rr:predicate p:tenant_id ; rr:objectMap [ rr:column "tenant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstname ; rr:objectMap [ rr:column "firstname" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastname ; rr:objectMap [ rr:column "lastname" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone ; rr:objectMap [ rr:column "phone" ] ] .

<#tm_scope_apartment_buildings_units_6_RentPayments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"payment_id\", \"amount\", \"paid_date\", \"due_date\", \"tenant_id\" FROM \"RentPayments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/RentPayments/{payment_id}" ; rr:class :RentPayments ] ;
  rr:predicateObjectMap [ rr:predicate p:payment_id ; rr:objectMap [ rr:column "payment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:amount ; rr:objectMap [ rr:column "amount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:paid_date ; rr:objectMap [ rr:column "paid_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:due_date ; rr:objectMap [ rr:column "due_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:tenant_id ; rr:objectMap [ rr:column "tenant_id" ] ] .

<#tm_scope_apartment_buildings_units_7_RentPayments_tenant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"payment_id\", \"tenant_id\" FROM \"RentPayments\" WHERE \"tenant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/RentPayments/{payment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTenants ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Tenants/{tenant_id}" ; rr:termType rr:IRI ] ] .

