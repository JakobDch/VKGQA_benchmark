@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_authorities_programs_0_Authorities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"authority_id\", \"name\", \"contact_info\" FROM \"Authorities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Authorities/{authority_id}" ; rr:class :Authorities ] ;
  rr:predicateObjectMap [ rr:predicate p:authority_id ; rr:objectMap [ rr:column "authority_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contact_info ; rr:objectMap [ rr:column "contact_info" ] ] .

<#tm_scope_authorities_programs_1_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"program_id\", \"program_name\", \"description\" FROM \"Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Programs/{program_id}" ; rr:class :Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:program_id ; rr:objectMap [ rr:column "program_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:program_name ; rr:objectMap [ rr:column "program_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_authorities_programs_2_Authorities_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"authority_id\", \"program_id\" FROM \"Authorities_Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Authorities_Programs/{id}" ; rr:class :Authorities_Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:authority_id ; rr:objectMap [ rr:column "authority_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:program_id ; rr:objectMap [ rr:column "program_id" ] ] .

<#tm_scope_authorities_programs_3_Authorities_Programs_program_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"program_id\" FROM \"Authorities_Programs\" WHERE \"program_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Authorities_Programs/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPrograms ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Programs/{program_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_authorities_programs_4_Authorities_Programs_authority_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"authority_id\" FROM \"Authorities_Programs\" WHERE \"authority_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Authorities_Programs/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthorities ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Authorities/{authority_id}" ; rr:termType rr:IRI ] ] .

