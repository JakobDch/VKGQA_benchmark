@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_communities_features1_0_Communities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"community_id\", \"community_name\", \"location\" FROM \"Communities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Communities/{community_id}" ; rr:class :Communities ] ;
  rr:predicateObjectMap [ rr:predicate p:community_id ; rr:objectMap [ rr:column "community_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:community_name ; rr:objectMap [ rr:column "community_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_communities_features1_1_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"feature_id\", \"feature_value\" FROM \"Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Features/{feature_id}" ; rr:class :Features ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_id ; rr:objectMap [ rr:column "feature_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_value ; rr:objectMap [ rr:column "feature_value" ] ] .

<#tm_scope_communities_features1_2_Communities_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cf_id\", \"community_id\", \"feature_id\", \"detail_description\" FROM \"Communities_Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Communities_Features/{cf_id}" ; rr:class :Communities_Features ] ;
  rr:predicateObjectMap [ rr:predicate p:cf_id ; rr:objectMap [ rr:column "cf_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:community_id ; rr:objectMap [ rr:column "community_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_id ; rr:objectMap [ rr:column "feature_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:detail_description ; rr:objectMap [ rr:column "detail_description" ] ] .

<#tm_scope_communities_features1_3_Communities_Features_feature_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cf_id\", \"feature_id\" FROM \"Communities_Features\" WHERE \"feature_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Communities_Features/{cf_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFeatures ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Features/{feature_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_communities_features1_4_Communities_Features_community_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cf_id\", \"community_id\" FROM \"Communities_Features\" WHERE \"community_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Communities_Features/{cf_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCommunities ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Communities/{community_id}" ; rr:termType rr:IRI ] ] .

