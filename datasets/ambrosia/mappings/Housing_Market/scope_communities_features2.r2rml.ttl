@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_communities_features2_0_Communities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Communities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Communities/{id}" ; rr:class :Communities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_communities_features2_1_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"feature_name\" FROM \"Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Features/{id}" ; rr:class :Features ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_name ; rr:objectMap [ rr:column "feature_name" ] ] .

<#tm_scope_communities_features2_2_Communities_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"community_id\", \"feature_id\" FROM \"Communities_Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Communities_Features/{_amb_rowid}" ; rr:class :Communities_Features ] ;
  rr:predicateObjectMap [ rr:predicate p:community_id ; rr:objectMap [ rr:column "community_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_id ; rr:objectMap [ rr:column "feature_id" ] ] .

<#tm_scope_communities_features2_3_Communities_Features_feature_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"feature_id\" FROM \"Communities_Features\" WHERE \"feature_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Communities_Features/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFeatures ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Features/{feature_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_communities_features2_4_Communities_Features_community_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"community_id\" FROM \"Communities_Features\" WHERE \"community_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Communities_Features/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCommunities ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Communities/{community_id}" ; rr:termType rr:IRI ] ] .

