@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_community_development_corporations_initiatives_0_Community_Development_Corporations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Community_Development_Corporations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Community_Development_Corporations/{id}" ; rr:class :Community_Development_Corporations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_community_development_corporations_initiatives_1_Initiatives_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"initiative_name\", \"description\" FROM \"Initiatives\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Initiatives/{id}" ; rr:class :Initiatives ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:initiative_name ; rr:objectMap [ rr:column "initiative_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_community_development_corporations_initiatives_2_Community_Development_Corporations_Initiatives_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"community_development_corporation_id\", \"initiative_id\" FROM \"Community_Development_Corporations_Initiatives\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Community_Development_Corporations_Initiatives/{_amb_rowid}" ; rr:class :Community_Development_Corporations_Initiatives ] ;
  rr:predicateObjectMap [ rr:predicate p:community_development_corporation_id ; rr:objectMap [ rr:column "community_development_corporation_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:initiative_id ; rr:objectMap [ rr:column "initiative_id" ] ] .

<#tm_scope_community_development_corporations_initiatives_3_Community_Development_Corporations_Initiatives_initiative_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"initiative_id\" FROM \"Community_Development_Corporations_Initiatives\" WHERE \"initiative_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Community_Development_Corporations_Initiatives/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInitiatives ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Initiatives/{initiative_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_community_development_corporations_initiatives_4_Community_Development_Corporations_Initiatives_community_development_corporation_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"community_development_corporation_id\" FROM \"Community_Development_Corporations_Initiatives\" WHERE \"community_development_corporation_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Community_Development_Corporations_Initiatives/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCommunity_Development_Corporations ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Community_Development_Corporations/{community_development_corporation_id}" ; rr:termType rr:IRI ] ] .

