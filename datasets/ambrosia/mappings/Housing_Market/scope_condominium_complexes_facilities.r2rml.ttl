@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_condominium_complexes_facilities_0_Condominium_Complexes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Condominium_Complexes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Condominium_Complexes/{id}" ; rr:class :Condominium_Complexes ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_condominium_complexes_facilities_1_Facilities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"facilityName\" FROM \"Facilities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Facilities/{id}" ; rr:class :Facilities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:facilityName ; rr:objectMap [ rr:column "facilityName" ] ] .

<#tm_scope_condominium_complexes_facilities_2_Condominium_Complexes_Facilities_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"condoId\", \"facilityId\" FROM \"Condominium_Complexes_Facilities\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Condominium_Complexes_Facilities/{_amb_rowid}" ; rr:class :Condominium_Complexes_Facilities ] ;
  rr:predicateObjectMap [ rr:predicate p:condoId ; rr:objectMap [ rr:column "condoId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:facilityId ; rr:objectMap [ rr:column "facilityId" ] ] .

<#tm_scope_condominium_complexes_facilities_3_Condominium_Complexes_Facilities_facilityId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"facilityId\" FROM \"Condominium_Complexes_Facilities\" WHERE \"facilityId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Condominium_Complexes_Facilities/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFacilities ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Facilities/{facilityId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_condominium_complexes_facilities_4_Condominium_Complexes_Facilities_condoId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"condoId\" FROM \"Condominium_Complexes_Facilities\" WHERE \"condoId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Condominium_Complexes_Facilities/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCondominium_Complexes ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Condominium_Complexes/{condoId}" ; rr:termType rr:IRI ] ] .

