@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_construction_companies_projects_0_Construction_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"company_name\", \"location\" FROM \"Construction_Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Construction_Companies/{id}" ; rr:class :Construction_Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_name ; rr:objectMap [ rr:column "company_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_construction_companies_projects_1_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"project_type\", \"start_date\", \"end_date\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Projects/{id}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:project_type ; rr:objectMap [ rr:column "project_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] .

<#tm_scope_construction_companies_projects_2_Construction_Companies_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"construction_company_id\", \"project_id\" FROM \"Construction_Companies_Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Construction_Companies_Projects/{construction_company_id}/{project_id}" ; rr:class :Construction_Companies_Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:construction_company_id ; rr:objectMap [ rr:column "construction_company_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:project_id ; rr:objectMap [ rr:column "project_id" ] ] .

<#tm_scope_construction_companies_projects_3_Construction_Companies_Projects_project_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"construction_company_id\", \"project_id\" FROM \"Construction_Companies_Projects\" WHERE \"project_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Construction_Companies_Projects/{construction_company_id}/{project_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Projects/{project_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_construction_companies_projects_4_Construction_Companies_Projects_construction_company_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"construction_company_id\", \"project_id\" FROM \"Construction_Companies_Projects\" WHERE \"construction_company_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Construction_Companies_Projects/{construction_company_id}/{project_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasConstruction_Companies ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Construction_Companies/{construction_company_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_construction_companies_projects_5_House_Sizes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"house_size_id\", \"size_in_sqft\", \"price\" FROM \"House_Sizes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/House_Sizes/{house_size_id}" ; rr:class :House_Sizes ] ;
  rr:predicateObjectMap [ rr:predicate p:house_size_id ; rr:objectMap [ rr:column "house_size_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:size_in_sqft ; rr:objectMap [ rr:column "size_in_sqft" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_construction_companies_projects_6_Material_Types_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"material_type_id\", \"type_of_material\", \"cost_per_unit\" FROM \"Material_Types\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Material_Types/{material_type_id}" ; rr:class :Material_Types ] ;
  rr:predicateObjectMap [ rr:predicate p:material_type_id ; rr:objectMap [ rr:column "material_type_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type_of_material ; rr:objectMap [ rr:column "type_of_material" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cost_per_unit ; rr:objectMap [ rr:column "cost_per_unit" ] ] .

