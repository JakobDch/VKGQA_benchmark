@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_design_build_firms_project_types_0_Design_Build_Firms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"FirmID\", \"Name\", \"Address\" FROM \"Design_Build_Firms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Design_Build_Firms/{FirmID}" ; rr:class :Design_Build_Firms ] ;
  rr:predicateObjectMap [ rr:predicate p:FirmID ; rr:objectMap [ rr:column "FirmID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] .

<#tm_scope_design_build_firms_project_types_1_Project_Types_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TypeID\", \"Description\" FROM \"Project_Types\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Project_Types/{TypeID}" ; rr:class :Project_Types ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeID ; rr:objectMap [ rr:column "TypeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_scope_design_build_firms_project_types_2_Design_Build_Firms_Project_Types_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"FirmID\", \"TypeID\" FROM \"Design_Build_Firms_Project_Types\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Design_Build_Firms_Project_Types/{_amb_rowid}" ; rr:class :Design_Build_Firms_Project_Types ] ;
  rr:predicateObjectMap [ rr:predicate p:FirmID ; rr:objectMap [ rr:column "FirmID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeID ; rr:objectMap [ rr:column "TypeID" ] ] .

<#tm_scope_design_build_firms_project_types_3_Design_Build_Firms_Project_Types_TypeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"TypeID\" FROM \"Design_Build_Firms_Project_Types\" WHERE \"TypeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Design_Build_Firms_Project_Types/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProject_Types ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Project_Types/{TypeID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_design_build_firms_project_types_4_Design_Build_Firms_Project_Types_FirmID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"FirmID\" FROM \"Design_Build_Firms_Project_Types\" WHERE \"FirmID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Design_Build_Firms_Project_Types/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDesign_Build_Firms ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Design_Build_Firms/{FirmID}" ; rr:termType rr:IRI ] ] .

