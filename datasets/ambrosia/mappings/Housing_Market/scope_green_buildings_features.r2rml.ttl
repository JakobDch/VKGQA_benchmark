@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_green_buildings_features_0_Green_Buildings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"address\", \"price\" FROM \"Green_Buildings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Green_Buildings/{id}" ; rr:class :Green_Buildings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_green_buildings_features_1_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"feature_id\", \"name\" FROM \"Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Features/{feature_id}" ; rr:class :Features ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_id ; rr:objectMap [ rr:column "feature_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_green_buildings_features_2_Green_Buildings_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"green_building_id\", \"feature_id\" FROM \"Green_Buildings_Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Green_Buildings_Features/{green_building_id}/{feature_id}" ; rr:class :Green_Buildings_Features ] ;
  rr:predicateObjectMap [ rr:predicate p:green_building_id ; rr:objectMap [ rr:column "green_building_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feature_id ; rr:objectMap [ rr:column "feature_id" ] ] .

<#tm_scope_green_buildings_features_3_Green_Buildings_Features_feature_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"green_building_id\", \"feature_id\" FROM \"Green_Buildings_Features\" WHERE \"feature_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Green_Buildings_Features/{green_building_id}/{feature_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFeatures ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Features/{feature_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_green_buildings_features_4_Green_Buildings_Features_green_building_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"green_building_id\", \"feature_id\" FROM \"Green_Buildings_Features\" WHERE \"green_building_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Green_Buildings_Features/{green_building_id}/{feature_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGreen_Buildings ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Green_Buildings/{green_building_id}" ; rr:termType rr:IRI ] ] .

