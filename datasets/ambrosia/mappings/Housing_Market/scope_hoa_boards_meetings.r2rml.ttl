@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_hoa_boards_meetings_0_Hoa_Boards_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"board_id\", \"address\", \"president_name\" FROM \"Hoa_Boards\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Hoa_Boards/{board_id}" ; rr:class :Hoa_Boards ] ;
  rr:predicateObjectMap [ rr:predicate p:board_id ; rr:objectMap [ rr:column "board_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:president_name ; rr:objectMap [ rr:column "president_name" ] ] .

<#tm_scope_hoa_boards_meetings_1_Meetings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"meeting_id\", \"meeting_type\" FROM \"Meetings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Meetings/{meeting_id}" ; rr:class :Meetings ] ;
  rr:predicateObjectMap [ rr:predicate p:meeting_id ; rr:objectMap [ rr:column "meeting_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:meeting_type ; rr:objectMap [ rr:column "meeting_type" ] ] .

<#tm_scope_hoa_boards_meetings_2_Members_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"member_id\", \"name\", \"email\" FROM \"Members\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Members/{member_id}" ; rr:class :Members ] ;
  rr:predicateObjectMap [ rr:predicate p:member_id ; rr:objectMap [ rr:column "member_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_hoa_boards_meetings_3_Hoa_Board_Members_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"hoa_board_id\", \"member_id\" FROM \"Hoa_Board_Members\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Hoa_Board_Members/{hoa_board_id}/{member_id}" ; rr:class :Hoa_Board_Members ] ;
  rr:predicateObjectMap [ rr:predicate p:hoa_board_id ; rr:objectMap [ rr:column "hoa_board_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:member_id ; rr:objectMap [ rr:column "member_id" ] ] .

<#tm_scope_hoa_boards_meetings_4_Hoa_Board_Members_member_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"hoa_board_id\", \"member_id\" FROM \"Hoa_Board_Members\" WHERE \"member_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Hoa_Board_Members/{hoa_board_id}/{member_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMembers ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Members/{member_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_hoa_boards_meetings_5_Hoa_Board_Members_hoa_board_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"hoa_board_id\", \"member_id\" FROM \"Hoa_Board_Members\" WHERE \"hoa_board_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Hoa_Board_Members/{hoa_board_id}/{member_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHoa_Boards ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Hoa_Boards/{hoa_board_id}" ; rr:termType rr:IRI ] ] .

