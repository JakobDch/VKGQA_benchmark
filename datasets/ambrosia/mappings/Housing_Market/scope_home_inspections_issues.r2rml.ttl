@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_home_inspections_issues_0_Home_Inspections_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"address\", \"inspection_date\" FROM \"Home_Inspections\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Home_Inspections/{id}" ; rr:class :Home_Inspections ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:inspection_date ; rr:objectMap [ rr:column "inspection_date" ] ] .

<#tm_scope_home_inspections_issues_1_Issues_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"issue_type\" FROM \"Issues\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Issues/{id}" ; rr:class :Issues ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:issue_type ; rr:objectMap [ rr:column "issue_type" ] ] .

<#tm_scope_home_inspections_issues_2_Home_Inspection_Issues_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"home_inspection_id\", \"issue_id\" FROM \"Home_Inspection_Issues\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Home_Inspection_Issues/{_amb_rowid}" ; rr:class :Home_Inspection_Issues ] ;
  rr:predicateObjectMap [ rr:predicate p:home_inspection_id ; rr:objectMap [ rr:column "home_inspection_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:issue_id ; rr:objectMap [ rr:column "issue_id" ] ] .

<#tm_scope_home_inspections_issues_3_Home_Inspection_Issues_issue_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"issue_id\" FROM \"Home_Inspection_Issues\" WHERE \"issue_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Home_Inspection_Issues/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasIssues ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Issues/{issue_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_home_inspections_issues_4_Home_Inspection_Issues_home_inspection_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"home_inspection_id\" FROM \"Home_Inspection_Issues\" WHERE \"home_inspection_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Home_Inspection_Issues/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHome_Inspections ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Home_Inspections/{home_inspection_id}" ; rr:termType rr:IRI ] ] .

