@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_home_insurance_policies_coverage_options_0_Home_Insurance_Policies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PolicyID\", \"HomeAddress\", \"InsuredAmount\" FROM \"Home_Insurance_Policies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Home_Insurance_Policies/{PolicyID}" ; rr:class :Home_Insurance_Policies ] ;
  rr:predicateObjectMap [ rr:predicate p:PolicyID ; rr:objectMap [ rr:column "PolicyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HomeAddress ; rr:objectMap [ rr:column "HomeAddress" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:InsuredAmount ; rr:objectMap [ rr:column "InsuredAmount" ] ] .

<#tm_scope_home_insurance_policies_coverage_options_1_Coverage_Options_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OptionID\", \"Description\" FROM \"Coverage_Options\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Coverage_Options/{OptionID}" ; rr:class :Coverage_Options ] ;
  rr:predicateObjectMap [ rr:predicate p:OptionID ; rr:objectMap [ rr:column "OptionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_scope_home_insurance_policies_coverage_options_2_Home_Insurance_Policies_Coverage_Options_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PolicyID\", \"OptionID\" FROM \"Home_Insurance_Policies_Coverage_Options\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Home_Insurance_Policies_Coverage_Options/{PolicyID}/{OptionID}" ; rr:class :Home_Insurance_Policies_Coverage_Options ] ;
  rr:predicateObjectMap [ rr:predicate p:PolicyID ; rr:objectMap [ rr:column "PolicyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OptionID ; rr:objectMap [ rr:column "OptionID" ] ] .

<#tm_scope_home_insurance_policies_coverage_options_3_Home_Insurance_Policies_Coverage_Options_OptionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PolicyID\", \"OptionID\" FROM \"Home_Insurance_Policies_Coverage_Options\" WHERE \"OptionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Home_Insurance_Policies_Coverage_Options/{PolicyID}/{OptionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCoverage_Options ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Coverage_Options/{OptionID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_home_insurance_policies_coverage_options_4_Home_Insurance_Policies_Coverage_Options_PolicyID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PolicyID\", \"OptionID\" FROM \"Home_Insurance_Policies_Coverage_Options\" WHERE \"PolicyID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Home_Insurance_Policies_Coverage_Options/{PolicyID}/{OptionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHome_Insurance_Policies ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Home_Insurance_Policies/{PolicyID}" ; rr:termType rr:IRI ] ] .

