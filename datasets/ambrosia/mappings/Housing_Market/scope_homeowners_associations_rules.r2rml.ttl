@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_homeowners_associations_rules_0_Homeowners_associations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Homeowners_associations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homeowners_associations/{id}" ; rr:class :Homeowners_associations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_homeowners_associations_rules_1_Rules_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ruleid\", \"rulename\", \"description\" FROM \"Rules\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Rules/{ruleid}" ; rr:class :Rules ] ;
  rr:predicateObjectMap [ rr:predicate p:ruleid ; rr:objectMap [ rr:column "ruleid" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rulename ; rr:objectMap [ rr:column "rulename" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_homeowners_associations_rules_2_Homes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"houseid\", \"address\", \"price\" FROM \"Homes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homes/{houseid}" ; rr:class :Homes ] ;
  rr:predicateObjectMap [ rr:predicate p:houseid ; rr:objectMap [ rr:column "houseid" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_homeowners_associations_rules_3_Homeowners_associations_homes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"associd\", \"houseid\" FROM \"Homeowners_associations_homes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homeowners_associations_homes/{associd}/{houseid}" ; rr:class :Homeowners_associations_homes ] ;
  rr:predicateObjectMap [ rr:predicate p:associd ; rr:objectMap [ rr:column "associd" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:houseid ; rr:objectMap [ rr:column "houseid" ] ] .

<#tm_scope_homeowners_associations_rules_4_Homeowners_associations_homes_houseid_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"associd\", \"houseid\" FROM \"Homeowners_associations_homes\" WHERE \"houseid\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homeowners_associations_homes/{associd}/{houseid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHomes ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homes/{houseid}" ; rr:termType rr:IRI ] ] .

<#tm_scope_homeowners_associations_rules_5_Homeowners_associations_homes_associd_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"associd\", \"houseid\" FROM \"Homeowners_associations_homes\" WHERE \"associd\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homeowners_associations_homes/{associd}/{houseid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHomeowners_associations ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homeowners_associations/{associd}" ; rr:termType rr:IRI ] ] .

<#tm_scope_homeowners_associations_rules_6_Homeowners_association_rules_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"associd\", \"ruleid\" FROM \"Homeowners_association_rules\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homeowners_association_rules/{associd}/{ruleid}" ; rr:class :Homeowners_association_rules ] ;
  rr:predicateObjectMap [ rr:predicate p:associd ; rr:objectMap [ rr:column "associd" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ruleid ; rr:objectMap [ rr:column "ruleid" ] ] .

<#tm_scope_homeowners_associations_rules_7_Homeowners_association_rules_ruleid_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"associd\", \"ruleid\" FROM \"Homeowners_association_rules\" WHERE \"ruleid\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homeowners_association_rules/{associd}/{ruleid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRules ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Rules/{ruleid}" ; rr:termType rr:IRI ] ] .

<#tm_scope_homeowners_associations_rules_8_Homeowners_association_rules_associd_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"associd\", \"ruleid\" FROM \"Homeowners_association_rules\" WHERE \"associd\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homeowners_association_rules/{associd}/{ruleid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHomeowners_associations ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Homeowners_associations/{associd}" ; rr:termType rr:IRI ] ] .

