@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_houses_rooms_0_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"roomType\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Rooms/{id}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roomType ; rr:objectMap [ rr:column "roomType" ] ] .

<#tm_scope_houses_rooms_1_HouseFeatures_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"featureName\" FROM \"HouseFeatures\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/HouseFeatures/{id}" ; rr:class :HouseFeatures ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:featureName ; rr:objectMap [ rr:column "featureName" ] ] .

<#tm_scope_houses_rooms_2_Houses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"address\", \"price\", \"numOfFloors\" FROM \"Houses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Houses/{id}" ; rr:class :Houses ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:numOfFloors ; rr:objectMap [ rr:column "numOfFloors" ] ] .

<#tm_scope_houses_rooms_3_Houses_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"houseId\", \"roomId\" FROM \"Houses_Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Houses_Rooms/{houseId}/{roomId}" ; rr:class :Houses_Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:houseId ; rr:objectMap [ rr:column "houseId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roomId ; rr:objectMap [ rr:column "roomId" ] ] .

<#tm_scope_houses_rooms_4_Houses_Rooms_roomId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"houseId\", \"roomId\" FROM \"Houses_Rooms\" WHERE \"roomId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Houses_Rooms/{houseId}/{roomId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Rooms/{roomId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_houses_rooms_5_Houses_Rooms_houseId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"houseId\", \"roomId\" FROM \"Houses_Rooms\" WHERE \"houseId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Houses_Rooms/{houseId}/{roomId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHouses ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Houses/{houseId}" ; rr:termType rr:IRI ] ] .

