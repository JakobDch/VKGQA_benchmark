@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_housing_finance_agencies_loan_programs_0_Housing_Market_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"city\", \"median_home_price\" FROM \"Housing_Market\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Housing_Market/{id}" ; rr:class :Housing_Market ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:median_home_price ; rr:objectMap [ rr:column "median_home_price" ] ] .

<#tm_scope_housing_finance_agencies_loan_programs_1_RealEstateAgents_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"agent_id\", \"name\", \"years_experience\" FROM \"RealEstateAgents\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/RealEstateAgents/{agent_id}" ; rr:class :RealEstateAgents ] ;
  rr:predicateObjectMap [ rr:predicate p:agent_id ; rr:objectMap [ rr:column "agent_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_experience ; rr:objectMap [ rr:column "years_experience" ] ] .

<#tm_scope_housing_finance_agencies_loan_programs_2_Housing_Finance_Agencies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"agency_id\", \"name\", \"rating\" FROM \"Housing_Finance_Agencies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Housing_Finance_Agencies/{agency_id}" ; rr:class :Housing_Finance_Agencies ] ;
  rr:predicateObjectMap [ rr:predicate p:agency_id ; rr:objectMap [ rr:column "agency_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rating ; rr:objectMap [ rr:column "rating" ] ] .

<#tm_scope_housing_finance_agencies_loan_programs_3_Loan_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"program_id\", \"description\", \"interest_rate\" FROM \"Loan_Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Loan_Programs/{program_id}" ; rr:class :Loan_Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:program_id ; rr:objectMap [ rr:column "program_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:interest_rate ; rr:objectMap [ rr:column "interest_rate" ] ] .

<#tm_scope_housing_finance_agencies_loan_programs_4_Housing_Finance_Agencies_Loan_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"housing_finance_agency_id\", \"loan_program_id\" FROM \"Housing_Finance_Agencies_Loan_Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Housing_Finance_Agencies_Loan_Programs/{housing_finance_agency_id}/{loan_program_id}" ; rr:class :Housing_Finance_Agencies_Loan_Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:housing_finance_agency_id ; rr:objectMap [ rr:column "housing_finance_agency_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:loan_program_id ; rr:objectMap [ rr:column "loan_program_id" ] ] .

<#tm_scope_housing_finance_agencies_loan_programs_5_Housing_Finance_Agencies_Loan_Programs_loan_program_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"housing_finance_agency_id\", \"loan_program_id\" FROM \"Housing_Finance_Agencies_Loan_Programs\" WHERE \"loan_program_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Housing_Finance_Agencies_Loan_Programs/{housing_finance_agency_id}/{loan_program_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLoan_Programs ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Loan_Programs/{loan_program_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_housing_finance_agencies_loan_programs_6_Housing_Finance_Agencies_Loan_Programs_housing_finance_agency_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"housing_finance_agency_id\", \"loan_program_id\" FROM \"Housing_Finance_Agencies_Loan_Programs\" WHERE \"housing_finance_agency_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Housing_Finance_Agencies_Loan_Programs/{housing_finance_agency_id}/{loan_program_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHousing_Finance_Agencies ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Housing_Finance_Agencies/{housing_finance_agency_id}" ; rr:termType rr:IRI ] ] .

