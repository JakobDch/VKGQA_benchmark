@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_land_trusts_properties_0_Land_Trusts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"trustName\", \"location\" FROM \"Land_Trusts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Land_Trusts/{id}" ; rr:class :Land_Trusts ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:trustName ; rr:objectMap [ rr:column "trustName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_land_trusts_properties_1_Land_Trusts_Properties_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"landTrustId\", \"propertyId\" FROM \"Land_Trusts_Properties\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Land_Trusts_Properties/{landTrustId}/{propertyId}" ; rr:class :Land_Trusts_Properties ] ;
  rr:predicateObjectMap [ rr:predicate p:landTrustId ; rr:objectMap [ rr:column "landTrustId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:propertyId ; rr:objectMap [ rr:column "propertyId" ] ] .

<#tm_scope_land_trusts_properties_2_Land_Trusts_Properties_propertyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"landTrustId\", \"propertyId\" FROM \"Land_Trusts_Properties\" WHERE \"propertyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Land_Trusts_Properties/{landTrustId}/{propertyId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProperties ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Properties/{propertyId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_land_trusts_properties_3_Land_Trusts_Properties_landTrustId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"landTrustId\", \"propertyId\" FROM \"Land_Trusts_Properties\" WHERE \"landTrustId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Land_Trusts_Properties/{landTrustId}/{propertyId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLand_Trusts ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Land_Trusts/{landTrustId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_land_trusts_properties_4_Properties_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"propertyId\", \"typeOfProperty\" FROM \"Properties\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Properties/{propertyId}" ; rr:class :Properties ] ;
  rr:predicateObjectMap [ rr:predicate p:propertyId ; rr:objectMap [ rr:column "propertyId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:typeOfProperty ; rr:objectMap [ rr:column "typeOfProperty" ] ] .

