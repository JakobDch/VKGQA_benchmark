@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_preservation_societies_projects_0_Preservation_Societies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Address\" FROM \"Preservation_Societies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Preservation_Societies/{ID}" ; rr:class :Preservation_Societies ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] .

<#tm_scope_preservation_societies_projects_1_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Type\", \"Description\", \"Cost\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Projects/{ID}" ; rr:class :Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Cost ; rr:objectMap [ rr:column "Cost" ] ] .

<#tm_scope_preservation_societies_projects_2_Preservation_Societies_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Societies_ID\", \"Projects_ID\", \"StartDate\", \"EndDate\" FROM \"Preservation_Societies_Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Preservation_Societies_Projects/{Societies_ID}/{Projects_ID}" ; rr:class :Preservation_Societies_Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:Societies_ID ; rr:objectMap [ rr:column "Societies_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Projects_ID ; rr:objectMap [ rr:column "Projects_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] .

<#tm_scope_preservation_societies_projects_3_Preservation_Societies_Projects_Projects_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Societies_ID\", \"Projects_ID\" FROM \"Preservation_Societies_Projects\" WHERE \"Projects_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Preservation_Societies_Projects/{Societies_ID}/{Projects_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Projects/{Projects_ID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_preservation_societies_projects_4_Preservation_Societies_Projects_Societies_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Societies_ID\", \"Projects_ID\" FROM \"Preservation_Societies_Projects\" WHERE \"Societies_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Preservation_Societies_Projects/{Societies_ID}/{Projects_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPreservation_Societies ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Preservation_Societies/{Societies_ID}" ; rr:termType rr:IRI ] ] .

