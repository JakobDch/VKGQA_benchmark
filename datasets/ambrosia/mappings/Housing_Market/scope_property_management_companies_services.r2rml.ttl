@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_property_management_companies_services_0_Property_Management_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\" FROM \"Property_Management_Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Property_Management_Companies/{id}" ; rr:class :Property_Management_Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_scope_property_management_companies_services_1_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"service_name\" FROM \"Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Services/{id}" ; rr:class :Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_name ; rr:objectMap [ rr:column "service_name" ] ] .

<#tm_scope_property_management_companies_services_2_Properties_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"property_address\", \"price\" FROM \"Properties\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Properties/{id}" ; rr:class :Properties ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:property_address ; rr:objectMap [ rr:column "property_address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_property_management_companies_services_3_Clients_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"client_name\", \"contact\" FROM \"Clients\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Clients/{id}" ; rr:class :Clients ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:client_name ; rr:objectMap [ rr:column "client_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contact ; rr:objectMap [ rr:column "contact" ] ] .

<#tm_scope_property_management_companies_services_4_Transactions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"transaction_id\", \"property_id\", \"client_id\", \"management_company_id\", \"service_id\" FROM \"Transactions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Transactions/{transaction_id}" ; rr:class :Transactions ] ;
  rr:predicateObjectMap [ rr:predicate p:transaction_id ; rr:objectMap [ rr:column "transaction_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:property_id ; rr:objectMap [ rr:column "property_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:client_id ; rr:objectMap [ rr:column "client_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:management_company_id ; rr:objectMap [ rr:column "management_company_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_id ; rr:objectMap [ rr:column "service_id" ] ] .

<#tm_scope_property_management_companies_services_5_Transactions_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"transaction_id\", \"service_id\" FROM \"Transactions\" WHERE \"service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Transactions/{transaction_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasServices ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Services/{service_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_property_management_companies_services_6_Transactions_management_company_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"transaction_id\", \"management_company_id\" FROM \"Transactions\" WHERE \"management_company_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Transactions/{transaction_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProperty_Management_Companies ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Property_Management_Companies/{management_company_id}" ; rr:termType rr:IRI ] ] .

