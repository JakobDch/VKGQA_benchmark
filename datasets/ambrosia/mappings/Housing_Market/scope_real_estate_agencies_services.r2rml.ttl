@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_real_estate_agencies_services_0_Real_Estate_Agencies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"agency_id\", \"name\", \"location\" FROM \"Real_Estate_Agencies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Real_Estate_Agencies/{agency_id}" ; rr:class :Real_Estate_Agencies ] ;
  rr:predicateObjectMap [ rr:predicate p:agency_id ; rr:objectMap [ rr:column "agency_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_real_estate_agencies_services_1_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"service_id\", \"description\", \"price\" FROM \"Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Services/{service_id}" ; rr:class :Services ] ;
  rr:predicateObjectMap [ rr:predicate p:service_id ; rr:objectMap [ rr:column "service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_real_estate_agencies_services_2_Real_Estate_Agencies_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"real_estate_agency_id\", \"service_id\" FROM \"Real_Estate_Agencies_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Real_Estate_Agencies_Services/{real_estate_agency_id}/{service_id}" ; rr:class :Real_Estate_Agencies_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:real_estate_agency_id ; rr:objectMap [ rr:column "real_estate_agency_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_id ; rr:objectMap [ rr:column "service_id" ] ] .

<#tm_scope_real_estate_agencies_services_3_Real_Estate_Agencies_Services_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"real_estate_agency_id\", \"service_id\" FROM \"Real_Estate_Agencies_Services\" WHERE \"service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Real_Estate_Agencies_Services/{real_estate_agency_id}/{service_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasServices ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Services/{service_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_real_estate_agencies_services_4_Real_Estate_Agencies_Services_real_estate_agency_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"real_estate_agency_id\", \"service_id\" FROM \"Real_Estate_Agencies_Services\" WHERE \"real_estate_agency_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Real_Estate_Agencies_Services/{real_estate_agency_id}/{service_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReal_Estate_Agencies ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Real_Estate_Agencies/{real_estate_agency_id}" ; rr:termType rr:IRI ] ] .

