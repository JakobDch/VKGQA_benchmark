@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_suburbs_schools_0_suburbs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"population\" FROM \"suburbs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/suburbs/{id}" ; rr:class :suburbs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:population ; rr:objectMap [ rr:column "population" ] ] .

<#tm_scope_suburbs_schools_1_schools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"school_type\" FROM \"schools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/schools/{id}" ; rr:class :schools ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:school_type ; rr:objectMap [ rr:column "school_type" ] ] .

<#tm_scope_suburbs_schools_2_suburbs_schools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"suburb_id\", \"school_id\" FROM \"suburbs_schools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/suburbs_schools/{_amb_rowid}" ; rr:class :suburbs_schools ] ;
  rr:predicateObjectMap [ rr:predicate p:suburb_id ; rr:objectMap [ rr:column "suburb_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:school_id ; rr:objectMap [ rr:column "school_id" ] ] .

<#tm_scope_suburbs_schools_3_suburbs_schools_school_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"school_id\" FROM \"suburbs_schools\" WHERE \"school_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/suburbs_schools/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasschools ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/schools/{school_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_suburbs_schools_4_suburbs_schools_suburb_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"suburb_id\" FROM \"suburbs_schools\" WHERE \"suburb_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/suburbs_schools/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hassuburbs ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/suburbs/{suburb_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_suburbs_schools_5_houses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"address\", \"price\", \"size\", \"bedrooms\", \"bathrooms\", \"suburb_id\" FROM \"houses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Houses/{id}" ; rr:class :Houses ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:size ; rr:objectMap [ rr:column "size" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bedrooms ; rr:objectMap [ rr:column "bedrooms" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bathrooms ; rr:objectMap [ rr:column "bathrooms" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:suburb_id ; rr:objectMap [ rr:column "suburb_id" ] ] .

<#tm_scope_suburbs_schools_6_houses_suburb_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"suburb_id\" FROM \"houses\" WHERE \"suburb_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Houses/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hassuburbs ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/suburbs/{suburb_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_suburbs_schools_7_neighborhoods_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"crime_rate\" FROM \"neighborhoods\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/neighborhoods/{id}" ; rr:class :neighborhoods ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:crime_rate ; rr:objectMap [ rr:column "crime_rate" ] ] .

<#tm_scope_suburbs_schools_8_suburbs_neighborhoods_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"suburb_id\", \"neighborhood_id\" FROM \"suburbs_neighborhoods\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/suburbs_neighborhoods/{suburb_id}/{neighborhood_id}" ; rr:class :suburbs_neighborhoods ] ;
  rr:predicateObjectMap [ rr:predicate p:suburb_id ; rr:objectMap [ rr:column "suburb_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:neighborhood_id ; rr:objectMap [ rr:column "neighborhood_id" ] ] .

<#tm_scope_suburbs_schools_9_suburbs_neighborhoods_neighborhood_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"suburb_id\", \"neighborhood_id\" FROM \"suburbs_neighborhoods\" WHERE \"neighborhood_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/suburbs_neighborhoods/{suburb_id}/{neighborhood_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasneighborhoods ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/neighborhoods/{neighborhood_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_suburbs_schools_10_suburbs_neighborhoods_suburb_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"suburb_id\", \"neighborhood_id\" FROM \"suburbs_neighborhoods\" WHERE \"suburb_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/suburbs_neighborhoods/{suburb_id}/{neighborhood_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hassuburbs ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/suburbs/{suburb_id}" ; rr:termType rr:IRI ] ] .

