  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"house_id\", \"sale_date\", \"purchase_price\" FROM \"SaleRecord\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/SaleRecord/{id}" ; rr:class :SaleRecord ] ;
