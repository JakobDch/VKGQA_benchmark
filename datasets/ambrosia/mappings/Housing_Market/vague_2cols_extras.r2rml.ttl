@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_extras_0_Location_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"city\", \"state\", \"country\" FROM \"Location\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Location/{id}" ; rr:class :Location ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:state ; rr:objectMap [ rr:column "state" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_vague_2cols_extras_1_Neighborhood_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location_id\" FROM \"Neighborhood\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/neighborhoods/{id}" ; rr:class :neighborhoods ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location_id ; rr:objectMap [ rr:column "location_id" ] ] .

<#tm_vague_2cols_extras_2_Neighborhood_location_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"location_id\" FROM \"Neighborhood\" WHERE \"location_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/neighborhoods/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocation ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Location/{location_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_extras_3_PropertyType_base> a rr:TriplesMap ;
