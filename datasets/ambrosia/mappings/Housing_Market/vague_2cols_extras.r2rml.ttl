<#tm_vague_2cols_extras_10_Mortgage_sale_record_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"sale_record_id\" FROM \"Mortgage\" WHERE \"sale_record_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Mortgage/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSaleRecord ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/SaleRecord/{sale_record_id}" ; rr:termType rr:IRI ] ] .

