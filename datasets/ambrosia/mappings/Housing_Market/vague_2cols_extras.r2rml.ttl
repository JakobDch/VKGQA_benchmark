  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"neighborhood_id\" FROM \"House\" WHERE \"neighborhood_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/House/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasneighborhoods ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/neighborhoods/{neighborhood_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_extras_6_House_property_type_id_fk> a rr:TriplesMap ;
