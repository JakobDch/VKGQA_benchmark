<#tm_vague_2cols_extras_9_Mortgage_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"sale_record_id\", \"loan_amount\", \"interest_rate\", \"mortgage_term\", \"monthly_payment\", \"start_date\", \"end_date\" FROM \"Mortgage\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Mortgage/{id}" ; rr:class :Mortgage ] ;
