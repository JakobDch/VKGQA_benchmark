  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/PropertyType/{id}" ; rr:class :PropertyType ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

