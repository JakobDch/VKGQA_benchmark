@prefix : <http://ambrosia.example.org/housingmarket#> .
@prefix p: <http://ambrosia.example.org/housingmarket/prop#> .
@prefix ex: <http://ambrosia.example.org/housingmarket/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_location_0_Properties_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"property_id\", \"Street_Address\", \"City\", \"Real_Estate_Offices\", \"Price\", \"Property_Type\", \"Square_Feet\" FROM \"Properties\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Properties/{property_id}" ; rr:class :Properties ] ;
  rr:predicateObjectMap [ rr:predicate p:property_id ; rr:objectMap [ rr:column "property_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Street_Address ; rr:objectMap [ rr:column "Street_Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Real_Estate_Offices ; rr:objectMap [ rr:column "Real_Estate_Offices" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Property_Type ; rr:objectMap [ rr:column "Property_Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Square_Feet ; rr:objectMap [ rr:column "Square_Feet" ] ] .

<#tm_vague_2cols_location_1_RealEstateOffices_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"real_estate_office_id\", \"Name\", \"Address\", \"PhoneNumber\" FROM \"RealEstateOffices\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/RealEstateOffices/{real_estate_office_id}" ; rr:class :RealEstateOffices ] ;
  rr:predicateObjectMap [ rr:predicate p:real_estate_office_id ; rr:objectMap [ rr:column "real_estate_office_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_vague_2cols_location_2_Clients_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"client_id\", \"Name\", \"Email\", \"PhoneNumber\" FROM \"Clients\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Clients/{client_id}" ; rr:class :Clients ] ;
  rr:predicateObjectMap [ rr:predicate p:client_id ; rr:objectMap [ rr:column "client_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_vague_2cols_location_3_ClientProperties_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"client_id\", \"property_id\", \"InterestedDate\" FROM \"ClientProperties\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/ClientProperties/{_amb_rowid}" ; rr:class :ClientProperties ] ;
  rr:predicateObjectMap [ rr:predicate p:client_id ; rr:objectMap [ rr:column "client_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:property_id ; rr:objectMap [ rr:column "property_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:InterestedDate ; rr:objectMap [ rr:column "InterestedDate" ] ] .

<#tm_vague_2cols_location_4_ClientProperties_property_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"property_id\" FROM \"ClientProperties\" WHERE \"property_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/ClientProperties/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProperties ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Properties/{property_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_5_ClientProperties_client_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"client_id\" FROM \"ClientProperties\" WHERE \"client_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/ClientProperties/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClients ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Clients/{client_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_6_Transactions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"transaction_id\", \"TransactionDate\", \"client_id\", \"property_id\", \"TypeOfTransaction\" FROM \"Transactions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Transactions/{transaction_id}" ; rr:class :Transactions ] ;
  rr:predicateObjectMap [ rr:predicate p:transaction_id ; rr:objectMap [ rr:column "transaction_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TransactionDate ; rr:objectMap [ rr:column "TransactionDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:client_id ; rr:objectMap [ rr:column "client_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:property_id ; rr:objectMap [ rr:column "property_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeOfTransaction ; rr:objectMap [ rr:column "TypeOfTransaction" ] ] .

<#tm_vague_2cols_location_7_Transactions_property_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"transaction_id\", \"property_id\" FROM \"Transactions\" WHERE \"property_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Transactions/{transaction_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProperties ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Properties/{property_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_8_Transactions_client_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"transaction_id\", \"client_id\" FROM \"Transactions\" WHERE \"client_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Transactions/{transaction_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClients ; rr:objectMap [ rr:template "http://ambrosia.example.org/housingmarket/id/Clients/{client_id}" ; rr:termType rr:IRI ] ] .

