@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_business_professions_0_Business_Profession_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"profession\" FROM \"Business_Profession\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Business_Profession/{id}" ; rr:class :Business_Profession ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:profession ; rr:objectMap [ rr:column "profession" ] ] .

<#tm_attachment_1tab_ref_business_professions_1_Working_Arrangement_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"arrangement\" FROM \"Working_Arrangement\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Working_Arrangement/{id}" ; rr:class :Working_Arrangement ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:arrangement ; rr:objectMap [ rr:column "arrangement" ] ] .

<#tm_attachment_1tab_ref_business_professions_2_Company_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"industry\", \"location\" FROM \"Company\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:industry ; rr:objectMap [ rr:column "industry" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_attachment_1tab_ref_business_professions_3_Job_Posting_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"required_skills\", \"salary\", \"post_date\", \"business_profession_id\", \"working_arrangement_id\", \"company_id\" FROM \"Job_Posting\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:required_skills ; rr:objectMap [ rr:column "required_skills" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:post_date ; rr:objectMap [ rr:column "post_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:business_profession_id ; rr:objectMap [ rr:column "business_profession_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:working_arrangement_id ; rr:objectMap [ rr:column "working_arrangement_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_id ; rr:objectMap [ rr:column "company_id" ] ] .

<#tm_attachment_1tab_ref_business_professions_4_Job_Posting_company_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"company_id\" FROM \"Job_Posting\" WHERE \"company_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{company_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_business_professions_5_Job_Posting_working_arrangement_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"working_arrangement_id\" FROM \"Job_Posting\" WHERE \"working_arrangement_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWorking_Arrangement ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Working_Arrangement/{working_arrangement_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_business_professions_6_Job_Posting_business_profession_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"business_profession_id\" FROM \"Job_Posting\" WHERE \"business_profession_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBusiness_Profession ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Business_Profession/{business_profession_id}" ; rr:termType rr:IRI ] ] .

