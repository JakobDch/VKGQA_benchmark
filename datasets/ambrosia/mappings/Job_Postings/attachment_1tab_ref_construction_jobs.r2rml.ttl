@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_construction_jobs_0_Employers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employerID\", \"companyName\", \"location\" FROM \"Employers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{employerID}" ; rr:class :Employers ] ;
  rr:predicateObjectMap [ rr:predicate p:employerID ; rr:objectMap [ rr:column "employerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:companyName ; rr:objectMap [ rr:column "companyName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_attachment_1tab_ref_construction_jobs_1_Applicants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"applicantID\", \"firstName\", \"lastName\", \"email\", \"phoneNumber\", \"resumePath\" FROM \"Applicants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{applicantID}" ; rr:class :Applicants ] ;
  rr:predicateObjectMap [ rr:predicate p:applicantID ; rr:objectMap [ rr:column "applicantID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:resumePath ; rr:objectMap [ rr:column "resumePath" ] ] .

<#tm_attachment_1tab_ref_construction_jobs_2_Construction_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"constructionJobID\", \"jobTitle\", \"jobDescription\", \"requiredSkills\", \"constructionJobType\", \"designSoftware\" FROM \"Construction_Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Construction_Jobs/{constructionJobID}" ; rr:class :Construction_Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:constructionJobID ; rr:objectMap [ rr:column "constructionJobID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobTitle ; rr:objectMap [ rr:column "jobTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobDescription ; rr:objectMap [ rr:column "jobDescription" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:requiredSkills ; rr:objectMap [ rr:column "requiredSkills" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:constructionJobType ; rr:objectMap [ rr:column "constructionJobType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:designSoftware ; rr:objectMap [ rr:column "designSoftware" ] ] .

<#tm_attachment_1tab_ref_construction_jobs_3_Construction_Jobs_designSoftware_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"constructionJobID\", \"designSoftware\" FROM \"Construction_Jobs\" WHERE \"designSoftware\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Construction_Jobs/{constructionJobID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDesign_Software_Expertise ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Design_Software_Expertise/{designSoftware}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_construction_jobs_4_Design_Software_Expertise_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"softwareID\", \"softwareName\" FROM \"Design_Software_Expertise\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Design_Software_Expertise/{softwareID}" ; rr:class :Design_Software_Expertise ] ;
  rr:predicateObjectMap [ rr:predicate p:softwareID ; rr:objectMap [ rr:column "softwareID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:softwareName ; rr:objectMap [ rr:column "softwareName" ] ] .

<#tm_attachment_1tab_ref_construction_jobs_5_Employed_in_Construction_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employedID\", \"applicantID\", \"constructionJobID\", \"startDate\", \"endDate\" FROM \"Employed_in_Construction_Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employed_in_Construction_Jobs/{employedID}" ; rr:class :Employed_in_Construction_Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:employedID ; rr:objectMap [ rr:column "employedID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:applicantID ; rr:objectMap [ rr:column "applicantID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:constructionJobID ; rr:objectMap [ rr:column "constructionJobID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] .

<#tm_attachment_1tab_ref_construction_jobs_6_Employed_in_Construction_Jobs_constructionJobID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employedID\", \"constructionJobID\" FROM \"Employed_in_Construction_Jobs\" WHERE \"constructionJobID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employed_in_Construction_Jobs/{employedID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasConstruction_Jobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Construction_Jobs/{constructionJobID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_construction_jobs_7_Employed_in_Construction_Jobs_applicantID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employedID\", \"applicantID\" FROM \"Employed_in_Construction_Jobs\" WHERE \"applicantID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employed_in_Construction_Jobs/{employedID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApplicants ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{applicantID}" ; rr:termType rr:IRI ] ] .

