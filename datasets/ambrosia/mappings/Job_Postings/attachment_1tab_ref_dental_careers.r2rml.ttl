@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_dental_careers_0_Education_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Degree\" FROM \"Education\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Education/{ID}" ; rr:class :Education ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Degree ; rr:objectMap [ rr:column "Degree" ] ] .

<#tm_attachment_1tab_ref_dental_careers_1_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Description\", \"Location\", \"CompanyName\", \"PostedDate\", \"FullTimePartTime\" FROM \"Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{ID}" ; rr:class :Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyName ; rr:objectMap [ rr:column "CompanyName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PostedDate ; rr:objectMap [ rr:column "PostedDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FullTimePartTime ; rr:objectMap [ rr:column "FullTimePartTime" ] ] .

<#tm_attachment_1tab_ref_dental_careers_2_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Email\", \"PhoneNumber\", \"HireDate\", \"JobID\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{ID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HireDate ; rr:objectMap [ rr:column "HireDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:JobID ; rr:objectMap [ rr:column "JobID" ] ] .

<#tm_attachment_1tab_ref_dental_careers_3_Employees_JobID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"JobID\" FROM \"Employees\" WHERE \"JobID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{JobID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_dental_careers_4_Dentists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"DentalSpecialty\", \"JoiningDate\", \"EducationID\", \"FullName\" FROM \"Dentists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Dentists/{ID}" ; rr:class :Dentists ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DentalSpecialty ; rr:objectMap [ rr:column "DentalSpecialty" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:JoiningDate ; rr:objectMap [ rr:column "JoiningDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EducationID ; rr:objectMap [ rr:column "EducationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_ref_dental_careers_5_Dentists_EducationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"EducationID\" FROM \"Dentists\" WHERE \"EducationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Dentists/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEducation ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Education/{EducationID}" ; rr:termType rr:IRI ] ] .

