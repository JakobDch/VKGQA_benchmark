@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_helping_professions_0_HelpingProfession_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProfessionID\", \"ProfessionName\" FROM \"HelpingProfession\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/HelpingProfession/{ProfessionID}" ; rr:class :HelpingProfession ] ;
  rr:predicateObjectMap [ rr:predicate p:ProfessionID ; rr:objectMap [ rr:column "ProfessionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProfessionName ; rr:objectMap [ rr:column "ProfessionName" ] ] .

<#tm_attachment_1tab_ref_helping_professions_1_GeoArea_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AreaID\", \"LocationText\" FROM \"GeoArea\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/GeoArea/{AreaID}" ; rr:class :GeoArea ] ;
  rr:predicateObjectMap [ rr:predicate p:AreaID ; rr:objectMap [ rr:column "AreaID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationText ; rr:objectMap [ rr:column "LocationText" ] ] .

<#tm_attachment_1tab_ref_helping_professions_2_Company_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CompanyID\", \"Name\", \"AddressLine1\", \"AddressLine2\", \"City\", \"State\", \"ZipCode\", \"PhoneNumber\", \"EmailAddress\" FROM \"Company\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{CompanyID}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyID ; rr:objectMap [ rr:column "CompanyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AddressLine1 ; rr:objectMap [ rr:column "AddressLine1" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AddressLine2 ; rr:objectMap [ rr:column "AddressLine2" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:State ; rr:objectMap [ rr:column "State" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ZipCode ; rr:objectMap [ rr:column "ZipCode" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] .

<#tm_attachment_1tab_ref_helping_professions_3_JobPosting_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"Title\", \"Description\", \"PostedDate\", \"DeadlineDate\", \"SalaryRange\", \"Status\", \"ProfessionID\", \"AreaID\" FROM \"JobPosting\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{JobID}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:JobID ; rr:objectMap [ rr:column "JobID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PostedDate ; rr:objectMap [ rr:column "PostedDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DeadlineDate ; rr:objectMap [ rr:column "DeadlineDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SalaryRange ; rr:objectMap [ rr:column "SalaryRange" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Status ; rr:objectMap [ rr:column "Status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProfessionID ; rr:objectMap [ rr:column "ProfessionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AreaID ; rr:objectMap [ rr:column "AreaID" ] ] .

<#tm_attachment_1tab_ref_helping_professions_4_JobPosting_AreaID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"AreaID\" FROM \"JobPosting\" WHERE \"AreaID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{JobID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGeoArea ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/GeoArea/{AreaID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_helping_professions_5_JobPosting_ProfessionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"ProfessionID\" FROM \"JobPosting\" WHERE \"ProfessionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{JobID}" ] ;
