<#tm_attachment_1tab_ref_helping_professions_7_Application_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AppID\", \"JobID\", \"ApplicantID\", \"SubmissionDate\", \"CoverLetterPath\", \"Status\" FROM \"Application\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{AppID}" ; rr:class :Application ] ;
