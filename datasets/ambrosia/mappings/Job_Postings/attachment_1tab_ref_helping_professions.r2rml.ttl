<#tm_attachment_1tab_ref_helping_professions_8_Application_ApplicantID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AppID\", \"ApplicantID\" FROM \"Application\" WHERE \"ApplicantID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{AppID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApplicants ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{ApplicantID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_helping_professions_9_Application_JobID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AppID\", \"JobID\" FROM \"Application\" WHERE \"JobID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{AppID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobPostings ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{JobID}" ; rr:termType rr:IRI ] ] .

