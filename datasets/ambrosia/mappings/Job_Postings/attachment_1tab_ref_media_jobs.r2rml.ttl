@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_media_jobs_0_Media_Types_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"TypeName\" FROM \"Media_Types\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Media_Types/{ID}" ; rr:class :Media_Types ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TypeName ; rr:objectMap [ rr:column "TypeName" ] ] .

<#tm_attachment_1tab_ref_media_jobs_1_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Description\", \"Salary\", \"PostedDate\", \"ClosingDate\", \"Status\", \"MediaTypeID\", \"LanguageProficiencyID\" FROM \"Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{ID}" ; rr:class :Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PostedDate ; rr:objectMap [ rr:column "PostedDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ClosingDate ; rr:objectMap [ rr:column "ClosingDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Status ; rr:objectMap [ rr:column "Status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MediaTypeID ; rr:objectMap [ rr:column "MediaTypeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LanguageProficiencyID ; rr:objectMap [ rr:column "LanguageProficiencyID" ] ] .

<#tm_attachment_1tab_ref_media_jobs_2_Jobs_LanguageProficiencyID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"LanguageProficiencyID\" FROM \"Jobs\" WHERE \"LanguageProficiencyID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLanguages ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Languages/{LanguageProficiencyID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_media_jobs_3_Jobs_MediaTypeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"MediaTypeID\" FROM \"Jobs\" WHERE \"MediaTypeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMedia_Types ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Media_Types/{MediaTypeID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_media_jobs_4_Media_Types_Values_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Value\" FROM \"Media_Types_Values\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Media_Types_Values/{ID}" ; rr:class :Media_Types_Values ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Value ; rr:objectMap [ rr:column "Value" ] ] .

<#tm_attachment_1tab_ref_media_jobs_5_Jobs_Values_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"JobID\", \"ValueID\" FROM \"Jobs_Values\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs_Values/{ID}" ; rr:class :Jobs_Values ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:JobID ; rr:objectMap [ rr:column "JobID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ValueID ; rr:objectMap [ rr:column "ValueID" ] ] .

<#tm_attachment_1tab_ref_media_jobs_6_Jobs_Values_ValueID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"ValueID\" FROM \"Jobs_Values\" WHERE \"ValueID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs_Values/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMedia_Types_Values ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Media_Types_Values/{ValueID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_media_jobs_7_Jobs_Values_JobID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"JobID\" FROM \"Jobs_Values\" WHERE \"JobID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs_Values/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{JobID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_media_jobs_8_Languages_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\" FROM \"Languages\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Languages/{ID}" ; rr:class :Languages ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

