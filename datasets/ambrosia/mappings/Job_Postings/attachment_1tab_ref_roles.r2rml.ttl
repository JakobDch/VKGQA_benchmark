  rr:predicateObjectMap [ rr:predicate p:DataTypeID ; rr:objectMap [ rr:column "DataTypeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DataTypeName ; rr:objectMap [ rr:column "DataTypeName" ] ] .

<#tm_attachment_1tab_ref_roles_3_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"Title\", \"Description\", \"PostedDate\", \"CompanyID\", \"ROLEID\", \"DATAID\" FROM \"Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{JobID}" ; rr:class :Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:JobID ; rr:objectMap [ rr:column "JobID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PostedDate ; rr:objectMap [ rr:column "PostedDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyID ; rr:objectMap [ rr:column "CompanyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ROLEID ; rr:objectMap [ rr:column "ROLEID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DATAID ; rr:objectMap [ rr:column "DATAID" ] ] .

<#tm_attachment_1tab_ref_roles_4_Jobs_DATAID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"DATAID\" FROM \"Jobs\" WHERE \"DATAID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{JobID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDataTypes ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/DataTypes/{DATAID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_roles_5_Jobs_ROLEID_fk> a rr:TriplesMap ;
