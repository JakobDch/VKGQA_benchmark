  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{JobID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRoles ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Roles/{ROLEID}" ; rr:termType rr:IRI ] ] .

