@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_visual_art_professions_0_Employers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employerID\", \"name\", \"email\", \"phoneNumber\" FROM \"Employers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{employerID}" ; rr:class :Employers ] ;
  rr:predicateObjectMap [ rr:predicate p:employerID ; rr:objectMap [ rr:column "employerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] .

<#tm_attachment_1tab_ref_visual_art_professions_1_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"locationID\", \"city\", \"state\", \"country\" FROM \"Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{locationID}" ; rr:class :Locations ] ;
  rr:predicateObjectMap [ rr:predicate p:locationID ; rr:objectMap [ rr:column "locationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:state ; rr:objectMap [ rr:column "state" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_attachment_1tab_ref_visual_art_professions_2_Pricing_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"pricingID\", \"price\" FROM \"Pricing\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Pricing/{pricingID}" ; rr:class :Pricing ] ;
  rr:predicateObjectMap [ rr:predicate p:pricingID ; rr:objectMap [ rr:column "pricingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_attachment_1tab_ref_visual_art_professions_3_JobPostings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"jobID\", \"title\", \"postingDate\", \"employerID\", \"skills\", \"locationID\", \"visualArtProfession\", \"pricingID\" FROM \"JobPostings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{jobID}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:jobID ; rr:objectMap [ rr:column "jobID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:postingDate ; rr:objectMap [ rr:column "postingDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:employerID ; rr:objectMap [ rr:column "employerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skills ; rr:objectMap [ rr:column "skills" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationID ; rr:objectMap [ rr:column "locationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:visualArtProfession ; rr:objectMap [ rr:column "visualArtProfession" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:pricingID ; rr:objectMap [ rr:column "pricingID" ] ] .

<#tm_attachment_1tab_ref_visual_art_professions_4_JobPostings_pricingID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"jobID\", \"pricingID\" FROM \"JobPostings\" WHERE \"pricingID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{jobID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPricing ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Pricing/{pricingID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_visual_art_professions_5_JobPostings_locationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"jobID\", \"locationID\" FROM \"JobPostings\" WHERE \"locationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{jobID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocations ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{locationID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_visual_art_professions_6_JobPostings_employerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"jobID\", \"employerID\" FROM \"JobPostings\" WHERE \"employerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{jobID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{employerID}" ; rr:termType rr:IRI ] ] .

