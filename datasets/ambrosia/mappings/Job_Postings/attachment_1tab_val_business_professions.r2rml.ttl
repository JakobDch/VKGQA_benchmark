@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_business_professions_0_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CompanyID\", \"Name\", \"Industry\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{CompanyID}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyID ; rr:objectMap [ rr:column "CompanyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Industry ; rr:objectMap [ rr:column "Industry" ] ] .

<#tm_attachment_1tab_val_business_professions_1_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LocationID\", \"City\", \"State\", \"Country\" FROM \"Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{LocationID}" ; rr:class :Locations ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationID ; rr:objectMap [ rr:column "LocationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:State ; rr:objectMap [ rr:column "State" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_1tab_val_business_professions_2_Applicants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ApplicantID\", \"FirstName\", \"LastName\", \"Email\", \"PhoneNumber\" FROM \"Applicants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{ApplicantID}" ; rr:class :Applicants ] ;
  rr:predicateObjectMap [ rr:predicate p:ApplicantID ; rr:objectMap [ rr:column "ApplicantID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_attachment_1tab_val_business_professions_3_JobPostings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"Title\", \"Description\", \"CompanyID\", \"Business_Profession\", \"Working_Arrangement\", \"LocationID\", \"PostedDate\", \"CloseDate\" FROM \"JobPostings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{JobID}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:JobID ; rr:objectMap [ rr:column "JobID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyID ; rr:objectMap [ rr:column "CompanyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Business_Profession ; rr:objectMap [ rr:column "Business_Profession" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Working_Arrangement ; rr:objectMap [ rr:column "Working_Arrangement" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationID ; rr:objectMap [ rr:column "LocationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PostedDate ; rr:objectMap [ rr:column "PostedDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CloseDate ; rr:objectMap [ rr:column "CloseDate" ] ] .

<#tm_attachment_1tab_val_business_professions_4_JobPostings_LocationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"LocationID\" FROM \"JobPostings\" WHERE \"LocationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{JobID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocations ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{LocationID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_business_professions_5_JobPostings_CompanyID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"CompanyID\" FROM \"JobPostings\" WHERE \"CompanyID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{JobID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{CompanyID}" ; rr:termType rr:IRI ] ] .

