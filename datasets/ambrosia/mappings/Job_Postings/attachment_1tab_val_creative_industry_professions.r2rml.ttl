@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_creative_industry_professions_0_Company_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"website\" FROM \"Company\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:website ; rr:objectMap [ rr:column "website" ] ] .

<#tm_attachment_1tab_val_creative_industry_professions_1_Department_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"company_id\", \"name\" FROM \"Department\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{id}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_id ; rr:objectMap [ rr:column "company_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_val_creative_industry_professions_2_Department_company_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"company_id\" FROM \"Department\" WHERE \"company_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{company_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_creative_industry_professions_3_Position_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"department_id\", \"title\", \"creative_industry_profession\", \"office\", \"salary\" FROM \"Position\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{id}" ; rr:class :Position ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:department_id ; rr:objectMap [ rr:column "department_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:creative_industry_profession ; rr:objectMap [ rr:column "creative_industry_profession" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:office ; rr:objectMap [ rr:column "office" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] .

<#tm_attachment_1tab_val_creative_industry_professions_4_Position_department_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"department_id\" FROM \"Position\" WHERE \"department_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDepartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{department_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_creative_industry_professions_5_Employee_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"position_id\", \"employee_name\", \"hire_date\" FROM \"Employee\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position_id ; rr:objectMap [ rr:column "position_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:employee_name ; rr:objectMap [ rr:column "employee_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hire_date ; rr:objectMap [ rr:column "hire_date" ] ] .

<#tm_attachment_1tab_val_creative_industry_professions_6_Employee_position_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"position_id\" FROM \"Employee\" WHERE \"position_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPosition ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{position_id}" ; rr:termType rr:IRI ] ] .

