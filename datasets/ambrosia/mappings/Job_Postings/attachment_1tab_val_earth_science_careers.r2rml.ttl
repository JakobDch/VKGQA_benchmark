@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_earth_science_careers_0_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_attachment_1tab_val_earth_science_careers_1_Departments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Departments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{id}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_val_earth_science_careers_2_EarthSciencesJobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"jobTitle\", \"departmentId\", \"companyId\" FROM \"EarthSciencesJobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/EarthSciencesJobs/{id}" ; rr:class :EarthSciencesJobs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobTitle ; rr:objectMap [ rr:column "jobTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departmentId ; rr:objectMap [ rr:column "departmentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:companyId ; rr:objectMap [ rr:column "companyId" ] ] .

<#tm_attachment_1tab_val_earth_science_careers_3_EarthSciencesJobs_companyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"companyId\" FROM \"EarthSciencesJobs\" WHERE \"companyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/EarthSciencesJobs/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{companyId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_earth_science_careers_4_EarthSciencesJobs_departmentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"departmentId\" FROM \"EarthSciencesJobs\" WHERE \"departmentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/EarthSciencesJobs/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDepartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{departmentId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_earth_science_careers_5_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"startDate\", \"endDate\", \"university\", \"FullName\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:startDate ; rr:objectMap [ rr:column "startDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:endDate ; rr:objectMap [ rr:column "endDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:university ; rr:objectMap [ rr:column "university" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_val_earth_science_careers_6_Education_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"employeeId\", \"degree\", \"major\", \"institution\", \"yearGraduated\" FROM \"Education\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Education/{_amb_rowid}" ; rr:class :Education ] ;
  rr:predicateObjectMap [ rr:predicate p:employeeId ; rr:objectMap [ rr:column "employeeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:degree ; rr:objectMap [ rr:column "degree" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:major ; rr:objectMap [ rr:column "major" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:institution ; rr:objectMap [ rr:column "institution" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:yearGraduated ; rr:objectMap [ rr:column "yearGraduated" ] ] .

<#tm_attachment_1tab_val_earth_science_careers_7_Education_employeeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"employeeId\" FROM \"Education\" WHERE \"employeeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Education/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployees ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{employeeId}" ; rr:termType rr:IRI ] ] .

