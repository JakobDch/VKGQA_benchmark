@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_healthcare_jobs_0_Employers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\" FROM \"Employers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{id}" ; rr:class :Employers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_attachment_1tab_val_healthcare_jobs_1_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"city\", \"state\" FROM \"Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{id}" ; rr:class :Locations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:state ; rr:objectMap [ rr:column "state" ] ] .

<#tm_attachment_1tab_val_healthcare_jobs_2_Skills_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"skillName\" FROM \"Skills\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Skill/{id}" ; rr:class :Skill ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skillName ; rr:objectMap [ rr:column "skillName" ] ] .

<#tm_attachment_1tab_val_healthcare_jobs_3_Requirements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"requirement\" FROM \"Requirements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Requirements/{id}" ; rr:class :Requirements ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:requirement ; rr:objectMap [ rr:column "requirement" ] ] .

<#tm_attachment_1tab_val_healthcare_jobs_4_JobPostings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"healthcare\", \"shift\", \"employerId\", \"locationId\", \"skillsIds\", \"requirementsIds\" FROM \"JobPostings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:healthcare ; rr:objectMap [ rr:column "healthcare" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:shift ; rr:objectMap [ rr:column "shift" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:employerId ; rr:objectMap [ rr:column "employerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationId ; rr:objectMap [ rr:column "locationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skillsIds ; rr:objectMap [ rr:column "skillsIds" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:requirementsIds ; rr:objectMap [ rr:column "requirementsIds" ] ] .

<#tm_attachment_1tab_val_healthcare_jobs_5_JobPostings_locationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"locationId\" FROM \"JobPostings\" WHERE \"locationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocations ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{locationId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_healthcare_jobs_6_JobPostings_employerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"employerId\" FROM \"JobPostings\" WHERE \"employerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{employerId}" ; rr:termType rr:IRI ] ] .

