@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_it_jobs_0_CompanyInfo_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\", \"industry\" FROM \"CompanyInfo\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/CompanyInfo/{id}" ; rr:class :CompanyInfo ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:industry ; rr:objectMap [ rr:column "industry" ] ] .

<#tm_attachment_1tab_val_it_jobs_1_JobLocations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"city\", \"state\", \"country\" FROM \"JobLocations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobLocations/{id}" ; rr:class :JobLocations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:state ; rr:objectMap [ rr:column "state" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_attachment_1tab_val_it_jobs_2_SkillsRequired_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"skillName\" FROM \"SkillsRequired\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/SkillsRequired/{id}" ; rr:class :SkillsRequired ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skillName ; rr:objectMap [ rr:column "skillName" ] ] .

<#tm_attachment_1tab_val_it_jobs_3_EducationRequirements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"degreeLevel\", \"yearsOfExperience\" FROM \"EducationRequirements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/EducationRequirements/{id}" ; rr:class :EducationRequirements ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:degreeLevel ; rr:objectMap [ rr:column "degreeLevel" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:yearsOfExperience ; rr:objectMap [ rr:column "yearsOfExperience" ] ] .

<#tm_attachment_1tab_val_it_jobs_4_JobPostings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"itJobs\", \"salary\", \"companyId\", \"locationId\", \"skillsId\", \"educationId\" FROM \"JobPostings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:itJobs ; rr:objectMap [ rr:column "itJobs" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:companyId ; rr:objectMap [ rr:column "companyId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationId ; rr:objectMap [ rr:column "locationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skillsId ; rr:objectMap [ rr:column "skillsId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:educationId ; rr:objectMap [ rr:column "educationId" ] ] .

<#tm_attachment_1tab_val_it_jobs_5_JobPostings_educationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"educationId\" FROM \"JobPostings\" WHERE \"educationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEducationRequirements ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/EducationRequirements/{educationId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_it_jobs_6_JobPostings_skillsId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"skillsId\" FROM \"JobPostings\" WHERE \"skillsId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSkillsRequired ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/SkillsRequired/{skillsId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_it_jobs_7_JobPostings_locationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"locationId\" FROM \"JobPostings\" WHERE \"locationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobLocations ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobLocations/{locationId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_it_jobs_8_JobPostings_companyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"companyId\" FROM \"JobPostings\" WHERE \"companyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanyInfo ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/CompanyInfo/{companyId}" ; rr:termType rr:IRI ] ] .

