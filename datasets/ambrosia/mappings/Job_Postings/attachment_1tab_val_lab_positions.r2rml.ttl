@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_lab_positions_0_Company_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Company\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_val_lab_positions_1_Department_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"companyId\", \"departmentName\" FROM \"Department\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{id}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:companyId ; rr:objectMap [ rr:column "companyId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departmentName ; rr:objectMap [ rr:column "departmentName" ] ] .

<#tm_attachment_1tab_val_lab_positions_2_Department_companyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"companyId\" FROM \"Department\" WHERE \"companyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{companyId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_lab_positions_3_PositionType_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"typeName\" FROM \"PositionType\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/PositionType/{id}" ; rr:class :PositionType ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:typeName ; rr:objectMap [ rr:column "typeName" ] ] .

<#tm_attachment_1tab_val_lab_positions_4_LabPosition_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"positionTypeId\", \"labPosition\", \"gender\", \"minimumEducation\", \"experienceInYears\", \"salaryRange\" FROM \"LabPosition\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/LabPosition/{id}" ; rr:class :LabPosition ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:positionTypeId ; rr:objectMap [ rr:column "positionTypeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:labPosition ; rr:objectMap [ rr:column "labPosition" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:gender ; rr:objectMap [ rr:column "gender" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:minimumEducation ; rr:objectMap [ rr:column "minimumEducation" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experienceInYears ; rr:objectMap [ rr:column "experienceInYears" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salaryRange ; rr:objectMap [ rr:column "salaryRange" ] ] .

<#tm_attachment_1tab_val_lab_positions_5_LabPosition_positionTypeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"positionTypeId\" FROM \"LabPosition\" WHERE \"positionTypeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/LabPosition/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPositionType ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/PositionType/{positionTypeId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_lab_positions_6_Employee_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"dateOfBirth\", \"email\", \"phoneNumber\", \"hireDate\", \"jobTitle\", \"departmentId\", \"gender\" FROM \"Employee\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dateOfBirth ; rr:objectMap [ rr:column "dateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hireDate ; rr:objectMap [ rr:column "hireDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobTitle ; rr:objectMap [ rr:column "jobTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:departmentId ; rr:objectMap [ rr:column "departmentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:gender ; rr:objectMap [ rr:column "gender" ] ] .

<#tm_attachment_1tab_val_lab_positions_7_Employee_departmentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"departmentId\" FROM \"Employee\" WHERE \"departmentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDepartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{departmentId}" ; rr:termType rr:IRI ] ] .

