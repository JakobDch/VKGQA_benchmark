[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Hospitals_base
target		ex:Hospitals/{HospitalID} a :Hospitals ; p:HospitalID {HospitalID} ; p:name {Name} ; p:location {Location} .
source		SELECT `HospitalID`, `Name`, `Location` FROM `Hospitals`

mappingId	Departments_base
target		ex:Departments/{DepartmentID} a :Departments ; p:DepartmentID {DepartmentID} ; p:DepartmentName {DepartmentName} ; p:HospitalID {HospitalID} .
source		SELECT `DepartmentID`, `DepartmentName`, `HospitalID` FROM `Departments`

mappingId	Departments_HospitalID_fk
target		ex:Departments/{DepartmentID} p:hasHospitals ex:Hospitals/{HospitalID} .
source		SELECT `DepartmentID`, `HospitalID` FROM `Departments` WHERE `HospitalID` IS NOT NULL

mappingId	Employees_base
target		ex:Employees/{EmployeeID} a :Employees ; p:EmployeeID {EmployeeID} ; p:email {Email} ; p:PhoneNumber {PhoneNumber} ; p:MedicalProfession {MedicalProfession} ; p:Patient {Patient} ; p:name {FullName} .
source		SELECT `EmployeeID`, `Email`, `PhoneNumber`, `MedicalProfession`, `Patient`, `FullName` FROM `Employees`

mappingId	JobPostings_base
target		ex:JobPostings/{JobPostID} a :JobPostings ; p:JobPostID {JobPostID} ; p:PositionTitle {PositionTitle} ; p:Description {Description} ; p:Requirements {Requirements} ; p:StartDate {StartDate} ; p:EndDate {EndDate} ; p:Salary {Salary} ; p:Vacancy {Vacancy} ; p:DepartmentID {DepartmentID} .
source		SELECT `JobPostID`, `PositionTitle`, `Description`, `Requirements`, `StartDate`, `EndDate`, `Salary`, `Vacancy`, `DepartmentID` FROM `JobPostings`

mappingId	JobPostings_DepartmentID_fk
target		ex:JobPostings/{JobPostID} p:hasDepartments ex:Departments/{DepartmentID} .
source		SELECT `JobPostID`, `DepartmentID` FROM `JobPostings` WHERE `DepartmentID` IS NOT NULL

]]
