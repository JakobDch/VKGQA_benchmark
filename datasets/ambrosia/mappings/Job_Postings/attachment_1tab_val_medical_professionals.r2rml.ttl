@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_medical_professionals_0_Hospitals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"HospitalID\", \"Name\", \"Location\" FROM \"Hospitals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Hospitals/{HospitalID}" ; rr:class :Hospitals ] ;
  rr:predicateObjectMap [ rr:predicate p:HospitalID ; rr:objectMap [ rr:column "HospitalID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_attachment_1tab_val_medical_professionals_1_Departments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DepartmentID\", \"DepartmentName\", \"HospitalID\" FROM \"Departments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{DepartmentID}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartmentID ; rr:objectMap [ rr:column "DepartmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartmentName ; rr:objectMap [ rr:column "DepartmentName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HospitalID ; rr:objectMap [ rr:column "HospitalID" ] ] .

<#tm_attachment_1tab_val_medical_professionals_2_Departments_HospitalID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DepartmentID\", \"HospitalID\" FROM \"Departments\" WHERE \"HospitalID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{DepartmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHospitals ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Hospitals/{HospitalID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_medical_professionals_3_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EmployeeID\", \"Email\", \"PhoneNumber\", \"MedicalProfession\", \"Patient\", \"FullName\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{EmployeeID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:EmployeeID ; rr:objectMap [ rr:column "EmployeeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MedicalProfession ; rr:objectMap [ rr:column "MedicalProfession" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Patient ; rr:objectMap [ rr:column "Patient" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_val_medical_professionals_4_JobPostings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobPostID\", \"PositionTitle\", \"Description\", \"Requirements\", \"StartDate\", \"EndDate\", \"Salary\", \"Vacancy\", \"DepartmentID\" FROM \"JobPostings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{JobPostID}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:JobPostID ; rr:objectMap [ rr:column "JobPostID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PositionTitle ; rr:objectMap [ rr:column "PositionTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Requirements ; rr:objectMap [ rr:column "Requirements" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Vacancy ; rr:objectMap [ rr:column "Vacancy" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartmentID ; rr:objectMap [ rr:column "DepartmentID" ] ] .

<#tm_attachment_1tab_val_medical_professionals_5_JobPostings_DepartmentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobPostID\", \"DepartmentID\" FROM \"JobPostings\" WHERE \"DepartmentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{JobPostID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDepartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{DepartmentID}" ; rr:termType rr:IRI ] ] .

