[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Companies_base
target		ex:Companies/{CompanyID} a :Companies ; p:CompanyID {CompanyID} ; p:name {Name} ; p:Address {Address} ; p:PhoneNumber {PhoneNumber} .
source		SELECT `CompanyID`, `Name`, `Address`, `PhoneNumber` FROM `Companies`

mappingId	Departments_base
target		ex:Departments/{DepartmentID} a :Departments ; p:DepartmentID {DepartmentID} ; p:name {Name} ; p:Description {Description} ; p:LocationID {LocationID} .
source		SELECT `DepartmentID`, `Name`, `Description`, `LocationID` FROM `Departments`

mappingId	Departments_LocationID_fk
target		ex:Departments/{DepartmentID} p:hasCompanies ex:Companies/{LocationID} .
source		SELECT `DepartmentID`, `LocationID` FROM `Departments` WHERE `LocationID` IS NOT NULL

mappingId	Positions_base
target		ex:Position/{PositionID} a :Position ; p:PositionID {PositionID} ; p:Title {Title} ; p:Salary {Salary} ; p:DepartmentID {DepartmentID} .
source		SELECT `PositionID`, `Title`, `Salary`, `DepartmentID` FROM `Positions`

mappingId	Positions_DepartmentID_fk
target		ex:Position/{PositionID} p:hasDepartments ex:Departments/{DepartmentID} .
source		SELECT `PositionID`, `DepartmentID` FROM `Positions` WHERE `DepartmentID` IS NOT NULL

mappingId	Employees_base
target		ex:Employees/{EmployeeID} a :Employees ; p:EmployeeID {EmployeeID} ; p:BirthDate {BirthDate} ; p:HireDate {HireDate} ; p:PositionID {PositionID} ; p:Mental_Health_Career {Mental_Health_Career} ; p:Clinic {Clinic} ; p:name {FullName} .
source		SELECT `EmployeeID`, `BirthDate`, `HireDate`, `PositionID`, `Mental_Health_Career`, `Clinic`, `FullName` FROM `Employees`

mappingId	Employees_PositionID_fk
target		ex:Employees/{EmployeeID} p:hasPosition ex:Position/{PositionID} .
source		SELECT `EmployeeID`, `PositionID` FROM `Employees` WHERE `PositionID` IS NOT NULL

]]
