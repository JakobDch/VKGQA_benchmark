@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_mental_health_careers_0_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CompanyID\", \"Name\", \"Address\", \"PhoneNumber\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{CompanyID}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyID ; rr:objectMap [ rr:column "CompanyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_attachment_1tab_val_mental_health_careers_1_Departments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DepartmentID\", \"Name\", \"Description\", \"LocationID\" FROM \"Departments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{DepartmentID}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartmentID ; rr:objectMap [ rr:column "DepartmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationID ; rr:objectMap [ rr:column "LocationID" ] ] .

<#tm_attachment_1tab_val_mental_health_careers_2_Departments_LocationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DepartmentID\", \"LocationID\" FROM \"Departments\" WHERE \"LocationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{DepartmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{LocationID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_mental_health_careers_3_Positions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PositionID\", \"Title\", \"Salary\", \"DepartmentID\" FROM \"Positions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{PositionID}" ; rr:class :Position ] ;
  rr:predicateObjectMap [ rr:predicate p:PositionID ; rr:objectMap [ rr:column "PositionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartmentID ; rr:objectMap [ rr:column "DepartmentID" ] ] .

<#tm_attachment_1tab_val_mental_health_careers_4_Positions_DepartmentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PositionID\", \"DepartmentID\" FROM \"Positions\" WHERE \"DepartmentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{PositionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDepartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{DepartmentID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_mental_health_careers_5_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EmployeeID\", \"BirthDate\", \"HireDate\", \"PositionID\", \"Mental_Health_Career\", \"Clinic\", \"FullName\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{EmployeeID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:EmployeeID ; rr:objectMap [ rr:column "EmployeeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HireDate ; rr:objectMap [ rr:column "HireDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PositionID ; rr:objectMap [ rr:column "PositionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Mental_Health_Career ; rr:objectMap [ rr:column "Mental_Health_Career" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Clinic ; rr:objectMap [ rr:column "Clinic" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_val_mental_health_careers_6_Employees_PositionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EmployeeID\", \"PositionID\" FROM \"Employees\" WHERE \"PositionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{EmployeeID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPosition ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{PositionID}" ; rr:termType rr:IRI ] ] .

