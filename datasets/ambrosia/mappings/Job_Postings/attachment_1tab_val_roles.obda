[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Companies_base
target		ex:Companies/{ID} a :Companies ; p:ID {ID} ; p:name {Name} .
source		SELECT `ID`, `Name` FROM `Companies`

mappingId	Locations_base
target		ex:Locations/{ID} a :Locations ; p:ID {ID} ; p:City {City} ; p:State {State} ; p:Country {Country} .
source		SELECT `ID`, `City`, `State`, `Country` FROM `Locations`

mappingId	Education_Requirements_base
target		ex:EducationRequirements/{ID} a :EducationRequirements ; p:ID {ID} ; p:Degree_Required {Degree_Required} ; p:Years_Experience {Years_Experience} .
source		SELECT `ID`, `Degree_Required`, `Years_Experience` FROM `Education_Requirements`

mappingId	JobPostings_base
target		ex:JobPostings/{ID} a :JobPostings ; p:ID {ID} ; p:CompanyID {CompanyID} ; p:LocationID {LocationID} ; p:Title {Title} ; p:Description {Description} ; p:Roles {Roles} ; p:Data {Data} .
source		SELECT `ID`, `CompanyID`, `LocationID`, `Title`, `Description`, `Roles`, `Data` FROM `JobPostings`

mappingId	JobPostings_LocationID_fk
target		ex:JobPostings/{ID} p:hasLocations ex:Locations/{LocationID} .
source		SELECT `ID`, `LocationID` FROM `JobPostings` WHERE `LocationID` IS NOT NULL

mappingId	JobPostings_LocationID_fk
target		ex:JobPostings/{ID} p:hasLocations ex:Locations/{LocationID} .
source		SELECT `ID`, `LocationID` FROM `JobPostings` WHERE `LocationID` IS NOT NULL

mappingId	JobPostings_CompanyID_fk
target		ex:JobPostings/{ID} p:hasCompanies ex:Companies/{CompanyID} .
source		SELECT `ID`, `CompanyID` FROM `JobPostings` WHERE `CompanyID` IS NOT NULL

]]
