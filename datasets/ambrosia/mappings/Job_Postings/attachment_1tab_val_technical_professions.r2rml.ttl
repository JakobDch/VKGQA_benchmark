@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_technical_professions_0_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"email\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_attachment_1tab_val_technical_professions_1_Technologies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"technologyName\" FROM \"Technologies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Technologies/{id}" ; rr:class :Technologies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technologyName ; rr:objectMap [ rr:column "technologyName" ] ] .

<#tm_attachment_1tab_val_technical_professions_2_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"companyId\", \"salary\", \"technicalProfession\", \"skillIds\", \"locationId\" FROM \"Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{id}" ; rr:class :Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:companyId ; rr:objectMap [ rr:column "companyId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technicalProfession ; rr:objectMap [ rr:column "technicalProfession" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skillIds ; rr:objectMap [ rr:column "skillIds" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationId ; rr:objectMap [ rr:column "locationId" ] ] .

<#tm_attachment_1tab_val_technical_professions_3_Jobs_skillIds_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"skillIds\" FROM \"Jobs\" WHERE \"skillIds\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTechnologies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Technologies/{skillIds}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_technical_professions_4_Jobs_companyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"companyId\" FROM \"Jobs\" WHERE \"companyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{companyId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_technical_professions_5_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"city\", \"country\" FROM \"Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{id}" ; rr:class :Locations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

