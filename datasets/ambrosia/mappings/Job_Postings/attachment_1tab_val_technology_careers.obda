[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Companies_base
target		ex:Companies/{id} a :Companies ; p:id {id} ; p:name {name} ; p:location {location} .
source		SELECT `id`, `name`, `location` FROM `Companies`

mappingId	Technologies_base
target		ex:Technologies/{id} a :Technologies ; p:id {id} ; p:technology_name {technology_name} .
source		SELECT `id`, `technology_name` FROM `Technologies`

mappingId	Roles_base
target		ex:Roles/{id} a :Roles ; p:id {id} ; p:title {title} ; p:Technology_Career {Technology_Career} ; p:Grade {Grade} .
source		SELECT `id`, `title`, `Technology_Career`, `Grade` FROM `Roles`

]]
