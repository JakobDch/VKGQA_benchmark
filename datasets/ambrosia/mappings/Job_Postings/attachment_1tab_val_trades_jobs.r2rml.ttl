@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_trades_jobs_0_Trade_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"trade_job\", \"company_owner\", \"posted_date\", \"salary\" FROM \"Trade_Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Trade_Jobs/{id}" ; rr:class :Trade_Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:trade_job ; rr:objectMap [ rr:column "trade_job" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_owner ; rr:objectMap [ rr:column "company_owner" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:posted_date ; rr:objectMap [ rr:column "posted_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] .

<#tm_attachment_1tab_val_trades_jobs_1_Company_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"contact_number\", \"address\" FROM \"Company\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contact_number ; rr:objectMap [ rr:column "contact_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_attachment_1tab_val_trades_jobs_2_Company_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\" FROM \"Company\" WHERE \"id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTrade_Jobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Trade_Jobs/{id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_trades_jobs_3_Employee_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"employee_name\", \"position\", \"hire_date\" FROM \"Employee\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:employee_name ; rr:objectMap [ rr:column "employee_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position ; rr:objectMap [ rr:column "position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hire_date ; rr:objectMap [ rr:column "hire_date" ] ] .

<#tm_attachment_1tab_val_trades_jobs_4_Employee_employee_name_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"employee_name\" FROM \"Employee\" WHERE \"employee_name\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTrade_Jobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Trade_Jobs/{employee_name}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_trades_jobs_5_Education_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"degree\", \"major\", \"institution\", \"completion_year\" FROM \"Education\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Education/{id}" ; rr:class :Education ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:degree ; rr:objectMap [ rr:column "degree" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:major ; rr:objectMap [ rr:column "major" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:institution ; rr:objectMap [ rr:column "institution" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:completion_year ; rr:objectMap [ rr:column "completion_year" ] ] .

<#tm_attachment_1tab_val_trades_jobs_6_Education_degree_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"degree\" FROM \"Education\" WHERE \"degree\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Education/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployees ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{degree}" ; rr:termType rr:IRI ] ] .

