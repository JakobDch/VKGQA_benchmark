@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_visual_art_professions_0_Visual_Art_Profession_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Profession_ID\", \"Profession\", \"Price\", \"Experience_Level\", \"Specialization\" FROM \"Visual_Art_Profession\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Visual_Art_Profession/{Profession_ID}" ; rr:class :Visual_Art_Profession ] ;
  rr:predicateObjectMap [ rr:predicate p:Profession_ID ; rr:objectMap [ rr:column "Profession_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Profession ; rr:objectMap [ rr:column "Profession" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience_Level ; rr:objectMap [ rr:column "Experience_Level" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Specialization ; rr:objectMap [ rr:column "Specialization" ] ] .

<#tm_attachment_1tab_val_visual_art_professions_1_Employer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\" FROM \"Employer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{ID}" ; rr:class :Employers ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_val_visual_art_professions_2_JobPosting_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Description\", \"Date\", \"Status\" FROM \"JobPosting\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{ID}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Status ; rr:objectMap [ rr:column "Status" ] ] .

<#tm_attachment_1tab_val_visual_art_professions_3_AppliesToJobPosting_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Apply_ID\", \"Job_ID\", \"Applicant_Name\", \"Resume_Path\", \"Application_Date\" FROM \"AppliesToJobPosting\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/AppliesToJobPosting/{Apply_ID}" ; rr:class :AppliesToJobPosting ] ;
  rr:predicateObjectMap [ rr:predicate p:Apply_ID ; rr:objectMap [ rr:column "Apply_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Job_ID ; rr:objectMap [ rr:column "Job_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Applicant_Name ; rr:objectMap [ rr:column "Applicant_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Resume_Path ; rr:objectMap [ rr:column "Resume_Path" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Application_Date ; rr:objectMap [ rr:column "Application_Date" ] ] .

<#tm_attachment_1tab_val_visual_art_professions_4_AppliesToJobPosting_Job_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Apply_ID\", \"Job_ID\" FROM \"AppliesToJobPosting\" WHERE \"Job_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/AppliesToJobPosting/{Apply_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobPostings ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{Job_ID}" ; rr:termType rr:IRI ] ] .

