  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience ; rr:objectMap [ rr:column "Experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HireDate ; rr:objectMap [ rr:column "HireDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Training_Center_ID ; rr:objectMap [ rr:column "Training_Center_ID" ] ] .

<#tm_attachment_2tab_ref_aviation_jobs_2_Flight_Attendants_Training_Center_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Training_Center_ID\" FROM \"Flight_Attendants\" WHERE \"Training_Center_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Flight_Attendants/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTraining_Center ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Training_Center/{Training_Center_ID}" ; rr:termType rr:IRI ] ] .

