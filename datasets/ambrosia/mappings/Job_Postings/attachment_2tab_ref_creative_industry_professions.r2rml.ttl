@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_creative_industry_professions_0_Office_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"address\" FROM \"Office\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Office/{id}" ; rr:class :Office ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_attachment_2tab_ref_creative_industry_professions_1_Graphic_Designers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"officeId\", \"name\", \"skills\" FROM \"Graphic_Designers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Graphic_Designers/{id}" ; rr:class :Graphic_Designers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:officeId ; rr:objectMap [ rr:column "officeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skills ; rr:objectMap [ rr:column "skills" ] ] .

<#tm_attachment_2tab_ref_creative_industry_professions_2_Graphic_Designers_officeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"officeId\" FROM \"Graphic_Designers\" WHERE \"officeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Graphic_Designers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOffice ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Office/{officeId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_creative_industry_professions_3_Web_Developers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"officeId\", \"name\", \"languages\" FROM \"Web_Developers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Web_Developers/{id}" ; rr:class :Web_Developers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:officeId ; rr:objectMap [ rr:column "officeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:languages ; rr:objectMap [ rr:column "languages" ] ] .

<#tm_attachment_2tab_ref_creative_industry_professions_4_Web_Developers_officeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"officeId\" FROM \"Web_Developers\" WHERE \"officeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Web_Developers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOffice ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Office/{officeId}" ; rr:termType rr:IRI ] ] .

