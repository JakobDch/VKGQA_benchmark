@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_customer_facing_roles_0_Languages_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Languages\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Languages/{id}" ; rr:class :Languages ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_customer_facing_roles_1_Customer_Service_Advisors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"advisor_name\", \"language_id\" FROM \"Customer_Service_Advisors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Customer_Service_Advisors/{id}" ; rr:class :Customer_Service_Advisors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:advisor_name ; rr:objectMap [ rr:column "advisor_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:language_id ; rr:objectMap [ rr:column "language_id" ] ] .

<#tm_attachment_2tab_ref_customer_facing_roles_2_Customer_Service_Advisors_language_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"language_id\" FROM \"Customer_Service_Advisors\" WHERE \"language_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Customer_Service_Advisors/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLanguages ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Languages/{language_id}" ; rr:termType rr:IRI ] ] .

