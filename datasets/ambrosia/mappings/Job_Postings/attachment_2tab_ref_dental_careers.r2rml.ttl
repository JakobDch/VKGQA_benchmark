@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_dental_careers_0_Education_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"degree_name\" FROM \"Education\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Education/{id}" ; rr:class :Education ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:degree_name ; rr:objectMap [ rr:column "degree_name" ] ] .

<#tm_attachment_2tab_ref_dental_careers_1_Specialization_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"speciality_name\" FROM \"Specialization\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Specialization/{id}" ; rr:class :Specialization ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:speciality_name ; rr:objectMap [ rr:column "speciality_name" ] ] .

<#tm_attachment_2tab_ref_dental_careers_2_Orthodontists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"education_id\", \"specialty_id\" FROM \"Orthodontists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Orthodontists/{id}" ; rr:class :Orthodontists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:education_id ; rr:objectMap [ rr:column "education_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specialty_id ; rr:objectMap [ rr:column "specialty_id" ] ] .

<#tm_attachment_2tab_ref_dental_careers_3_Orthodontists_specialty_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"specialty_id\" FROM \"Orthodontists\" WHERE \"specialty_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Orthodontists/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSpecialization ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Specialization/{specialty_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_dental_careers_4_Orthodontists_education_id_fk> a rr:TriplesMap ;
