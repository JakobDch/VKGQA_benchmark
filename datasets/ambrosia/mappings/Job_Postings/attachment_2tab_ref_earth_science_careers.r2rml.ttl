@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_earth_science_careers_0_University_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"University\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/University/{id}" ; rr:class :University ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_earth_science_careers_1_Chemist_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"university_id\", \"fieldOfStudy\", \"FullName\" FROM \"Chemist\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Chemist/{id}" ; rr:class :Chemist ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:university_id ; rr:objectMap [ rr:column "university_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fieldOfStudy ; rr:objectMap [ rr:column "fieldOfStudy" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_2tab_ref_earth_science_careers_2_Chemist_university_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"university_id\" FROM \"Chemist\" WHERE \"university_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Chemist/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUniversity ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/University/{university_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_earth_science_careers_3_Geoscientist_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"university_id\", \"fieldOfStudy\", \"FullName\" FROM \"Geoscientist\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Geoscientist/{id}" ; rr:class :Geoscientist ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:university_id ; rr:objectMap [ rr:column "university_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fieldOfStudy ; rr:objectMap [ rr:column "fieldOfStudy" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_2tab_ref_earth_science_careers_4_Geoscientist_university_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"university_id\" FROM \"Geoscientist\" WHERE \"university_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Geoscientist/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUniversity ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/University/{university_id}" ; rr:termType rr:IRI ] ] .

