  rr:logicalTable [ rr:sqlQuery """SELECT \"TripID\", \"StartDate\", \"EndDate\", \"NumOfPeople\", \"TotalCost\", \"AgentID\", \"GuideID\" FROM \"BookedTrips\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/BookedTrips/{TripID}" ; rr:class :BookedTrips ] ;
  rr:predicateObjectMap [ rr:predicate p:TripID ; rr:objectMap [ rr:column "TripID" ] ] ;
