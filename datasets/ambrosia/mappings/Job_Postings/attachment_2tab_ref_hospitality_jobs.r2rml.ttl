  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CommissionRate ; rr:objectMap [ rr:column "CommissionRate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AgencyID ; rr:objectMap [ rr:column "AgencyID" ] ] .

