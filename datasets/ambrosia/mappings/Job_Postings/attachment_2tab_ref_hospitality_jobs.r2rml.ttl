@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_hospitality_jobs_0_Agencies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AgencyID\", \"Name\" FROM \"Agencies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Agency/{AgencyID}" ; rr:class :Agency ] ;
  rr:predicateObjectMap [ rr:predicate p:AgencyID ; rr:objectMap [ rr:column "AgencyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_ref_hospitality_jobs_1_TourGuides_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GuideID\", \"Name\", \"Age\", \"Experience\", \"AgencyID\" FROM \"TourGuides\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/TourGuides/{GuideID}" ; rr:class :TourGuides ] ;
  rr:predicateObjectMap [ rr:predicate p:GuideID ; rr:objectMap [ rr:column "GuideID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience ; rr:objectMap [ rr:column "Experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AgencyID ; rr:objectMap [ rr:column "AgencyID" ] ] .

<#tm_attachment_2tab_ref_hospitality_jobs_2_TourGuides_AgencyID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GuideID\", \"AgencyID\" FROM \"TourGuides\" WHERE \"AgencyID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/TourGuides/{GuideID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAgency ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Agency/{AgencyID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_hospitality_jobs_3_TravelAgents_base> a rr:TriplesMap ;
