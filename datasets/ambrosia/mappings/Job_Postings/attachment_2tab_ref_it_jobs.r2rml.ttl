<#tm_attachment_2tab_ref_it_jobs_5_Employee_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"First_Name\", \"Last_Name\", \"Position\", \"Salary\", \"Joining_Date\" FROM \"Employee\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{ID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:First_Name ; rr:objectMap [ rr:column "First_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Last_Name ; rr:objectMap [ rr:column "Last_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Position ; rr:objectMap [ rr:column "Position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Joining_Date ; rr:objectMap [ rr:column "Joining_Date" ] ] .

