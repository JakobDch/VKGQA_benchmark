@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_it_jobs_0_Operating_System_Knowledge_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"OS_Name\" FROM \"Operating_System_Knowledge\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Operating_System_Knowledge/{ID}" ; rr:class :Operating_System_Knowledge ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OS_Name ; rr:objectMap [ rr:column "OS_Name" ] ] .

<#tm_attachment_2tab_ref_it_jobs_1_IT_Support_Technician_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Contact_Email\", \"Phone_Number\", \"Hire_Date\", \"Operating_System_ID\" FROM \"IT_Support_Technician\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/IT_Support_Technicians/{ID}" ; rr:class :IT_Support_Technicians ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Contact_Email ; rr:objectMap [ rr:column "Contact_Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Phone_Number ; rr:objectMap [ rr:column "Phone_Number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Hire_Date ; rr:objectMap [ rr:column "Hire_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Operating_System_ID ; rr:objectMap [ rr:column "Operating_System_ID" ] ] .

<#tm_attachment_2tab_ref_it_jobs_2_IT_Support_Technician_Operating_System_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Operating_System_ID\" FROM \"IT_Support_Technician\" WHERE \"Operating_System_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/IT_Support_Technicians/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOperating_System_Knowledge ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Operating_System_Knowledge/{Operating_System_ID}" ; rr:termType rr:IRI ] ] .

