@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_mental_health_careers_0_Clinics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Clinics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Clinics/{id}" ; rr:class :Clinics ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_mental_health_careers_1_Psychologists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"clinic_id\", \"name\", \"specialty\" FROM \"Psychologists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Psychologists/{id}" ; rr:class :Psychologists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:clinic_id ; rr:objectMap [ rr:column "clinic_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specialty ; rr:objectMap [ rr:column "specialty" ] ] .

<#tm_attachment_2tab_ref_mental_health_careers_2_Psychologists_clinic_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"clinic_id\" FROM \"Psychologists\" WHERE \"clinic_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Psychologists/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClinics ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Clinics/{clinic_id}" ; rr:termType rr:IRI ] ] .

