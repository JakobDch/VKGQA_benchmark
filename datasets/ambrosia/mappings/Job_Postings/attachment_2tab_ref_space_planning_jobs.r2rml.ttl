@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_space_planning_jobs_0_Style_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"style_id\", \"style_name\" FROM \"Style\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Styles/{style_id}" ; rr:class :Styles ] ;
  rr:predicateObjectMap [ rr:predicate p:style_id ; rr:objectMap [ rr:column "style_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:style_name ; rr:objectMap [ rr:column "style_name" ] ] .

<#tm_attachment_2tab_ref_space_planning_jobs_1_Interior_Designer_base> a rr:TriplesMap ;
