  rr:predicateObjectMap [ rr:predicate p:design_style ; rr:objectMap [ rr:column "design_style" ] ] .

<#tm_attachment_2tab_ref_space_planning_jobs_2_Interior_Designer_design_style_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"designer_id\", \"design_style\" FROM \"Interior_Designer\" WHERE \"design_style\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Interior_Designers/{designer_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStyles ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Styles/{design_style}" ; rr:termType rr:IRI ] ] .

