<#tm_attachment_2tab_ref_technology_careers_10_Data_Analyst_employeeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"employeeId\" FROM \"Data_Analyst\" WHERE \"employeeId\" IS NOT NULL""" ] ;
