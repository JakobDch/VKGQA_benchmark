[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Marine_Biologists_base
target		ex:Marine_Biologists/{id} a :Marine_Biologists ; p:id {id} ; p:name {Name} ; p:Age {Age} ; p:Specialization {Specialization} ; p:Experience {Experience} .
source		SELECT `id`, `Name`, `Age`, `Specialization`, `Experience` FROM `Marine_Biologists`

mappingId	Zoologists_base
target		ex:Zoologists/{id} a :Zoologists ; p:id {id} ; p:name {Name} ; p:Age {Age} ; p:Specialization {Specialization} ; p:Experience {Experience} .
source		SELECT `id`, `Name`, `Age`, `Specialization`, `Experience` FROM `Zoologists`

mappingId	Companies_base
target		ex:Companies/{id} a :Companies ; p:id {id} ; p:CompanyName {CompanyName} ; p:location {Location} ; p:Size {Size} .
source		SELECT `id`, `CompanyName`, `Location`, `Size` FROM `Companies`

mappingId	Jobs_base
target		ex:Jobs/{id} a :Jobs ; p:id {id} ; p:PositionTitle {PositionTitle} ; p:Description {Description} ; p:Salary {Salary} ; p:PostedDate {PostedDate} .
source		SELECT `id`, `PositionTitle`, `Description`, `Salary`, `PostedDate` FROM `Jobs`

mappingId	Applications_base
target		ex:Application/{id} a :Application ; p:id {id} ; p:ApplicantID {ApplicantID} ; p:JobID {JobID} ; p:ApplicationDate {ApplicationDate} ; p:Status {Status} .
source		SELECT `id`, `ApplicantID`, `JobID`, `ApplicationDate`, `Status` FROM `Applications`

mappingId	Skills_base
target		ex:Skill/{id} a :Skill ; p:id {id} ; p:SkillName {SkillName} ; p:Level {Level} ; p:ProficiencyScore {ProficiencyScore} .
source		SELECT `id`, `SkillName`, `Level`, `ProficiencyScore` FROM `Skills`

]]
