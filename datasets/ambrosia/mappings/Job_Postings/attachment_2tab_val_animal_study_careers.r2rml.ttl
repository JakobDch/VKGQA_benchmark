@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_animal_study_careers_0_Marine_Biologists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Age\", \"Specialization\", \"Experience\" FROM \"Marine_Biologists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Marine_Biologists/{id}" ; rr:class :Marine_Biologists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Specialization ; rr:objectMap [ rr:column "Specialization" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience ; rr:objectMap [ rr:column "Experience" ] ] .

