[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Flight_Attendants_base
target		ex:Flight_Attendants/{id} a :Flight_Attendants ; p:id {id} ; p:name {Name} ; p:Age {Age} ; p:Experience_Years {Experience_Years} ; p:Training_Center {Training_Center} .
source		SELECT `id`, `Name`, `Age`, `Experience_Years`, `Training_Center` FROM `Flight_Attendants`

mappingId	Flight_Attendants_Training_Center_fk
target		ex:Flight_Attendants/{id} p:hasAviation_Academies ex:Aviation_Academies/{Training_Center} .
source		SELECT `id`, `Training_Center` FROM `Flight_Attendants` WHERE `Training_Center` IS NOT NULL

mappingId	Pilots_base
target		ex:Pilots/{id} a :Pilots ; p:id {id} ; p:name {Name} ; p:Age {Age} ; p:Licenses {Licenses} ; p:Training_Center {Training_Center} .
source		SELECT `id`, `Name`, `Age`, `Licenses`, `Training_Center` FROM `Pilots`

mappingId	Pilots_Training_Center_fk
target		ex:Pilots/{id} p:hasAviation_Academies ex:Aviation_Academies/{Training_Center} .
source		SELECT `id`, `Training_Center` FROM `Pilots` WHERE `Training_Center` IS NOT NULL

mappingId	Aviation_Academies_base
target		ex:Aviation_Academies/{id} a :Aviation_Academies ; p:id {id} ; p:name {Name} ; p:location {Location} ; p:Years_Operating {Years_Operating} .
source		SELECT `id`, `Name`, `Location`, `Years_Operating` FROM `Aviation_Academies`

mappingId	Airlines_base
target		ex:Airlines/{id} a :Airlines ; p:id {id} ; p:name {Name} ; p:Headquarters {Headquarters} ; p:Fleet_Size {Fleet_Size} .
source		SELECT `id`, `Name`, `Headquarters`, `Fleet_Size` FROM `Airlines`

mappingId	Aircrafts_base
target		ex:Aircrafts/{id} a :Aircrafts ; p:id {id} ; p:Model {Model} ; p:Manufacturer {Manufacturer} ; p:Year_Manufactured {Year_Manufactured} .
source		SELECT `id`, `Model`, `Manufacturer`, `Year_Manufactured` FROM `Aircrafts`

mappingId	Flight_Routes_base
target		ex:Flight_Routes/{id} a :Flight_Routes ; p:id {id} ; p:Route_Number {Route_Number} ; p:Origin_Airport {Origin_Airport} ; p:Destination_Airport {Destination_Airport} ; p:Distance {Distance} .
source		SELECT `id`, `Route_Number`, `Origin_Airport`, `Destination_Airport`, `Distance` FROM `Flight_Routes`

]]
