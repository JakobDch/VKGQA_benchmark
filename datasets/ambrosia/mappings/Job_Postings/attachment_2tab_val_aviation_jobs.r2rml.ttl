  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Licenses ; rr:objectMap [ rr:column "Licenses" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Training_Center ; rr:objectMap [ rr:column "Training_Center" ] ] .

<#tm_attachment_2tab_val_aviation_jobs_3_Pilots_Training_Center_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Training_Center\" FROM \"Pilots\" WHERE \"Training_Center\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Pilots/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAviation_Academies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Aviation_Academies/{Training_Center}" ; rr:termType rr:IRI ] ] .

