@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_aviation_jobs_0_Flight_Attendants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Age\", \"Experience_Years\", \"Training_Center\" FROM \"Flight_Attendants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Flight_Attendants/{id}" ; rr:class :Flight_Attendants ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Age ; rr:objectMap [ rr:column "Age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Experience_Years ; rr:objectMap [ rr:column "Experience_Years" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Training_Center ; rr:objectMap [ rr:column "Training_Center" ] ] .

<#tm_attachment_2tab_val_aviation_jobs_1_Flight_Attendants_Training_Center_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Training_Center\" FROM \"Flight_Attendants\" WHERE \"Training_Center\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Flight_Attendants/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAviation_Academies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Aviation_Academies/{Training_Center}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_aviation_jobs_2_Pilots_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Age\", \"Licenses\", \"Training_Center\" FROM \"Pilots\"""" ] ;
