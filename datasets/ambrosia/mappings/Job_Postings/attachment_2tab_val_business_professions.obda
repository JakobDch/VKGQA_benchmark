[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Sales_Manager_base
target		ex:Sales_Manager/{id} a :Sales_Manager ; p:id {id} ; p:name {name} ; p:age {age} ; p:experience {experience} ; p:working_arrangement {working_arrangement} .
source		SELECT `id`, `name`, `age`, `experience`, `working_arrangement` FROM `Sales_Manager`

mappingId	Marketing_Specialist_base
target		ex:MarketingSpecialists/{id} a :MarketingSpecialists ; p:id {id} ; p:name {name} ; p:age {age} ; p:experience {experience} ; p:working_arrangement {working_arrangement} .
source		SELECT `id`, `name`, `age`, `experience`, `working_arrangement` FROM `Marketing_Specialist`

mappingId	Software_Developer_base
target		ex:Software_Developers/{id} a :Software_Developers ; p:id {id} ; p:name {name} ; p:age {age} ; p:experience {experience} ; p:programming_language {programming_language} .
source		SELECT `id`, `name`, `age`, `experience`, `programming_language` FROM `Software_Developer`

mappingId	Data_Analyst_base
target		ex:Data_Analysts/{id} a :Data_Analysts ; p:id {id} ; p:name {name} ; p:age {age} ; p:experience {experience} ; p:software_used {software_used} .
source		SELECT `id`, `name`, `age`, `experience`, `software_used` FROM `Data_Analyst`

mappingId	HR_Recruiter_base
target		ex:HR_Recruiter/{id} a :HR_Recruiter ; p:id {id} ; p:name {name} ; p:age {age} ; p:experience {experience} ; p:recruitment_strategy {recruitment_strategy} .
source		SELECT `id`, `name`, `age`, `experience`, `recruitment_strategy` FROM `HR_Recruiter`

]]
