@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_construction_jobs_0_Civil_Engineers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"years_of_experience\", \"design_software_expertise\", \"salary\" FROM \"Civil_Engineers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Civil_Engineers/{id}" ; rr:class :Civil_Engineers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_of_experience ; rr:objectMap [ rr:column "years_of_experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:design_software_expertise ; rr:objectMap [ rr:column "design_software_expertise" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] .

<#tm_attachment_2tab_val_construction_jobs_1_Design_Softwares_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"software_name\", \"popularity\" FROM \"Design_Softwares\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Design_Softwares/{software_name}" ; rr:class :Design_Softwares ] ;
  rr:predicateObjectMap [ rr:predicate p:software_name ; rr:objectMap [ rr:column "software_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:popularity ; rr:objectMap [ rr:column "popularity" ] ] .

<#tm_attachment_2tab_val_construction_jobs_2_Architects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"years_in_practice\", \"design_software_expertise\", \"salary\" FROM \"Architects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Architects/{id}" ; rr:class :Architects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_in_practice ; rr:objectMap [ rr:column "years_in_practice" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:design_software_expertise ; rr:objectMap [ rr:column "design_software_expertise" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] .

<#tm_attachment_2tab_val_construction_jobs_3_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"project_id\", \"title\", \"description\", \"start_date\", \"end_date\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Project/{project_id}" ; rr:class :Project ] ;
  rr:predicateObjectMap [ rr:predicate p:project_id ; rr:objectMap [ rr:column "project_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] .

<#tm_attachment_2tab_val_construction_jobs_4_Engineer_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"engineer_id\", \"project_id\" FROM \"Engineer_Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Engineer_Projects/{engineer_id}/{project_id}" ; rr:class :Engineer_Projects ] ;
  rr:predicateObjectMap [ rr:predicate p:engineer_id ; rr:objectMap [ rr:column "engineer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:project_id ; rr:objectMap [ rr:column "project_id" ] ] .

<#tm_attachment_2tab_val_construction_jobs_5_Engineer_Projects_project_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"engineer_id\", \"project_id\" FROM \"Engineer_Projects\" WHERE \"project_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Engineer_Projects/{engineer_id}/{project_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProject ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Project/{project_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_construction_jobs_6_Engineer_Projects_engineer_id_fk> a rr:TriplesMap ;
