[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Graphic_Designers_base
target		ex:Graphic_Designers/{id} a :Graphic_Designers ; p:id {id} ; p:name {name} ; p:experience {experience} ; p:skills {skills} ; p:office {office} .
source		SELECT `id`, `name`, `experience`, `skills`, `office` FROM `Graphic_Designers`

mappingId	Web_Developers_base
target		ex:Web_Developers/{id} a :Web_Developers ; p:id {id} ; p:name {name} ; p:programming_languages {programming_languages} ; p:projects {projects} ; p:office {office} .
source		SELECT `id`, `name`, `programming_languages`, `projects`, `office` FROM `Web_Developers`

mappingId	HR_Managers_base
target		ex:HR_Managers/{id} a :HR_Managers ; p:id {id} ; p:name {name} ; p:years_experience {years_experience} ; p:department {department} ; p:office {office} .
source		SELECT `id`, `name`, `years_experience`, `department`, `office` FROM `HR_Managers`

mappingId	Recruitment_Coordinators_base
target		ex:Recruitment_Coordinators/{id} a :Recruitment_Coordinators ; p:id {id} ; p:name {name} ; p:job_type {job_type} ; p:responsibilities {responsibilities} ; p:office {office} .
source		SELECT `id`, `name`, `job_type`, `responsibilities`, `office` FROM `Recruitment_Coordinators`

mappingId	Software_Engineers_base
target		ex:Software_Engineers/{id} a :Software_Engineers ; p:id {id} ; p:name {name} ; p:programming_skills {programming_skills} ; p:project_history {project_history} ; p:office {office} .
source		SELECT `id`, `name`, `programming_skills`, `project_history`, `office` FROM `Software_Engineers`

]]
