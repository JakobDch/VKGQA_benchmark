@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_hospitality_jobs_0_Agency_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Agency\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Agency/{id}" ; rr:class :Agency ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_val_hospitality_jobs_1_Tour_Guide_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"guideName\", \"agencyId\" FROM \"Tour_Guide\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Tour_Guide/{id}" ; rr:class :Tour_Guide ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:guideName ; rr:objectMap [ rr:column "guideName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:agencyId ; rr:objectMap [ rr:column "agencyId" ] ] .

<#tm_attachment_2tab_val_hospitality_jobs_2_Tour_Guide_agencyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"agencyId\" FROM \"Tour_Guide\" WHERE \"agencyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Tour_Guide/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAgency ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Agency/{agencyId}" ; rr:termType rr:IRI ] ] .

