  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"tourGuideId\", \"travelAgentId\", \"jobId\", \"applicationDate\" FROM \"Applications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{_amb_rowid}" ; rr:class :Application ] ;
