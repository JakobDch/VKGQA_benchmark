  rr:predicateObjectMap [ rr:predicate p:travelAgentId ; rr:objectMap [ rr:column "travelAgentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobId ; rr:objectMap [ rr:column "jobId" ] ] ;
