<#tm_attachment_2tab_val_information_management_jobs_3_Applicants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\", \"email\", \"phone\" FROM \"Applicants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{id}" ; rr:class :Applicants ] ;
