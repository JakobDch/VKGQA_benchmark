<#tm_attachment_2tab_val_information_management_jobs_4_JobsPosted_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"employer_id\", \"position\", \"description\", \"start_date\", \"end_date\" FROM \"JobsPosted\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobsPosted/{id}" ; rr:class :JobsPosted ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:employer_id ; rr:objectMap [ rr:column "employer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position ; rr:objectMap [ rr:column "position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] .

<#tm_attachment_2tab_val_information_management_jobs_5_JobsPosted_employer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"employer_id\" FROM \"JobsPosted\" WHERE \"employer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobsPosted/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{employer_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_information_management_jobs_6_ApplicationsSubmitted_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"applicant_id\", \"job_posting_id\", \"resume\", \"cover_letter\" FROM \"ApplicationsSubmitted\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/ApplicationsSubmitted/{application_id}" ; rr:class :ApplicationsSubmitted ] ;
  rr:predicateObjectMap [ rr:predicate p:application_id ; rr:objectMap [ rr:column "application_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:applicant_id ; rr:objectMap [ rr:column "applicant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_posting_id ; rr:objectMap [ rr:column "job_posting_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:resume ; rr:objectMap [ rr:column "resume" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cover_letter ; rr:objectMap [ rr:column "cover_letter" ] ] .

<#tm_attachment_2tab_val_information_management_jobs_7_ApplicationsSubmitted_job_posting_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"job_posting_id\" FROM \"ApplicationsSubmitted\" WHERE \"job_posting_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/ApplicationsSubmitted/{application_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobsPosted ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobsPosted/{job_posting_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_information_management_jobs_8_ApplicationsSubmitted_applicant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"applicant_id\" FROM \"ApplicationsSubmitted\" WHERE \"applicant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/ApplicationsSubmitted/{application_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApplicants ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{applicant_id}" ; rr:termType rr:IRI ] ] .

