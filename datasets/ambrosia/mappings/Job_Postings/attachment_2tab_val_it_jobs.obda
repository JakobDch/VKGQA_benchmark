[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Network_Admin_base
target		ex:Network_Admin/{id} a :Network_Admin ; p:id {id} ; p:Position {Position} ; p:Years_of_Experience {Years_of_Experience} ; p:Degree_Level {Degree_Level} ; p:Salary {Salary} .
source		SELECT `id`, `Position`, `Years_of_Experience`, `Degree_Level`, `Salary` FROM `Network_Admin`

mappingId	IT_Consultant_base
target		ex:IT_Consultant/{id} a :IT_Consultant ; p:id {id} ; p:Type {Type} ; p:Projects_Worked {Projects_Worked} ; p:Languages_Known {Languages_Known} ; p:Salary {Salary} .
source		SELECT `id`, `Type`, `Projects_Worked`, `Languages_Known`, `Salary` FROM `IT_Consultant`

mappingId	Software_Engineer_base
target		ex:Software_Engineers/{id} a :Software_Engineers ; p:id {id} ; p:Programming_Languages {Programming_Languages} ; p:Experience_in_Teamwork {Experience_in_Teamwork} ; p:Specialization {Specialization} ; p:Salary {Salary} .
source		SELECT `id`, `Programming_Languages`, `Experience_in_Teamwork`, `Specialization`, `Salary` FROM `Software_Engineer`

mappingId	HR_Specialist_base
target		ex:HR_Specialists/{id} a :HR_Specialists ; p:id {id} ; p:Industry_Experience {Industry_Experience} ; p:Certifications {Certifications} ; p:Recruitment_Methods {Recruitment_Methods} ; p:Salary {Salary} .
source		SELECT `id`, `Industry_Experience`, `Certifications`, `Recruitment_Methods`, `Salary` FROM `HR_Specialist`

mappingId	Data_Analyst_base
target		ex:Data_Analysts/{id} a :Data_Analysts ; p:id {id} ; p:Tools_Used {Tools_Used} ; p:Analytical_Skills {Analytical_Skills} ; p:Problem_Solving_Abilities {Problem_Solving_Abilities} ; p:Salary {Salary} .
source		SELECT `id`, `Tools_Used`, `Analytical_Skills`, `Problem_Solving_Abilities`, `Salary` FROM `Data_Analyst`

]]
