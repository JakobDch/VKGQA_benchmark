@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_it_jobs_0_Network_Admin_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Position\", \"Years_of_Experience\", \"Degree_Level\", \"Salary\" FROM \"Network_Admin\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Network_Admin/{id}" ; rr:class :Network_Admin ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Position ; rr:objectMap [ rr:column "Position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Years_of_Experience ; rr:objectMap [ rr:column "Years_of_Experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Degree_Level ; rr:objectMap [ rr:column "Degree_Level" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] .

