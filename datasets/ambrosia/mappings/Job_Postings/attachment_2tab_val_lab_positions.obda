[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Research_Scientists_base
target		ex:Research_Scientists/{id} a :Research_Scientists ; p:id {id} ; p:name {name} ; p:age {age} ; p:salary {salary} ; p:Gender {Gender} .
source		SELECT `id`, `name`, `age`, `salary`, `Gender` FROM `Research_Scientists`

mappingId	Laboratory_Technicians_base
target		ex:Laboratory_Technicians/{id} a :Laboratory_Technicians ; p:id {id} ; p:name {name} ; p:age {age} ; p:experience {experience} ; p:Gender {Gender} .
source		SELECT `id`, `name`, `age`, `experience`, `Gender` FROM `Laboratory_Technicians`

mappingId	Software_Engineers_base
target		ex:Software_Engineers/{id} a :Software_Engineers ; p:id {id} ; p:name {name} ; p:skills {skills} ; p:years_experience {years_experience} ; p:gender {gender} .
source		SELECT `id`, `name`, `skills`, `years_experience`, `gender` FROM `Software_Engineers`

mappingId	Data_Analysts_base
target		ex:Data_Analysts/{id} a :Data_Analysts ; p:id {id} ; p:name {name} ; p:specialization {specialization} ; p:education {education} ; p:gender {gender} .
source		SELECT `id`, `name`, `specialization`, `education`, `gender` FROM `Data_Analysts`

mappingId	HR_Specialists_base
target		ex:HR_Specialists/{id} a :HR_Specialists ; p:id {id} ; p:name {name} ; p:department {department} ; p:employment_duration {employment_duration} ; p:gender {gender} .
source		SELECT `id`, `name`, `department`, `employment_duration`, `gender` FROM `HR_Specialists`

mappingId	Accountants_base
target		ex:Accountants/{id} a :Accountants ; p:id {id} ; p:name {name} ; p:qualification {qualification} ; p:years_in_industry {years_in_industry} ; p:gender {gender} .
source		SELECT `id`, `name`, `qualification`, `years_in_industry`, `gender` FROM `Accountants`

]]
