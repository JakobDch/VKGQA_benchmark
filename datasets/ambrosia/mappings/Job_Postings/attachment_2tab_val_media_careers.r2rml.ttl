  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\", \"phoneNumber\", \"languages\" FROM \"Editors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Editors/{id}" ; rr:class :Editors ] ;
