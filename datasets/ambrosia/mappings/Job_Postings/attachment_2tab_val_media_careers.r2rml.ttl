<#tm_attachment_2tab_val_media_careers_3_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"content\", \"publishDate\", \"editorId\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publishDate ; rr:objectMap [ rr:column "publishDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:editorId ; rr:objectMap [ rr:column "editorId" ] ] .

<#tm_attachment_2tab_val_media_careers_4_Articles_editorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"editorId\" FROM \"Articles\" WHERE \"editorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEditors ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Editors/{editorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_media_careers_5_Articles_editorId_fk> a rr:TriplesMap ;
