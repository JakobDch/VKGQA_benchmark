[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Journalists_base
target		ex:Journalists/{id} a :Journalists ; p:id {id} ; p:name {name} ; p:email {email} ; p:language_proficiency {language_proficiency} ; p:years_experience {years_experience} .
source		SELECT `id`, `name`, `email`, `language_proficiency`, `years_experience` FROM `Journalists`

mappingId	Editors_base
target		ex:Editors/{id} a :Editors ; p:id {id} ; p:name {name} ; p:email {email} ; p:language_proficiency {language_proficiency} ; p:experience_years {experience_years} .
source		SELECT `id`, `name`, `email`, `language_proficiency`, `experience_years` FROM `Editors`

mappingId	Companies_base
target		ex:Companies/{id} a :Companies ; p:id {id} ; p:companyName {companyName} ; p:location {location} .
source		SELECT `id`, `companyName`, `location` FROM `Companies`

mappingId	JobPostings_base
target		ex:JobPostings/{id} a :JobPostings ; p:id {id} ; p:jobTitle {jobTitle} ; p:description {description} ; p:salary {salary} .
source		SELECT `id`, `jobTitle`, `description`, `salary` FROM `JobPostings`

mappingId	Applications_base
target		ex:Application/{applicationId} a :Application ; p:applicationId {applicationId} ; p:applicantEmail {applicantEmail} ; p:appliedJob {appliedJob} ; p:applyDate {applyDate} .
source		SELECT `applicationId`, `applicantEmail`, `appliedJob`, `applyDate` FROM `Applications`

]]
