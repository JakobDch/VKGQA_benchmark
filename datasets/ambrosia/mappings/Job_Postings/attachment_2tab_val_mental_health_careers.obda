[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Psychologists_base
target		ex:Psychologists/{id} a :Psychologists ; p:id {id} ; p:name {name} ; p:specialty {specialty} ; p:experience_years {experience_years} ; p:clinic {clinic} .
source		SELECT `id`, `name`, `specialty`, `experience_years`, `clinic` FROM `Psychologists`

mappingId	Psychologists_clinic_fk
target		ex:Psychologists/{id} p:hasClinics ex:Clinics/{clinic} .
source		SELECT `id`, `clinic` FROM `Psychologists` WHERE `clinic` IS NOT NULL

mappingId	Psychiatrists_base
target		ex:Psychiatrists/{id} a :Psychiatrists ; p:id {id} ; p:name {name} ; p:specialty {specialty} ; p:experience_years {experience_years} ; p:clinic {clinic} .
source		SELECT `id`, `name`, `specialty`, `experience_years`, `clinic` FROM `Psychiatrists`

mappingId	Psychiatrists_clinic_fk
target		ex:Psychiatrists/{id} p:hasClinics ex:Clinics/{clinic} .
source		SELECT `id`, `clinic` FROM `Psychiatrists` WHERE `clinic` IS NOT NULL

mappingId	Jobs_base
target		ex:Jobs/{id} a :Jobs ; p:id {id} ; p:title {title} ; p:description {description} ; p:salary {salary} ; p:start_date {start_date} ; p:end_date {end_date} ; p:status {status} .
source		SELECT `id`, `title`, `description`, `salary`, `start_date`, `end_date`, `status` FROM `Jobs`

mappingId	Applicants_base
target		ex:Applicants/{id} a :Applicants ; p:id {id} ; p:first_name {first_name} ; p:last_name {last_name} ; p:email {email} ; p:phone_number {phone_number} ; p:job_id {job_id} .
source		SELECT `id`, `first_name`, `last_name`, `email`, `phone_number`, `job_id` FROM `Applicants`

mappingId	Applicants_job_id_fk
target		ex:Applicants/{id} p:hasJobs ex:Jobs/{job_id} .
source		SELECT `id`, `job_id` FROM `Applicants` WHERE `job_id` IS NOT NULL

mappingId	Clinics_base
target		ex:Clinics/{id} a :Clinics ; p:id {id} ; p:name {name} ; p:address {address} ; p:city {city} ; p:state {state} ; p:zipcode {zipcode} .
source		SELECT `id`, `name`, `address`, `city`, `state`, `zipcode` FROM `Clinics`

]]
