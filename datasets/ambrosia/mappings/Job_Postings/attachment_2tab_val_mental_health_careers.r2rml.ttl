@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_mental_health_careers_0_Psychologists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"specialty\", \"experience_years\", \"clinic\" FROM \"Psychologists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Psychologists/{id}" ; rr:class :Psychologists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specialty ; rr:objectMap [ rr:column "specialty" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience_years ; rr:objectMap [ rr:column "experience_years" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:clinic ; rr:objectMap [ rr:column "clinic" ] ] .

<#tm_attachment_2tab_val_mental_health_careers_1_Psychologists_clinic_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"clinic\" FROM \"Psychologists\" WHERE \"clinic\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Psychologists/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClinics ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Clinics/{clinic}" ; rr:termType rr:IRI ] ] .

