  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"job_id\" FROM \"Applicants\" WHERE \"job_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{job_id}" ; rr:termType rr:IRI ] ] .

