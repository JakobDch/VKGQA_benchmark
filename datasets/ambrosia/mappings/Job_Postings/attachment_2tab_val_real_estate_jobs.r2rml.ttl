<#tm_attachment_2tab_val_real_estate_jobs_0_Real_Estate_Agents_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"agent_id\", \"name\", \"phone_number\", \"email\", \"commission\" FROM \"Real_Estate_Agents\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Real_Estate_Agents/{agent_id}" ; rr:class :Real_Estate_Agents ] ;
  rr:predicateObjectMap [ rr:predicate p:agent_id ; rr:objectMap [ rr:column "agent_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:commission ; rr:objectMap [ rr:column "commission" ] ] .

