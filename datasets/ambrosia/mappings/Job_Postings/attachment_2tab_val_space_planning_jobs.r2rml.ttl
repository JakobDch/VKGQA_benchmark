<#tm_attachment_2tab_val_space_planning_jobs_2_Projects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"DesignerID\", \"ArchitectID\", \"Title\", \"Location\", \"StartDate\", \"EndDate\", \"Budget\", \"Status\" FROM \"Projects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Project/{ID}" ; rr:class :Project ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DesignerID ; rr:objectMap [ rr:column "DesignerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArchitectID ; rr:objectMap [ rr:column "ArchitectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Budget ; rr:objectMap [ rr:column "Budget" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Status ; rr:objectMap [ rr:column "Status" ] ] .

<#tm_attachment_2tab_val_space_planning_jobs_3_Projects_ArchitectID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"ArchitectID\" FROM \"Projects\" WHERE \"ArchitectID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Project/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLandscape_Architects ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Landscape_Architects/{ArchitectID}" ; rr:termType rr:IRI ] ] .

