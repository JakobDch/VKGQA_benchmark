[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Construction_Workers_base
target		ex:Construction_Workers/{id} a :Construction_Workers ; p:id {id} ; p:name {name} ; p:company_owner {company_owner} ; p:work_experience {work_experience} ; p:salary {salary} .
source		SELECT `id`, `name`, `company_owner`, `work_experience`, `salary` FROM `Construction_Workers`

mappingId	Electricians_base
target		ex:Electricians/{id} a :Electricians ; p:id {id} ; p:name {name} ; p:company_owner {company_owner} ; p:certifications {certifications} ; p:hourly_rate {hourly_rate} .
source		SELECT `id`, `name`, `company_owner`, `certifications`, `hourly_rate` FROM `Electricians`

mappingId	Software_Engineers_base
target		ex:Software_Engineers/{id} a :Software_Engineers ; p:id {id} ; p:name {name} ; p:company_name {company_name} ; p:programming_language {programming_language} ; p:years_of_experience {years_of_experience} .
source		SELECT `id`, `name`, `company_name`, `programming_language`, `years_of_experience` FROM `Software_Engineers`

mappingId	Accountants_base
target		ex:Accountants/{id} a :Accountants ; p:id {id} ; p:name {name} ; p:company_name {company_name} ; p:education {education} ; p:experience_years {experience_years} .
source		SELECT `id`, `name`, `company_name`, `education`, `experience_years` FROM `Accountants`

mappingId	HR_Specialists_base
target		ex:HR_Specialists/{id} a :HR_Specialists ; p:id {id} ; p:name {name} ; p:company_name {company_name} ; p:industry {industry} ; p:years_in_industry {years_in_industry} .
source		SELECT `id`, `name`, `company_name`, `industry`, `years_in_industry` FROM `HR_Specialists`

mappingId	Marketing_Managers_base
target		ex:Marketing_Managers/{id} a :Marketing_Managers ; p:id {id} ; p:name {name} ; p:company_name {company_name} ; p:marketing_strategy {marketing_strategy} ; p:campaign_successes {campaign_successes} .
source		SELECT `id`, `name`, `company_name`, `marketing_strategy`, `campaign_successes` FROM `Marketing_Managers`

]]
