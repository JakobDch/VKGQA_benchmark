[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Photographers_base
target		ex:Photographers/{id} a :Photographers ; p:id {id} ; p:photographerName {photographerName} ; p:price {price} ; p:experience {experience} ; p:specialization {specialization} .
source		SELECT `id`, `photographerName`, `price`, `experience`, `specialization` FROM `Photographers`

mappingId	Videographers_base
target		ex:Videographers/{id} a :Videographers ; p:id {id} ; p:videographerName {videographerName} ; p:price {price} ; p:experience {experience} ; p:specialization {specialization} .
source		SELECT `id`, `videographerName`, `price`, `experience`, `specialization` FROM `Videographers`

mappingId	JobPosts_base
target		ex:JobPostings/{id} a :JobPostings ; p:id {id} ; p:jobTitle {jobTitle} ; p:description {description} ; p:requiredSkills {requiredSkills} ; p:budget {budget} .
source		SELECT `id`, `jobTitle`, `description`, `requiredSkills`, `budget` FROM `JobPosts`

mappingId	Applications_base
target		ex:Application/{id} a :Application ; p:id {id} ; p:applicantId {applicantId} ; p:applicationDate {applicationDate} ; p:coverLetter {coverLetter} ; p:status {status} .
source		SELECT `id`, `applicantId`, `applicationDate`, `coverLetter`, `status` FROM `Applications`

mappingId	Skills_base
target		ex:Skill/{skillId} a :Skill ; p:skillId {skillId} ; p:skillName {skillName} .
source		SELECT `skillId`, `skillName` FROM `Skills`

mappingId	SkillRequirements_base
target		ex:SkillRequirements/{requirementID} a :SkillRequirements ; p:requirementID {requirementID} ; p:jobPostId {jobPostId} ; p:skillId {skillId} .
source		SELECT `requirementID`, `jobPostId`, `skillId` FROM `SkillRequirements`

mappingId	SkillRequirements_skillId_fk
target		ex:SkillRequirements/{requirementID} p:hasSkill ex:Skill/{skillId} .
source		SELECT `requirementID`, `skillId` FROM `SkillRequirements` WHERE `skillId` IS NOT NULL

mappingId	SkillRequirements_jobPostId_fk
target		ex:SkillRequirements/{requirementID} p:hasJobPostings ex:JobPostings/{jobPostId} .
source		SELECT `requirementID`, `jobPostId` FROM `SkillRequirements` WHERE `jobPostId` IS NOT NULL

]]
