@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_visual_art_professions_0_Photographers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"photographerName\", \"price\", \"experience\", \"specialization\" FROM \"Photographers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Photographers/{id}" ; rr:class :Photographers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:photographerName ; rr:objectMap [ rr:column "photographerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specialization ; rr:objectMap [ rr:column "specialization" ] ] .

<#tm_attachment_2tab_val_visual_art_professions_1_Videographers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"videographerName\", \"price\", \"experience\", \"specialization\" FROM \"Videographers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Videographers/{id}" ; rr:class :Videographers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:videographerName ; rr:objectMap [ rr:column "videographerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specialization ; rr:objectMap [ rr:column "specialization" ] ] .

<#tm_attachment_2tab_val_visual_art_professions_2_JobPosts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"jobTitle\", \"description\", \"requiredSkills\", \"budget\" FROM \"JobPosts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobTitle ; rr:objectMap [ rr:column "jobTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:requiredSkills ; rr:objectMap [ rr:column "requiredSkills" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:budget ; rr:objectMap [ rr:column "budget" ] ] .

<#tm_attachment_2tab_val_visual_art_professions_3_Applications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"applicantId\", \"applicationDate\", \"coverLetter\", \"status\" FROM \"Applications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{id}" ; rr:class :Application ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:applicantId ; rr:objectMap [ rr:column "applicantId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:applicationDate ; rr:objectMap [ rr:column "applicationDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:coverLetter ; rr:objectMap [ rr:column "coverLetter" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] .

<#tm_attachment_2tab_val_visual_art_professions_4_Skills_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"skillId\", \"skillName\" FROM \"Skills\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Skill/{skillId}" ; rr:class :Skill ] ;
  rr:predicateObjectMap [ rr:predicate p:skillId ; rr:objectMap [ rr:column "skillId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skillName ; rr:objectMap [ rr:column "skillName" ] ] .

<#tm_attachment_2tab_val_visual_art_professions_5_SkillRequirements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"requirementID\", \"jobPostId\", \"skillId\" FROM \"SkillRequirements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/SkillRequirements/{requirementID}" ; rr:class :SkillRequirements ] ;
  rr:predicateObjectMap [ rr:predicate p:requirementID ; rr:objectMap [ rr:column "requirementID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobPostId ; rr:objectMap [ rr:column "jobPostId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:skillId ; rr:objectMap [ rr:column "skillId" ] ] .

<#tm_attachment_2tab_val_visual_art_professions_6_SkillRequirements_skillId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"requirementID\", \"skillId\" FROM \"SkillRequirements\" WHERE \"skillId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/SkillRequirements/{requirementID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSkill ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Skill/{skillId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_visual_art_professions_7_SkillRequirements_jobPostId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"requirementID\", \"jobPostId\" FROM \"SkillRequirements\" WHERE \"jobPostId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/SkillRequirements/{requirementID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobPostings ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{jobPostId}" ; rr:termType rr:IRI ] ] .

