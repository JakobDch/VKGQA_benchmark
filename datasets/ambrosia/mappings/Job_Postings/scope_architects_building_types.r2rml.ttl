@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_architects_building_types_0_Architects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"experience\" FROM \"Architects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Architects/{id}" ; rr:class :Architects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] .

<#tm_scope_architects_building_types_1_Building_Types_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\" FROM \"Building_Types\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Building_Types/{id}" ; rr:class :Building_Types ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_scope_architects_building_types_2_Job_Postings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"required_skills\", \"salary\", \"post_date\" FROM \"Job_Postings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:required_skills ; rr:objectMap [ rr:column "required_skills" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:post_date ; rr:objectMap [ rr:column "post_date" ] ] .

<#tm_scope_architects_building_types_3_Architects_Building_Types_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"architect_id\", \"building_type_id\" FROM \"Architects_Building_Types\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Architects_Building_Types/{architect_id}/{building_type_id}" ; rr:class :Architects_Building_Types ] ;
  rr:predicateObjectMap [ rr:predicate p:architect_id ; rr:objectMap [ rr:column "architect_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:building_type_id ; rr:objectMap [ rr:column "building_type_id" ] ] .

<#tm_scope_architects_building_types_4_Architects_Building_Types_building_type_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"architect_id\", \"building_type_id\" FROM \"Architects_Building_Types\" WHERE \"building_type_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Architects_Building_Types/{architect_id}/{building_type_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBuilding_Types ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Building_Types/{building_type_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_architects_building_types_5_Architects_Building_Types_architect_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"architect_id\", \"building_type_id\" FROM \"Architects_Building_Types\" WHERE \"architect_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Architects_Building_Types/{architect_id}/{building_type_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArchitects ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Architects/{architect_id}" ; rr:termType rr:IRI ] ] .

