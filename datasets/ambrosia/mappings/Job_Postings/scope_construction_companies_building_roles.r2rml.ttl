@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_construction_companies_building_roles_0_Construction_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"company_name\", \"address\" FROM \"Construction_Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Construction_Companies/{id}" ; rr:class :Construction_Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_name ; rr:objectMap [ rr:column "company_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_scope_construction_companies_building_roles_1_Building_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"role_id\", \"role_value\" FROM \"Building_Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Building_Roles/{role_id}" ; rr:class :Building_Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:role_id ; rr:objectMap [ rr:column "role_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role_value ; rr:objectMap [ rr:column "role_value" ] ] .

<#tm_scope_construction_companies_building_roles_2_Construction_Companies_Building_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"construction_company_id\", \"building_role_id\" FROM \"Construction_Companies_Building_Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Construction_Companies_Building_Roles/{construction_company_id}/{building_role_id}" ; rr:class :Construction_Companies_Building_Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:construction_company_id ; rr:objectMap [ rr:column "construction_company_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:building_role_id ; rr:objectMap [ rr:column "building_role_id" ] ] .

<#tm_scope_construction_companies_building_roles_3_Construction_Companies_Building_Roles_building_role_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"construction_company_id\", \"building_role_id\" FROM \"Construction_Companies_Building_Roles\" WHERE \"building_role_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Construction_Companies_Building_Roles/{construction_company_id}/{building_role_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBuilding_Roles ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Building_Roles/{building_role_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_construction_companies_building_roles_4_Construction_Companies_Building_Roles_construction_company_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"construction_company_id\", \"building_role_id\" FROM \"Construction_Companies_Building_Roles\" WHERE \"construction_company_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Construction_Companies_Building_Roles/{construction_company_id}/{building_role_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasConstruction_Companies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Construction_Companies/{construction_company_id}" ; rr:termType rr:IRI ] ] .

