@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_content_creators_platforms_0_Content_Creators_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Content_Creators\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Content_Creators/{id}" ; rr:class :Content_Creators ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_content_creators_platforms_1_Platforms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"platform_name\" FROM \"Platforms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Platforms/{id}" ; rr:class :Platforms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:platform_name ; rr:objectMap [ rr:column "platform_name" ] ] .

<#tm_scope_content_creators_platforms_2_Content_Creators_Platforms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"content_creator_id\", \"platform_id\" FROM \"Content_Creators_Platforms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Content_Creators_Platforms/{content_creator_id}/{platform_id}" ; rr:class :Content_Creators_Platforms ] ;
  rr:predicateObjectMap [ rr:predicate p:content_creator_id ; rr:objectMap [ rr:column "content_creator_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:platform_id ; rr:objectMap [ rr:column "platform_id" ] ] .

<#tm_scope_content_creators_platforms_3_Content_Creators_Platforms_platform_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"content_creator_id\", \"platform_id\" FROM \"Content_Creators_Platforms\" WHERE \"platform_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Content_Creators_Platforms/{content_creator_id}/{platform_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPlatforms ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Platforms/{platform_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_content_creators_platforms_4_Content_Creators_Platforms_content_creator_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"content_creator_id\", \"platform_id\" FROM \"Content_Creators_Platforms\" WHERE \"content_creator_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Content_Creators_Platforms/{content_creator_id}/{platform_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasContent_Creators ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Content_Creators/{content_creator_id}" ; rr:termType rr:IRI ] ] .

