[PrefixDeclaration]
:	http://ambrosia.example.org/jobpostings#
p:	http://ambrosia.example.org/jobpostings/prop#
ex:	http://ambrosia.example.org/jobpostings/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Customer_Service_Representatives_base
target		ex:Customer_Service_Representatives/{id} a :Customer_Service_Representatives ; p:id {id} ; p:email {email} ; p:name {full_name} .
source		SELECT `id`, `email`, `full_name` FROM `Customer_Service_Representatives`

mappingId	Channels_base
target		ex:Channels/{channel_id} a :Channels ; p:channel_id {channel_id} ; p:channel_value {channel_value} .
source		SELECT `channel_id`, `channel_value` FROM `Channels`

mappingId	Customer_Service_Representatives_Channels_base
target		ex:Customer_Service_Representatives_Channels/{_amb_rowid} a :Customer_Service_Representatives_Channels ; p:representative_id {representative_id} ; p:channel_id {channel_id} .
source		SELECT `_amb_rowid`, `representative_id`, `channel_id` FROM `Customer_Service_Representatives_Channels`

mappingId	Customer_Service_Representatives_Channels_channel_id_fk
target		ex:Customer_Service_Representatives_Channels/{_amb_rowid} p:hasChannels ex:Channels/{channel_id} .
source		SELECT `_amb_rowid`, `channel_id` FROM `Customer_Service_Representatives_Channels` WHERE `channel_id` IS NOT NULL

mappingId	Customer_Service_Representatives_Channels_representative_id_fk
target		ex:Customer_Service_Representatives_Channels/{_amb_rowid} p:hasCustomer_Service_Representatives ex:Customer_Service_Representatives/{representative_id} .
source		SELECT `_amb_rowid`, `representative_id` FROM `Customer_Service_Representatives_Channels` WHERE `representative_id` IS NOT NULL

]]
