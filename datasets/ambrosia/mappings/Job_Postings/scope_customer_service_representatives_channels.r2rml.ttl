@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_customer_service_representatives_channels_0_Customer_Service_Representatives_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"email\", \"full_name\" FROM \"Customer_Service_Representatives\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Customer_Service_Representatives/{id}" ; rr:class :Customer_Service_Representatives ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_scope_customer_service_representatives_channels_1_Channels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"channel_id\", \"channel_value\" FROM \"Channels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Channels/{channel_id}" ; rr:class :Channels ] ;
  rr:predicateObjectMap [ rr:predicate p:channel_id ; rr:objectMap [ rr:column "channel_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:channel_value ; rr:objectMap [ rr:column "channel_value" ] ] .

<#tm_scope_customer_service_representatives_channels_2_Customer_Service_Representatives_Channels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"representative_id\", \"channel_id\" FROM \"Customer_Service_Representatives_Channels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Customer_Service_Representatives_Channels/{_amb_rowid}" ; rr:class :Customer_Service_Representatives_Channels ] ;
  rr:predicateObjectMap [ rr:predicate p:representative_id ; rr:objectMap [ rr:column "representative_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:channel_id ; rr:objectMap [ rr:column "channel_id" ] ] .

<#tm_scope_customer_service_representatives_channels_3_Customer_Service_Representatives_Channels_channel_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"channel_id\" FROM \"Customer_Service_Representatives_Channels\" WHERE \"channel_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Customer_Service_Representatives_Channels/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasChannels ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Channels/{channel_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_customer_service_representatives_channels_4_Customer_Service_Representatives_Channels_representative_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"representative_id\" FROM \"Customer_Service_Representatives_Channels\" WHERE \"representative_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Customer_Service_Representatives_Channels/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomer_Service_Representatives ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Customer_Service_Representatives/{representative_id}" ; rr:termType rr:IRI ] ] .

