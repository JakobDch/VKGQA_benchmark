@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_data_analysts_techniques_0_Data_Analysts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"years_of_experience\" FROM \"Data_Analysts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Data_Analysts/{id}" ; rr:class :Data_Analysts ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_of_experience ; rr:objectMap [ rr:column "years_of_experience" ] ] .

<#tm_scope_data_analysts_techniques_1_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"technique_name\" FROM \"Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Techniques/{id}" ; rr:class :Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_name ; rr:objectMap [ rr:column "technique_name" ] ] .

<#tm_scope_data_analysts_techniques_2_Data_Analysts_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"data_analyst_id\", \"technique_id\" FROM \"Data_Analysts_Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Data_Analysts_Techniques/{_amb_rowid}" ; rr:class :Data_Analysts_Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:data_analyst_id ; rr:objectMap [ rr:column "data_analyst_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technique_id ; rr:objectMap [ rr:column "technique_id" ] ] .

<#tm_scope_data_analysts_techniques_3_Data_Analysts_Techniques_technique_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"technique_id\" FROM \"Data_Analysts_Techniques\" WHERE \"technique_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Data_Analysts_Techniques/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTechniques ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Techniques/{technique_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_data_analysts_techniques_4_Data_Analysts_Techniques_data_analyst_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"data_analyst_id\" FROM \"Data_Analysts_Techniques\" WHERE \"data_analyst_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Data_Analysts_Techniques/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasData_Analysts ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Data_Analysts/{data_analyst_id}" ; rr:termType rr:IRI ] ] .

