@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_designers_tools_0_Designers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"experience\" FROM \"Designers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Designers/{id}" ; rr:class :Designers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] .

<#tm_scope_designers_tools_1_Tools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"tool_name\", \"description\" FROM \"Tools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Tools/{tool_name}" ; rr:class :Tools ] ;
  rr:predicateObjectMap [ rr:predicate p:tool_name ; rr:objectMap [ rr:column "tool_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_designers_tools_2_Designer_Tools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"designer_id\", \"tool_name\" FROM \"Designer_Tools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Designer_Tools/{_amb_rowid}" ; rr:class :Designer_Tools ] ;
  rr:predicateObjectMap [ rr:predicate p:designer_id ; rr:objectMap [ rr:column "designer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:tool_name ; rr:objectMap [ rr:column "tool_name" ] ] .

<#tm_scope_designers_tools_3_Designer_Tools_tool_name_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"tool_name\" FROM \"Designer_Tools\" WHERE \"tool_name\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Designer_Tools/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTools ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Tools/{tool_name}" ; rr:termType rr:IRI ] ] .

<#tm_scope_designers_tools_4_Designer_Tools_designer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"designer_id\" FROM \"Designer_Tools\" WHERE \"designer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Designer_Tools/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDesigners ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Designers/{designer_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_designers_tools_5_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"company_id\", \"company_name\", \"location\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{company_id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:company_id ; rr:objectMap [ rr:column "company_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_name ; rr:objectMap [ rr:column "company_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_designers_tools_6_JobPostings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"posting_id\", \"title\", \"description\", \"salary\", \"posted_date\", \"company_id\" FROM \"JobPostings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{posting_id}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:posting_id ; rr:objectMap [ rr:column "posting_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:posted_date ; rr:objectMap [ rr:column "posted_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_id ; rr:objectMap [ rr:column "company_id" ] ] .

<#tm_scope_designers_tools_7_JobPostings_company_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"posting_id\", \"company_id\" FROM \"JobPostings\" WHERE \"company_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{posting_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{company_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_designers_tools_8_Applications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"applicant_name\", \"email\", \"resume_path\", \"status\", \"job_posting_id\" FROM \"Applications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{application_id}" ; rr:class :Application ] ;
  rr:predicateObjectMap [ rr:predicate p:application_id ; rr:objectMap [ rr:column "application_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:applicant_name ; rr:objectMap [ rr:column "applicant_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:resume_path ; rr:objectMap [ rr:column "resume_path" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_posting_id ; rr:objectMap [ rr:column "job_posting_id" ] ] .

<#tm_scope_designers_tools_9_Applications_job_posting_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"job_posting_id\" FROM \"Applications\" WHERE \"job_posting_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{application_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobPostings ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{job_posting_id}" ; rr:termType rr:IRI ] ] .

