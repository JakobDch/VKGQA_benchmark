@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_employers_benefits_0_Employers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Employers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{id}" ; rr:class :Employers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_employers_benefits_1_Benefits_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"benefit_name\", \"description\" FROM \"Benefits\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Benefits/{id}" ; rr:class :Benefits ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:benefit_name ; rr:objectMap [ rr:column "benefit_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_employers_benefits_2_Employers_Benefits_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employer_id\", \"benefit_id\" FROM \"Employers_Benefits\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers_Benefits/{employer_id}/{benefit_id}" ; rr:class :Employers_Benefits ] ;
  rr:predicateObjectMap [ rr:predicate p:employer_id ; rr:objectMap [ rr:column "employer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:benefit_id ; rr:objectMap [ rr:column "benefit_id" ] ] .

<#tm_scope_employers_benefits_3_Employers_Benefits_benefit_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employer_id\", \"benefit_id\" FROM \"Employers_Benefits\" WHERE \"benefit_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers_Benefits/{employer_id}/{benefit_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBenefits ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Benefits/{benefit_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_employers_benefits_4_Employers_Benefits_employer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employer_id\", \"benefit_id\" FROM \"Employers_Benefits\" WHERE \"employer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers_Benefits/{employer_id}/{benefit_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{employer_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_employers_benefits_5_JobPostings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"location\", \"salary\", \"posting_date\" FROM \"JobPostings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:posting_date ; rr:objectMap [ rr:column "posting_date" ] ] .

<#tm_scope_employers_benefits_6_Applicants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\", \"email\", \"phone_number\", \"resume\" FROM \"Applicants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{id}" ; rr:class :Applicants ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:resume ; rr:objectMap [ rr:column "resume" ] ] .

<#tm_scope_employers_benefits_7_ApplicationStatuses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"application_id\", \"status\", \"interview_date\", \"feedback\" FROM \"ApplicationStatuses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/ApplicationStatuses/{_amb_rowid}" ; rr:class :ApplicationStatuses ] ;
  rr:predicateObjectMap [ rr:predicate p:application_id ; rr:objectMap [ rr:column "application_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:interview_date ; rr:objectMap [ rr:column "interview_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:feedback ; rr:objectMap [ rr:column "feedback" ] ] .

<#tm_scope_employers_benefits_8_ApplicationStatuses_application_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"application_id\" FROM \"ApplicationStatuses\" WHERE \"application_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/ApplicationStatuses/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApplicants ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{application_id}" ; rr:termType rr:IRI ] ] .

