@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_financial_analysts_metrics_0_Financial_Analysts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"experience\" FROM \"Financial_Analysts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Financial_Analysts/{id}" ; rr:class :Financial_Analysts ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] .

<#tm_scope_financial_analysts_metrics_1_Metrics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"metric_id\", \"metric_name\" FROM \"Metrics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Metrics/{metric_id}" ; rr:class :Metrics ] ;
  rr:predicateObjectMap [ rr:predicate p:metric_id ; rr:objectMap [ rr:column "metric_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:metric_name ; rr:objectMap [ rr:column "metric_name" ] ] .

<#tm_scope_financial_analysts_metrics_2_Company_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"company_id\", \"company_name\", \"location\" FROM \"Company\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{company_id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:company_id ; rr:objectMap [ rr:column "company_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_name ; rr:objectMap [ rr:column "company_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_financial_analysts_metrics_3_JobPostings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"job_posting_id\", \"title\", \"description\", \"salary\", \"created_at\" FROM \"JobPostings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{job_posting_id}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:job_posting_id ; rr:objectMap [ rr:column "job_posting_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:created_at ; rr:objectMap [ rr:column "created_at" ] ] .

<#tm_scope_financial_analysts_metrics_4_Financial_Analysts_JobPostings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"financial_analyst_id\", \"job_posting_id\" FROM \"Financial_Analysts_JobPostings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Financial_Analysts_JobPostings/{_amb_rowid}" ; rr:class :Financial_Analysts_JobPostings ] ;
