<#tm_scope_financial_analysts_metrics_5_Financial_Analysts_JobPostings_job_posting_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"job_posting_id\" FROM \"Financial_Analysts_JobPostings\" WHERE \"job_posting_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Financial_Analysts_JobPostings/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobPostings ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{job_posting_id}" ; rr:termType rr:IRI ] ] .

