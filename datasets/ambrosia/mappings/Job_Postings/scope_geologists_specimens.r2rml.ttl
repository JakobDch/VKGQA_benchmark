@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_geologists_specimens_0_Geologists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Geologists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Geologists/{id}" ; rr:class :Geologists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_geologists_specimens_1_Specimens_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\", \"description\" FROM \"Specimens\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Specimens/{id}" ; rr:class :Specimens ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_geologists_specimens_2_Geologists_Specimens_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"geologistId\", \"specimenType\" FROM \"Geologists_Specimens\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Geologists_Specimens/{_amb_rowid}" ; rr:class :Geologists_Specimens ] ;
  rr:predicateObjectMap [ rr:predicate p:geologistId ; rr:objectMap [ rr:column "geologistId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specimenType ; rr:objectMap [ rr:column "specimenType" ] ] .

<#tm_scope_geologists_specimens_3_Geologists_Specimens_specimenType_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"specimenType\" FROM \"Geologists_Specimens\" WHERE \"specimenType\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Geologists_Specimens/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSpecimens ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Specimens/{specimenType}" ; rr:termType rr:IRI ] ] .

<#tm_scope_geologists_specimens_4_Geologists_Specimens_geologistId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"geologistId\" FROM \"Geologists_Specimens\" WHERE \"geologistId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Geologists_Specimens/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGeologists ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Geologists/{geologistId}" ; rr:termType rr:IRI ] ] .

