@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_graphic_designers_programs_0_Graphic_Designers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"experience\" FROM \"Graphic_Designers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Graphic_Designers/{id}" ; rr:class :Graphic_Designers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] .

<#tm_scope_graphic_designers_programs_1_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"programName\" FROM \"Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Programs/{id}" ; rr:class :Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:programName ; rr:objectMap [ rr:column "programName" ] ] .

<#tm_scope_graphic_designers_programs_2_Graphic_Designers_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"graphicDesignerId\", \"programId\" FROM \"Graphic_Designers_Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Graphic_Designers_Programs/{_amb_rowid}" ; rr:class :Graphic_Designers_Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:graphicDesignerId ; rr:objectMap [ rr:column "graphicDesignerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:programId ; rr:objectMap [ rr:column "programId" ] ] .

<#tm_scope_graphic_designers_programs_3_Graphic_Designers_Programs_programId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"programId\" FROM \"Graphic_Designers_Programs\" WHERE \"programId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Graphic_Designers_Programs/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPrograms ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Programs/{programId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_graphic_designers_programs_4_Graphic_Designers_Programs_graphicDesignerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"graphicDesignerId\" FROM \"Graphic_Designers_Programs\" WHERE \"graphicDesignerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Graphic_Designers_Programs/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGraphic_Designers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Graphic_Designers/{graphicDesignerId}" ; rr:termType rr:IRI ] ] .

