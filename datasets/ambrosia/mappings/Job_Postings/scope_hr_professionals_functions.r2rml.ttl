@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_hr_professionals_functions_0_Hr_Professionals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Hr_Professionals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Hr_Professionals/{id}" ; rr:class :Hr_Professionals ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_hr_professionals_functions_1_Functions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"functionId\", \"description\" FROM \"Functions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Functions/{functionId}" ; rr:class :Functions ] ;
  rr:predicateObjectMap [ rr:predicate p:functionId ; rr:objectMap [ rr:column "functionId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_hr_professionals_functions_2_Hr_Professionals_Functions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"hrProfessionalId\", \"functionId\" FROM \"Hr_Professionals_Functions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Hr_Professionals_Functions/{_amb_rowid}" ; rr:class :Hr_Professionals_Functions ] ;
  rr:predicateObjectMap [ rr:predicate p:hrProfessionalId ; rr:objectMap [ rr:column "hrProfessionalId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:functionId ; rr:objectMap [ rr:column "functionId" ] ] .

<#tm_scope_hr_professionals_functions_3_Hr_Professionals_Functions_functionId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"functionId\" FROM \"Hr_Professionals_Functions\" WHERE \"functionId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Hr_Professionals_Functions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFunctions ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Functions/{functionId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_hr_professionals_functions_4_Hr_Professionals_Functions_hrProfessionalId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"hrProfessionalId\" FROM \"Hr_Professionals_Functions\" WHERE \"hrProfessionalId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Hr_Professionals_Functions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHr_Professionals ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Hr_Professionals/{hrProfessionalId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_hr_professionals_functions_5_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"jobId\", \"title\", \"description\" FROM \"Jobs\"""" ] ;
