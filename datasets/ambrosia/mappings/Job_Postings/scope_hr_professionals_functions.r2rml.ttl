  rr:logicalTable [ rr:sqlQuery """SELECT \"applicationId\", \"jobId\" FROM \"Applications\" WHERE \"jobId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{applicationId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{jobId}" ; rr:termType rr:IRI ] ] .

