<#tm_scope_internships_responsibilities_6_CompanyLocations_locationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"companyId\", \"locationId\" FROM \"CompanyLocations\" WHERE \"locationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/CompanyLocations/{companyId}/{locationId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocations ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{locationId}" ; rr:termType rr:IRI ] ] .

