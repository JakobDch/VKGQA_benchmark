@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_it_support_specialists_systems_0_It_Support_Specialists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"experience\" FROM \"It_Support_Specialists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/It_Support_Specialists/{id}" ; rr:class :It_Support_Specialists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] .

<#tm_scope_it_support_specialists_systems_1_Systems_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"system_id\", \"system_name\", \"is_active\" FROM \"Systems\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Systems/{system_id}" ; rr:class :Systems ] ;
  rr:predicateObjectMap [ rr:predicate p:system_id ; rr:objectMap [ rr:column "system_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:system_name ; rr:objectMap [ rr:column "system_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:is_active ; rr:objectMap [ rr:column "is_active" ] ] .

<#tm_scope_it_support_specialists_systems_2_It_Support_Specialists_Systems_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"it_specialist_id\", \"system_id\" FROM \"It_Support_Specialists_Systems\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/It_Support_Specialists_Systems/{_amb_rowid}" ; rr:class :It_Support_Specialists_Systems ] ;
  rr:predicateObjectMap [ rr:predicate p:it_specialist_id ; rr:objectMap [ rr:column "it_specialist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:system_id ; rr:objectMap [ rr:column "system_id" ] ] .

<#tm_scope_it_support_specialists_systems_3_It_Support_Specialists_Systems_system_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"system_id\" FROM \"It_Support_Specialists_Systems\" WHERE \"system_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/It_Support_Specialists_Systems/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSystems ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Systems/{system_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_it_support_specialists_systems_4_It_Support_Specialists_Systems_it_specialist_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"it_specialist_id\" FROM \"It_Support_Specialists_Systems\" WHERE \"it_specialist_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/It_Support_Specialists_Systems/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasIt_Support_Specialists ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/It_Support_Specialists/{it_specialist_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_it_support_specialists_systems_5_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"company_id\", \"company_name\", \"location\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{company_id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:company_id ; rr:objectMap [ rr:column "company_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_name ; rr:objectMap [ rr:column "company_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

