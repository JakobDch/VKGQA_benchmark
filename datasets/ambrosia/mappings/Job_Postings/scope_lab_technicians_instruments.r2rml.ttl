@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_lab_technicians_instruments_0_Lab_Technicians_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Lab_Technicians\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Lab_Technicians/{id}" ; rr:class :Lab_Technicians ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_lab_technicians_instruments_1_Instruments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"instrumentName\", \"description\" FROM \"Instruments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Instruments/{id}" ; rr:class :Instruments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:instrumentName ; rr:objectMap [ rr:column "instrumentName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_lab_technicians_instruments_2_Lab_Technicians_Instruments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"technicianId\", \"instrumentId\" FROM \"Lab_Technicians_Instruments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Lab_Technicians_Instruments/{_amb_rowid}" ; rr:class :Lab_Technicians_Instruments ] ;
  rr:predicateObjectMap [ rr:predicate p:technicianId ; rr:objectMap [ rr:column "technicianId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:instrumentId ; rr:objectMap [ rr:column "instrumentId" ] ] .

<#tm_scope_lab_technicians_instruments_3_Lab_Technicians_Instruments_instrumentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"instrumentId\" FROM \"Lab_Technicians_Instruments\" WHERE \"instrumentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Lab_Technicians_Instruments/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInstruments ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Instruments/{instrumentId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_lab_technicians_instruments_4_Lab_Technicians_Instruments_technicianId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"technicianId\" FROM \"Lab_Technicians_Instruments\" WHERE \"technicianId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Lab_Technicians_Instruments/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLab_Technicians ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Lab_Technicians/{technicianId}" ; rr:termType rr:IRI ] ] .

