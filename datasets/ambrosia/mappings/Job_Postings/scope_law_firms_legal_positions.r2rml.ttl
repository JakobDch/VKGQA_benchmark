@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_law_firms_legal_positions_0_Law_Firms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"website\" FROM \"Law_Firms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Law_Firms/{id}" ; rr:class :Law_Firms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:website ; rr:objectMap [ rr:column "website" ] ] .

<#tm_scope_law_firms_legal_positions_1_Legal_Positions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"position_name\", \"required_experience\" FROM \"Legal_Positions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Legal_Positions/{id}" ; rr:class :Legal_Positions ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position_name ; rr:objectMap [ rr:column "position_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:required_experience ; rr:objectMap [ rr:column "required_experience" ] ] .

<#tm_scope_law_firms_legal_positions_2_Law_Firm_Job_Postings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"job_title\", \"posted_date\", \"application_deadline\", \"description\", \"salary\" FROM \"Law_Firm_Job_Postings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Law_Firm_Job_Postings/{id}" ; rr:class :Law_Firm_Job_Postings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_title ; rr:objectMap [ rr:column "job_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:posted_date ; rr:objectMap [ rr:column "posted_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:application_deadline ; rr:objectMap [ rr:column "application_deadline" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] .

<#tm_scope_law_firms_legal_positions_3_Law_Firms_Legal_Positions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"firm_id\", \"position_id\" FROM \"Law_Firms_Legal_Positions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Law_Firms_Legal_Positions/{firm_id}/{position_id}" ; rr:class :Law_Firms_Legal_Positions ] ;
  rr:predicateObjectMap [ rr:predicate p:firm_id ; rr:objectMap [ rr:column "firm_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position_id ; rr:objectMap [ rr:column "position_id" ] ] .

<#tm_scope_law_firms_legal_positions_4_Law_Firms_Legal_Positions_position_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"firm_id\", \"position_id\" FROM \"Law_Firms_Legal_Positions\" WHERE \"position_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Law_Firms_Legal_Positions/{firm_id}/{position_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLegal_Positions ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Legal_Positions/{position_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_law_firms_legal_positions_5_Law_Firms_Legal_Positions_firm_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"firm_id\", \"position_id\" FROM \"Law_Firms_Legal_Positions\" WHERE \"firm_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Law_Firms_Legal_Positions/{firm_id}/{position_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLaw_Firms ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Law_Firms/{firm_id}" ; rr:termType rr:IRI ] ] .

