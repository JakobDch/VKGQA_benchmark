@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_marketing_agency_creative_position_0_Marketing_Agency_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Marketing_Agency\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Marketing_Agency/{id}" ; rr:class :Marketing_Agency ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_marketing_agency_creative_position_1_Creative_Position_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"position\" FROM \"Creative_Position\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Creative_Position/{id}" ; rr:class :Creative_Position ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position ; rr:objectMap [ rr:column "position" ] ] .

<#tm_scope_marketing_agency_creative_position_2_Marketing_Agency_Creative_Positions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"agency_id\", \"position_id\" FROM \"Marketing_Agency_Creative_Positions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Marketing_Agency_Creative_Positions/{_amb_rowid}" ; rr:class :Marketing_Agency_Creative_Positions ] ;
  rr:predicateObjectMap [ rr:predicate p:agency_id ; rr:objectMap [ rr:column "agency_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position_id ; rr:objectMap [ rr:column "position_id" ] ] .

<#tm_scope_marketing_agency_creative_position_3_Marketing_Agency_Creative_Positions_position_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"position_id\" FROM \"Marketing_Agency_Creative_Positions\" WHERE \"position_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Marketing_Agency_Creative_Positions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCreative_Position ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Creative_Position/{position_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_marketing_agency_creative_position_4_Marketing_Agency_Creative_Positions_agency_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"agency_id\" FROM \"Marketing_Agency_Creative_Positions\" WHERE \"agency_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Marketing_Agency_Creative_Positions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMarketing_Agency ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Marketing_Agency/{agency_id}" ; rr:termType rr:IRI ] ] .

