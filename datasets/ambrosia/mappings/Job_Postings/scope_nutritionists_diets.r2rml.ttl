@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_nutritionists_diets_0_Nutritionists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"nutritionist_id\", \"email\", \"full_name\" FROM \"Nutritionists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Nutritionists/{nutritionist_id}" ; rr:class :Nutritionists ] ;
  rr:predicateObjectMap [ rr:predicate p:nutritionist_id ; rr:objectMap [ rr:column "nutritionist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_scope_nutritionists_diets_1_Diets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"diet_type_id\", \"diet_type_value\" FROM \"Diets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Diets/{diet_type_id}" ; rr:class :Diets ] ;
  rr:predicateObjectMap [ rr:predicate p:diet_type_id ; rr:objectMap [ rr:column "diet_type_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:diet_type_value ; rr:objectMap [ rr:column "diet_type_value" ] ] .

<#tm_scope_nutritionists_diets_2_Nutritionists_Diets_base> a rr:TriplesMap ;
