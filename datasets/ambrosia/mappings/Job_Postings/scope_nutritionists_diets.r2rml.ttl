  rr:predicateObjectMap [ rr:predicate p:diet_type_id ; rr:objectMap [ rr:column "diet_type_id" ] ] .

<#tm_scope_nutritionists_diets_3_Nutritionists_Diets_diet_type_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"nutritionist_id\", \"diet_type_id\" FROM \"Nutritionists_Diets\" WHERE \"diet_type_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Nutritionists_Diets/{nutritionist_id}/{diet_type_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDiets ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Diets/{diet_type_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_nutritionists_diets_4_Nutritionists_Diets_nutritionist_id_fk> a rr:TriplesMap ;
