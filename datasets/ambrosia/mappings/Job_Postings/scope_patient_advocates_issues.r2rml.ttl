@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_patient_advocates_issues_0_Patient_Advocates_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Patient_Advocates\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Patient_Advocates/{id}" ; rr:class :Patient_Advocates ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_patient_advocates_issues_1_Issues_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"issue_name\", \"description\" FROM \"Issues\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Issues/{id}" ; rr:class :Issues ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:issue_name ; rr:objectMap [ rr:column "issue_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_patient_advocates_issues_2_Patient_Advocates_Issues_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"patient_advocate_id\", \"issue_id\" FROM \"Patient_Advocates_Issues\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Patient_Advocates_Issues/{_amb_rowid}" ; rr:class :Patient_Advocates_Issues ] ;
  rr:predicateObjectMap [ rr:predicate p:patient_advocate_id ; rr:objectMap [ rr:column "patient_advocate_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:issue_id ; rr:objectMap [ rr:column "issue_id" ] ] .

<#tm_scope_patient_advocates_issues_3_Patient_Advocates_Issues_issue_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"issue_id\" FROM \"Patient_Advocates_Issues\" WHERE \"issue_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Patient_Advocates_Issues/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasIssues ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Issues/{issue_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_patient_advocates_issues_4_Patient_Advocates_Issues_patient_advocate_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"patient_advocate_id\" FROM \"Patient_Advocates_Issues\" WHERE \"patient_advocate_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Patient_Advocates_Issues/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPatient_Advocates ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Patient_Advocates/{patient_advocate_id}" ; rr:termType rr:IRI ] ] .

