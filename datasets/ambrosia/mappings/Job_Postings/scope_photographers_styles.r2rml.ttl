@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_photographers_styles_0_Photographers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Photographers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Photographers/{id}" ; rr:class :Photographers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_photographers_styles_1_Styles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"styleName\" FROM \"Styles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Styles/{id}" ; rr:class :Styles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:styleName ; rr:objectMap [ rr:column "styleName" ] ] .

<#tm_scope_photographers_styles_2_Photographers_Styles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"photographerId\", \"styleId\" FROM \"Photographers_Styles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Photographers_Styles/{_amb_rowid}" ; rr:class :Photographers_Styles ] ;
  rr:predicateObjectMap [ rr:predicate p:photographerId ; rr:objectMap [ rr:column "photographerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:styleId ; rr:objectMap [ rr:column "styleId" ] ] .

<#tm_scope_photographers_styles_3_Photographers_Styles_styleId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"styleId\" FROM \"Photographers_Styles\" WHERE \"styleId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Photographers_Styles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStyles ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Styles/{styleId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_photographers_styles_4_Photographers_Styles_photographerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"photographerId\" FROM \"Photographers_Styles\" WHERE \"photographerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Photographers_Styles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPhotographers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Photographers/{photographerId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_photographers_styles_5_JobPostings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"jobID\", \"title\", \"description\", \"deadline\" FROM \"JobPostings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{jobID}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:jobID ; rr:objectMap [ rr:column "jobID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:deadline ; rr:objectMap [ rr:column "deadline" ] ] .

<#tm_scope_photographers_styles_6_BookedJobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bookingID\", \"photograherId\", \"jobId\", \"bookDate\", \"paymentAmount\" FROM \"BookedJobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/BookedJobs/{bookingID}" ; rr:class :BookedJobs ] ;
  rr:predicateObjectMap [ rr:predicate p:bookingID ; rr:objectMap [ rr:column "bookingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:photograherId ; rr:objectMap [ rr:column "photograherId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobId ; rr:objectMap [ rr:column "jobId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:bookDate ; rr:objectMap [ rr:column "bookDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:paymentAmount ; rr:objectMap [ rr:column "paymentAmount" ] ] .

<#tm_scope_photographers_styles_7_BookedJobs_jobId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bookingID\", \"jobId\" FROM \"BookedJobs\" WHERE \"jobId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/BookedJobs/{bookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobPostings ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{jobId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_photographers_styles_8_BookedJobs_photograherId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"bookingID\", \"photograherId\" FROM \"BookedJobs\" WHERE \"photograherId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/BookedJobs/{bookingID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPhotographers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Photographers/{photograherId}" ; rr:termType rr:IRI ] ] .

