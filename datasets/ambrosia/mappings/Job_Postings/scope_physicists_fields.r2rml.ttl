@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_physicists_fields_0_Physicists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Physicists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Physicists/{id}" ; rr:class :Physicists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_physicists_fields_1_Fields_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"fieldName\" FROM \"Fields\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Fields/{id}" ; rr:class :Fields ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fieldName ; rr:objectMap [ rr:column "fieldName" ] ] .

<#tm_scope_physicists_fields_2_Physicist_Fields_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"physicistId\", \"fieldId\" FROM \"Physicist_Fields\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Physicist_Fields/{_amb_rowid}" ; rr:class :Physicist_Fields ] ;
  rr:predicateObjectMap [ rr:predicate p:physicistId ; rr:objectMap [ rr:column "physicistId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:fieldId ; rr:objectMap [ rr:column "fieldId" ] ] .

<#tm_scope_physicists_fields_3_Physicist_Fields_fieldId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"fieldId\" FROM \"Physicist_Fields\" WHERE \"fieldId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Physicist_Fields/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFields ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Fields/{fieldId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_physicists_fields_4_Physicist_Fields_physicistId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"physicistId\" FROM \"Physicist_Fields\" WHERE \"physicistId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Physicist_Fields/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPhysicists ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Physicists/{physicistId}" ; rr:termType rr:IRI ] ] .

