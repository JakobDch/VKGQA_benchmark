@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_product_managers_metrics_0_Product_Managers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Product_Managers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Product_Managers/{id}" ; rr:class :Product_Managers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_product_managers_metrics_1_Metrics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"metric_name\", \"value\" FROM \"Metrics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Metrics/{id}" ; rr:class :Metrics ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:metric_name ; rr:objectMap [ rr:column "metric_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:value ; rr:objectMap [ rr:column "value" ] ] .

<#tm_scope_product_managers_metrics_2_Product_Managers_Metrics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"product_manager_id\", \"metrics_id\" FROM \"Product_Managers_Metrics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Product_Managers_Metrics/{_amb_rowid}" ; rr:class :Product_Managers_Metrics ] ;
  rr:predicateObjectMap [ rr:predicate p:product_manager_id ; rr:objectMap [ rr:column "product_manager_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:metrics_id ; rr:objectMap [ rr:column "metrics_id" ] ] .

<#tm_scope_product_managers_metrics_3_Product_Managers_Metrics_metrics_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"metrics_id\" FROM \"Product_Managers_Metrics\" WHERE \"metrics_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Product_Managers_Metrics/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMetrics ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Metrics/{metrics_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_product_managers_metrics_4_Product_Managers_Metrics_product_manager_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"product_manager_id\" FROM \"Product_Managers_Metrics\" WHERE \"product_manager_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Product_Managers_Metrics/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProduct_Managers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Product_Managers/{product_manager_id}" ; rr:termType rr:IRI ] ] .

