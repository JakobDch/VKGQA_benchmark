@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_project_managers_methodologies_0_Project_Managers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"years_of_experience\" FROM \"Project_Managers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Project_Managers/{id}" ; rr:class :Project_Managers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_of_experience ; rr:objectMap [ rr:column "years_of_experience" ] ] .

<#tm_scope_project_managers_methodologies_1_Methodologies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"methodology_id\", \"name\" FROM \"Methodologies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Methodologies/{methodology_id}" ; rr:class :Methodologies ] ;
  rr:predicateObjectMap [ rr:predicate p:methodology_id ; rr:objectMap [ rr:column "methodology_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_project_managers_methodologies_2_Project_Managers_Methodologies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"project_manager_id\", \"methodology_id\" FROM \"Project_Managers_Methodologies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Project_Managers_Methodologies/{_amb_rowid}" ; rr:class :Project_Managers_Methodologies ] ;
  rr:predicateObjectMap [ rr:predicate p:project_manager_id ; rr:objectMap [ rr:column "project_manager_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:methodology_id ; rr:objectMap [ rr:column "methodology_id" ] ] .

<#tm_scope_project_managers_methodologies_3_Project_Managers_Methodologies_methodology_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"methodology_id\" FROM \"Project_Managers_Methodologies\" WHERE \"methodology_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Project_Managers_Methodologies/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMethodologies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Methodologies/{methodology_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_project_managers_methodologies_4_Project_Managers_Methodologies_project_manager_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"project_manager_id\" FROM \"Project_Managers_Methodologies\" WHERE \"project_manager_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Project_Managers_Methodologies/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProject_Managers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Project_Managers/{project_manager_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_project_managers_methodologies_5_Other_Tables1_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"column2\", \"column3\" FROM \"Other_Tables1\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Other_Tables1/{id}" ; rr:class :Other_Tables1 ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:column2 ; rr:objectMap [ rr:column "column2" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:column3 ; rr:objectMap [ rr:column "column3" ] ] .

<#tm_scope_project_managers_methodologies_6_Other_Tables2_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"columnA\", \"columnB\" FROM \"Other_Tables2\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Other_Tables2/{id}" ; rr:class :Other_Tables2 ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:columnA ; rr:objectMap [ rr:column "columnA" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:columnB ; rr:objectMap [ rr:column "columnB" ] ] .

