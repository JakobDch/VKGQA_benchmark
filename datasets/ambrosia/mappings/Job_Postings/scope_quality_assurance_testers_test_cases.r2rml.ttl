@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_quality_assurance_testers_test_cases_0_Quality_Assurance_Testers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"testerID\", \"fullName\" FROM \"Quality_Assurance_Testers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Quality_Assurance_Testers/{testerID}" ; rr:class :Quality_Assurance_Testers ] ;
  rr:predicateObjectMap [ rr:predicate p:testerID ; rr:objectMap [ rr:column "testerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "fullName" ] ] .

<#tm_scope_quality_assurance_testers_test_cases_1_Test_Cases_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"testCaseID\", \"caseType\", \"description\" FROM \"Test_Cases\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Test_Cases/{testCaseID}" ; rr:class :Test_Cases ] ;
  rr:predicateObjectMap [ rr:predicate p:testCaseID ; rr:objectMap [ rr:column "testCaseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:caseType ; rr:objectMap [ rr:column "caseType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_quality_assurance_testers_test_cases_2_Qualified_Tests_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"testerID\", \"testCaseID\", \"qualificationDate\" FROM \"Qualified_Tests\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Qualified_Tests/{_amb_rowid}" ; rr:class :Qualified_Tests ] ;
  rr:predicateObjectMap [ rr:predicate p:testerID ; rr:objectMap [ rr:column "testerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:testCaseID ; rr:objectMap [ rr:column "testCaseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:qualificationDate ; rr:objectMap [ rr:column "qualificationDate" ] ] .

<#tm_scope_quality_assurance_testers_test_cases_3_Qualified_Tests_testCaseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"testCaseID\" FROM \"Qualified_Tests\" WHERE \"testCaseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Qualified_Tests/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTest_Cases ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Test_Cases/{testCaseID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_quality_assurance_testers_test_cases_4_Qualified_Tests_testerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"testerID\" FROM \"Qualified_Tests\" WHERE \"testerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Qualified_Tests/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasQuality_Assurance_Testers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Quality_Assurance_Testers/{testerID}" ; rr:termType rr:IRI ] ] .

