@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_restaurants_kitchen_roles_0_Restaurants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\", \"phone_number\" FROM \"Restaurants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Restaurants/{id}" ; rr:class :Restaurants ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_scope_restaurants_kitchen_roles_1_Kitchen_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"role_id\", \"role_name\" FROM \"Kitchen_Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Kitchen_Roles/{role_id}" ; rr:class :Kitchen_Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:role_id ; rr:objectMap [ rr:column "role_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role_name ; rr:objectMap [ rr:column "role_name" ] ] .

<#tm_scope_restaurants_kitchen_roles_2_Restaurants_Kitchen_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"restaurant_id\", \"kitchen_role_id\" FROM \"Restaurants_Kitchen_Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Restaurants_Kitchen_Roles/{_amb_rowid}" ; rr:class :Restaurants_Kitchen_Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:restaurant_id ; rr:objectMap [ rr:column "restaurant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:kitchen_role_id ; rr:objectMap [ rr:column "kitchen_role_id" ] ] .

<#tm_scope_restaurants_kitchen_roles_3_Restaurants_Kitchen_Roles_kitchen_role_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"kitchen_role_id\" FROM \"Restaurants_Kitchen_Roles\" WHERE \"kitchen_role_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Restaurants_Kitchen_Roles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasKitchen_Roles ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Kitchen_Roles/{kitchen_role_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_restaurants_kitchen_roles_4_Restaurants_Kitchen_Roles_restaurant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"restaurant_id\" FROM \"Restaurants_Kitchen_Roles\" WHERE \"restaurant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Restaurants_Kitchen_Roles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRestaurants ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Restaurants/{restaurant_id}" ; rr:termType rr:IRI ] ] .

