@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_retail_stores_staff_roles_0_Retail_Stores_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"store_id\", \"store_name\", \"store_location\" FROM \"Retail_Stores\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Retail_Stores/{store_id}" ; rr:class :Retail_Stores ] ;
  rr:predicateObjectMap [ rr:predicate p:store_id ; rr:objectMap [ rr:column "store_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:store_name ; rr:objectMap [ rr:column "store_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:store_location ; rr:objectMap [ rr:column "store_location" ] ] .

<#tm_scope_retail_stores_staff_roles_1_Staff_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"role_id\", \"role_title\" FROM \"Staff_Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Staff_Roles/{role_id}" ; rr:class :Staff_Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:role_id ; rr:objectMap [ rr:column "role_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role_title ; rr:objectMap [ rr:column "role_title" ] ] .

<#tm_scope_retail_stores_staff_roles_2_Retail_Stores_Staff_Roles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"retail_store_id\", \"staff_role_id\" FROM \"Retail_Stores_Staff_Roles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Retail_Stores_Staff_Roles/{_amb_rowid}" ; rr:class :Retail_Stores_Staff_Roles ] ;
  rr:predicateObjectMap [ rr:predicate p:retail_store_id ; rr:objectMap [ rr:column "retail_store_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:staff_role_id ; rr:objectMap [ rr:column "staff_role_id" ] ] .

<#tm_scope_retail_stores_staff_roles_3_Retail_Stores_Staff_Roles_staff_role_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"staff_role_id\" FROM \"Retail_Stores_Staff_Roles\" WHERE \"staff_role_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Retail_Stores_Staff_Roles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStaff_Roles ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Staff_Roles/{staff_role_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_retail_stores_staff_roles_4_Retail_Stores_Staff_Roles_retail_store_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"retail_store_id\" FROM \"Retail_Stores_Staff_Roles\" WHERE \"retail_store_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Retail_Stores_Staff_Roles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRetail_Stores ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Retail_Stores/{retail_store_id}" ; rr:termType rr:IRI ] ] .

