@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_sales_representatives_territories_0_Sales_Representatives_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FullName\" FROM \"Sales_Representatives\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Sales_Representatives/{ID}" ; rr:class :Sales_Representatives ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_scope_sales_representatives_territories_1_Territories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RegionID\", \"Name\", \"OtherColumn1\", \"OtherColumn2\" FROM \"Territories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Territories/{RegionID}" ; rr:class :Territories ] ;
  rr:predicateObjectMap [ rr:predicate p:RegionID ; rr:objectMap [ rr:column "RegionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OtherColumn1 ; rr:objectMap [ rr:column "OtherColumn1" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OtherColumn2 ; rr:objectMap [ rr:column "OtherColumn2" ] ] .

<#tm_scope_sales_representatives_territories_2_Sales_Representatives_Territories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"SalesRepID\", \"TerritoryID\" FROM \"Sales_Representatives_Territories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Sales_Representatives_Territories/{_amb_rowid}" ; rr:class :Sales_Representatives_Territories ] ;
  rr:predicateObjectMap [ rr:predicate p:SalesRepID ; rr:objectMap [ rr:column "SalesRepID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TerritoryID ; rr:objectMap [ rr:column "TerritoryID" ] ] .

<#tm_scope_sales_representatives_territories_3_Sales_Representatives_Territories_TerritoryID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"TerritoryID\" FROM \"Sales_Representatives_Territories\" WHERE \"TerritoryID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Sales_Representatives_Territories/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTerritories ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Territories/{TerritoryID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_sales_representatives_territories_4_Sales_Representatives_Territories_SalesRepID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"SalesRepID\" FROM \"Sales_Representatives_Territories\" WHERE \"SalesRepID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Sales_Representatives_Territories/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSales_Representatives ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Sales_Representatives/{SalesRepID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_sales_representatives_territories_5_Company_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CompanyID\", \"Name\", \"Industry\" FROM \"Company\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{CompanyID}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyID ; rr:objectMap [ rr:column "CompanyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Industry ; rr:objectMap [ rr:column "Industry" ] ] .

<#tm_scope_sales_representatives_territories_6_Products_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProductID\", \"Name\", \"Price\" FROM \"Products\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Products/{ProductID}" ; rr:class :Products ] ;
  rr:predicateObjectMap [ rr:predicate p:ProductID ; rr:objectMap [ rr:column "ProductID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

