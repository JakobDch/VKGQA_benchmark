@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_schools_educational_jobs_0_Schools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Schools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Schools/{id}" ; rr:class :Schools ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_schools_educational_jobs_1_Educational_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"job_id\", \"title\", \"description\" FROM \"Educational_Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Educational_Jobs/{job_id}" ; rr:class :Educational_Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:job_id ; rr:objectMap [ rr:column "job_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_schools_educational_jobs_2_School_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employee_id\", \"first_name\", \"last_name\", \"job_title\", \"school_id\" FROM \"School_Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/School_Employees/{employee_id}" ; rr:class :School_Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:employee_id ; rr:objectMap [ rr:column "employee_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_title ; rr:objectMap [ rr:column "job_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:school_id ; rr:objectMap [ rr:column "school_id" ] ] .

<#tm_scope_schools_educational_jobs_3_School_Employees_school_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employee_id\", \"school_id\" FROM \"School_Employees\" WHERE \"school_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/School_Employees/{employee_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSchools ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Schools/{school_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_schools_educational_jobs_4_Jobs_at_School_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"school_job_id\", \"school_id\", \"job_id\", \"start_date\", \"end_date\" FROM \"Jobs_at_School\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs_at_School/{school_job_id}" ; rr:class :Jobs_at_School ] ;
  rr:predicateObjectMap [ rr:predicate p:school_job_id ; rr:objectMap [ rr:column "school_job_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:school_id ; rr:objectMap [ rr:column "school_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_id ; rr:objectMap [ rr:column "job_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] .

<#tm_scope_schools_educational_jobs_5_Jobs_at_School_job_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"school_job_id\", \"job_id\" FROM \"Jobs_at_School\" WHERE \"job_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs_at_School/{school_job_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEducational_Jobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Educational_Jobs/{job_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_schools_educational_jobs_6_Jobs_at_School_school_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"school_job_id\", \"school_id\" FROM \"Jobs_at_School\" WHERE \"school_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs_at_School/{school_job_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSchools ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Schools/{school_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_schools_educational_jobs_7_Employee_Education_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employee_education_id\", \"employee_id\", \"education_level\", \"major\", \"degree_year\" FROM \"Employee_Education\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employee_Education/{employee_education_id}" ; rr:class :Employee_Education ] ;
  rr:predicateObjectMap [ rr:predicate p:employee_education_id ; rr:objectMap [ rr:column "employee_education_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:employee_id ; rr:objectMap [ rr:column "employee_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:education_level ; rr:objectMap [ rr:column "education_level" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:major ; rr:objectMap [ rr:column "major" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:degree_year ; rr:objectMap [ rr:column "degree_year" ] ] .

<#tm_scope_schools_educational_jobs_8_Employee_Education_employee_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employee_education_id\", \"employee_id\" FROM \"Employee_Education\" WHERE \"employee_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employee_Education/{employee_education_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSchool_Employees ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/School_Employees/{employee_id}" ; rr:termType rr:IRI ] ] .

