@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_software_companies_job_positions_0_Software_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"company_name\", \"location\" FROM \"Software_Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Companies/{id}" ; rr:class :Software_Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_name ; rr:objectMap [ rr:column "company_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_software_companies_job_positions_1_Job_Positions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"position_title\", \"description\" FROM \"Job_Positions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Job_Positions/{id}" ; rr:class :Job_Positions ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position_title ; rr:objectMap [ rr:column "position_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_software_companies_job_positions_2_Software_Companies_Job_Positions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"software_company_id\", \"job_position_id\" FROM \"Software_Companies_Job_Positions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Companies_Job_Positions/{software_company_id}/{job_position_id}" ; rr:class :Software_Companies_Job_Positions ] ;
  rr:predicateObjectMap [ rr:predicate p:software_company_id ; rr:objectMap [ rr:column "software_company_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_position_id ; rr:objectMap [ rr:column "job_position_id" ] ] .

<#tm_scope_software_companies_job_positions_3_Software_Companies_Job_Positions_job_position_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"software_company_id\", \"job_position_id\" FROM \"Software_Companies_Job_Positions\" WHERE \"job_position_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Companies_Job_Positions/{software_company_id}/{job_position_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJob_Positions ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Job_Positions/{job_position_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_software_companies_job_positions_4_Software_Companies_Job_Positions_software_company_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"software_company_id\", \"job_position_id\" FROM \"Software_Companies_Job_Positions\" WHERE \"software_company_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Companies_Job_Positions/{software_company_id}/{job_position_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSoftware_Companies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Companies/{software_company_id}" ; rr:termType rr:IRI ] ] .

