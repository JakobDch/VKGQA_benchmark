  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Languages/{LanguageID}" ; rr:class :Languages ] ;
  rr:predicateObjectMap [ rr:predicate p:LanguageID ; rr:objectMap [ rr:column "LanguageID" ] ] ;
