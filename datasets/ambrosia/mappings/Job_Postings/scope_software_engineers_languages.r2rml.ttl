@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_software_engineers_languages_0_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CompanyID\", \"CompanyName\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{CompanyID}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyID ; rr:objectMap [ rr:column "CompanyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyName ; rr:objectMap [ rr:column "CompanyName" ] ] .

<#tm_scope_software_engineers_languages_1_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LocationID\", \"LocationName\" FROM \"Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{LocationID}" ; rr:class :Locations ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationID ; rr:objectMap [ rr:column "LocationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationName ; rr:objectMap [ rr:column "LocationName" ] ] .

<#tm_scope_software_engineers_languages_2_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"JobTitle\", \"Description\", \"Salary\", \"CompanyID\" FROM \"Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{JobID}" ; rr:class :Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:JobID ; rr:objectMap [ rr:column "JobID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:JobTitle ; rr:objectMap [ rr:column "JobTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyID ; rr:objectMap [ rr:column "CompanyID" ] ] .

<#tm_scope_software_engineers_languages_3_Jobs_CompanyID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"CompanyID\" FROM \"Jobs\" WHERE \"CompanyID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{JobID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{CompanyID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_software_engineers_languages_4_Software_Engineers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EngineerID\", \"Name\", \"Email\", \"LocationID\" FROM \"Software_Engineers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Engineers/{EngineerID}" ; rr:class :Software_Engineers ] ;
  rr:predicateObjectMap [ rr:predicate p:EngineerID ; rr:objectMap [ rr:column "EngineerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LocationID ; rr:objectMap [ rr:column "LocationID" ] ] .

<#tm_scope_software_engineers_languages_5_Software_Engineers_LocationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EngineerID\", \"LocationID\" FROM \"Software_Engineers\" WHERE \"LocationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Engineers/{EngineerID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocations ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{LocationID}" ; rr:termType rr:IRI ] ] .

