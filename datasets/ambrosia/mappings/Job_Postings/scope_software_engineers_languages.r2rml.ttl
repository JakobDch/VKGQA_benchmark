<#tm_scope_software_engineers_languages_8_Software_Engineers_Languages_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SE_LanguageID\", \"SE_Id\" FROM \"Software_Engineers_Languages\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Engineers_Languages/{SE_LanguageID}/{SE_Id}" ; rr:class :Software_Engineers_Languages ] ;
  rr:predicateObjectMap [ rr:predicate p:SE_LanguageID ; rr:objectMap [ rr:column "SE_LanguageID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SE_Id ; rr:objectMap [ rr:column "SE_Id" ] ] .

<#tm_scope_software_engineers_languages_9_Software_Engineers_Languages_SE_Id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SE_LanguageID\", \"SE_Id\" FROM \"Software_Engineers_Languages\" WHERE \"SE_Id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Engineers_Languages/{SE_LanguageID}/{SE_Id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSoftware_Engineers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Engineers/{SE_Id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_software_engineers_languages_10_Software_Engineers_Languages_SE_LanguageID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SE_LanguageID\", \"SE_Id\" FROM \"Software_Engineers_Languages\" WHERE \"SE_LanguageID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Software_Engineers_Languages/{SE_LanguageID}/{SE_Id}" ] ;
