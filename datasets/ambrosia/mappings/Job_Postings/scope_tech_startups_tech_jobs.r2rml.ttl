@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_tech_startups_tech_jobs_0_Tech_Startups_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Tech_Startups\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Tech_Startups/{id}" ; rr:class :Tech_Startups ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_tech_startups_tech_jobs_1_Tech_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"job_title\", \"description\" FROM \"Tech_Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/TechJob/{id}" ; rr:class :TechJob ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_title ; rr:objectMap [ rr:column "job_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_tech_startups_tech_jobs_2_Tech_Startups_Tech_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"tech_startup_id\", \"tech_job_id\" FROM \"Tech_Startups_Tech_Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Tech_Startups_Tech_Jobs/{tech_startup_id}/{tech_job_id}" ; rr:class :Tech_Startups_Tech_Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:tech_startup_id ; rr:objectMap [ rr:column "tech_startup_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:tech_job_id ; rr:objectMap [ rr:column "tech_job_id" ] ] .

<#tm_scope_tech_startups_tech_jobs_3_Tech_Startups_Tech_Jobs_tech_job_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"tech_startup_id\", \"tech_job_id\" FROM \"Tech_Startups_Tech_Jobs\" WHERE \"tech_job_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Tech_Startups_Tech_Jobs/{tech_startup_id}/{tech_job_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTechJob ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/TechJob/{tech_job_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_tech_startups_tech_jobs_4_Tech_Startups_Tech_Jobs_tech_startup_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"tech_startup_id\", \"tech_job_id\" FROM \"Tech_Startups_Tech_Jobs\" WHERE \"tech_startup_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Tech_Startups_Tech_Jobs/{tech_startup_id}/{tech_job_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTech_Startups ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Tech_Startups/{tech_startup_id}" ; rr:termType rr:IRI ] ] .

