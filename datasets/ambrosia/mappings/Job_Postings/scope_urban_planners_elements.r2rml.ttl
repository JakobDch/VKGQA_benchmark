@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_urban_planners_elements_0_Urban_Planners_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"experience\" FROM \"Urban_Planners\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Urban_Planners/{id}" ; rr:class :Urban_Planners ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:experience ; rr:objectMap [ rr:column "experience" ] ] .

<#tm_scope_urban_planners_elements_1_Elements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"element_name\" FROM \"Elements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Elements/{id}" ; rr:class :Elements ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:element_name ; rr:objectMap [ rr:column "element_name" ] ] .

<#tm_scope_urban_planners_elements_2_Urban_Planners_Elements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"urban_planner_id\", \"element_id\" FROM \"Urban_Planners_Elements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Urban_Planners_Elements/{urban_planner_id}/{element_id}" ; rr:class :Urban_Planners_Elements ] ;
  rr:predicateObjectMap [ rr:predicate p:urban_planner_id ; rr:objectMap [ rr:column "urban_planner_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:element_id ; rr:objectMap [ rr:column "element_id" ] ] .

<#tm_scope_urban_planners_elements_3_Urban_Planners_Elements_element_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"urban_planner_id\", \"element_id\" FROM \"Urban_Planners_Elements\" WHERE \"element_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Urban_Planners_Elements/{urban_planner_id}/{element_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasElements ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Elements/{element_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_urban_planners_elements_4_Urban_Planners_Elements_urban_planner_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"urban_planner_id\", \"element_id\" FROM \"Urban_Planners_Elements\" WHERE \"urban_planner_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Urban_Planners_Elements/{urban_planner_id}/{element_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUrban_Planners ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Urban_Planners/{urban_planner_id}" ; rr:termType rr:IRI ] ] .

