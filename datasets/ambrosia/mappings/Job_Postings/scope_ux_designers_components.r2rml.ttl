@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_ux_designers_components_0_Ux_Designers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"years_of_experience\" FROM \"Ux_Designers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Ux_Designers/{id}" ; rr:class :Ux_Designers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_of_experience ; rr:objectMap [ rr:column "years_of_experience" ] ] .

<#tm_scope_ux_designers_components_1_Components_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"component_name\", \"description\" FROM \"Components\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Components/{id}" ; rr:class :Components ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:component_name ; rr:objectMap [ rr:column "component_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_ux_designers_components_2_Ux_Designers_Components_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ux_designer_id\", \"component_id\" FROM \"Ux_Designers_Components\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Ux_Designers_Components/{_amb_rowid}" ; rr:class :Ux_Designers_Components ] ;
  rr:predicateObjectMap [ rr:predicate p:ux_designer_id ; rr:objectMap [ rr:column "ux_designer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:component_id ; rr:objectMap [ rr:column "component_id" ] ] .

<#tm_scope_ux_designers_components_3_Ux_Designers_Components_component_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"component_id\" FROM \"Ux_Designers_Components\" WHERE \"component_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Ux_Designers_Components/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasComponents ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Components/{component_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_ux_designers_components_4_Ux_Designers_Components_ux_designer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ux_designer_id\" FROM \"Ux_Designers_Components\" WHERE \"ux_designer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Ux_Designers_Components/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUx_Designers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Ux_Designers/{ux_designer_id}" ; rr:termType rr:IRI ] ] .

