@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_compensation_0_Employer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Name\", \"Email\", \"PhoneNumber\" FROM \"Employer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{Id}" ; rr:class :Employers ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] .

<#tm_vague_2cols_compensation_1_Position_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Title\", \"Description\" FROM \"Position\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{Id}" ; rr:class :Position ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_vague_2cols_compensation_2_SalaryDetails_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"Salary_Range\", \"Hourly_Rate\", \"PositionId\" FROM \"SalaryDetails\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/SalaryDetails/{Id}" ; rr:class :SalaryDetails ] ;
  rr:predicateObjectMap [ rr:predicate p:Id ; rr:objectMap [ rr:column "Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary_Range ; rr:objectMap [ rr:column "Salary_Range" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Hourly_Rate ; rr:objectMap [ rr:column "Hourly_Rate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PositionId ; rr:objectMap [ rr:column "PositionId" ] ] .

<#tm_vague_2cols_compensation_3_SalaryDetails_PositionId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Id\", \"PositionId\" FROM \"SalaryDetails\" WHERE \"PositionId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/SalaryDetails/{Id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPosition ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{PositionId}" ; rr:termType rr:IRI ] ] .

