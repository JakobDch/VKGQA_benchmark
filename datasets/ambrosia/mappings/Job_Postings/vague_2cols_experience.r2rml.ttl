@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_experience_0_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CompanyID\", \"Name\", \"Location\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{CompanyID}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:CompanyID ; rr:objectMap [ rr:column "CompanyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_vague_2cols_experience_1_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"JobID\", \"Minimum_Years\", \"Preferred_Years\", \"JobTitle\", \"Description\", \"Salary\" FROM \"Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{JobID}" ; rr:class :Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:JobID ; rr:objectMap [ rr:column "JobID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Minimum_Years ; rr:objectMap [ rr:column "Minimum_Years" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Preferred_Years ; rr:objectMap [ rr:column "Preferred_Years" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:JobTitle ; rr:objectMap [ rr:column "JobTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] .

<#tm_vague_2cols_experience_2_EducationRequirements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RequirementID\", \"DegreeLevel\", \"FieldOfStudy\" FROM \"EducationRequirements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/EducationRequirements/{RequirementID}" ; rr:class :EducationRequirements ] ;
  rr:predicateObjectMap [ rr:predicate p:RequirementID ; rr:objectMap [ rr:column "RequirementID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DegreeLevel ; rr:objectMap [ rr:column "DegreeLevel" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FieldOfStudy ; rr:objectMap [ rr:column "FieldOfStudy" ] ] .

<#tm_vague_2cols_experience_3_RequiredSkills_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SkillID\", \"SkillName\", \"ProficiencyLevel\" FROM \"RequiredSkills\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/RequiredSkills/{SkillID}" ; rr:class :RequiredSkills ] ;
  rr:predicateObjectMap [ rr:predicate p:SkillID ; rr:objectMap [ rr:column "SkillID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SkillName ; rr:objectMap [ rr:column "SkillName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ProficiencyLevel ; rr:objectMap [ rr:column "ProficiencyLevel" ] ] .

