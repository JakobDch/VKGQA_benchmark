@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_experience_level_0_Applicants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\", \"phone\", \"resume\" FROM \"Applicants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{id}" ; rr:class :Applicants ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone ; rr:objectMap [ rr:column "phone" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:resume ; rr:objectMap [ rr:column "resume" ] ] .

<#tm_vague_2cols_experience_level_1_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"location\", \"salary\" FROM \"Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{id}" ; rr:class :Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] .

<#tm_vague_2cols_experience_level_2_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"industry\", \"size\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:industry ; rr:objectMap [ rr:column "industry" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:size ; rr:objectMap [ rr:column "size" ] ] .

<#tm_vague_2cols_experience_level_3_CompanyJobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"company_id\", \"job_id\" FROM \"CompanyJobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/CompanyJobs/{company_id}/{job_id}" ; rr:class :CompanyJobs ] ;
  rr:predicateObjectMap [ rr:predicate p:company_id ; rr:objectMap [ rr:column "company_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_id ; rr:objectMap [ rr:column "job_id" ] ] .

<#tm_vague_2cols_experience_level_4_CompanyJobs_job_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"company_id\", \"job_id\" FROM \"CompanyJobs\" WHERE \"job_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/CompanyJobs/{company_id}/{job_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{job_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_experience_level_5_CompanyJobs_company_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"company_id\", \"job_id\" FROM \"CompanyJobs\" WHERE \"company_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/CompanyJobs/{company_id}/{job_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{company_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_experience_level_6_Experiences_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"applicant_id\", \"years_of_experience\", \"number_of_completed_projects\", \"job\", \"additional_skills\" FROM \"Experiences\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Experiences/{applicant_id}/{job}" ; rr:class :Experiences ] ;
  rr:predicateObjectMap [ rr:predicate p:applicant_id ; rr:objectMap [ rr:column "applicant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:years_of_experience ; rr:objectMap [ rr:column "years_of_experience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number_of_completed_projects ; rr:objectMap [ rr:column "number_of_completed_projects" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job ; rr:objectMap [ rr:column "job" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:additional_skills ; rr:objectMap [ rr:column "additional_skills" ] ] .

<#tm_vague_2cols_experience_level_7_Experiences_applicant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"applicant_id\", \"job\" FROM \"Experiences\" WHERE \"applicant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Experiences/{applicant_id}/{job}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApplicants ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{applicant_id}" ; rr:termType rr:IRI ] ] .

