@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_location_0_Office_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Office_Address\", \"City\" FROM \"Office\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Office/{ID}" ; rr:class :Office ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Office_Address ; rr:objectMap [ rr:column "Office_Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] .

<#tm_vague_2cols_location_1_Department_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\" FROM \"Department\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{ID}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_vague_2cols_location_2_Internship_Position_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Position_Title\", \"Description\", \"Duration\" FROM \"Internship_Position\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Internship_Position/{ID}" ; rr:class :Internship_Position ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Position_Title ; rr:objectMap [ rr:column "Position_Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Duration ; rr:objectMap [ rr:column "Duration" ] ] .

<#tm_vague_2cols_location_3_Employee_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"First_Name\", \"Last_Name\", \"Email\", \"Phone_Number\", \"Hire_Date\" FROM \"Employee\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{ID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:First_Name ; rr:objectMap [ rr:column "First_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Last_Name ; rr:objectMap [ rr:column "Last_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Phone_Number ; rr:objectMap [ rr:column "Phone_Number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Hire_Date ; rr:objectMap [ rr:column "Hire_Date" ] ] .

<#tm_vague_2cols_location_4_Job_Posting_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Description\", \"Required_Skills\", \"Salary\", \"Application_Deadline\", \"Office_ID\", \"Departments_ID\", \"Internships_ID\" FROM \"Job_Posting\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{ID}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Required_Skills ; rr:objectMap [ rr:column "Required_Skills" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Salary ; rr:objectMap [ rr:column "Salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Application_Deadline ; rr:objectMap [ rr:column "Application_Deadline" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Office_ID ; rr:objectMap [ rr:column "Office_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Departments_ID ; rr:objectMap [ rr:column "Departments_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Internships_ID ; rr:objectMap [ rr:column "Internships_ID" ] ] .

<#tm_vague_2cols_location_5_Job_Posting_Internships_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Internships_ID\" FROM \"Job_Posting\" WHERE \"Internships_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInternship_Position ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Internship_Position/{Internships_ID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_6_Job_Posting_Departments_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Departments_ID\" FROM \"Job_Posting\" WHERE \"Departments_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDepartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{Departments_ID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_7_Job_Posting_Office_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Office_ID\" FROM \"Job_Posting\" WHERE \"Office_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOffice ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Office/{Office_ID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_8_Applicant_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Full_name\", \"Email\", \"Phone_number\", \"Resume_url\", \"Date_applied\", \"Job_posting_id\" FROM \"Applicant\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{ID}" ; rr:class :Applicants ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Full_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Phone_number ; rr:objectMap [ rr:column "Phone_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Resume_url ; rr:objectMap [ rr:column "Resume_url" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date_applied ; rr:objectMap [ rr:column "Date_applied" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Job_posting_id ; rr:objectMap [ rr:column "Job_posting_id" ] ] .

<#tm_vague_2cols_location_9_Applicant_Job_posting_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Job_posting_id\" FROM \"Applicant\" WHERE \"Job_posting_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobPostings ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{Job_posting_id}" ; rr:termType rr:IRI ] ] .

