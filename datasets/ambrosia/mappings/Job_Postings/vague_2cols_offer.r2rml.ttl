<#tm_vague_2cols_offer_3_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"employerId\", \"jobTypeId\", \"locationId\", \"Base_Pay_Range\", \"Benefits\", \"Job_Post\" FROM \"Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{id}" ; rr:class :Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:employerId ; rr:objectMap [ rr:column "employerId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobTypeId ; rr:objectMap [ rr:column "jobTypeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationId ; rr:objectMap [ rr:column "locationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Base_Pay_Range ; rr:objectMap [ rr:column "Base_Pay_Range" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Benefits ; rr:objectMap [ rr:column "Benefits" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Job_Post ; rr:objectMap [ rr:column "Job_Post" ] ] .

<#tm_vague_2cols_offer_4_Jobs_locationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"locationId\" FROM \"Jobs\" WHERE \"locationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocations ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{locationId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_offer_5_Jobs_jobTypeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"jobTypeId\" FROM \"Jobs\" WHERE \"jobTypeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJob_Type ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Job_Type/{jobTypeId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_offer_6_Jobs_employerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"employerId\" FROM \"Jobs\" WHERE \"employerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployers ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{employerId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_offer_7_Applicants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"fullName\", \"emailAddress\", \"phoneNumber\" FROM \"Applicants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{id}" ; rr:class :Applicants ] ;
