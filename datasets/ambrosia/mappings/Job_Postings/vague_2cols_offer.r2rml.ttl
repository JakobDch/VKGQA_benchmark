@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_offer_0_Employers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"companyName\", \"contactNumber\" FROM \"Employers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employers/{id}" ; rr:class :Employers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:companyName ; rr:objectMap [ rr:column "companyName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contactNumber ; rr:objectMap [ rr:column "contactNumber" ] ] .

<#tm_vague_2cols_offer_1_JobTypes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"typeName\" FROM \"JobTypes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Job_Type/{id}" ; rr:class :Job_Type ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:typeName ; rr:objectMap [ rr:column "typeName" ] ] .

<#tm_vague_2cols_offer_2_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"locationName\" FROM \"Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Locations/{id}" ; rr:class :Locations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
