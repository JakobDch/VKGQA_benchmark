<#tm_vague_2cols_offer_8_ApplicationStatuses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"applicationId\", \"applicantId\", \"status\", \"dateApplied\" FROM \"ApplicationStatuses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/ApplicationStatuses/{applicationId}" ; rr:class :ApplicationStatuses ] ;
  rr:predicateObjectMap [ rr:predicate p:applicationId ; rr:objectMap [ rr:column "applicationId" ] ] ;
