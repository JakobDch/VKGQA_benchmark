  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dateApplied ; rr:objectMap [ rr:column "dateApplied" ] ] .

<#tm_vague_2cols_offer_9_ApplicationStatuses_applicantId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"applicationId\", \"applicantId\" FROM \"ApplicationStatuses\" WHERE \"applicantId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/ApplicationStatuses/{applicationId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApplicants ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{applicantId}" ; rr:termType rr:IRI ] ] .

