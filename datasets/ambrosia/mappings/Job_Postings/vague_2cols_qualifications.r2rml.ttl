@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_qualifications_0_Degrees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"degree_level\", \"certification\", \"job_post\" FROM \"Degrees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Degrees/{id}" ; rr:class :Degrees ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:degree_level ; rr:objectMap [ rr:column "degree_level" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:certification ; rr:objectMap [ rr:column "certification" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_post ; rr:objectMap [ rr:column "job_post" ] ] .

<#tm_vague_2cols_qualifications_1_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"company_name\", \"location\", \"industry\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:company_name ; rr:objectMap [ rr:column "company_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:industry ; rr:objectMap [ rr:column "industry" ] ] .

<#tm_vague_2cols_qualifications_2_Applicants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"applicant_name\", \"email\", \"phone_number\" FROM \"Applicants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{id}" ; rr:class :Applicants ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:applicant_name ; rr:objectMap [ rr:column "applicant_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone_number ; rr:objectMap [ rr:column "phone_number" ] ] .

<#tm_vague_2cols_qualifications_3_Jobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"salary\", \"posted_date\" FROM \"Jobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{id}" ; rr:class :Jobs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:posted_date ; rr:objectMap [ rr:column "posted_date" ] ] .

<#tm_vague_2cols_qualifications_4_CompanyJobs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"company_id\", \"job_id\" FROM \"CompanyJobs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/CompanyJobs/{company_id}/{job_id}" ; rr:class :CompanyJobs ] ;
  rr:predicateObjectMap [ rr:predicate p:company_id ; rr:objectMap [ rr:column "company_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_id ; rr:objectMap [ rr:column "job_id" ] ] .

<#tm_vague_2cols_qualifications_5_CompanyJobs_job_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"company_id\", \"job_id\" FROM \"CompanyJobs\" WHERE \"job_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/CompanyJobs/{company_id}/{job_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{job_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_qualifications_6_CompanyJobs_company_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"company_id\", \"job_id\" FROM \"CompanyJobs\" WHERE \"company_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/CompanyJobs/{company_id}/{job_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{company_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_qualifications_7_Applications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"applicant_id\", \"job_id\", \"status\", \"submission_date\" FROM \"Applications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{application_id}" ; rr:class :Application ] ;
  rr:predicateObjectMap [ rr:predicate p:application_id ; rr:objectMap [ rr:column "application_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:applicant_id ; rr:objectMap [ rr:column "applicant_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_id ; rr:objectMap [ rr:column "job_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:submission_date ; rr:objectMap [ rr:column "submission_date" ] ] .

<#tm_vague_2cols_qualifications_8_Applications_job_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"job_id\" FROM \"Applications\" WHERE \"job_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{application_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJobs ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Jobs/{job_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_qualifications_9_Applications_applicant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"applicant_id\" FROM \"Applications\" WHERE \"applicant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{application_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApplicants ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Applicants/{applicant_id}" ; rr:termType rr:IRI ] ] .

