@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_recruiter_0_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"email\", \"phoneNumber\", \"hireDate\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{id}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hireDate ; rr:objectMap [ rr:column "hireDate" ] ] .

<#tm_vague_2cols_recruiter_1_Departments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"managerId\" FROM \"Departments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{id}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:managerId ; rr:objectMap [ rr:column "managerId" ] ] .

<#tm_vague_2cols_recruiter_2_Departments_managerId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"managerId\" FROM \"Departments\" WHERE \"managerId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployees ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{managerId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_recruiter_3_Salaries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"employeeId\", \"salary\", \"effectiveDate\" FROM \"Salaries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Salaries/{_amb_rowid}" ; rr:class :Salaries ] ;
  rr:predicateObjectMap [ rr:predicate p:employeeId ; rr:objectMap [ rr:column "employeeId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:effectiveDate ; rr:objectMap [ rr:column "effectiveDate" ] ] .

<#tm_vague_2cols_recruiter_4_Salaries_employeeId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"employeeId\" FROM \"Salaries\" WHERE \"employeeId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Salaries/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployees ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{employeeId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_recruiter_5_Positions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"company\", \"recruitment_agency\", \"position\", \"description\" FROM \"Positions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{company}/{recruitment_agency}/{position}" ; rr:class :Position ] ;
  rr:predicateObjectMap [ rr:predicate p:company ; rr:objectMap [ rr:column "company" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:recruitment_agency ; rr:objectMap [ rr:column "recruitment_agency" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:position ; rr:objectMap [ rr:column "position" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2cols_recruiter_6_Applications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"applicationId\", \"applicantId\", \"jobId\", \"resumePath\", \"coverLetterPath\", \"status\" FROM \"Applications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{applicationId}" ; rr:class :Application ] ;
  rr:predicateObjectMap [ rr:predicate p:applicationId ; rr:objectMap [ rr:column "applicationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:applicantId ; rr:objectMap [ rr:column "applicantId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jobId ; rr:objectMap [ rr:column "jobId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:resumePath ; rr:objectMap [ rr:column "resumePath" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:coverLetterPath ; rr:objectMap [ rr:column "coverLetterPath" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] .

<#tm_vague_2cols_recruiter_7_Applications_applicantId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"applicationId\", \"applicantId\" FROM \"Applications\" WHERE \"applicantId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Application/{applicationId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEmployees ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{applicantId}" ; rr:termType rr:IRI ] ] .

