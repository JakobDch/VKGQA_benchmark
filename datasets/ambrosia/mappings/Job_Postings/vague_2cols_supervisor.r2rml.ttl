  rr:predicateObjectMap [ rr:predicate p:hasTeams ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Teams/{teamID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_supervisor_7_Management_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"roleID\", \"PositionID\", \"Department_Head\", \"Team_Leader\" FROM \"Management\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Management/{roleID}" ; rr:class :Management ] ;
  rr:predicateObjectMap [ rr:predicate p:roleID ; rr:objectMap [ rr:column "roleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PositionID ; rr:objectMap [ rr:column "PositionID" ] ] ;
