  rr:logicalTable [ rr:sqlQuery """SELECT \"roleID\", \"PositionID\" FROM \"Management\" WHERE \"PositionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Management/{roleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPosition ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{PositionID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_supervisor_9_Employees_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"employeeID\", \"email\", \"phoneNumber\", \"hireDate\", \"positionID\", \"fullname\" FROM \"Employees\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Employees/{employeeID}" ; rr:class :Employees ] ;
  rr:predicateObjectMap [ rr:predicate p:employeeID ; rr:objectMap [ rr:column "employeeID" ] ] ;
