@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_supervisor_0_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"companyID\", \"name\", \"location\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{companyID}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:companyID ; rr:objectMap [ rr:column "companyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_vague_2cols_supervisor_1_Departments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"deptID\", \"deptName\", \"companyID\" FROM \"Departments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{deptID}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:deptID ; rr:objectMap [ rr:column "deptID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:deptName ; rr:objectMap [ rr:column "deptName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:companyID ; rr:objectMap [ rr:column "companyID" ] ] .

<#tm_vague_2cols_supervisor_2_Departments_companyID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"deptID\", \"companyID\" FROM \"Departments\" WHERE \"companyID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{deptID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCompanies ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{companyID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_supervisor_3_Teams_base> a rr:TriplesMap ;
