  rr:predicateObjectMap [ rr:predicate p:teamName ; rr:objectMap [ rr:column "teamName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:deptID ; rr:objectMap [ rr:column "deptID" ] ] .

<#tm_vague_2cols_supervisor_4_Teams_deptID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"teamID\", \"deptID\" FROM \"Teams\" WHERE \"deptID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Teams/{teamID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDepartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Departments/{deptID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_supervisor_5_Positions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"positionID\", \"title\", \"description\", \"teamID\" FROM \"Positions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{positionID}" ; rr:class :Position ] ;
