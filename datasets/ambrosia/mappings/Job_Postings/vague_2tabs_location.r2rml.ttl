<#tm_vague_2tabs_location_3_Internship_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"start_date\", \"end_date\", \"office_address_id\", \"city_id\" FROM \"Internship\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Internships/{id}" ; rr:class :Internships ] ;
