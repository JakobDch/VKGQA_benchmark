@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_offer_0_Companies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Companies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_vague_2tabs_offer_1_Base_Pay_Range_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"min_pay\", \"max_pay\" FROM \"Base_Pay_Range\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Base_Pay_Range/{id}" ; rr:class :Base_Pay_Range ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:min_pay ; rr:objectMap [ rr:column "min_pay" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:max_pay ; rr:objectMap [ rr:column "max_pay" ] ] .

<#tm_vague_2tabs_offer_2_Benefits_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"health_insurance\", \"dental_insurance\", \"vision_insurance\" FROM \"Benefits\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Benefits/{id}" ; rr:class :Benefits ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:health_insurance ; rr:objectMap [ rr:column "health_insurance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dental_insurance ; rr:objectMap [ rr:column "dental_insurance" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:vision_insurance ; rr:objectMap [ rr:column "vision_insurance" ] ] .

<#tm_vague_2tabs_offer_3_Job_Post_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"base_pay_id\", \"benefit_package_id\" FROM \"Job_Post\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:base_pay_id ; rr:objectMap [ rr:column "base_pay_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:benefit_package_id ; rr:objectMap [ rr:column "benefit_package_id" ] ] .

<#tm_vague_2tabs_offer_4_Job_Post_benefit_package_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"benefit_package_id\" FROM \"Job_Post\" WHERE \"benefit_package_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBenefits ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Benefits/{benefit_package_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_offer_5_Job_Post_base_pay_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"base_pay_id\" FROM \"Job_Post\" WHERE \"base_pay_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBase_Pay_Range ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Base_Pay_Range/{base_pay_id}" ; rr:termType rr:IRI ] ] .

