<#tm_vague_2tabs_qualifications_4_Job_Post_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"job_type_id\", \"degree_level_id\", \"certification_id\", \"company_id\" FROM \"Job_Post\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/JobPostings/{id}" ; rr:class :JobPostings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:job_type_id ; rr:objectMap [ rr:column "job_type_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:degree_level_id ; rr:objectMap [ rr:column "degree_level_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:certification_id ; rr:objectMap [ rr:column "certification_id" ] ] ;
