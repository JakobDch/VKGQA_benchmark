  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"date\", \"time\", \"applicantId\", \"interviewerId\", \"positionId\", \"status\" FROM \"Interview\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Interview/{id}" ; rr:class :Interview ] ;
