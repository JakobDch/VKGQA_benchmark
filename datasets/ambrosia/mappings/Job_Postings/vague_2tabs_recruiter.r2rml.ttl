@prefix : <http://ambrosia.example.org/jobpostings#> .
@prefix p: <http://ambrosia.example.org/jobpostings/prop#> .
@prefix ex: <http://ambrosia.example.org/jobpostings/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_recruiter_0_Company_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Company\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Companies/{id}" ; rr:class :Companies ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_vague_2tabs_recruiter_1_Recruitment_Agency_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"agencyName\", \"contactEmail\", \"contactPhone\" FROM \"Recruitment_Agency\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Recruitment_Agency/{id}" ; rr:class :Recruitment_Agency ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:agencyName ; rr:objectMap [ rr:column "agencyName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contactEmail ; rr:objectMap [ rr:column "contactEmail" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contactPhone ; rr:objectMap [ rr:column "contactPhone" ] ] .

<#tm_vague_2tabs_recruiter_2_Position_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"description\", \"salary\", \"companyId\", \"recruitmentAgencyId\" FROM \"Position\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{id}" ; rr:class :Position ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:salary ; rr:objectMap [ rr:column "salary" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:companyId ; rr:objectMap [ rr:column "companyId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:recruitmentAgencyId ; rr:objectMap [ rr:column "recruitmentAgencyId" ] ] .

<#tm_vague_2tabs_recruiter_3_Position_recruitmentAgencyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"recruitmentAgencyId\" FROM \"Position\" WHERE \"recruitmentAgencyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Position/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRecruitment_Agency ; rr:objectMap [ rr:template "http://ambrosia.example.org/jobpostings/id/Recruitment_Agency/{recruitmentAgencyId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_recruiter_4_Position_companyId_fk> a rr:TriplesMap ;
