@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_events_0_Persons_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PersonID\", \"FullName\" FROM \"Persons\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Persons/{PersonID}" ; rr:class :Persons ] ;
  rr:predicateObjectMap [ rr:predicate p:PersonID ; rr:objectMap [ rr:column "PersonID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_attachment_1tab_ref_events_1_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"Title\", \"Content\", \"AuthorID\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] .

<#tm_attachment_1tab_ref_events_2_Articles_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"AuthorID\" FROM \"Articles\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPersons ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Persons/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_events_3_MediaScrums_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MediaScrumID\", \"Description\", \"StartTime\", \"EndTime\", \"PersonID\" FROM \"MediaScrums\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Media_Scrums/{MediaScrumID}" ; rr:class :Media_Scrums ] ;
  rr:predicateObjectMap [ rr:predicate p:MediaScrumID ; rr:objectMap [ rr:column "MediaScrumID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartTime ; rr:objectMap [ rr:column "StartTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndTime ; rr:objectMap [ rr:column "EndTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PersonID ; rr:objectMap [ rr:column "PersonID" ] ] .

<#tm_attachment_1tab_ref_events_4_MediaScrums_PersonID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MediaScrumID\", \"PersonID\" FROM \"MediaScrums\" WHERE \"PersonID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Media_Scrums/{MediaScrumID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPersons ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Persons/{PersonID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_events_5_Events_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EventID\", \"EventName\", \"EventType\", \"Date\", \"Location\", \"PersonID\" FROM \"Events\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Events/{EventID}" ; rr:class :Events ] ;
  rr:predicateObjectMap [ rr:predicate p:EventID ; rr:objectMap [ rr:column "EventID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EventName ; rr:objectMap [ rr:column "EventName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EventType ; rr:objectMap [ rr:column "EventType" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PersonID ; rr:objectMap [ rr:column "PersonID" ] ] .

<#tm_attachment_1tab_ref_events_6_Events_PersonID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EventID\", \"PersonID\" FROM \"Events\" WHERE \"PersonID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Events/{EventID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPersons ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Persons/{PersonID}" ; rr:termType rr:IRI ] ] .

