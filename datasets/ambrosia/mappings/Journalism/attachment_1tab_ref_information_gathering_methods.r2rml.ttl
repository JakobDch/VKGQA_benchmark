@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_information_gathering_methods_0_Information_Gathering_Method_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"method\" FROM \"Information_Gathering_Method\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Information_Gathering_Method/{id}" ; rr:class :Information_Gathering_Method ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:method ; rr:objectMap [ rr:column "method" ] ] .

<#tm_attachment_1tab_ref_information_gathering_methods_1_Participant_Type_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\" FROM \"Participant_Type\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Participant_Type/{id}" ; rr:class :Participant_Type ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_attachment_1tab_ref_information_gathering_methods_2_News_Article_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_id\", \"title\", \"content\", \"date\", \"author_id\", \"information_gathering_method_id\", \"participant_type_id\" FROM \"News_Article\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{article_id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:article_id ; rr:objectMap [ rr:column "article_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:information_gathering_method_id ; rr:objectMap [ rr:column "information_gathering_method_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:participant_type_id ; rr:objectMap [ rr:column "participant_type_id" ] ] .

<#tm_attachment_1tab_ref_information_gathering_methods_3_News_Article_participant_type_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_id\", \"participant_type_id\" FROM \"News_Article\" WHERE \"participant_type_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{article_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasParticipant_Type ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Participant_Type/{participant_type_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_information_gathering_methods_4_News_Article_information_gathering_method_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_id\", \"information_gathering_method_id\" FROM \"News_Article\" WHERE \"information_gathering_method_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{article_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInformation_Gathering_Method ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Information_Gathering_Method/{information_gathering_method_id}" ; rr:termType rr:IRI ] ] .

