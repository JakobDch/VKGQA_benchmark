@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_news_content_types_0_News_Contents_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Content\", \"News_Type\", \"Volume_ID\" FROM \"News_Contents\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/News_Contents/{id}" ; rr:class :News_Contents ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:News_Type ; rr:objectMap [ rr:column "News_Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Volume_ID ; rr:objectMap [ rr:column "Volume_ID" ] ] .

<#tm_attachment_1tab_ref_news_content_types_1_News_Contents_Volume_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Volume_ID\" FROM \"News_Contents\" WHERE \"Volume_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/News_Contents/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVolumes ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Volumes/{Volume_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_news_content_types_2_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{id}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_ref_news_content_types_3_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Author_ID\", \"Published_Date\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Author_ID ; rr:objectMap [ rr:column "Author_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Published_Date ; rr:objectMap [ rr:column "Published_Date" ] ] .

<#tm_attachment_1tab_ref_news_content_types_4_Articles_Author_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Author_ID\" FROM \"Articles\" WHERE \"Author_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{Author_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_news_content_types_5_Volumes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Issue_Number\" FROM \"Volumes\"""" ] ;
