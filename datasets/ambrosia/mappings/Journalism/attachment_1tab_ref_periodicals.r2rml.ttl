<#tm_attachment_1tab_ref_periodicals_7_ArticleCategory_article_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"article_id\" FROM \"ArticleCategory\" WHERE \"article_id\" IS NOT NULL""" ] ;
