  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"cat_id\" FROM \"ArticleCategory\" WHERE \"cat_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/ArticleCategories/{_amb_rowid}" ] ;
