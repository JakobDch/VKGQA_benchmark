<#tm_attachment_1tab_ref_periodicals_5_ArticleCategory_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"article_id\", \"cat_id\" FROM \"ArticleCategory\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/ArticleCategories/{_amb_rowid}" ; rr:class :ArticleCategories ] ;
  rr:predicateObjectMap [ rr:predicate p:article_id ; rr:objectMap [ rr:column "article_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cat_id ; rr:objectMap [ rr:column "cat_id" ] ] .

