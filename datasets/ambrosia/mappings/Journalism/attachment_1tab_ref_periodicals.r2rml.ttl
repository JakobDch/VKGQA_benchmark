@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_periodicals_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\", \"phone\", \"address\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{id}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone ; rr:objectMap [ rr:column "phone" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_attachment_1tab_ref_periodicals_1_Publications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"circulation_numbers\", \"location\" FROM \"Publications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{id}" ; rr:class :Publications ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:circulation_numbers ; rr:objectMap [ rr:column "circulation_numbers" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_attachment_1tab_ref_periodicals_2_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"content\", \"pub_date\", \"author_id\", \"publication_type\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:pub_date ; rr:objectMap [ rr:column "pub_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_type ; rr:objectMap [ rr:column "publication_type" ] ] .

<#tm_attachment_1tab_ref_periodicals_3_Articles_author_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"author_id\" FROM \"Articles\" WHERE \"author_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{author_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_periodicals_4_Category_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"descr\" FROM \"Category\"""" ] ;
