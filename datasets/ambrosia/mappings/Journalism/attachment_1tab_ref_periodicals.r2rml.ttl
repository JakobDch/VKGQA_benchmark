  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"publication_id\", \"periodical_type\" FROM \"PublicationsPeriodicals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/PublicationsPeriodicals/{_amb_rowid}" ; rr:class :PublicationsPeriodicals ] ;
