@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_writing_styles_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{id}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_ref_writing_styles_1_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Content\", \"PublicationDate\", \"AuthorId\", \"WritingStyleId\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationDate ; rr:objectMap [ rr:column "PublicationDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorId ; rr:objectMap [ rr:column "AuthorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:WritingStyleId ; rr:objectMap [ rr:column "WritingStyleId" ] ] .

<#tm_attachment_1tab_ref_writing_styles_2_Articles_WritingStyleId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"WritingStyleId\" FROM \"Articles\" WHERE \"WritingStyleId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWritingStyles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/WritingStyles/{WritingStyleId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_writing_styles_3_Articles_AuthorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"AuthorId\" FROM \"Articles\" WHERE \"AuthorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorId}" ; rr:termType rr:IRI ] ] .

