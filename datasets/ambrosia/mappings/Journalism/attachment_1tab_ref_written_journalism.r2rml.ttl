@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_ref_written_journalism_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{id}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_written_journalism_1_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"written_by\", \"Written_journalism\", \"word_count\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:written_by ; rr:objectMap [ rr:column "written_by" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Written_journalism ; rr:objectMap [ rr:column "Written_journalism" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:word_count ; rr:objectMap [ rr:column "word_count" ] ] .

<#tm_attachment_1tab_ref_written_journalism_2_Articles_word_count_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"word_count\" FROM \"Articles\" WHERE \"word_count\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWordCounts ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/WordCounts/{word_count}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_written_journalism_3_Articles_written_by_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"written_by\" FROM \"Articles\" WHERE \"written_by\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{written_by}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_written_journalism_4_WordCounts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"column\" FROM \"WordCounts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/WordCounts/{id}" ; rr:class :WordCounts ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:column ; rr:objectMap [ rr:column "column" ] ] .

<#tm_attachment_1tab_ref_written_journalism_5_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publishers/{id}" ; rr:class :Publishers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_1tab_ref_written_journalism_6_Publications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"article_id\", \"publisher_id\", \"publication_date\" FROM \"Publications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{id}" ; rr:class :Publications ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:article_id ; rr:objectMap [ rr:column "article_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publisher_id ; rr:objectMap [ rr:column "publisher_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_date ; rr:objectMap [ rr:column "publication_date" ] ] .

<#tm_attachment_1tab_ref_written_journalism_7_Publications_publisher_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"publisher_id\" FROM \"Publications\" WHERE \"publisher_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublishers ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publishers/{publisher_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_written_journalism_8_Publications_article_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"article_id\" FROM \"Publications\" WHERE \"article_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{article_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_ref_written_journalism_9_Comments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"comment\", \"article_id\" FROM \"Comments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Comments/{id}" ; rr:class :Comments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:comment ; rr:objectMap [ rr:column "comment" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:article_id ; rr:objectMap [ rr:column "article_id" ] ] .

<#tm_attachment_1tab_ref_written_journalism_10_Comments_article_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"article_id\" FROM \"Comments\" WHERE \"article_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Comments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{article_id}" ; rr:termType rr:IRI ] ] .

