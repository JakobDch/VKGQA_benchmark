@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_business_strategy_0_MediaFranchises_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Business_Strategy\", \"Audience\", \"OtherColumn1\", \"OtherColumn2\" FROM \"MediaFranchises\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/MediaFranchises/{ID}" ; rr:class :MediaFranchises ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Business_Strategy ; rr:objectMap [ rr:column "Business_Strategy" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Audience ; rr:objectMap [ rr:column "Audience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OtherColumn1 ; rr:objectMap [ rr:column "OtherColumn1" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OtherColumn2 ; rr:objectMap [ rr:column "OtherColumn2" ] ] .

<#tm_attachment_1tab_val_business_strategy_1_CrossPlatformExpansions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Business_Strategy\", \"Audience\", \"Platform\", \"Year\" FROM \"CrossPlatformExpansions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/CrossPlatformExpansions/{ID}" ; rr:class :CrossPlatformExpansions ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Business_Strategy ; rr:objectMap [ rr:column "Business_Strategy" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Audience ; rr:objectMap [ rr:column "Audience" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Platform ; rr:objectMap [ rr:column "Platform" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] .

<#tm_attachment_1tab_val_business_strategy_2_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Content\", \"PublicationDate\", \"AuthorID\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationDate ; rr:objectMap [ rr:column "PublicationDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] .

<#tm_attachment_1tab_val_business_strategy_3_Articles_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"AuthorID\" FROM \"Articles\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_business_strategy_4_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FirstName\", \"LastName\", \"Role\", \"AffiliatedMediaFranchiseID\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{ID}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Role ; rr:objectMap [ rr:column "Role" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AffiliatedMediaFranchiseID ; rr:objectMap [ rr:column "AffiliatedMediaFranchiseID" ] ] .

<#tm_attachment_1tab_val_business_strategy_5_Authors_AffiliatedMediaFranchiseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"AffiliatedMediaFranchiseID\" FROM \"Authors\" WHERE \"AffiliatedMediaFranchiseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMediaFranchises ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/MediaFranchises/{AffiliatedMediaFranchiseID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_business_strategy_6_Readers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FirstName\", \"LastName\", \"AgeGroup\", \"PreferredGenre\", \"FavouriteMediaFranchiseID\" FROM \"Readers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Readers/{ID}" ; rr:class :Readers ] ;
