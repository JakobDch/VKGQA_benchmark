  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AgeGroup ; rr:objectMap [ rr:column "AgeGroup" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PreferredGenre ; rr:objectMap [ rr:column "PreferredGenre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FavouriteMediaFranchiseID ; rr:objectMap [ rr:column "FavouriteMediaFranchiseID" ] ] .

<#tm_attachment_1tab_val_business_strategy_7_Readers_FavouriteMediaFranchiseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FavouriteMediaFranchiseID\" FROM \"Readers\" WHERE \"FavouriteMediaFranchiseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Readers/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMediaFranchises ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/MediaFranchises/{FavouriteMediaFranchiseID}" ; rr:termType rr:IRI ] ] .

