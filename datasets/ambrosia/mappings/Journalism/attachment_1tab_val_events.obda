[PrefixDeclaration]
:	http://ambrosia.example.org/journalism#
p:	http://ambrosia.example.org/journalism/prop#
ex:	http://ambrosia.example.org/journalism/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Articles_base
target		ex:Articles/{id} a :Articles ; p:id {id} ; p:title {title} ; p:content {content} ; p:date {date} .
source		SELECT `id`, `title`, `content`, `date` FROM `Articles`

mappingId	Reporters_base
target		ex:Reporters/{id} a :Reporters ; p:id {id} ; p:name {name} ; p:email {email} .
source		SELECT `id`, `name`, `email` FROM `Reporters`

mappingId	Sources_base
target		ex:Sources/{id} a :Sources ; p:id {id} ; p:name {name} ; p:event {event} ; p:person {person} .
source		SELECT `id`, `name`, `event`, `person` FROM `Sources`

mappingId	Categories_base
target		ex:Category/{id} a :Category ; p:id {id} ; p:name {name} .
source		SELECT `id`, `name` FROM `Categories`

mappingId	ArticleCategories_base
target		ex:ArticleCategories/{_amb_rowid} a :ArticleCategories ; p:article_id {article_id} ; p:category_id {category_id} .
source		SELECT `_amb_rowid`, `article_id`, `category_id` FROM `ArticleCategories`

mappingId	ArticleCategories_category_id_fk
target		ex:ArticleCategories/{_amb_rowid} p:hasCategory ex:Category/{category_id} .
source		SELECT `_amb_rowid`, `category_id` FROM `ArticleCategories` WHERE `category_id` IS NOT NULL

mappingId	ArticleCategories_article_id_fk
target		ex:ArticleCategories/{_amb_rowid} p:hasArticles ex:Articles/{article_id} .
source		SELECT `_amb_rowid`, `article_id` FROM `ArticleCategories` WHERE `article_id` IS NOT NULL

mappingId	ArticleSources_base
target		ex:Article_Source/{_amb_rowid} a :Article_Source ; p:source_id {source_id} ; p:article_id {article_id} .
source		SELECT `_amb_rowid`, `source_id`, `article_id` FROM `ArticleSources`

mappingId	ArticleSources_article_id_fk
target		ex:Article_Source/{_amb_rowid} p:hasArticles ex:Articles/{article_id} .
source		SELECT `_amb_rowid`, `article_id` FROM `ArticleSources` WHERE `article_id` IS NOT NULL

mappingId	ArticleSources_source_id_fk
target		ex:Article_Source/{_amb_rowid} p:hasSources ex:Sources/{source_id} .
source		SELECT `_amb_rowid`, `source_id` FROM `ArticleSources` WHERE `source_id` IS NOT NULL

mappingId	ArticleReporters_base
target		ex:ArticleReporters/{_amb_rowid} a :ArticleReporters ; p:reporter_id {reporter_id} ; p:article_id {article_id} .
source		SELECT `_amb_rowid`, `reporter_id`, `article_id` FROM `ArticleReporters`

mappingId	ArticleReporters_article_id_fk
target		ex:ArticleReporters/{_amb_rowid} p:hasArticles ex:Articles/{article_id} .
source		SELECT `_amb_rowid`, `article_id` FROM `ArticleReporters` WHERE `article_id` IS NOT NULL

mappingId	ArticleReporters_reporter_id_fk
target		ex:ArticleReporters/{_amb_rowid} p:hasReporters ex:Reporters/{reporter_id} .
source		SELECT `_amb_rowid`, `reporter_id` FROM `ArticleReporters` WHERE `reporter_id` IS NOT NULL

]]
