<#tm_attachment_1tab_val_events_4_ArticleCategories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"article_id\", \"category_id\" FROM \"ArticleCategories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/ArticleCategories/{_amb_rowid}" ; rr:class :ArticleCategories ] ;
  rr:predicateObjectMap [ rr:predicate p:article_id ; rr:objectMap [ rr:column "article_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:category_id ; rr:objectMap [ rr:column "category_id" ] ] .

<#tm_attachment_1tab_val_events_5_ArticleCategories_category_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"category_id\" FROM \"ArticleCategories\" WHERE \"category_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/ArticleCategories/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCategory ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Category/{category_id}" ; rr:termType rr:IRI ] ] .

