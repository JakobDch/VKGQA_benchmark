@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_journalist_classifications_0_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"Title\", \"Content\", \"PublishDate\", \"AuthorID\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublishDate ; rr:objectMap [ rr:column "PublishDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] .

<#tm_attachment_1tab_val_journalist_classifications_1_Articles_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"AuthorID\" FROM \"Articles\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_journalist_classifications_2_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorID\", \"Name\", \"Email\", \"PhoneNumber\", \"Classification\", \"Payment\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Classification ; rr:objectMap [ rr:column "Classification" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Payment ; rr:objectMap [ rr:column "Payment" ] ] .

<#tm_attachment_1tab_val_journalist_classifications_3_NewsOutlets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OutletID\", \"Name\", \"Location\", \"Website\" FROM \"NewsOutlets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/NewsOutlets/{OutletID}" ; rr:class :NewsOutlets ] ;
  rr:predicateObjectMap [ rr:predicate p:OutletID ; rr:objectMap [ rr:column "OutletID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Website ; rr:objectMap [ rr:column "Website" ] ] .

<#tm_attachment_1tab_val_journalist_classifications_4_Submissions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SubmissionID\", \"ArticleID\", \"OutletID\", \"Accepted\" FROM \"Submissions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Submissions/{SubmissionID}" ; rr:class :Submissions ] ;
  rr:predicateObjectMap [ rr:predicate p:SubmissionID ; rr:objectMap [ rr:column "SubmissionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:OutletID ; rr:objectMap [ rr:column "OutletID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Accepted ; rr:objectMap [ rr:column "Accepted" ] ] .

<#tm_attachment_1tab_val_journalist_classifications_5_Submissions_OutletID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SubmissionID\", \"OutletID\" FROM \"Submissions\" WHERE \"OutletID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Submissions/{SubmissionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNewsOutlets ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/NewsOutlets/{OutletID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_journalist_classifications_6_Submissions_ArticleID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SubmissionID\", \"ArticleID\" FROM \"Submissions\" WHERE \"ArticleID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Submissions/{SubmissionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_journalist_classifications_7_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SourceID\", \"Name\", \"ContactInfo\", \"Reliability\", \"LastUsed\" FROM \"Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{SourceID}" ; rr:class :Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:SourceID ; rr:objectMap [ rr:column "SourceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ContactInfo ; rr:objectMap [ rr:column "ContactInfo" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Reliability ; rr:objectMap [ rr:column "Reliability" ] ] ;
