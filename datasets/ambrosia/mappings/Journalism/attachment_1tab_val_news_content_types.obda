[PrefixDeclaration]
:	http://ambrosia.example.org/journalism#
p:	http://ambrosia.example.org/journalism/prop#
ex:	http://ambrosia.example.org/journalism/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Author_base
target		ex:Authors/{id} a :Authors ; p:id {id} ; p:name {name} ; p:email {email} .
source		SELECT `id`, `name`, `email` FROM `Author`

mappingId	Category_base
target		ex:Category/{id} a :Category ; p:id {id} ; p:title {title} ; p:description {description} .
source		SELECT `id`, `title`, `description` FROM `Category`

mappingId	Publication_base
target		ex:Publications/{id} a :Publications ; p:id {id} ; p:name {name} ; p:address {address} .
source		SELECT `id`, `name`, `address` FROM `Publication`

mappingId	Article_base
target		ex:Articles/{id} a :Articles ; p:id {id} ; p:title {title} ; p:content {content} ; p:news_content_type {news_content_type} ; p:volume {volume} ; p:date {date} ; p:author_id {author_id} ; p:category_id {category_id} ; p:publication_id {publication_id} .
source		SELECT `id`, `title`, `content`, `news_content_type`, `volume`, `date`, `author_id`, `category_id`, `publication_id` FROM `Article`

mappingId	Article_publication_id_fk
target		ex:Articles/{id} p:hasPublications ex:Publications/{publication_id} .
source		SELECT `id`, `publication_id` FROM `Article` WHERE `publication_id` IS NOT NULL

mappingId	Article_category_id_fk
target		ex:Articles/{id} p:hasCategory ex:Category/{category_id} .
source		SELECT `id`, `category_id` FROM `Article` WHERE `category_id` IS NOT NULL

mappingId	Article_author_id_fk
target		ex:Articles/{id} p:hasAuthors ex:Authors/{author_id} .
source		SELECT `id`, `author_id` FROM `Article` WHERE `author_id` IS NOT NULL

]]
