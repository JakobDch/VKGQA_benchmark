@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_newspaper_formats_0_Newspapers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Format\", \"Distributor\", \"FoundedDate\" FROM \"Newspapers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspapers/{id}" ; rr:class :Newspapers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Format ; rr:objectMap [ rr:column "Format" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Distributor ; rr:objectMap [ rr:column "Distributor" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FoundedDate ; rr:objectMap [ rr:column "FoundedDate" ] ] .

<#tm_attachment_1tab_val_newspaper_formats_1_Newspapers_Distributor_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Distributor\" FROM \"Newspapers\" WHERE \"Distributor\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspapers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDistributors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Distributors/{Distributor}" ; rr:termType rr:IRI ] ] .

