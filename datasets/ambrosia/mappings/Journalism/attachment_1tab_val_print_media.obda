[PrefixDeclaration]
:	http://ambrosia.example.org/journalism#
p:	http://ambrosia.example.org/journalism/prop#
ex:	http://ambrosia.example.org/journalism/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Publications_base
target		ex:Publications/{ID} a :Publications ; p:ID {ID} ; p:Title {Title} ; p:Print_Media {Print_Media} ; p:Publication_Frequency {Publication_Frequency} .
source		SELECT `ID`, `Title`, `Print_Media`, `Publication_Frequency` FROM `Publications`

mappingId	Authors_base
target		ex:Authors/{AuthorID} a :Authors ; p:AuthorID {AuthorID} ; p:FirstName {FirstName} ; p:LastName {LastName} .
source		SELECT `AuthorID`, `FirstName`, `LastName` FROM `Authors`

mappingId	Articles_base
target		ex:Articles/{ArticleID} a :Articles ; p:ArticleID {ArticleID} ; p:Title {Title} ; p:Content {Content} ; p:PublishDate {PublishDate} ; p:AuthorID {AuthorID} .
source		SELECT `ArticleID`, `Title`, `Content`, `PublishDate`, `AuthorID` FROM `Articles`

mappingId	Articles_AuthorID_fk
target		ex:Articles/{ArticleID} p:hasAuthors ex:Authors/{AuthorID} .
source		SELECT `ArticleID`, `AuthorID` FROM `Articles` WHERE `AuthorID` IS NOT NULL

mappingId	PublicationsAuthors_base
target		ex:PublicationsAuthors/{_amb_rowid} a :PublicationsAuthors ; p:PublicationID {PublicationID} ; p:AuthorID {AuthorID} .
source		SELECT `_amb_rowid`, `PublicationID`, `AuthorID` FROM `PublicationsAuthors`

mappingId	PublicationsAuthors_AuthorID_fk
target		ex:PublicationsAuthors/{_amb_rowid} p:hasAuthors ex:Authors/{AuthorID} .
source		SELECT `_amb_rowid`, `AuthorID` FROM `PublicationsAuthors` WHERE `AuthorID` IS NOT NULL

mappingId	PublicationsAuthors_PublicationID_fk
target		ex:PublicationsAuthors/{_amb_rowid} p:hasPublications ex:Publications/{PublicationID} .
source		SELECT `_amb_rowid`, `PublicationID` FROM `PublicationsAuthors` WHERE `PublicationID` IS NOT NULL

]]
