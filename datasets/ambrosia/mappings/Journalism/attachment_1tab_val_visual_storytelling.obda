[PrefixDeclaration]
:	http://ambrosia.example.org/journalism#
p:	http://ambrosia.example.org/journalism/prop#
ex:	http://ambrosia.example.org/journalism/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Authors_base
target		ex:Authors/{id} a :Authors ; p:id {id} ; p:firstName {firstName} ; p:lastName {lastName} ; p:email {email} ; p:phoneNumber {phoneNumber} .
source		SELECT `id`, `firstName`, `lastName`, `email`, `phoneNumber` FROM `Authors`

mappingId	Publishers_base
target		ex:Publishers/{id} a :Publishers ; p:id {id} ; p:pubName {pubName} ; p:address {address} ; p:city {city} ; p:country {country} .
source		SELECT `id`, `pubName`, `address`, `city`, `country` FROM `Publishers`

mappingId	Articles_base
target		ex:Articles/{id} a :Articles ; p:id {id} ; p:title {title} ; p:authorId {authorId} ; p:pubId {pubId} ; p:publicationDate {publicationDate} ; p:visualStorytelling {visualStorytelling} ; p:articleType {articleType} .
source		SELECT `id`, `title`, `authorId`, `pubId`, `publicationDate`, `visualStorytelling`, `articleType` FROM `Articles`

mappingId	Articles_authorId_fk
target		ex:Articles/{id} p:hasAuthors ex:Authors/{authorId} .
source		SELECT `id`, `authorId` FROM `Articles` WHERE `authorId` IS NOT NULL

mappingId	Articles_pubId_fk
target		ex:Articles/{id} p:hasPublishers ex:Publishers/{pubId} .
source		SELECT `id`, `pubId` FROM `Articles` WHERE `pubId` IS NOT NULL

mappingId	Articles_authorId_fk
target		ex:Articles/{id} p:hasAuthors ex:Authors/{authorId} .
source		SELECT `id`, `authorId` FROM `Articles` WHERE `authorId` IS NOT NULL

mappingId	Categories_base
target		ex:Category/{id} a :Category ; p:id {id} ; p:catName {catName} .
source		SELECT `id`, `catName` FROM `Categories`

]]
