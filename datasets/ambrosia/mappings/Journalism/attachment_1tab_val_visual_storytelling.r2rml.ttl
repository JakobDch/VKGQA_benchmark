@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_visual_storytelling_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"email\", \"phoneNumber\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{id}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] .

<#tm_attachment_1tab_val_visual_storytelling_1_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"pubName\", \"address\", \"city\", \"country\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publishers/{id}" ; rr:class :Publishers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:pubName ; rr:objectMap [ rr:column "pubName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_attachment_1tab_val_visual_storytelling_2_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"authorId\", \"pubId\", \"publicationDate\", \"visualStorytelling\", \"articleType\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:authorId ; rr:objectMap [ rr:column "authorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:pubId ; rr:objectMap [ rr:column "pubId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publicationDate ; rr:objectMap [ rr:column "publicationDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:visualStorytelling ; rr:objectMap [ rr:column "visualStorytelling" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:articleType ; rr:objectMap [ rr:column "articleType" ] ] .

<#tm_attachment_1tab_val_visual_storytelling_3_Articles_authorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"authorId\" FROM \"Articles\" WHERE \"authorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{authorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_visual_storytelling_4_Articles_pubId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"pubId\" FROM \"Articles\" WHERE \"pubId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublishers ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publishers/{pubId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_visual_storytelling_5_Articles_authorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"authorId\" FROM \"Articles\" WHERE \"authorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{authorId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_visual_storytelling_6_Categories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"catName\" FROM \"Categories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Category/{id}" ; rr:class :Category ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
