@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_1tab_val_written_journalism_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorID\", \"FirstName\", \"LastName\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] .

<#tm_attachment_1tab_val_written_journalism_1_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PublisherID\", \"Name\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publishers/{PublisherID}" ; rr:class :Publishers ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_1tab_val_written_journalism_2_Categories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CategoryID\", \"CategoryName\" FROM \"Categories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Category/{CategoryID}" ; rr:class :Category ] ;
  rr:predicateObjectMap [ rr:predicate p:CategoryID ; rr:objectMap [ rr:column "CategoryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CategoryName ; rr:objectMap [ rr:column "CategoryName" ] ] .

<#tm_attachment_1tab_val_written_journalism_3_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"Title\", \"Written_Journalism\", \"Word_Count\", \"PublicationDate\", \"AuthorID\", \"CategoryID\", \"PublisherID\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Written_Journalism ; rr:objectMap [ rr:column "Written_Journalism" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Word_Count ; rr:objectMap [ rr:column "Word_Count" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationDate ; rr:objectMap [ rr:column "PublicationDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CategoryID ; rr:objectMap [ rr:column "CategoryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] .

<#tm_attachment_1tab_val_written_journalism_4_Articles_PublisherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"PublisherID\" FROM \"Articles\" WHERE \"PublisherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublishers ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publishers/{PublisherID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_written_journalism_5_Articles_CategoryID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"CategoryID\" FROM \"Articles\" WHERE \"CategoryID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCategory ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Category/{CategoryID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_1tab_val_written_journalism_6_Articles_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"AuthorID\" FROM \"Articles\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:termType rr:IRI ] ] .

