  rr:predicateObjectMap [ rr:predicate p:personId ; rr:objectMap [ rr:column "personId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:time ; rr:objectMap [ rr:column "time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:topic ; rr:objectMap [ rr:column "topic" ] ] .

<#tm_attachment_2tab_ref_events_4_Media_Scrum_personId_fk> a rr:TriplesMap ;
