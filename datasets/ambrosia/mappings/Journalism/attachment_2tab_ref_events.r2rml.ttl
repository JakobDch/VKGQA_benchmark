<#tm_attachment_2tab_ref_events_5_Article_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"content\", \"authorId\", \"pressConferenceId\", \"mediaScrumId\", \"publicationDate\" FROM \"Article\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:authorId ; rr:objectMap [ rr:column "authorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:pressConferenceId ; rr:objectMap [ rr:column "pressConferenceId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:mediaScrumId ; rr:objectMap [ rr:column "mediaScrumId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publicationDate ; rr:objectMap [ rr:column "publicationDate" ] ] .

