<#tm_attachment_2tab_ref_events_7_Article_pressConferenceId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"pressConferenceId\" FROM \"Article\" WHERE \"pressConferenceId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPress_Conferences ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Press_Conferences/{pressConferenceId}" ; rr:termType rr:IRI ] ] .

