@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_events_0_Person_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Person\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Persons/{id}" ; rr:class :Persons ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_attachment_2tab_ref_events_1_Press_Conference_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"personId\", \"date\", \"time\", \"venue\", \"notes\" FROM \"Press_Conference\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Press_Conferences/{id}" ; rr:class :Press_Conferences ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:personId ; rr:objectMap [ rr:column "personId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:time ; rr:objectMap [ rr:column "time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:venue ; rr:objectMap [ rr:column "venue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:notes ; rr:objectMap [ rr:column "notes" ] ] .

<#tm_attachment_2tab_ref_events_2_Press_Conference_personId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"personId\" FROM \"Press_Conference\" WHERE \"personId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Press_Conferences/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPersons ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Persons/{personId}" ; rr:termType rr:IRI ] ] .

