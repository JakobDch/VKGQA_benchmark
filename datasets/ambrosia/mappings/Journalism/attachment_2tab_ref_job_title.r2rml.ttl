@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_job_title_0_Public_Relations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"contact\", \"department\", \"role\", \"email\", \"phone\", \"description\" FROM \"Public_Relations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Public_Relations/{id}" ; rr:class :Public_Relations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contact ; rr:objectMap [ rr:column "contact" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:department ; rr:objectMap [ rr:column "department" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role ; rr:objectMap [ rr:column "role" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone ; rr:objectMap [ rr:column "phone" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

