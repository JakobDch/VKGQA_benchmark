<#tm_attachment_2tab_ref_job_title_2_Contacts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"organization\", \"public_relations_id\", \"government_communications_id\" FROM \"Contacts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Contacts/{id}" ; rr:class :Contacts ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:organization ; rr:objectMap [ rr:column "organization" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:public_relations_id ; rr:objectMap [ rr:column "public_relations_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:government_communications_id ; rr:objectMap [ rr:column "government_communications_id" ] ] .

<#tm_attachment_2tab_ref_job_title_3_Contacts_government_communications_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"government_communications_id\" FROM \"Contacts\" WHERE \"government_communications_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Contacts/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGovernment_Communications ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Government_Communications/{government_communications_id}" ; rr:termType rr:IRI ] ] .

