@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_news_content_types_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"author_id\", \"name\", \"email\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{author_id}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_attachment_2tab_ref_news_content_types_1_Volumes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"volume_id\", \"number\", \"publication_date\" FROM \"Volumes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Volumes/{volume_id}" ; rr:class :Volumes ] ;
  rr:predicateObjectMap [ rr:predicate p:volume_id ; rr:objectMap [ rr:column "volume_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number ; rr:objectMap [ rr:column "number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_date ; rr:objectMap [ rr:column "publication_date" ] ] .

<#tm_attachment_2tab_ref_news_content_types_2_Opinion_Pieces_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"opinion_piece_id\", \"title\", \"content\", \"volume_id\" FROM \"Opinion_Pieces\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Opinion_Pieces/{opinion_piece_id}" ; rr:class :Opinion_Pieces ] ;
  rr:predicateObjectMap [ rr:predicate p:opinion_piece_id ; rr:objectMap [ rr:column "opinion_piece_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:volume_id ; rr:objectMap [ rr:column "volume_id" ] ] .

<#tm_attachment_2tab_ref_news_content_types_3_Opinion_Pieces_volume_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"opinion_piece_id\", \"volume_id\" FROM \"Opinion_Pieces\" WHERE \"volume_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Opinion_Pieces/{opinion_piece_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVolumes ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Volumes/{volume_id}" ; rr:termType rr:IRI ] ] .

