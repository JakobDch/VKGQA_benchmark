  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:volume_id ; rr:objectMap [ rr:column "volume_id" ] ] .

<#tm_attachment_2tab_ref_news_content_types_5_Feature_Articles_volume_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"feature_article_id\", \"volume_id\" FROM \"Feature_Articles\" WHERE \"volume_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Feature_Articles/{feature_article_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVolumes ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Volumes/{volume_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_news_content_types_6_Publications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"publication_id\", \"name\", \"address\" FROM \"Publications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{publication_id}" ; rr:class :Publications ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_id ; rr:objectMap [ rr:column "publication_id" ] ] ;
