@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_news_types_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{id}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_attachment_2tab_ref_news_types_1_Events_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"eventId\", \"eventName\" FROM \"Events\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Events/{eventId}" ; rr:class :Events ] ;
  rr:predicateObjectMap [ rr:predicate p:eventId ; rr:objectMap [ rr:column "eventId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:eventName ; rr:objectMap [ rr:column "eventName" ] ] .

<#tm_attachment_2tab_ref_news_types_2_Breaking_News_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"newsId\", \"headline\", \"content\", \"authorId\", \"eventId\" FROM \"Breaking_News\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Breaking_News/{newsId}" ; rr:class :Breaking_News ] ;
  rr:predicateObjectMap [ rr:predicate p:newsId ; rr:objectMap [ rr:column "newsId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:headline ; rr:objectMap [ rr:column "headline" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:authorId ; rr:objectMap [ rr:column "authorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:eventId ; rr:objectMap [ rr:column "eventId" ] ] .

<#tm_attachment_2tab_ref_news_types_3_Breaking_News_eventId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"newsId\", \"eventId\" FROM \"Breaking_News\" WHERE \"eventId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Breaking_News/{newsId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEvents ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Events/{eventId}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_news_types_4_Breaking_News_authorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"newsId\", \"authorId\" FROM \"Breaking_News\" WHERE \"authorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Breaking_News/{newsId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{authorId}" ; rr:termType rr:IRI ] ] .

