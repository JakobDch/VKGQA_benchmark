@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_ref_newspaper_formats_0_Distributor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\" FROM \"Distributor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Distributors/{ID}" ; rr:class :Distributors ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_attachment_2tab_ref_newspaper_formats_1_Broadsheet_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"NewspaperID\", \"Title\", \"Content\", \"Price\", \"DistributorID\" FROM \"Broadsheet\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Broadsheet/{NewspaperID}" ; rr:class :Broadsheet ] ;
  rr:predicateObjectMap [ rr:predicate p:NewspaperID ; rr:objectMap [ rr:column "NewspaperID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DistributorID ; rr:objectMap [ rr:column "DistributorID" ] ] .

<#tm_attachment_2tab_ref_newspaper_formats_2_Broadsheet_DistributorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"NewspaperID\", \"DistributorID\" FROM \"Broadsheet\" WHERE \"DistributorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Broadsheet/{NewspaperID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDistributors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Distributors/{DistributorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_newspaper_formats_3_Tabloid_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"NewspaperID\", \"Title\", \"Content\", \"Price\", \"DistributorID\" FROM \"Tabloid\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Tabloid/{NewspaperID}" ; rr:class :Tabloid ] ;
  rr:predicateObjectMap [ rr:predicate p:NewspaperID ; rr:objectMap [ rr:column "NewspaperID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DistributorID ; rr:objectMap [ rr:column "DistributorID" ] ] .

<#tm_attachment_2tab_ref_newspaper_formats_4_Tabloid_DistributorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"NewspaperID\", \"DistributorID\" FROM \"Tabloid\" WHERE \"DistributorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Tabloid/{NewspaperID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDistributors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Distributors/{DistributorID}" ; rr:termType rr:IRI ] ] .

