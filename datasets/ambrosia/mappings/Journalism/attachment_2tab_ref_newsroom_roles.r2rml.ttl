  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"source_id\" FROM \"ArticleSources\" WHERE \"source_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Source/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSources ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{source_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_newsroom_roles_8_ArticleSources_article_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"article_id\" FROM \"ArticleSources\" WHERE \"article_id\" IS NOT NULL""" ] ;
