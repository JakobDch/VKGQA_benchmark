  rr:predicateObjectMap [ rr:predicate p:hasphotos ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/photos/{photoID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_ref_visual_storytelling_5_photos_articleID_fk> a rr:TriplesMap ;
