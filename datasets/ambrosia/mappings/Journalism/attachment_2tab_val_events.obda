[PrefixDeclaration]
:	http://ambrosia.example.org/journalism#
p:	http://ambrosia.example.org/journalism/prop#
ex:	http://ambrosia.example.org/journalism/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	News_Articles_base
target		ex:Articles/{id} a :Articles ; p:id {id} ; p:title {title} ; p:content {content} ; p:author {author} .
source		SELECT `id`, `title`, `content`, `author` FROM `News_Articles`

mappingId	Interviews_base
target		ex:Interviews/{id} a :Interviews ; p:id {id} ; p:date {date} ; p:time {time} ; p:interviewee {interviewee} .
source		SELECT `id`, `date`, `time`, `interviewee` FROM `Interviews`

mappingId	Awards_base
target		ex:Awards/{id} a :Awards ; p:id {id} ; p:award_name {award_name} ; p:winner {winner} .
source		SELECT `id`, `award_name`, `winner` FROM `Awards`

mappingId	Publications_base
target		ex:Publications/{id} a :Publications ; p:id {id} ; p:publication_name {publication_name} ; p:publication_date {publication_date} ; p:editor {editor} .
source		SELECT `id`, `publication_name`, `publication_date`, `editor` FROM `Publications`

mappingId	Press_Conferences_base
target		ex:Press_Conferences/{id} a :Press_Conferences ; p:id {id} ; p:topic {topic} ; p:date {date} ; p:location {location} ; p:person {person} .
source		SELECT `id`, `topic`, `date`, `location`, `person` FROM `Press_Conferences`

mappingId	Media_Scrums_base
target		ex:Media_Scrums/{id} a :Media_Scrums ; p:id {id} ; p:topic {topic} ; p:date {date} ; p:location {location} ; p:person {person} .
source		SELECT `id`, `topic`, `date`, `location`, `person` FROM `Media_Scrums`

]]
