@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_information_gathering_methods_0_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Author\", \"Publication_Date\", \"Content\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Author ; rr:objectMap [ rr:column "Author" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Publication_Date ; rr:objectMap [ rr:column "Publication_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] .

<#tm_attachment_2tab_val_information_gathering_methods_1_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Type\", \"Contact_Info\" FROM \"Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{id}" ; rr:class :Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Contact_Info ; rr:objectMap [ rr:column "Contact_Info" ] ] .

<#tm_attachment_2tab_val_information_gathering_methods_2_Keywords_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Word\" FROM \"Keywords\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Keywords/{id}" ; rr:class :Keywords ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Word ; rr:objectMap [ rr:column "Word" ] ] .

<#tm_attachment_2tab_val_information_gathering_methods_3_Article_Keywords_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"article_id\", \"keyword_id\" FROM \"Article_Keywords\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Keywords/{_amb_rowid}" ; rr:class :Article_Keywords ] ;
  rr:predicateObjectMap [ rr:predicate p:article_id ; rr:objectMap [ rr:column "article_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:keyword_id ; rr:objectMap [ rr:column "keyword_id" ] ] .

<#tm_attachment_2tab_val_information_gathering_methods_4_Article_Keywords_keyword_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"keyword_id\" FROM \"Article_Keywords\" WHERE \"keyword_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Keywords/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasKeywords ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Keywords/{keyword_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_information_gathering_methods_5_Article_Keywords_article_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"article_id\" FROM \"Article_Keywords\" WHERE \"article_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Keywords/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{article_id}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_information_gathering_methods_6_Interviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Date\", \"Location\", \"Interviewer\", \"Participant_Type\" FROM \"Interviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Interviews/{id}" ; rr:class :Interviews ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Interviewer ; rr:objectMap [ rr:column "Interviewer" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Participant_Type ; rr:objectMap [ rr:column "Participant_Type" ] ] .

<#tm_attachment_2tab_val_information_gathering_methods_7_Press_Conferences_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Date\", \"Location\", \"Participant_Type\", \"Speaker1\", \"Speaker2\" FROM \"Press_Conferences\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Press_Conferences/{id}" ; rr:class :Press_Conferences ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Participant_Type ; rr:objectMap [ rr:column "Participant_Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Speaker1 ; rr:objectMap [ rr:column "Speaker1" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Speaker2 ; rr:objectMap [ rr:column "Speaker2" ] ] .

