  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Phone_Number ; rr:objectMap [ rr:column "Phone_Number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Payment ; rr:objectMap [ rr:column "Payment" ] ] .

<#tm_attachment_2tab_val_journalist_classifications_2_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Content\", \"EditorID\", \"PublishDate\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EditorID ; rr:objectMap [ rr:column "EditorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublishDate ; rr:objectMap [ rr:column "PublishDate" ] ] .

<#tm_attachment_2tab_val_journalist_classifications_3_Articles_EditorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"EditorID\" FROM \"Articles\" WHERE \"EditorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEditors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Editors/{EditorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_journalist_classifications_4_Readerships_base> a rr:TriplesMap ;
