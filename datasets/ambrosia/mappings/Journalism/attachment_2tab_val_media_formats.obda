[PrefixDeclaration]
:	http://ambrosia.example.org/journalism#
p:	http://ambrosia.example.org/journalism/prop#
ex:	http://ambrosia.example.org/journalism/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Podcasts_base
target		ex:Podcasts/{id} a :Podcasts ; p:id {id} ; p:Title {Title} ; p:Description {Description} ; p:Length {Length} ; p:ReleaseDate {ReleaseDate} .
source		SELECT `id`, `Title`, `Description`, `Length`, `ReleaseDate` FROM `Podcasts`

mappingId	AudioDocuments_base
target		ex:AudioDocuments/{id} a :AudioDocuments ; p:id {id} ; p:Title {Title} ; p:Description {Description} ; p:Length {Length} ; p:ReleaseDate {ReleaseDate} .
source		SELECT `id`, `Title`, `Description`, `Length`, `ReleaseDate` FROM `AudioDocuments`

mappingId	Articles_base
target		ex:Articles/{id} a :Articles ; p:id {id} ; p:Title {Title} ; p:AuthorName {AuthorName} ; p:PublicationDate {PublicationDate} .
source		SELECT `id`, `Title`, `AuthorName`, `PublicationDate` FROM `Articles`

mappingId	Newspapers_base
target		ex:Newspapers/{id} a :Newspapers ; p:id {id} ; p:name {Name} ; p:location {Location} .
source		SELECT `id`, `Name`, `Location` FROM `Newspapers`

mappingId	Authors_base
target		ex:Authors/{id} a :Authors ; p:id {id} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:BirthDate {BirthDate} .
source		SELECT `id`, `FirstName`, `LastName`, `BirthDate` FROM `Authors`

]]
