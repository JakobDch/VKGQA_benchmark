[PrefixDeclaration]
:	http://ambrosia.example.org/journalism#
p:	http://ambrosia.example.org/journalism/prop#
ex:	http://ambrosia.example.org/journalism/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Opinion_Pieces_base
target		ex:Opinion_Pieces/{id} a :Opinion_Pieces ; p:id {id} ; p:Title {Title} ; p:Author {Author} ; p:PublicationDate {PublicationDate} ; p:Volume {Volume} .
source		SELECT `id`, `Title`, `Author`, `PublicationDate`, `Volume` FROM `Opinion_Pieces`

mappingId	Feature_Articles_base
target		ex:Feature_Articles/{id} a :Feature_Articles ; p:id {id} ; p:Title {Title} ; p:Author {Author} ; p:PublicationDate {PublicationDate} ; p:Volume {Volume} .
source		SELECT `id`, `Title`, `Author`, `PublicationDate`, `Volume` FROM `Feature_Articles`

mappingId	Magazines_base
target		ex:Magazines/{id} a :Magazines ; p:id {id} ; p:name {Name} ; p:Country {Country} ; p:FoundedYear {FoundedYear} .
source		SELECT `id`, `Name`, `Country`, `FoundedYear` FROM `Magazines`

mappingId	Authors_base
target		ex:Authors/{id} a :Authors ; p:id {id} ; p:FirstName {FirstName} ; p:LastName {LastName} ; p:Birthdate {Birthdate} ; p:Biography {Biography} .
source		SELECT `id`, `FirstName`, `LastName`, `Birthdate`, `Biography` FROM `Authors`

mappingId	Publishers_base
target		ex:Publishers/{id} a :Publishers ; p:id {id} ; p:name {Name} ; p:Address {Address} ; p:EstablishedYear {EstablishedYear} .
source		SELECT `id`, `Name`, `Address`, `EstablishedYear` FROM `Publishers`

]]
