@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_news_content_types_0_Opinion_Pieces_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Author\", \"PublicationDate\", \"Volume\" FROM \"Opinion_Pieces\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Opinion_Pieces/{id}" ; rr:class :Opinion_Pieces ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Author ; rr:objectMap [ rr:column "Author" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationDate ; rr:objectMap [ rr:column "PublicationDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Volume ; rr:objectMap [ rr:column "Volume" ] ] .

