[PrefixDeclaration]
:	http://ambrosia.example.org/journalism#
p:	http://ambrosia.example.org/journalism/prop#
ex:	http://ambrosia.example.org/journalism/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	Headlines_base
target		ex:Headlines/{id} a :Headlines ; p:id {id} ; p:headline {headline} ; p:Author {Author} ; p:publication_date {publication_date} ; p:category {category} .
source		SELECT `id`, `headline`, `Author`, `publication_date`, `category` FROM `Headlines`

mappingId	Ledes_base
target		ex:Ledes/{id} a :Ledes ; p:id {id} ; p:lede {lede} ; p:Author {Author} ; p:publication_date {publication_date} ; p:source_of_info {source_of_info} .
source		SELECT `id`, `lede`, `Author`, `publication_date`, `source_of_info` FROM `Ledes`

mappingId	Articles_base
target		ex:Articles/{id} a :Articles ; p:id {id} ; p:title {title} ; p:content {content} ; p:editor {editor} ; p:publishing_status {publishing_status} .
source		SELECT `id`, `title`, `content`, `editor`, `publishing_status` FROM `Articles`

mappingId	Reporters_base
target		ex:Reporters/{id} a :Reporters ; p:id {id} ; p:name {name} ; p:email {email} ; p:phone_number {phone_number} .
source		SELECT `id`, `name`, `email`, `phone_number` FROM `Reporters`

mappingId	Sources_base
target		ex:Sources/{id} a :Sources ; p:id {id} ; p:name {name} ; p:url {url} .
source		SELECT `id`, `name`, `url` FROM `Sources`

mappingId	Readers_base
target		ex:Readers/{id} a :Readers ; p:id {id} ; p:name {name} ; p:email {email} ; p:preferred_source {preferred_source} .
source		SELECT `id`, `name`, `email`, `preferred_source` FROM `Readers`

]]
