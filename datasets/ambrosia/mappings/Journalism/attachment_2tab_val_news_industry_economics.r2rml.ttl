@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_news_industry_economics_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Email\", \"Birthdate\", \"Nationality\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{ID}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Birthdate ; rr:objectMap [ rr:column "Birthdate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Nationality ; rr:objectMap [ rr:column "Nationality" ] ] .

<#tm_attachment_2tab_val_news_industry_economics_1_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Title\", \"Content\", \"AuthorID\", \"PublishDate\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublishDate ; rr:objectMap [ rr:column "PublishDate" ] ] .

<#tm_attachment_2tab_val_news_industry_economics_2_Articles_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"AuthorID\" FROM \"Articles\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_news_industry_economics_3_Magazines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Category\", \"EditorInChief\", \"PublishingHouse\" FROM \"Magazines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{ID}" ; rr:class :Magazines ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Category ; rr:objectMap [ rr:column "Category" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EditorInChief ; rr:objectMap [ rr:column "EditorInChief" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublishingHouse ; rr:objectMap [ rr:column "PublishingHouse" ] ] .

<#tm_attachment_2tab_val_news_industry_economics_4_Issues_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"IssueNumber\", \"MagazineID\", \"ReleaseDate\" FROM \"Issues\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Issues/{IssueNumber}" ; rr:class :Issues ] ;
  rr:predicateObjectMap [ rr:predicate p:IssueNumber ; rr:objectMap [ rr:column "IssueNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MagazineID ; rr:objectMap [ rr:column "MagazineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseDate ; rr:objectMap [ rr:column "ReleaseDate" ] ] .

<#tm_attachment_2tab_val_news_industry_economics_5_Issues_MagazineID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"IssueNumber\", \"MagazineID\" FROM \"Issues\" WHERE \"MagazineID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Issues/{IssueNumber}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMagazines ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{MagazineID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_news_industry_economics_6_Advertising_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Magazine\", \"Advertising_Revenue\", \"Subscribers\", \"Country\", \"Type\" FROM \"Advertising\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Advertising/{ID}" ; rr:class :Advertising ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Magazine ; rr:objectMap [ rr:column "Magazine" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Advertising_Revenue ; rr:objectMap [ rr:column "Advertising_Revenue" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Subscribers ; rr:objectMap [ rr:column "Subscribers" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] .

<#tm_attachment_2tab_val_news_industry_economics_7_Subscriptions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Magazine\", \"Subscription_Fees\", \"NumberOfSubscribers\", \"Type\" FROM \"Subscriptions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Subscriptions/{ID}" ; rr:class :Subscriptions ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Magazine ; rr:objectMap [ rr:column "Magazine" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Subscription_Fees ; rr:objectMap [ rr:column "Subscription_Fees" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfSubscribers ; rr:objectMap [ rr:column "NumberOfSubscribers" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Type ; rr:objectMap [ rr:column "Type" ] ] .

