@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_news_sources_0_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"articleID\", \"title\", \"authorName\", \"publishDate\", \"content\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{articleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:articleID ; rr:objectMap [ rr:column "articleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:authorName ; rr:objectMap [ rr:column "authorName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publishDate ; rr:objectMap [ rr:column "publishDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] .

<#tm_attachment_2tab_val_news_sources_1_PressReleases_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"pressReleaseID\", \"title\", \"releaseDate\", \"content\", \"FK_articleID\" FROM \"PressReleases\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/PressReleases/{pressReleaseID}" ; rr:class :PressReleases ] ;
  rr:predicateObjectMap [ rr:predicate p:pressReleaseID ; rr:objectMap [ rr:column "pressReleaseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:releaseDate ; rr:objectMap [ rr:column "releaseDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FK_articleID ; rr:objectMap [ rr:column "FK_articleID" ] ] .

<#tm_attachment_2tab_val_news_sources_2_PressReleases_FK_articleID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"pressReleaseID\", \"FK_articleID\" FROM \"PressReleases\" WHERE \"FK_articleID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/PressReleases/{pressReleaseID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{FK_articleID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_news_sources_3_Interviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"interviewID\", \"intervieweeName\", \"interviewerName\", \"interviewDate\", \"content\", \"FK_articleID\" FROM \"Interviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Interviews/{interviewID}" ; rr:class :Interviews ] ;
  rr:predicateObjectMap [ rr:predicate p:interviewID ; rr:objectMap [ rr:column "interviewID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:intervieweeName ; rr:objectMap [ rr:column "intervieweeName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:interviewerName ; rr:objectMap [ rr:column "interviewerName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:interviewDate ; rr:objectMap [ rr:column "interviewDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FK_articleID ; rr:objectMap [ rr:column "FK_articleID" ] ] .

<#tm_attachment_2tab_val_news_sources_4_Interviews_FK_articleID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"interviewID\", \"FK_articleID\" FROM \"Interviews\" WHERE \"FK_articleID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Interviews/{interviewID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{FK_articleID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_news_sources_5_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"sourceID\", \"name\", \"description\", \"contactInfo\" FROM \"Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{sourceID}" ; rr:class :Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:sourceID ; rr:objectMap [ rr:column "sourceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contactInfo ; rr:objectMap [ rr:column "contactInfo" ] ] .

