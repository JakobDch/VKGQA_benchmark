@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_periodicals_0_Newspapers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Circulation_Numbers\", \"Founded_Year\", \"Headquarters\", \"Editor_in_Chief\" FROM \"Newspapers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspapers/{ID}" ; rr:class :Newspapers ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Circulation_Numbers ; rr:objectMap [ rr:column "Circulation_Numbers" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Founded_Year ; rr:objectMap [ rr:column "Founded_Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Headquarters ; rr:objectMap [ rr:column "Headquarters" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Editor_in_Chief ; rr:objectMap [ rr:column "Editor_in_Chief" ] ] .

<#tm_attachment_2tab_val_periodicals_1_Magazines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Circulation_Numbers\", \"Issue_Frequency\", \"Publisher\", \"Topic\" FROM \"Magazines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{ID}" ; rr:class :Magazines ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Circulation_Numbers ; rr:objectMap [ rr:column "Circulation_Numbers" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Issue_Frequency ; rr:objectMap [ rr:column "Issue_Frequency" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Publisher ; rr:objectMap [ rr:column "Publisher" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Topic ; rr:objectMap [ rr:column "Topic" ] ] .

<#tm_attachment_2tab_val_periodicals_2_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Article_ID\", \"Title\", \"Publication_Date\", \"Content_Length\", \"Author_Name\", \"Newspaper_ID\", \"Magazine_ID\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{Article_ID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:Article_ID ; rr:objectMap [ rr:column "Article_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Publication_Date ; rr:objectMap [ rr:column "Publication_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content_Length ; rr:objectMap [ rr:column "Content_Length" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Author_Name ; rr:objectMap [ rr:column "Author_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Newspaper_ID ; rr:objectMap [ rr:column "Newspaper_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Magazine_ID ; rr:objectMap [ rr:column "Magazine_ID" ] ] .

<#tm_attachment_2tab_val_periodicals_3_Articles_Magazine_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Article_ID\", \"Magazine_ID\" FROM \"Articles\" WHERE \"Magazine_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{Article_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMagazines ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{Magazine_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_periodicals_4_Articles_Newspaper_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Article_ID\", \"Newspaper_ID\" FROM \"Articles\" WHERE \"Newspaper_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{Article_ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNewspapers ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspapers/{Newspaper_ID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_periodicals_5_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Author_ID\", \"First_Name\", \"Last_Name\", \"Biography\", \"Email\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{Author_ID}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:Author_ID ; rr:objectMap [ rr:column "Author_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:First_Name ; rr:objectMap [ rr:column "First_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Last_Name ; rr:objectMap [ rr:column "Last_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Biography ; rr:objectMap [ rr:column "Biography" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

<#tm_attachment_2tab_val_periodicals_6_Subscriptions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Subscription_ID\", \"Customer_Name\", \"Address\", \"Phone_Number\", \"Subscribed_To\", \"Start_Date\", \"End_Date\" FROM \"Subscriptions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Subscriptions/{Subscription_ID}" ; rr:class :Subscriptions ] ;
  rr:predicateObjectMap [ rr:predicate p:Subscription_ID ; rr:objectMap [ rr:column "Subscription_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Customer_Name ; rr:objectMap [ rr:column "Customer_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Phone_Number ; rr:objectMap [ rr:column "Phone_Number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Subscribed_To ; rr:objectMap [ rr:column "Subscribed_To" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Start_Date ; rr:objectMap [ rr:column "Start_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:End_Date ; rr:objectMap [ rr:column "End_Date" ] ] .

