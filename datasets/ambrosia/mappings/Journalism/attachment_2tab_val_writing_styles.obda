[PrefixDeclaration]
:	http://ambrosia.example.org/journalism#
p:	http://ambrosia.example.org/journalism/prop#
ex:	http://ambrosia.example.org/journalism/id/
rdf:	http://www.w3.org/1999/02/22-rdf-syntax-ns#
xsd:	http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId	NewsReports_base
target		ex:NewsReports/{ReportID} a :NewsReports ; p:ReportID {ReportID} ; p:EventName {EventName} ; p:Reporter {Reporter} ; p:location {Location} ; p:DatePublished {DatePublished} .
source		SELECT `ReportID`, `EventName`, `Reporter`, `Location`, `DatePublished` FROM `NewsReports`

mappingId	MagazineArticles_base
target		ex:MagazineArticles/{ArticleID} a :MagazineArticles ; p:ArticleID {ArticleID} ; p:Title {Title} ; p:Category {Category} ; p:Writer {Writer} ; p:IssueDate {IssueDate} .
source		SELECT `ArticleID`, `Title`, `Category`, `Writer`, `IssueDate` FROM `MagazineArticles`

mappingId	Short_Stories_base
target		ex:Short_Stories/{StoryID} a :Short_Stories ; p:StoryID {StoryID} ; p:Title {Title} ; p:Author {Author} ; p:Genre {Genre} ; p:WordCount {WordCount} ; p:PublicationDate {PublicationDate} .
source		SELECT `StoryID`, `Title`, `Author`, `Genre`, `WordCount`, `PublicationDate` FROM `Short_Stories`

mappingId	Personal_Essays_base
target		ex:Personal_Essays/{EssayID} a :Personal_Essays ; p:EssayID {EssayID} ; p:Title {Title} ; p:Author {Author} ; p:Topic {Topic} ; p:Length {Length} ; p:PublishDate {PublishDate} .
source		SELECT `EssayID`, `Title`, `Author`, `Topic`, `Length`, `PublishDate` FROM `Personal_Essays`

]]
