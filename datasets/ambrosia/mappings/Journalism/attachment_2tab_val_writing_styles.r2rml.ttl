@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_writing_styles_0_NewsReports_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReportID\", \"EventName\", \"Reporter\", \"Location\", \"DatePublished\" FROM \"NewsReports\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/NewsReports/{ReportID}" ; rr:class :NewsReports ] ;
  rr:predicateObjectMap [ rr:predicate p:ReportID ; rr:objectMap [ rr:column "ReportID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EventName ; rr:objectMap [ rr:column "EventName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Reporter ; rr:objectMap [ rr:column "Reporter" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DatePublished ; rr:objectMap [ rr:column "DatePublished" ] ] .

