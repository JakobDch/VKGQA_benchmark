  rr:predicateObjectMap [ rr:predicate p:Category ; rr:objectMap [ rr:column "Category" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Writer ; rr:objectMap [ rr:column "Writer" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:IssueDate ; rr:objectMap [ rr:column "IssueDate" ] ] .

