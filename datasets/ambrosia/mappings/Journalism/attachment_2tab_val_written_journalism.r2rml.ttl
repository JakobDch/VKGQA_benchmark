@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_attachment_2tab_val_written_journalism_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorID\", \"FirstName\", \"LastName\", \"BirthDate\", \"Country\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Country ; rr:objectMap [ rr:column "Country" ] ] .

<#tm_attachment_2tab_val_written_journalism_1_News_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"Title\", \"Content\", \"Word_Count\", \"Published_Date\", \"AuthorID\" FROM \"News_Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Word_Count ; rr:objectMap [ rr:column "Word_Count" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Published_Date ; rr:objectMap [ rr:column "Published_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] .

<#tm_attachment_2tab_val_written_journalism_2_News_Articles_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"AuthorID\" FROM \"News_Articles\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_written_journalism_3_Feature_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"Title\", \"Content\", \"Word_Count\", \"Published_Date\", \"AuthorID\" FROM \"Feature_Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Feature_Articles/{ArticleID}" ; rr:class :Feature_Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Word_Count ; rr:objectMap [ rr:column "Word_Count" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Published_Date ; rr:objectMap [ rr:column "Published_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] .

<#tm_attachment_2tab_val_written_journalism_4_Feature_Articles_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"AuthorID\" FROM \"Feature_Articles\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Feature_Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_attachment_2tab_val_written_journalism_5_Publications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PublisherID\", \"Name\", \"Address\", \"Website\" FROM \"Publications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{PublisherID}" ; rr:class :Publications ] ;
