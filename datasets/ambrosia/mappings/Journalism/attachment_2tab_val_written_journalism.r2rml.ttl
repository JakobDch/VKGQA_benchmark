  rr:logicalTable [ rr:sqlQuery """SELECT \"PublisherID\", \"AuthorID\" FROM \"Publishers_and_Authors\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publishers_and_Authors/{PublisherID}/{AuthorID}" ] ;
