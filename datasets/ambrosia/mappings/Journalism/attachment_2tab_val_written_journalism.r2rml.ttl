<#tm_attachment_2tab_val_written_journalism_8_Publishers_and_Authors_PublisherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PublisherID\", \"AuthorID\" FROM \"Publishers_and_Authors\" WHERE \"PublisherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publishers_and_Authors/{PublisherID}/{AuthorID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublications ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{PublisherID}" ; rr:termType rr:IRI ] ] .

