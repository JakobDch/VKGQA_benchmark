@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_agriculture_reporters_crops_0_Agriculture_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Agriculture_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Agriculture_Reporters/{id}" ; rr:class :Agriculture_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_agriculture_reporters_crops_1_Crops_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"crop_name\", \"description\" FROM \"Crops\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Crops/{id}" ; rr:class :Crops ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:crop_name ; rr:objectMap [ rr:column "crop_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_agriculture_reporters_crops_2_Agriculture_Reporters_Crops_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"agriculture_reporter_id\", \"crop_id\" FROM \"Agriculture_Reporters_Crops\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Agriculture_Reporters_Crops/{agriculture_reporter_id}/{crop_id}" ; rr:class :Agriculture_Reporters_Crops ] ;
  rr:predicateObjectMap [ rr:predicate p:agriculture_reporter_id ; rr:objectMap [ rr:column "agriculture_reporter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:crop_id ; rr:objectMap [ rr:column "crop_id" ] ] .

<#tm_scope_agriculture_reporters_crops_3_Agriculture_Reporters_Crops_crop_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"agriculture_reporter_id\", \"crop_id\" FROM \"Agriculture_Reporters_Crops\" WHERE \"crop_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Agriculture_Reporters_Crops/{agriculture_reporter_id}/{crop_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCrops ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Crops/{crop_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_agriculture_reporters_crops_4_Agriculture_Reporters_Crops_agriculture_reporter_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"agriculture_reporter_id\", \"crop_id\" FROM \"Agriculture_Reporters_Crops\" WHERE \"agriculture_reporter_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Agriculture_Reporters_Crops/{agriculture_reporter_id}/{crop_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAgriculture_Reporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Agriculture_Reporters/{agriculture_reporter_id}" ; rr:termType rr:IRI ] ] .

