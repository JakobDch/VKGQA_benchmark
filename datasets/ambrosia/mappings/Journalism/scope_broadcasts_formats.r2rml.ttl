@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_broadcasts_formats_0_Formats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"format_name\" FROM \"Formats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Formats/{id}" ; rr:class :Formats ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:format_name ; rr:objectMap [ rr:column "format_name" ] ] .

<#tm_scope_broadcasts_formats_1_Broadcasts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"date\" FROM \"Broadcasts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Broadcasts/{id}" ; rr:class :Broadcasts ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] .

