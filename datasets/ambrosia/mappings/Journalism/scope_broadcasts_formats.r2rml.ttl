<#tm_scope_broadcasts_formats_7_Broadcasts_Formats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"broadcast_id\", \"format_id\" FROM \"Broadcasts_Formats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Broadcasts_Formats/{_amb_rowid}" ; rr:class :Broadcasts_Formats ] ;
