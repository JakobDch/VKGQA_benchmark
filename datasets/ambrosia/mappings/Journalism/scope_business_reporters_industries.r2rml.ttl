  rr:predicateObjectMap [ rr:predicate p:articleID ; rr:objectMap [ rr:column "articleID" ] ] .

<#tm_scope_business_reporters_industries_4_Business_Reporters_Articles_articleID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"articleID\" FROM \"Business_Reporters_Articles\" WHERE \"articleID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Business_Reporters_Articles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{articleID}" ; rr:termType rr:IRI ] ] .

