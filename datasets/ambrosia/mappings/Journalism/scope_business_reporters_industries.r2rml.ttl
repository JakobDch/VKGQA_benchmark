@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_business_reporters_industries_0_Industries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"industryID\", \"name\" FROM \"Industries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Industries/{industryID}" ; rr:class :Industries ] ;
  rr:predicateObjectMap [ rr:predicate p:industryID ; rr:objectMap [ rr:column "industryID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_business_reporters_industries_1_Business_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reporterID\", \"fullName\" FROM \"Business_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Business_Reporters/{reporterID}" ; rr:class :Business_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:reporterID ; rr:objectMap [ rr:column "reporterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "fullName" ] ] .

<#tm_scope_business_reporters_industries_2_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"articleID\", \"title\", \"content\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{articleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:articleID ; rr:objectMap [ rr:column "articleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] .

<#tm_scope_business_reporters_industries_3_Business_Reporters_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"businessReporterID\", \"articleID\" FROM \"Business_Reporters_Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Business_Reporters_Articles/{_amb_rowid}" ; rr:class :Business_Reporters_Articles ] ;
