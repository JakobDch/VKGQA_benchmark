@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_courts_reporters_trials_0_Courts_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Courts_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Courts_Reporters/{id}" ; rr:class :Courts_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_courts_reporters_trials_1_Trials_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"caseName\", \"trialType\" FROM \"Trials\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Trials/{id}" ; rr:class :Trials ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:caseName ; rr:objectMap [ rr:column "caseName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:trialType ; rr:objectMap [ rr:column "trialType" ] ] .

<#tm_scope_courts_reporters_trials_2_Courts_Reporters_Trials_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"reporterId\", \"trialId\" FROM \"Courts_Reporters_Trials\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Courts_Reporters_Trials/{_amb_rowid}" ; rr:class :Courts_Reporters_Trials ] ;
  rr:predicateObjectMap [ rr:predicate p:reporterId ; rr:objectMap [ rr:column "reporterId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:trialId ; rr:objectMap [ rr:column "trialId" ] ] .

<#tm_scope_courts_reporters_trials_3_Courts_Reporters_Trials_trialId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"trialId\" FROM \"Courts_Reporters_Trials\" WHERE \"trialId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Courts_Reporters_Trials/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTrials ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Trials/{trialId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_courts_reporters_trials_4_Courts_Reporters_Trials_reporterId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"reporterId\" FROM \"Courts_Reporters_Trials\" WHERE \"reporterId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Courts_Reporters_Trials/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourts_Reporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Courts_Reporters/{reporterId}" ; rr:termType rr:IRI ] ] .

