@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_environment_and_energy_reporters_sources_0_Environment_And_Energy_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Environment_And_Energy_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Environment_And_Energy_Reporters/{id}" ; rr:class :Environment_And_Energy_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_environment_and_energy_reporters_sources_1_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"source_id\", \"source_name\", \"description\" FROM \"Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{source_id}" ; rr:class :Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:source_id ; rr:objectMap [ rr:column "source_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:source_name ; rr:objectMap [ rr:column "source_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_environment_and_energy_reporters_sources_2_Environment_And_Energy_Reporters_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"reporter_id\", \"source_id\" FROM \"Environment_And_Energy_Reporters_Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Environment_And_Energy_Reporters_Sources/{_amb_rowid}" ; rr:class :Environment_And_Energy_Reporters_Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:reporter_id ; rr:objectMap [ rr:column "reporter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:source_id ; rr:objectMap [ rr:column "source_id" ] ] .

<#tm_scope_environment_and_energy_reporters_sources_3_Environment_And_Energy_Reporters_Sources_source_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"source_id\" FROM \"Environment_And_Energy_Reporters_Sources\" WHERE \"source_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Environment_And_Energy_Reporters_Sources/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSources ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{source_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_environment_and_energy_reporters_sources_4_Environment_And_Energy_Reporters_Sources_reporter_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"reporter_id\" FROM \"Environment_And_Energy_Reporters_Sources\" WHERE \"reporter_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Environment_And_Energy_Reporters_Sources/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEnvironment_And_Energy_Reporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Environment_And_Energy_Reporters/{reporter_id}" ; rr:termType rr:IRI ] ] .

