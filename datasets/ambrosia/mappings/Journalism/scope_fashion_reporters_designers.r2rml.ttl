@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_fashion_reporters_designers_0_Fashion_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReporterID\", \"FullName\" FROM \"Fashion_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Fashion_Reporters/{ReporterID}" ; rr:class :Fashion_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:ReporterID ; rr:objectMap [ rr:column "ReporterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "FullName" ] ] .

<#tm_scope_fashion_reporters_designers_1_Designers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DesignerID\", \"Name\" FROM \"Designers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Designers/{DesignerID}" ; rr:class :Designers ] ;
  rr:predicateObjectMap [ rr:predicate p:DesignerID ; rr:objectMap [ rr:column "DesignerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_scope_fashion_reporters_designers_2_Fashion_Reporters_Designers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReporterID\", \"DesignerID\" FROM \"Fashion_Reporters_Designers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Fashion_Reporters_Designers/{ReporterID}/{DesignerID}" ; rr:class :Fashion_Reporters_Designers ] ;
  rr:predicateObjectMap [ rr:predicate p:ReporterID ; rr:objectMap [ rr:column "ReporterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DesignerID ; rr:objectMap [ rr:column "DesignerID" ] ] .

<#tm_scope_fashion_reporters_designers_3_Fashion_Reporters_Designers_DesignerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReporterID\", \"DesignerID\" FROM \"Fashion_Reporters_Designers\" WHERE \"DesignerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Fashion_Reporters_Designers/{ReporterID}/{DesignerID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDesigners ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Designers/{DesignerID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_fashion_reporters_designers_4_Fashion_Reporters_Designers_ReporterID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReporterID\", \"DesignerID\" FROM \"Fashion_Reporters_Designers\" WHERE \"ReporterID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Fashion_Reporters_Designers/{ReporterID}/{DesignerID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFashion_Reporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Fashion_Reporters/{ReporterID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_fashion_reporters_designers_5_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"Title\", \"Content\", \"PublishDate\", \"ReporterID\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublishDate ; rr:objectMap [ rr:column "PublishDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReporterID ; rr:objectMap [ rr:column "ReporterID" ] ] .

<#tm_scope_fashion_reporters_designers_6_Articles_ReporterID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"ReporterID\" FROM \"Articles\" WHERE \"ReporterID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFashion_Reporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Fashion_Reporters/{ReporterID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_fashion_reporters_designers_7_Publications_base> a rr:TriplesMap ;
