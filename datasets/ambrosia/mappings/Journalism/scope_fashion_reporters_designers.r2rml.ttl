<#tm_scope_fashion_reporters_designers_9_Article_Publications_PublicationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"PublicationID\" FROM \"Article_Publications\" WHERE \"PublicationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Publications/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublications ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{PublicationID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_fashion_reporters_designers_10_Article_Publications_ArticleID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ArticleID\" FROM \"Article_Publications\" WHERE \"ArticleID\" IS NOT NULL""" ] ;
