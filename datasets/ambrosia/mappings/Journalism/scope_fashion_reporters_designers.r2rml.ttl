  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"ArticleID\", \"PublicationID\", \"PublishedOn\" FROM \"Article_Publications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Publications/{_amb_rowid}" ; rr:class :Article_Publications ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationID ; rr:objectMap [ rr:column "PublicationID" ] ] ;
