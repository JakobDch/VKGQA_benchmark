@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_food_critics_cuisines_0_Cuisines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"cuisine_name\" FROM \"Cuisines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Cuisines/{id}" ; rr:class :Cuisines ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cuisine_name ; rr:objectMap [ rr:column "cuisine_name" ] ] .

<#tm_scope_food_critics_cuisines_1_Food_Critics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"critic_name\", \"contact_email\" FROM \"Food_Critics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Food_Critics/{id}" ; rr:class :Food_Critics ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:critic_name ; rr:objectMap [ rr:column "critic_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contact_email ; rr:objectMap [ rr:column "contact_email" ] ] .

<#tm_scope_food_critics_cuisines_2_Food_Critics_Cuisines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"food_critic_id\", \"cuisine_id\" FROM \"Food_Critics_Cuisines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Food_Critics_Cuisines/{_amb_rowid}" ; rr:class :Food_Critics_Cuisines ] ;
  rr:predicateObjectMap [ rr:predicate p:food_critic_id ; rr:objectMap [ rr:column "food_critic_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cuisine_id ; rr:objectMap [ rr:column "cuisine_id" ] ] .

<#tm_scope_food_critics_cuisines_3_Food_Critics_Cuisines_cuisine_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"cuisine_id\" FROM \"Food_Critics_Cuisines\" WHERE \"cuisine_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Food_Critics_Cuisines/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCuisines ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Cuisines/{cuisine_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_food_critics_cuisines_4_Food_Critics_Cuisines_food_critic_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"food_critic_id\" FROM \"Food_Critics_Cuisines\" WHERE \"food_critic_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Food_Critics_Cuisines/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFood_Critics ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Food_Critics/{food_critic_id}" ; rr:termType rr:IRI ] ] .

