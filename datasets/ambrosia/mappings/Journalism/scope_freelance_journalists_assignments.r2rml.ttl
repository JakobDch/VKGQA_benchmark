@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_freelance_journalists_assignments_0_Freelance_Journalists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"journalist_id\", \"name\", \"email\" FROM \"Freelance_Journalists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Freelance_Journalists/{journalist_id}" ; rr:class :Freelance_Journalists ] ;
  rr:predicateObjectMap [ rr:predicate p:journalist_id ; rr:objectMap [ rr:column "journalist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_freelance_journalists_assignments_1_Assignments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignment_id\", \"title\", \"deadline\" FROM \"Assignments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Assignments/{assignment_id}" ; rr:class :Assignments ] ;
  rr:predicateObjectMap [ rr:predicate p:assignment_id ; rr:objectMap [ rr:column "assignment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:deadline ; rr:objectMap [ rr:column "deadline" ] ] .

<#tm_scope_freelance_journalists_assignments_2_Publications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"publication_id\", \"publication_name\", \"publisher_name\" FROM \"Publications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{publication_id}" ; rr:class :Publications ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_id ; rr:objectMap [ rr:column "publication_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_name ; rr:objectMap [ rr:column "publication_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publisher_name ; rr:objectMap [ rr:column "publisher_name" ] ] .

<#tm_scope_freelance_journalists_assignments_3_Article_Publication_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_publication_id\", \"freelance_journalist_id\", \"assignment_id\", \"publication_id\", \"publish_date\" FROM \"Article_Publication\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Publication/{article_publication_id}" ; rr:class :Article_Publication ] ;
  rr:predicateObjectMap [ rr:predicate p:article_publication_id ; rr:objectMap [ rr:column "article_publication_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:freelance_journalist_id ; rr:objectMap [ rr:column "freelance_journalist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:assignment_id ; rr:objectMap [ rr:column "assignment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_id ; rr:objectMap [ rr:column "publication_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publish_date ; rr:objectMap [ rr:column "publish_date" ] ] .

<#tm_scope_freelance_journalists_assignments_4_Article_Publication_publication_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_publication_id\", \"publication_id\" FROM \"Article_Publication\" WHERE \"publication_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Publication/{article_publication_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublications ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{publication_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_freelance_journalists_assignments_5_Article_Publication_assignment_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_publication_id\", \"assignment_id\" FROM \"Article_Publication\" WHERE \"assignment_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Publication/{article_publication_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAssignments ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Assignments/{assignment_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_freelance_journalists_assignments_6_Article_Publication_freelance_journalist_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_publication_id\", \"freelance_journalist_id\" FROM \"Article_Publication\" WHERE \"freelance_journalist_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Publication/{article_publication_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFreelance_Journalists ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Freelance_Journalists/{freelance_journalist_id}" ; rr:termType rr:IRI ] ] .

