@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_health_reporters_topics_0_Health_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReporterID\", \"Name\", \"Email\" FROM \"Health_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Health_Reporters/{ReporterID}" ; rr:class :Health_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:ReporterID ; rr:objectMap [ rr:column "ReporterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

<#tm_scope_health_reporters_topics_1_Topics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TopicID\", \"Name\" FROM \"Topics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/topics/{TopicID}" ; rr:class :topics ] ;
  rr:predicateObjectMap [ rr:predicate p:TopicID ; rr:objectMap [ rr:column "TopicID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] .

<#tm_scope_health_reporters_topics_2_Health_Reporters_Topics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReporterID\", \"TopicID\", \"PrimaryKey\" FROM \"Health_Reporters_Topics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Health_Reporters_Topics/{PrimaryKey}" ; rr:class :Health_Reporters_Topics ] ;
  rr:predicateObjectMap [ rr:predicate p:ReporterID ; rr:objectMap [ rr:column "ReporterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TopicID ; rr:objectMap [ rr:column "TopicID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PrimaryKey ; rr:objectMap [ rr:column "PrimaryKey" ] ] .

<#tm_scope_health_reporters_topics_3_Health_Reporters_Topics_TopicID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PrimaryKey\", \"TopicID\" FROM \"Health_Reporters_Topics\" WHERE \"TopicID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Health_Reporters_Topics/{PrimaryKey}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hastopics ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/topics/{TopicID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_health_reporters_topics_4_Health_Reporters_Topics_ReporterID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PrimaryKey\", \"ReporterID\" FROM \"Health_Reporters_Topics\" WHERE \"ReporterID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Health_Reporters_Topics/{PrimaryKey}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHealth_Reporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Health_Reporters/{ReporterID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_health_reporters_topics_5_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"Title\", \"Content\", \"PublishDate\", \"ReporterID\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublishDate ; rr:objectMap [ rr:column "PublishDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReporterID ; rr:objectMap [ rr:column "ReporterID" ] ] .

<#tm_scope_health_reporters_topics_6_Articles_ReporterID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"ReporterID\" FROM \"Articles\" WHERE \"ReporterID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasHealth_Reporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Health_Reporters/{ReporterID}" ; rr:termType rr:IRI ] ] .

<#tm_scope_health_reporters_topics_7_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SourceID\", \"Name\", \"URL\" FROM \"Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{SourceID}" ; rr:class :Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:SourceID ; rr:objectMap [ rr:column "SourceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:URL ; rr:objectMap [ rr:column "URL" ] ] .

