@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_immigration_reporters_countries_0_Countries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"countryName\" FROM \"Countries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Countries/{id}" ; rr:class :Countries ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:countryName ; rr:objectMap [ rr:column "countryName" ] ] .

<#tm_scope_immigration_reporters_countries_1_Immigration_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"reporterName\", \"email\" FROM \"Immigration_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Immigration_Reporters/{id}" ; rr:class :Immigration_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:reporterName ; rr:objectMap [ rr:column "reporterName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_immigration_reporters_countries_2_Immigration_Reporters_Countries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"immigrationReporterId\", \"countryId\" FROM \"Immigration_Reporters_Countries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Immigration_Reporters_Countries/{_amb_rowid}" ; rr:class :Immigration_Reporters_Countries ] ;
  rr:predicateObjectMap [ rr:predicate p:immigrationReporterId ; rr:objectMap [ rr:column "immigrationReporterId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:countryId ; rr:objectMap [ rr:column "countryId" ] ] .

<#tm_scope_immigration_reporters_countries_3_Immigration_Reporters_Countries_countryId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"countryId\" FROM \"Immigration_Reporters_Countries\" WHERE \"countryId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Immigration_Reporters_Countries/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCountries ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Countries/{countryId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_immigration_reporters_countries_4_Immigration_Reporters_Countries_immigrationReporterId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"immigrationReporterId\" FROM \"Immigration_Reporters_Countries\" WHERE \"immigrationReporterId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Immigration_Reporters_Countries/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasImmigration_Reporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Immigration_Reporters/{immigrationReporterId}" ; rr:termType rr:IRI ] ] .

