@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_investigative_reports_elements_0_Journalists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Journalists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalists/{id}" ; rr:class :Journalists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_investigative_reports_elements_1_Publications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"publication_date\" FROM \"Publications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{id}" ; rr:class :Publications ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_date ; rr:objectMap [ rr:column "publication_date" ] ] .

<#tm_scope_investigative_reports_elements_2_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"journalist_id\", \"publication_id\", \"article_title\", \"publish_date\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:journalist_id ; rr:objectMap [ rr:column "journalist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_id ; rr:objectMap [ rr:column "publication_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:article_title ; rr:objectMap [ rr:column "article_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publish_date ; rr:objectMap [ rr:column "publish_date" ] ] .

<#tm_scope_investigative_reports_elements_3_Articles_publication_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"publication_id\" FROM \"Articles\" WHERE \"publication_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublications ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{publication_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_investigative_reports_elements_4_Articles_journalist_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"journalist_id\" FROM \"Articles\" WHERE \"journalist_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJournalists ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalists/{journalist_id}" ; rr:termType rr:IRI ] ] .

