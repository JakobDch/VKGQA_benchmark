@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_journalism_schools_courses_0_Journalism_Schools_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Journalism_Schools\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalism_Schools/{id}" ; rr:class :Journalism_Schools ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_journalism_schools_courses_1_Courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"course_name\", \"description\" FROM \"Courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Courses/{id}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:course_name ; rr:objectMap [ rr:column "course_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_journalism_schools_courses_2_Journalism_Schools_Courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"journalism_schools_id\", \"course_id\" FROM \"Journalism_Schools_Courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalism_Schools_Courses/{journalism_schools_id}/{course_id}" ; rr:class :Journalism_Schools_Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:journalism_schools_id ; rr:objectMap [ rr:column "journalism_schools_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:course_id ; rr:objectMap [ rr:column "course_id" ] ] .

<#tm_scope_journalism_schools_courses_3_Journalism_Schools_Courses_course_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"journalism_schools_id\", \"course_id\" FROM \"Journalism_Schools_Courses\" WHERE \"course_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalism_Schools_Courses/{journalism_schools_id}/{course_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourses ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Courses/{course_id}" ; rr:termType rr:IRI ] ] .

