@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_legal_affairs_reporters_jurisdictions_0_Legal_Affairs_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reporter_id\", \"name\", \"email\" FROM \"Legal_Affairs_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Legal_Affairs_Reporters/{reporter_id}" ; rr:class :Legal_Affairs_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:reporter_id ; rr:objectMap [ rr:column "reporter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_legal_affairs_reporters_jurisdictions_1_Jurisdictions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"jurisdiction_id\", \"jurisdiction_name\" FROM \"Jurisdictions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Jurisdictions/{jurisdiction_id}" ; rr:class :Jurisdictions ] ;
  rr:predicateObjectMap [ rr:predicate p:jurisdiction_id ; rr:objectMap [ rr:column "jurisdiction_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jurisdiction_name ; rr:objectMap [ rr:column "jurisdiction_name" ] ] .

<#tm_scope_legal_affairs_reporters_jurisdictions_2_Legal_Affairs_Reporters_Jurisdictions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"legal_affairs_reporter_id\", \"jurisdiction_id\" FROM \"Legal_Affairs_Reporters_Jurisdictions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Legal_Affairs_Reporters_Jurisdictions/{_amb_rowid}" ; rr:class :Legal_Affairs_Reporters_Jurisdictions ] ;
  rr:predicateObjectMap [ rr:predicate p:legal_affairs_reporter_id ; rr:objectMap [ rr:column "legal_affairs_reporter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:jurisdiction_id ; rr:objectMap [ rr:column "jurisdiction_id" ] ] .

<#tm_scope_legal_affairs_reporters_jurisdictions_3_Legal_Affairs_Reporters_Jurisdictions_jurisdiction_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"jurisdiction_id\" FROM \"Legal_Affairs_Reporters_Jurisdictions\" WHERE \"jurisdiction_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Legal_Affairs_Reporters_Jurisdictions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJurisdictions ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Jurisdictions/{jurisdiction_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_legal_affairs_reporters_jurisdictions_4_Legal_Affairs_Reporters_Jurisdictions_legal_affairs_reporter_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"legal_affairs_reporter_id\" FROM \"Legal_Affairs_Reporters_Jurisdictions\" WHERE \"legal_affairs_reporter_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Legal_Affairs_Reporters_Jurisdictions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLegal_Affairs_Reporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Legal_Affairs_Reporters/{legal_affairs_reporter_id}" ; rr:termType rr:IRI ] ] .

