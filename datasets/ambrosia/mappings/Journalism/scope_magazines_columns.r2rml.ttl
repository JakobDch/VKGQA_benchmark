@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_magazines_columns_0_Magazines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"publication_date\", \"editor_name\" FROM \"Magazines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{id}" ; rr:class :Magazines ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_date ; rr:objectMap [ rr:column "publication_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:editor_name ; rr:objectMap [ rr:column "editor_name" ] ] .

<#tm_scope_magazines_columns_1_Columns_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"column_name\" FROM \"Columns\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Columns/{id}" ; rr:class :Columns ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:column_name ; rr:objectMap [ rr:column "column_name" ] ] .

