@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_multimedia_journalists_platforms_0_Multimedia_Journalists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Multimedia_Journalists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Multimedia_Journalists/{id}" ; rr:class :Multimedia_Journalists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_multimedia_journalists_platforms_1_Platforms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"platform_name\" FROM \"Platforms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Platforms/{id}" ; rr:class :Platforms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:platform_name ; rr:objectMap [ rr:column "platform_name" ] ] .

<#tm_scope_multimedia_journalists_platforms_2_Multimedia_Journalists_Platforms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"multimedia_journalist_id\", \"platforms_id\" FROM \"Multimedia_Journalists_Platforms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Multimedia_Journalists_Platforms/{multimedia_journalist_id}/{platforms_id}" ; rr:class :Multimedia_Journalists_Platforms ] ;
  rr:predicateObjectMap [ rr:predicate p:multimedia_journalist_id ; rr:objectMap [ rr:column "multimedia_journalist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:platforms_id ; rr:objectMap [ rr:column "platforms_id" ] ] .

<#tm_scope_multimedia_journalists_platforms_3_Multimedia_Journalists_Platforms_platforms_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"multimedia_journalist_id\", \"platforms_id\" FROM \"Multimedia_Journalists_Platforms\" WHERE \"platforms_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Multimedia_Journalists_Platforms/{multimedia_journalist_id}/{platforms_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPlatforms ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Platforms/{platforms_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_multimedia_journalists_platforms_4_Multimedia_Journalists_Platforms_multimedia_journalist_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"multimedia_journalist_id\", \"platforms_id\" FROM \"Multimedia_Journalists_Platforms\" WHERE \"multimedia_journalist_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Multimedia_Journalists_Platforms/{multimedia_journalist_id}/{platforms_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMultimedia_Journalists ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Multimedia_Journalists/{multimedia_journalist_id}" ; rr:termType rr:IRI ] ] .

