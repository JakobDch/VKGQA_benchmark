<#tm_scope_newspapers_columns_8_Newspapers_Columns_newspaper_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"newspaper_id\", \"column_id\" FROM \"Newspapers_Columns\" WHERE \"newspaper_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspapers_Columns/{newspaper_id}/{column_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNewspapers ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspapers/{newspaper_id}" ; rr:termType rr:IRI ] ] .

