@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_newspapers_columns_0_Newspapers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"publication_date\" FROM \"Newspapers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspapers/{id}" ; rr:class :Newspapers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_date ; rr:objectMap [ rr:column "publication_date" ] ] .

<#tm_scope_newspapers_columns_1_Columns_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"column_name\" FROM \"Columns\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Columns/{id}" ; rr:class :Columns ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:column_name ; rr:objectMap [ rr:column "column_name" ] ] .

<#tm_scope_newspapers_columns_2_Writers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\", \"email\" FROM \"Writers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Writers/{id}" ; rr:class :Writers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_newspapers_columns_3_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"content\", \"publish_date\", \"newspaper_id\", \"writer_id\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publish_date ; rr:objectMap [ rr:column "publish_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:newspaper_id ; rr:objectMap [ rr:column "newspaper_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:writer_id ; rr:objectMap [ rr:column "writer_id" ] ] .

<#tm_scope_newspapers_columns_4_Articles_writer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"writer_id\" FROM \"Articles\" WHERE \"writer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWriters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Writers/{writer_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_newspapers_columns_5_Articles_newspaper_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"newspaper_id\" FROM \"Articles\" WHERE \"newspaper_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNewspapers ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspapers/{newspaper_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_newspapers_columns_6_Newspapers_Columns_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"newspaper_id\", \"column_id\" FROM \"Newspapers_Columns\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspapers_Columns/{newspaper_id}/{column_id}" ; rr:class :Newspapers_Columns ] ;
