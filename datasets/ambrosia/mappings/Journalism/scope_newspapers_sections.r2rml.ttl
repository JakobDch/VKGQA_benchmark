  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:article_title ; rr:objectMap [ rr:column "article_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:article_content ; rr:objectMap [ rr:column "article_content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_date ; rr:objectMap [ rr:column "publication_date" ] ] .

