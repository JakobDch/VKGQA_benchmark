<#tm_scope_newspapers_sections_4_Newspaper_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"newspaper_id\", \"author_id\" FROM \"Newspaper_Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspaper_Authors/{_amb_rowid}" ; rr:class :Newspaper_Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:newspaper_id ; rr:objectMap [ rr:column "newspaper_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] .

<#tm_scope_newspapers_sections_5_Newspaper_Authors_author_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"author_id\" FROM \"Newspaper_Authors\" WHERE \"author_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Newspaper_Authors/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{author_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_newspapers_sections_6_Newspaper_Authors_newspaper_id_fk> a rr:TriplesMap ;
