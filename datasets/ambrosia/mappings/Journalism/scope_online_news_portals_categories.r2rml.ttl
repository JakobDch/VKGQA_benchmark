@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_online_news_portals_categories_0_Online_News_Portals_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"website\" FROM \"Online_News_Portals\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Online_News_Portals/{id}" ; rr:class :Online_News_Portals ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:website ; rr:objectMap [ rr:column "website" ] ] .

<#tm_scope_online_news_portals_categories_1_Categories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"category_name\" FROM \"Categories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Category/{id}" ; rr:class :Category ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:category_name ; rr:objectMap [ rr:column "category_name" ] ] .

<#tm_scope_online_news_portals_categories_2_Online_News_Portals_Categories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"online_news_portal_id\", \"category_id\" FROM \"Online_News_Portals_Categories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Online_News_Portals_Categories/{_amb_rowid}" ; rr:class :Online_News_Portals_Categories ] ;
  rr:predicateObjectMap [ rr:predicate p:online_news_portal_id ; rr:objectMap [ rr:column "online_news_portal_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:category_id ; rr:objectMap [ rr:column "category_id" ] ] .

<#tm_scope_online_news_portals_categories_3_Online_News_Portals_Categories_category_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"category_id\" FROM \"Online_News_Portals_Categories\" WHERE \"category_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Online_News_Portals_Categories/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCategory ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Category/{category_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_online_news_portals_categories_4_Online_News_Portals_Categories_online_news_portal_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"online_news_portal_id\" FROM \"Online_News_Portals_Categories\" WHERE \"online_news_portal_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Online_News_Portals_Categories/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOnline_News_Portals ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Online_News_Portals/{online_news_portal_id}" ; rr:termType rr:IRI ] ] .

