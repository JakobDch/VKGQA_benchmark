@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_photographers_subjects_0_Photographers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Photographers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photographers/{id}" ; rr:class :Photographers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_photographers_subjects_1_Subjects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"subject_name\" FROM \"Subjects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Subjects/{id}" ; rr:class :Subjects ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subject_name ; rr:objectMap [ rr:column "subject_name" ] ] .

<#tm_scope_photographers_subjects_2_Photographers_Subjects_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"photographer_id\", \"subject_id\" FROM \"Photographers_Subjects\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photographers_Subjects/{photographer_id}/{subject_id}" ; rr:class :Photographers_Subjects ] ;
  rr:predicateObjectMap [ rr:predicate p:photographer_id ; rr:objectMap [ rr:column "photographer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subject_id ; rr:objectMap [ rr:column "subject_id" ] ] .

<#tm_scope_photographers_subjects_3_Photographers_Subjects_subject_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"photographer_id\", \"subject_id\" FROM \"Photographers_Subjects\" WHERE \"subject_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photographers_Subjects/{photographer_id}/{subject_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubjects ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Subjects/{subject_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_photographers_subjects_4_Photographers_Subjects_photographer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"photographer_id\", \"subject_id\" FROM \"Photographers_Subjects\" WHERE \"photographer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photographers_Subjects/{photographer_id}/{subject_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPhotographers ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photographers/{photographer_id}" ; rr:termType rr:IRI ] ] .

