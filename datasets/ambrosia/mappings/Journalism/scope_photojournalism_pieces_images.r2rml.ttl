@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_photojournalism_pieces_images_0_Photojournalism_Pieces_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"date\" FROM \"Photojournalism_Pieces\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalism_Pieces/{id}" ; rr:class :Photojournalism_Pieces ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] .

<#tm_scope_photojournalism_pieces_images_1_Images_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"image_name\", \"description\" FROM \"Images\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Images/{id}" ; rr:class :Images ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:image_name ; rr:objectMap [ rr:column "image_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_photojournalism_pieces_images_2_Photojournalism_Pieces_Images_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"photojournalism_piece_id\", \"image_id\" FROM \"Photojournalism_Pieces_Images\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalism_Pieces_Images/{_amb_rowid}" ; rr:class :Photojournalism_Pieces_Images ] ;
  rr:predicateObjectMap [ rr:predicate p:photojournalism_piece_id ; rr:objectMap [ rr:column "photojournalism_piece_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:image_id ; rr:objectMap [ rr:column "image_id" ] ] .

<#tm_scope_photojournalism_pieces_images_3_Photojournalism_Pieces_Images_image_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"image_id\" FROM \"Photojournalism_Pieces_Images\" WHERE \"image_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalism_Pieces_Images/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasImages ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Images/{image_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_photojournalism_pieces_images_4_Photojournalism_Pieces_Images_photojournalism_piece_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"photojournalism_piece_id\" FROM \"Photojournalism_Pieces_Images\" WHERE \"photojournalism_piece_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalism_Pieces_Images/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPhotojournalism_Pieces ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalism_Pieces/{photojournalism_piece_id}" ; rr:termType rr:IRI ] ] .

