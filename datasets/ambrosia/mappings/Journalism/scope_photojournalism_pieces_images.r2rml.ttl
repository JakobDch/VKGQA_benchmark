  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"photojournalism_piece_id\", \"photographer_id\" FROM \"Photojournalism_Pieces_Photographer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalism_Pieces_Photographer/{_amb_rowid}" ; rr:class :Photojournalism_Pieces_Photographer ] ;
