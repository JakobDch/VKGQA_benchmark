  rr:predicateObjectMap [ rr:predicate p:hasPhotographers ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photographers/{photographer_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_photojournalism_pieces_images_8_Photojournalism_Pieces_Photographer_photojournalism_piece_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"photojournalism_piece_id\" FROM \"Photojournalism_Pieces_Photographer\" WHERE \"photojournalism_piece_id\" IS NOT NULL""" ] ;
