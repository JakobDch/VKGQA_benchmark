@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_photojournalists_equipment_0_Photojournalists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Photojournalists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalists/{id}" ; rr:class :Photojournalists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_photojournalists_equipment_1_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"equipment_id\", \"type\" FROM \"Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Equipment/{equipment_id}" ; rr:class :Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:equipment_id ; rr:objectMap [ rr:column "equipment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_scope_photojournalists_equipment_2_Photojournalist_Equipment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"photojournalist_id\", \"equipment_id\" FROM \"Photojournalist_Equipment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalist_Equipment/{photojournalist_id}/{equipment_id}" ; rr:class :Photojournalist_Equipment ] ;
  rr:predicateObjectMap [ rr:predicate p:photojournalist_id ; rr:objectMap [ rr:column "photojournalist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:equipment_id ; rr:objectMap [ rr:column "equipment_id" ] ] .

<#tm_scope_photojournalists_equipment_3_Photojournalist_Equipment_equipment_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"photojournalist_id\", \"equipment_id\" FROM \"Photojournalist_Equipment\" WHERE \"equipment_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalist_Equipment/{photojournalist_id}/{equipment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEquipment ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Equipment/{equipment_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_photojournalists_equipment_4_Photojournalist_Equipment_photojournalist_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"photojournalist_id\", \"equipment_id\" FROM \"Photojournalist_Equipment\" WHERE \"photojournalist_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalist_Equipment/{photojournalist_id}/{equipment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPhotojournalists ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalists/{photojournalist_id}" ; rr:termType rr:IRI ] ] .

