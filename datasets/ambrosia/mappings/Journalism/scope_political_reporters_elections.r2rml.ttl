@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_political_reporters_elections_0_Political_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Political_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Political_Reporters/{id}" ; rr:class :Political_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_political_reporters_elections_1_Elections_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"election_type\", \"start_date\", \"end_date\" FROM \"Elections\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Elections/{id}" ; rr:class :Elections ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:election_type ; rr:objectMap [ rr:column "election_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] .

<#tm_scope_political_reporters_elections_2_Political_Reporters_Elections_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"reporter_id\", \"election_id\" FROM \"Political_Reporters_Elections\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Political_Reporters_Elections/{_amb_rowid}" ; rr:class :Political_Reporters_Elections ] ;
  rr:predicateObjectMap [ rr:predicate p:reporter_id ; rr:objectMap [ rr:column "reporter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:election_id ; rr:objectMap [ rr:column "election_id" ] ] .

<#tm_scope_political_reporters_elections_3_Political_Reporters_Elections_election_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"election_id\" FROM \"Political_Reporters_Elections\" WHERE \"election_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Political_Reporters_Elections/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasElections ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Elections/{election_id}" ; rr:termType rr:IRI ] ] .

