@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_press_conferences_participants_0_Press_Conferences_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"date\" FROM \"Press_Conferences\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Press_Conferences/{id}" ; rr:class :Press_Conferences ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] .

<#tm_scope_press_conferences_participants_1_Participants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"role\", \"name\" FROM \"Participants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Participants/{id}" ; rr:class :Participants ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role ; rr:objectMap [ rr:column "role" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_press_conferences_participants_2_Press_Conferences_Participants_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"press_conference_id\", \"participant_id\" FROM \"Press_Conferences_Participants\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Press_Conferences_Participants/{_amb_rowid}" ; rr:class :Press_Conferences_Participants ] ;
  rr:predicateObjectMap [ rr:predicate p:press_conference_id ; rr:objectMap [ rr:column "press_conference_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:participant_id ; rr:objectMap [ rr:column "participant_id" ] ] .

<#tm_scope_press_conferences_participants_3_Press_Conferences_Participants_participant_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"participant_id\" FROM \"Press_Conferences_Participants\" WHERE \"participant_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Press_Conferences_Participants/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasParticipants ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Participants/{participant_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_press_conferences_participants_4_Press_Conferences_Participants_press_conference_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"press_conference_id\" FROM \"Press_Conferences_Participants\" WHERE \"press_conference_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Press_Conferences_Participants/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPress_Conferences ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Press_Conferences/{press_conference_id}" ; rr:termType rr:IRI ] ] .

