@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_radio_stations_programs_0_Radio_Stations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"stationName\", \"location\" FROM \"Radio_Stations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Radio_Stations/{id}" ; rr:class :Radio_Stations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:stationName ; rr:objectMap [ rr:column "stationName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_radio_stations_programs_1_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"programType\" FROM \"Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Programs/{id}" ; rr:class :Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:programType ; rr:objectMap [ rr:column "programType" ] ] .

<#tm_scope_radio_stations_programs_2_Radio_Stations_Programs_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"radioStationId\", \"programId\" FROM \"Radio_Stations_Programs\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Radio_Stations_Programs/{_amb_rowid}" ; rr:class :Radio_Stations_Programs ] ;
  rr:predicateObjectMap [ rr:predicate p:radioStationId ; rr:objectMap [ rr:column "radioStationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:programId ; rr:objectMap [ rr:column "programId" ] ] .

<#tm_scope_radio_stations_programs_3_Radio_Stations_Programs_programId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"programId\" FROM \"Radio_Stations_Programs\" WHERE \"programId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Radio_Stations_Programs/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPrograms ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Programs/{programId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_radio_stations_programs_4_Radio_Stations_Programs_radioStationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"radioStationId\" FROM \"Radio_Stations_Programs\" WHERE \"radioStationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Radio_Stations_Programs/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRadio_Stations ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Radio_Stations/{radioStationId}" ; rr:termType rr:IRI ] ] .

