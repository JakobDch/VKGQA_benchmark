@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_real_estate_reporters_markets_0_Real_Estate_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Real_Estate_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Real_Estate_Reporters/{id}" ; rr:class :Real_Estate_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_real_estate_reporters_markets_1_Markets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"market_name\", \"description\" FROM \"Markets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Markets/{id}" ; rr:class :Markets ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:market_name ; rr:objectMap [ rr:column "market_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_real_estate_reporters_markets_2_Real_Estate_Reporters_Markets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"reporter_id\", \"market_id\" FROM \"Real_Estate_Reporters_Markets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Real_Estate_Reporters_Markets/{_amb_rowid}" ; rr:class :Real_Estate_Reporters_Markets ] ;
  rr:predicateObjectMap [ rr:predicate p:reporter_id ; rr:objectMap [ rr:column "reporter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:market_id ; rr:objectMap [ rr:column "market_id" ] ] .

<#tm_scope_real_estate_reporters_markets_3_Real_Estate_Reporters_Markets_market_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"market_id\" FROM \"Real_Estate_Reporters_Markets\" WHERE \"market_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Real_Estate_Reporters_Markets/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMarkets ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Markets/{market_id}" ; rr:termType rr:IRI ] ] .

