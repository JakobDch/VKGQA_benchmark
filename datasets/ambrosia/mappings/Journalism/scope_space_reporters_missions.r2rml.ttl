@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_space_reporters_missions_0_Space_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reporter_id\", \"full_name\" FROM \"Space_Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Space_Reporters/{reporter_id}" ; rr:class :Space_Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:reporter_id ; rr:objectMap [ rr:column "reporter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "full_name" ] ] .

<#tm_scope_space_reporters_missions_1_Missions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"mission_id\", \"mission_name\" FROM \"Missions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Missions/{mission_id}" ; rr:class :Missions ] ;
  rr:predicateObjectMap [ rr:predicate p:mission_id ; rr:objectMap [ rr:column "mission_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:mission_name ; rr:objectMap [ rr:column "mission_name" ] ] .

<#tm_scope_space_reporters_missions_2_Space_Reporters_Missions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"space_reporter_id\", \"mission_id\", \"assignment_date\" FROM \"Space_Reporters_Missions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Space_Reporters_Missions/{_amb_rowid}" ; rr:class :Space_Reporters_Missions ] ;
  rr:predicateObjectMap [ rr:predicate p:space_reporter_id ; rr:objectMap [ rr:column "space_reporter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:mission_id ; rr:objectMap [ rr:column "mission_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:assignment_date ; rr:objectMap [ rr:column "assignment_date" ] ] .

<#tm_scope_space_reporters_missions_3_Space_Reporters_Missions_mission_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"mission_id\" FROM \"Space_Reporters_Missions\" WHERE \"mission_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Space_Reporters_Missions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMissions ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Missions/{mission_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_space_reporters_missions_4_Space_Reporters_Missions_space_reporter_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"space_reporter_id\" FROM \"Space_Reporters_Missions\" WHERE \"space_reporter_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Space_Reporters_Missions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSpace_Reporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Space_Reporters/{space_reporter_id}" ; rr:termType rr:IRI ] ] .

