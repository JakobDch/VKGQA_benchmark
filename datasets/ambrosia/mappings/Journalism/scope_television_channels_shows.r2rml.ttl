@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_television_channels_shows_0_Television_Channels_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"channel_name\", \"country\" FROM \"Television_Channels\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Television_Channels/{id}" ; rr:class :Television_Channels ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:channel_name ; rr:objectMap [ rr:column "channel_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] .

<#tm_scope_television_channels_shows_1_Shows_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"show_title\", \"genre\" FROM \"Shows\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Shows/{id}" ; rr:class :Shows ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:show_title ; rr:objectMap [ rr:column "show_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] .

<#tm_scope_television_channels_shows_2_Television_Channels_Shows_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"television_channels_id\", \"shows_id\" FROM \"Television_Channels_Shows\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Television_Channels_Shows/{_amb_rowid}" ; rr:class :Television_Channels_Shows ] ;
  rr:predicateObjectMap [ rr:predicate p:television_channels_id ; rr:objectMap [ rr:column "television_channels_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:shows_id ; rr:objectMap [ rr:column "shows_id" ] ] .

<#tm_scope_television_channels_shows_3_Television_Channels_Shows_shows_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"shows_id\" FROM \"Television_Channels_Shows\" WHERE \"shows_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Television_Channels_Shows/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasShows ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Shows/{shows_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_television_channels_shows_4_Television_Channels_Shows_television_channels_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"television_channels_id\" FROM \"Television_Channels_Shows\" WHERE \"television_channels_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Television_Channels_Shows/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTelevision_Channels ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Television_Channels/{television_channels_id}" ; rr:termType rr:IRI ] ] .

