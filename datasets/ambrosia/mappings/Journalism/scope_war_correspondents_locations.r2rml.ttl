@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_war_correspondents_locations_0_War_Correspondents_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"organization\" FROM \"War_Correspondents\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/War_Correspondents/{id}" ; rr:class :War_Correspondents ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:organization ; rr:objectMap [ rr:column "organization" ] ] .

<#tm_scope_war_correspondents_locations_1_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"locationName\" FROM \"Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Locations/{id}" ; rr:class :Locations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationName ; rr:objectMap [ rr:column "locationName" ] ] .

<#tm_scope_war_correspondents_locations_2_War_Correspondents_Locations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"warCorrespondentId\", \"locationId\", \"assignmentDate\" FROM \"War_Correspondents_Locations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/War_Correspondents_Locations/{_amb_rowid}" ; rr:class :War_Correspondents_Locations ] ;
  rr:predicateObjectMap [ rr:predicate p:warCorrespondentId ; rr:objectMap [ rr:column "warCorrespondentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:locationId ; rr:objectMap [ rr:column "locationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:assignmentDate ; rr:objectMap [ rr:column "assignmentDate" ] ] .

<#tm_scope_war_correspondents_locations_3_War_Correspondents_Locations_locationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"locationId\" FROM \"War_Correspondents_Locations\" WHERE \"locationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/War_Correspondents_Locations/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasLocations ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Locations/{locationId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_war_correspondents_locations_4_War_Correspondents_Locations_warCorrespondentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"warCorrespondentId\" FROM \"War_Correspondents_Locations\" WHERE \"warCorrespondentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/War_Correspondents_Locations/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWar_Correspondents ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/War_Correspondents/{warCorrespondentId}" ; rr:termType rr:IRI ] ] .

