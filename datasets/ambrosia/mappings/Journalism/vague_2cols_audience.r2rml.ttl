<#tm_vague_2cols_audience_5_MagazineArticles_magazineID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"magazineArticleID\", \"magazineID\" FROM \"MagazineArticles\" WHERE \"magazineID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/MagazineArticles/{magazineArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMagazines ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{magazineID}" ; rr:termType rr:IRI ] ] .

