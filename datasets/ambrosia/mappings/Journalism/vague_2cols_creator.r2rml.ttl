@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_creator_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorID\", \"FirstName\", \"LastName\", \"EmailAddress\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "EmailAddress" ] ] .

<#tm_vague_2cols_creator_1_Publishers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"PublisherID\", \"Name\", \"Address\" FROM \"Publishers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publishers/{PublisherID}" ; rr:class :Publishers ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] .

<#tm_vague_2cols_creator_2_Magazines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MagazineID\", \"Title\", \"YearEstablished\", \"PublisherId\" FROM \"Magazines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{MagazineID}" ; rr:class :Magazines ] ;
  rr:predicateObjectMap [ rr:predicate p:MagazineID ; rr:objectMap [ rr:column "MagazineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearEstablished ; rr:objectMap [ rr:column "YearEstablished" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherId ; rr:objectMap [ rr:column "PublisherId" ] ] .

<#tm_vague_2cols_creator_3_Magazines_PublisherId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MagazineID\", \"PublisherId\" FROM \"Magazines\" WHERE \"PublisherId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{MagazineID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublishers ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publishers/{PublisherId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_creator_4_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"Title\", \"PublicationDate\", \"WordCount\", \"MagazineId\", \"AuthorId\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationDate ; rr:objectMap [ rr:column "PublicationDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:WordCount ; rr:objectMap [ rr:column "WordCount" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MagazineId ; rr:objectMap [ rr:column "MagazineId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorId ; rr:objectMap [ rr:column "AuthorId" ] ] .

<#tm_vague_2cols_creator_5_Articles_AuthorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"AuthorId\" FROM \"Articles\" WHERE \"AuthorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_creator_6_Articles_MagazineId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"MagazineId\" FROM \"Articles\" WHERE \"MagazineId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMagazines ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{MagazineId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_creator_7_Documentaries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DocumentaryId\", \"Title\", \"ReleaseYear\", \"Producer\", \"Director\", \"LengthInMinutes\", \"MagazineId\" FROM \"Documentaries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Documentary/{DocumentaryId}" ; rr:class :Documentary ] ;
  rr:predicateObjectMap [ rr:predicate p:DocumentaryId ; rr:objectMap [ rr:column "DocumentaryId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReleaseYear ; rr:objectMap [ rr:column "ReleaseYear" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Producer ; rr:objectMap [ rr:column "Producer" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Director ; rr:objectMap [ rr:column "Director" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LengthInMinutes ; rr:objectMap [ rr:column "LengthInMinutes" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MagazineId ; rr:objectMap [ rr:column "MagazineId" ] ] .

<#tm_vague_2cols_creator_8_Documentaries_MagazineId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DocumentaryId\", \"MagazineId\" FROM \"Documentaries\" WHERE \"MagazineId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Documentary/{DocumentaryId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMagazines ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{MagazineId}" ; rr:termType rr:IRI ] ] .

