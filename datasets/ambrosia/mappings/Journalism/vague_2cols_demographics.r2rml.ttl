<#tm_vague_2cols_demographics_9_Advertisements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AdvID\", \"Description\", \"Budget\", \"StartDate\", \"EndDate\", \"OutletID\" FROM \"Advertisements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Advertisements/{AdvID}" ; rr:class :Advertisements ] ;
