<#tm_vague_2cols_duration_5_Subscriptions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SubscriptionID\", \"ReaderID\", \"PublisherID\", \"StartDate\", \"EndDate\", \"Price\" FROM \"Subscriptions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Subscriptions/{SubscriptionID}" ; rr:class :Subscriptions ] ;
  rr:predicateObjectMap [ rr:predicate p:SubscriptionID ; rr:objectMap [ rr:column "SubscriptionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReaderID ; rr:objectMap [ rr:column "ReaderID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublisherID ; rr:objectMap [ rr:column "PublisherID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Price ; rr:objectMap [ rr:column "Price" ] ] .

<#tm_vague_2cols_duration_6_Subscriptions_PublisherID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SubscriptionID\", \"PublisherID\" FROM \"Subscriptions\" WHERE \"PublisherID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Subscriptions/{SubscriptionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublications ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{PublisherID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_duration_7_Subscriptions_ReaderID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SubscriptionID\", \"ReaderID\" FROM \"Subscriptions\" WHERE \"ReaderID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Subscriptions/{SubscriptionID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReaders ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Readers/{ReaderID}" ; rr:termType rr:IRI ] ] .

