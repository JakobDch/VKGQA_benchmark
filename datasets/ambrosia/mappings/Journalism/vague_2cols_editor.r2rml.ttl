@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_editor_0_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AuthorID\", \"FirstName\", \"LastName\", \"Email\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{AuthorID}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

<#tm_vague_2cols_editor_1_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"Title\", \"Content\", \"PublishDate\", \"Managing_Editor\", \"Copy_Editor\", \"Final_Draft\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublishDate ; rr:objectMap [ rr:column "PublishDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Managing_Editor ; rr:objectMap [ rr:column "Managing_Editor" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Copy_Editor ; rr:objectMap [ rr:column "Copy_Editor" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Final_Draft ; rr:objectMap [ rr:column "Final_Draft" ] ] .

<#tm_vague_2cols_editor_2_Readers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReaderID\", \"Name\", \"SubscriptionDate\", \"PreferredEmail\" FROM \"Readers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Readers/{ReaderID}" ; rr:class :Readers ] ;
  rr:predicateObjectMap [ rr:predicate p:ReaderID ; rr:objectMap [ rr:column "ReaderID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SubscriptionDate ; rr:objectMap [ rr:column "SubscriptionDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PreferredEmail ; rr:objectMap [ rr:column "PreferredEmail" ] ] .

<#tm_vague_2cols_editor_3_Comments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CommentID\", \"ArticleID\", \"ReaderID\", \"CommentText\", \"Rating\" FROM \"Comments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Comments/{CommentID}" ; rr:class :Comments ] ;
  rr:predicateObjectMap [ rr:predicate p:CommentID ; rr:objectMap [ rr:column "CommentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReaderID ; rr:objectMap [ rr:column "ReaderID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CommentText ; rr:objectMap [ rr:column "CommentText" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Rating ; rr:objectMap [ rr:column "Rating" ] ] .

<#tm_vague_2cols_editor_4_Comments_ReaderID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CommentID\", \"ReaderID\" FROM \"Comments\" WHERE \"ReaderID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Comments/{CommentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReaders ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Readers/{ReaderID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_editor_5_Comments_ArticleID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CommentID\", \"ArticleID\" FROM \"Comments\" WHERE \"ArticleID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Comments/{CommentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:termType rr:IRI ] ] .

