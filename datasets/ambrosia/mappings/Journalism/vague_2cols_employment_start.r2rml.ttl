@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_employment_start_0_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"Name\", \"Email\", \"PhoneNumber\", \"Start_Year\", \"Start_Month\", \"ReporterName\" FROM \"Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Reporters/{ID}" ; rr:class :Reporters ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhoneNumber ; rr:objectMap [ rr:column "PhoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Start_Year ; rr:objectMap [ rr:column "Start_Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Start_Month ; rr:objectMap [ rr:column "Start_Month" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ReporterName ; rr:objectMap [ rr:column "ReporterName" ] ] .

<#tm_vague_2cols_employment_start_1_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"Title\", \"Content\", \"PublicationDate\", \"AuthorID\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:ArticleID ; rr:objectMap [ rr:column "ArticleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublicationDate ; rr:objectMap [ rr:column "PublicationDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AuthorID ; rr:objectMap [ rr:column "AuthorID" ] ] .

<#tm_vague_2cols_employment_start_2_Articles_AuthorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ArticleID\", \"AuthorID\" FROM \"Articles\" WHERE \"AuthorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{ArticleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Reporters/{AuthorID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_employment_start_3_Sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"SourceId\", \"Name\", \"ContactInfo\", \"LastContacted\" FROM \"Sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{SourceId}" ; rr:class :Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:SourceId ; rr:objectMap [ rr:column "SourceId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ContactInfo ; rr:objectMap [ rr:column "ContactInfo" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastContacted ; rr:objectMap [ rr:column "LastContacted" ] ] .

<#tm_vague_2cols_employment_start_4_Interviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InterviewID\", \"Date\", \"SourceId\", \"Notes\" FROM \"Interviews\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Interviews/{InterviewID}" ; rr:class :Interviews ] ;
  rr:predicateObjectMap [ rr:predicate p:InterviewID ; rr:objectMap [ rr:column "InterviewID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:SourceId ; rr:objectMap [ rr:column "SourceId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Notes ; rr:objectMap [ rr:column "Notes" ] ] .

<#tm_vague_2cols_employment_start_5_Interviews_SourceId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"InterviewID\", \"SourceId\" FROM \"Interviews\" WHERE \"SourceId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Interviews/{InterviewID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSources ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{SourceId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_employment_start_6_Magazines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MagazineId\", \"Name\", \"EditorInChiefID\" FROM \"Magazines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{MagazineId}" ; rr:class :Magazines ] ;
  rr:predicateObjectMap [ rr:predicate p:MagazineId ; rr:objectMap [ rr:column "MagazineId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EditorInChiefID ; rr:objectMap [ rr:column "EditorInChiefID" ] ] .

<#tm_vague_2cols_employment_start_7_Magazines_EditorInChiefID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"MagazineId\", \"EditorInChiefID\" FROM \"Magazines\" WHERE \"EditorInChiefID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{MagazineId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Reporters/{EditorInChiefID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_employment_start_8_Stories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StoryId\", \"Headline\", \"Content\", \"PublishDate\", \"AssignedToReporterID\", \"MagazineId\" FROM \"Stories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Stories/{StoryId}" ; rr:class :Stories ] ;
  rr:predicateObjectMap [ rr:predicate p:StoryId ; rr:objectMap [ rr:column "StoryId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Headline ; rr:objectMap [ rr:column "Headline" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Content ; rr:objectMap [ rr:column "Content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PublishDate ; rr:objectMap [ rr:column "PublishDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:AssignedToReporterID ; rr:objectMap [ rr:column "AssignedToReporterID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MagazineId ; rr:objectMap [ rr:column "MagazineId" ] ] .

<#tm_vague_2cols_employment_start_9_Stories_MagazineId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StoryId\", \"MagazineId\" FROM \"Stories\" WHERE \"MagazineId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Stories/{StoryId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMagazines ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{MagazineId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_employment_start_10_Stories_AssignedToReporterID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StoryId\", \"AssignedToReporterID\" FROM \"Stories\" WHERE \"AssignedToReporterID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Stories/{StoryId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Reporters/{AssignedToReporterID}" ; rr:termType rr:IRI ] ] .

