@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_origin_0_Photojournalists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Name\", \"Birthdate\" FROM \"Photojournalists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalists/{id}" ; rr:class :Photojournalists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Birthdate ; rr:objectMap [ rr:column "Birthdate" ] ] .

<#tm_vague_2cols_origin_1_Events_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Location\", \"Date\" FROM \"Events\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Events/{id}" ; rr:class :Events ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] .

<#tm_vague_2cols_origin_2_Photos_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"FilePath\", \"Caption\", \"TakenOn\" FROM \"Photos\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/photos/{id}" ; rr:class :photos ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FilePath ; rr:objectMap [ rr:column "FilePath" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Caption ; rr:objectMap [ rr:column "Caption" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TakenOn ; rr:objectMap [ rr:column "TakenOn" ] ] .

<#tm_vague_2cols_origin_3_Assignments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"EventId\", \"PhotojournalistId\" FROM \"Assignments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Assignments/{id}" ; rr:class :Assignments ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EventId ; rr:objectMap [ rr:column "EventId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PhotojournalistId ; rr:objectMap [ rr:column "PhotojournalistId" ] ] .

<#tm_vague_2cols_origin_4_Assignments_PhotojournalistId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"PhotojournalistId\" FROM \"Assignments\" WHERE \"PhotojournalistId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Assignments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPhotojournalists ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Photojournalists/{PhotojournalistId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_origin_5_Assignments_EventId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"EventId\" FROM \"Assignments\" WHERE \"EventId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Assignments/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEvents ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Events/{EventId}" ; rr:termType rr:IRI ] ] .

