<#tm_vague_2cols_origin_8_PublishedPhotos_AssignmentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"AssignmentId\" FROM \"PublishedPhotos\" WHERE \"AssignmentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/PublishedPhotos/{id}" ] ;
