@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_qualification_0_journalists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\", \"phoneNumber\", \"Degree\", \"Certificate\", \"Investigative_Journalist\" FROM \"journalists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalists/{id}" ; rr:class :Journalists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phoneNumber ; rr:objectMap [ rr:column "phoneNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Degree ; rr:objectMap [ rr:column "Degree" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Certificate ; rr:objectMap [ rr:column "Certificate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Investigative_Journalist ; rr:objectMap [ rr:column "Investigative_Journalist" ] ] .

<#tm_vague_2cols_qualification_1_articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"content\", \"publishDate\", \"authorId\", \"publicationId\", \"topicId\" FROM \"articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publishDate ; rr:objectMap [ rr:column "publishDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:authorId ; rr:objectMap [ rr:column "authorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publicationId ; rr:objectMap [ rr:column "publicationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:topicId ; rr:objectMap [ rr:column "topicId" ] ] .

<#tm_vague_2cols_qualification_2_articles_topicId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"topicId\" FROM \"articles\" WHERE \"topicId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hastopics ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/topics/{topicId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_qualification_3_articles_publicationId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"publicationId\" FROM \"articles\" WHERE \"publicationId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPublications ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{publicationId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_qualification_4_articles_authorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"authorId\" FROM \"articles\" WHERE \"authorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJournalists ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalists/{authorId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_qualification_5_publications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\" FROM \"publications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Publications/{id}" ; rr:class :Publications ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_vague_2cols_qualification_6_sources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"contactInfo\" FROM \"sources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{id}" ; rr:class :Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contactInfo ; rr:objectMap [ rr:column "contactInfo" ] ] .

<#tm_vague_2cols_qualification_7_topics_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"description\" FROM \"topics\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/topics/{id}" ; rr:class :topics ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

