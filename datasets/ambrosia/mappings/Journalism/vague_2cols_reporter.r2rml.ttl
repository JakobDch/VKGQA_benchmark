@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_reporter_0_journalists_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\", \"phone\" FROM \"journalists\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalists/{id}" ; rr:class :Journalists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:phone ; rr:objectMap [ rr:column "phone" ] ] .

<#tm_vague_2cols_reporter_1_news_agencies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\", \"contact_email\" FROM \"news_agencies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/News_Agency/{id}" ; rr:class :News_Agency ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contact_email ; rr:objectMap [ rr:column "contact_email" ] ] .

<#tm_vague_2cols_reporter_2_stories_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"content\", \"publish_date\", \"journalist_id\", \"news_agency_id\" FROM \"stories\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Stories/{id}" ; rr:class :Stories ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publish_date ; rr:objectMap [ rr:column "publish_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:journalist_id ; rr:objectMap [ rr:column "journalist_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:news_agency_id ; rr:objectMap [ rr:column "news_agency_id" ] ] .

<#tm_vague_2cols_reporter_3_stories_news_agency_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"news_agency_id\" FROM \"stories\" WHERE \"news_agency_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Stories/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNews_Agency ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/News_Agency/{news_agency_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_reporter_4_stories_journalist_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"journalist_id\" FROM \"stories\" WHERE \"journalist_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Stories/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJournalists ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalists/{journalist_id}" ; rr:termType rr:IRI ] ] .

