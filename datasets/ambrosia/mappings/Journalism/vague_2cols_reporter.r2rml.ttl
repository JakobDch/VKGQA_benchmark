  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"journalist_id\" FROM \"assigned_stories\" WHERE \"journalist_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/assigned_stories/{id}" ] ;
