<#tm_vague_2cols_timeframe_8_ReportersAttending_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReporterAttendeeID\", \"ReporterID\", \"ConferenceID\" FROM \"ReportersAttending\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/ReportersAttending/{ReporterAttendeeID}" ; rr:class :ReportersAttending ] ;
