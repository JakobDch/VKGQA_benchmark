  rr:predicateObjectMap [ rr:predicate p:ConferenceID ; rr:objectMap [ rr:column "ConferenceID" ] ] .

<#tm_vague_2cols_timeframe_9_ReportersAttending_ConferenceID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ReporterAttendeeID\", \"ConferenceID\" FROM \"ReportersAttending\" WHERE \"ConferenceID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/ReportersAttending/{ReporterAttendeeID}" ] ;
