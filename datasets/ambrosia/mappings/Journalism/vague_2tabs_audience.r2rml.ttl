  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:magazine_id ; rr:objectMap [ rr:column "magazine_id" ] ] .

<#tm_vague_2tabs_audience_6_Articles_magazine_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_id\", \"magazine_id\" FROM \"Articles\" WHERE \"magazine_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{article_id}" ] ;
