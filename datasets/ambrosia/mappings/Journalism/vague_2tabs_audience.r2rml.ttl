@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_audience_0_Demographic_Groups_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"group_name\", \"population\" FROM \"Demographic_Groups\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Demographic_Groups/{id}" ; rr:class :Demographic_Groups ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:group_name ; rr:objectMap [ rr:column "group_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:population ; rr:objectMap [ rr:column "population" ] ] .

<#tm_vague_2tabs_audience_1_Professional_Fields_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"field_id\", \"field_name\" FROM \"Professional_Fields\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Professional_Fields/{field_id}" ; rr:class :Professional_Fields ] ;
  rr:predicateObjectMap [ rr:predicate p:field_id ; rr:objectMap [ rr:column "field_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:field_name ; rr:objectMap [ rr:column "field_name" ] ] .

<#tm_vague_2tabs_audience_2_Magazines_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"magazine_id\", \"title\", \"publication_date\", \"demographic_group_id\", \"professional_field_id\" FROM \"Magazines\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{magazine_id}" ; rr:class :Magazines ] ;
  rr:predicateObjectMap [ rr:predicate p:magazine_id ; rr:objectMap [ rr:column "magazine_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publication_date ; rr:objectMap [ rr:column "publication_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:demographic_group_id ; rr:objectMap [ rr:column "demographic_group_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:professional_field_id ; rr:objectMap [ rr:column "professional_field_id" ] ] .

<#tm_vague_2tabs_audience_3_Magazines_professional_field_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"magazine_id\", \"professional_field_id\" FROM \"Magazines\" WHERE \"professional_field_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Magazines/{magazine_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProfessional_Fields ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Professional_Fields/{professional_field_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_audience_4_Magazines_demographic_group_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"magazine_id\", \"demographic_group_id\" FROM \"Magazines\" WHERE \"demographic_group_id\" IS NOT NULL""" ] ;
