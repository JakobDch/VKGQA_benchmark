@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_consulted_sources_0_Experts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"specialty\" FROM \"Experts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Experts/{id}" ; rr:class :Experts ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:specialty ; rr:objectMap [ rr:column "specialty" ] ] .

<#tm_vague_2tabs_consulted_sources_1_Archival_Footage_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"description\", \"source\", \"EXPERT_ID\" FROM \"Archival_Footage\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Archival_Footage/{id}" ; rr:class :Archival_Footage ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:source ; rr:objectMap [ rr:column "source" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EXPERT_ID ; rr:objectMap [ rr:column "EXPERT_ID" ] ] .

<#tm_vague_2tabs_consulted_sources_2_Archival_Footage_EXPERT_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"EXPERT_ID\" FROM \"Archival_Footage\" WHERE \"EXPERT_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Archival_Footage/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasExperts ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Experts/{EXPERT_ID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_consulted_sources_3_Documentary_base> a rr:TriplesMap ;
