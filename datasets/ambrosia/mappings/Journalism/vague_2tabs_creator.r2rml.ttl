  rr:predicateObjectMap [ rr:predicate p:documentary_id ; rr:objectMap [ rr:column "documentary_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:role ; rr:objectMap [ rr:column "role" ] ] .

<#tm_vague_2tabs_creator_8_Journalist_documentary_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"documentary_id\" FROM \"Journalist\" WHERE \"documentary_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalists/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDocumentary ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Documentary/{documentary_id}" ; rr:termType rr:IRI ] ] .

