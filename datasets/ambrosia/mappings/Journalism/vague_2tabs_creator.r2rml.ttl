<#tm_vague_2tabs_creator_3_Documentary_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_year\", \"producer_id\", \"director_id\", \"category_id\" FROM \"Documentary\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Documentary/{id}" ; rr:class :Documentary ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_year ; rr:objectMap [ rr:column "release_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:producer_id ; rr:objectMap [ rr:column "producer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:director_id ; rr:objectMap [ rr:column "director_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:category_id ; rr:objectMap [ rr:column "category_id" ] ] .

<#tm_vague_2tabs_creator_4_Documentary_category_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"category_id\" FROM \"Documentary\" WHERE \"category_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Documentary/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCategory ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Category/{category_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_creator_5_Documentary_director_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"director_id\" FROM \"Documentary\" WHERE \"director_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Documentary/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDirector ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Director/{director_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_creator_6_Documentary_producer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"producer_id\" FROM \"Documentary\" WHERE \"producer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Documentary/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProducer ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Producer/{producer_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_creator_7_Journalist_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"journalist_name\", \"email\", \"documentary_id\", \"role\" FROM \"Journalist\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalists/{id}" ; rr:class :Journalists ] ;
