<#tm_vague_2tabs_demographics_6_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"content\", \"publish_date\", \"author_id\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publish_date ; rr:objectMap [ rr:column "publish_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] .

<#tm_vague_2tabs_demographics_7_Articles_author_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"author_id\" FROM \"Articles\" WHERE \"author_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{author_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_demographics_8_Article_Readers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_id\", \"reader_id\" FROM \"Article_Readers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Readers/{article_id}/{reader_id}" ; rr:class :Article_Readers ] ;
  rr:predicateObjectMap [ rr:predicate p:article_id ; rr:objectMap [ rr:column "article_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:reader_id ; rr:objectMap [ rr:column "reader_id" ] ] .

<#tm_vague_2tabs_demographics_9_Article_Readers_reader_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_id\", \"reader_id\" FROM \"Article_Readers\" WHERE \"reader_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Readers/{article_id}/{reader_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReaders ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Readers/{reader_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_demographics_10_Article_Readers_article_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"article_id\", \"reader_id\" FROM \"Article_Readers\" WHERE \"article_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Readers/{article_id}/{reader_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{article_id}" ; rr:termType rr:IRI ] ] .

