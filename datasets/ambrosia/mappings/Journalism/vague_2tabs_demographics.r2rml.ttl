@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_demographics_0_Age_Range_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"min_age\", \"max_age\" FROM \"Age_Range\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Age_Range/{id}" ; rr:class :Age_Range ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:min_age ; rr:objectMap [ rr:column "min_age" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:max_age ; rr:objectMap [ rr:column "max_age" ] ] .

<#tm_vague_2tabs_demographics_1_Socioeconomic_Status_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"status\", \"description\" FROM \"Socioeconomic_Status\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Socioeconomic_Status/{id}" ; rr:class :Socioeconomic_Status ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2tabs_demographics_2_Readers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"age_range_id\", \"socioeconomic_status_id\" FROM \"Readers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Readers/{id}" ; rr:class :Readers ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:age_range_id ; rr:objectMap [ rr:column "age_range_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:socioeconomic_status_id ; rr:objectMap [ rr:column "socioeconomic_status_id" ] ] .

<#tm_vague_2tabs_demographics_3_Readers_socioeconomic_status_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"socioeconomic_status_id\" FROM \"Readers\" WHERE \"socioeconomic_status_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Readers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSocioeconomic_Status ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Socioeconomic_Status/{socioeconomic_status_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_demographics_4_Readers_age_range_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"age_range_id\" FROM \"Readers\" WHERE \"age_range_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Readers/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAge_Range ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Age_Range/{age_range_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_demographics_5_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"author_name\", \"bio\" FROM \"Authors\"""" ] ;
