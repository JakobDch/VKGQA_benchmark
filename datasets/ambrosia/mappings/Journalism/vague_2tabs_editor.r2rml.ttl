@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_editor_0_Managing_Editor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Managing_Editor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Managing_Editor/{id}" ; rr:class :Managing_Editor ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_vague_2tabs_editor_1_Copy_Editor_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"email\" FROM \"Copy_Editor\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Copy_Editor/{id}" ; rr:class :Copy_Editor ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_vague_2tabs_editor_2_Final_Draft_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"managing_editor_id\", \"copy_editor_id\" FROM \"Final_Draft\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Final_Draft/{id}" ; rr:class :Final_Draft ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:managing_editor_id ; rr:objectMap [ rr:column "managing_editor_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:copy_editor_id ; rr:objectMap [ rr:column "copy_editor_id" ] ] .

<#tm_vague_2tabs_editor_3_Final_Draft_copy_editor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"copy_editor_id\" FROM \"Final_Draft\" WHERE \"copy_editor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Final_Draft/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCopy_Editor ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Copy_Editor/{copy_editor_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_editor_4_Final_Draft_managing_editor_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"managing_editor_id\" FROM \"Final_Draft\" WHERE \"managing_editor_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Final_Draft/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasManaging_Editor ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Managing_Editor/{managing_editor_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_editor_5_Articles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"content\", \"author_id\", \"reporter_id\", \"final_draft_id\" FROM \"Articles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:reporter_id ; rr:objectMap [ rr:column "reporter_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:final_draft_id ; rr:objectMap [ rr:column "final_draft_id" ] ] .

<#tm_vague_2tabs_editor_6_Articles_final_draft_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"final_draft_id\" FROM \"Articles\" WHERE \"final_draft_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFinal_Draft ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Final_Draft/{final_draft_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_editor_7_Articles_reporter_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"reporter_id\" FROM \"Articles\" WHERE \"reporter_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasReporters ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Reporters/{reporter_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_editor_8_Articles_author_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"author_id\" FROM \"Articles\" WHERE \"author_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAuthors ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{author_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_editor_9_Authors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"author_id\", \"fullname\" FROM \"Authors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Authors/{author_id}" ; rr:class :Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:author_id ; rr:objectMap [ rr:column "author_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "fullname" ] ] .

<#tm_vague_2tabs_editor_10_Reporters_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"reporter_id\", \"fullname\" FROM \"Reporters\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Reporters/{reporter_id}" ; rr:class :Reporters ] ;
