@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_platform_0_Website_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"url\" FROM \"Website\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Website/{id}" ; rr:class :Website ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:url ; rr:objectMap [ rr:column "url" ] ] .

<#tm_vague_2tabs_platform_1_Mobile_App_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Mobile_App\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Mobile_App/{id}" ; rr:class :Mobile_App ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_vague_2tabs_platform_2_News_Agency_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"websiteId\", \"mobileAppId\" FROM \"News_Agency\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/News_Agency/{id}" ; rr:class :News_Agency ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:websiteId ; rr:objectMap [ rr:column "websiteId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:mobileAppId ; rr:objectMap [ rr:column "mobileAppId" ] ] .

<#tm_vague_2tabs_platform_3_News_Agency_mobileAppId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"mobileAppId\" FROM \"News_Agency\" WHERE \"mobileAppId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/News_Agency/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMobile_App ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Mobile_App/{mobileAppId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_platform_4_News_Agency_websiteId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"websiteId\" FROM \"News_Agency\" WHERE \"websiteId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/News_Agency/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWebsite ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Website/{websiteId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_platform_5_Article_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"content\", \"publishedDate\", \"newsAgencyId\" FROM \"Article\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publishedDate ; rr:objectMap [ rr:column "publishedDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:newsAgencyId ; rr:objectMap [ rr:column "newsAgencyId" ] ] .

<#tm_vague_2tabs_platform_6_Article_newsAgencyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"newsAgencyId\" FROM \"Article\" WHERE \"newsAgencyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNews_Agency ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/News_Agency/{newsAgencyId}" ; rr:termType rr:IRI ] ] .

