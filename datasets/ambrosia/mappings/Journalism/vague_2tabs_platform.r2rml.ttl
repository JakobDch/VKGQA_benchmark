<#tm_vague_2tabs_platform_8_AuthorArticle_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"authorId\", \"articleId\" FROM \"AuthorArticle\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Authors/{_amb_rowid}" ; rr:class :Article_Authors ] ;
  rr:predicateObjectMap [ rr:predicate p:authorId ; rr:objectMap [ rr:column "authorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:articleId ; rr:objectMap [ rr:column "articleId" ] ] .

