  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{articleId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_platform_10_AuthorArticle_authorId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"authorId\" FROM \"AuthorArticle\" WHERE \"authorId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Article_Authors/{_amb_rowid}" ] ;
