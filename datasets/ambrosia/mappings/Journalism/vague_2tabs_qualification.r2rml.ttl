@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_qualification_0_Degree_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"degreeID\", \"title\", \"major\" FROM \"Degree\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Degree/{degreeID}" ; rr:class :Degree ] ;
  rr:predicateObjectMap [ rr:predicate p:degreeID ; rr:objectMap [ rr:column "degreeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:major ; rr:objectMap [ rr:column "major" ] ] .

<#tm_vague_2tabs_qualification_1_Certificate_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"certificateID\", \"name\", \"issueDate\" FROM \"Certificate\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Certificate/{certificateID}" ; rr:class :Certificate ] ;
  rr:predicateObjectMap [ rr:predicate p:certificateID ; rr:objectMap [ rr:column "certificateID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:issueDate ; rr:objectMap [ rr:column "issueDate" ] ] .

<#tm_vague_2tabs_qualification_2_Investigative_Journalist_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"journalistID\", \"firstName\", \"lastName\", \"degreeID\", \"certificateID\" FROM \"Investigative_Journalist\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Investigative_Journalist/{journalistID}" ; rr:class :Investigative_Journalist ] ;
  rr:predicateObjectMap [ rr:predicate p:journalistID ; rr:objectMap [ rr:column "journalistID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:degreeID ; rr:objectMap [ rr:column "degreeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:certificateID ; rr:objectMap [ rr:column "certificateID" ] ] .

<#tm_vague_2tabs_qualification_3_Investigative_Journalist_certificateID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"journalistID\", \"certificateID\" FROM \"Investigative_Journalist\" WHERE \"certificateID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Investigative_Journalist/{journalistID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCertificate ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Certificate/{certificateID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_qualification_4_Investigative_Journalist_degreeID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"journalistID\", \"degreeID\" FROM \"Investigative_Journalist\" WHERE \"degreeID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Investigative_Journalist/{journalistID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDegree ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Degree/{degreeID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_qualification_5_Article_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"articleID\", \"headline\", \"content\", \"publishedDate\", \"journalistID\" FROM \"Article\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{articleID}" ; rr:class :Articles ] ;
  rr:predicateObjectMap [ rr:predicate p:articleID ; rr:objectMap [ rr:column "articleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:headline ; rr:objectMap [ rr:column "headline" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publishedDate ; rr:objectMap [ rr:column "publishedDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:journalistID ; rr:objectMap [ rr:column "journalistID" ] ] .

<#tm_vague_2tabs_qualification_6_Article_journalistID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"articleID\", \"journalistID\" FROM \"Article\" WHERE \"journalistID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{articleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasInvestigative_Journalist ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Investigative_Journalist/{journalistID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_qualification_7_Source_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"sourceID\", \"name\", \"type\", \"contactInfo\", \"articleID\" FROM \"Source\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{sourceID}" ; rr:class :Sources ] ;
  rr:predicateObjectMap [ rr:predicate p:sourceID ; rr:objectMap [ rr:column "sourceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:contactInfo ; rr:objectMap [ rr:column "contactInfo" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:articleID ; rr:objectMap [ rr:column "articleID" ] ] .

<#tm_vague_2tabs_qualification_8_Source_articleID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"sourceID\", \"articleID\" FROM \"Source\" WHERE \"articleID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Sources/{sourceID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasArticles ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Articles/{articleID}" ; rr:termType rr:IRI ] ] .

