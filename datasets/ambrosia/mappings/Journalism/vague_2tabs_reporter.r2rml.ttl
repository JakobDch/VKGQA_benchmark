@prefix : <http://ambrosia.example.org/journalism#> .
@prefix p: <http://ambrosia.example.org/journalism/prop#> .
@prefix ex: <http://ambrosia.example.org/journalism/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_reporter_0_Journalist_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"fullname\" FROM \"Journalist\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalists/{id}" ; rr:class :Journalists ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "fullname" ] ] .

<#tm_vague_2tabs_reporter_1_News_Agency_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"News_Agency\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/News_Agency/{id}" ; rr:class :News_Agency ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_vague_2tabs_reporter_2_Story_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"content\", \"publishedDate\", \"journalistId\", \"agencyId\", \"categoryId\" FROM \"Story\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Stories/{id}" ; rr:class :Stories ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content ; rr:objectMap [ rr:column "content" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:publishedDate ; rr:objectMap [ rr:column "publishedDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:journalistId ; rr:objectMap [ rr:column "journalistId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:agencyId ; rr:objectMap [ rr:column "agencyId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:categoryId ; rr:objectMap [ rr:column "categoryId" ] ] .

<#tm_vague_2tabs_reporter_3_Story_categoryId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"categoryId\" FROM \"Story\" WHERE \"categoryId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Stories/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCategory ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Category/{categoryId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_reporter_4_Story_agencyId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"agencyId\" FROM \"Story\" WHERE \"agencyId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Stories/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNews_Agency ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/News_Agency/{agencyId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_reporter_5_Story_journalistId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"journalistId\" FROM \"Story\" WHERE \"journalistId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Stories/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasJournalists ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Journalists/{journalistId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_reporter_6_Category_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Category\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Category/{id}" ; rr:class :Category ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

