  rr:predicateObjectMap [ rr:predicate p:web_framework_id ; rr:objectMap [ rr:column "web_framework_id" ] ] .

<#tm_vague_2tabs_technology_8_Online_News_Platform_web_framework_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"web_framework_id\" FROM \"Online_News_Platform\" WHERE \"web_framework_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Online_News_Platform/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasWeb_Framework ; rr:objectMap [ rr:template "http://ambrosia.example.org/journalism/id/Web_Framework/{web_framework_id}" ; rr:termType rr:IRI ] ] .

