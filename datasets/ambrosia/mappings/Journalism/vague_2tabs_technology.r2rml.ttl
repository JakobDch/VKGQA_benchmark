<#tm_vague_2tabs_technology_7_Online_News_Platform_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"platform_name\", \"url\", \"cms_id\", \"web_framework_id\" FROM \"Online_News_Platform\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/journalism/id/Online_News_Platform/{id}" ; rr:class :Online_News_Platform ] ;
