@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_service_advertisement_0_Streaming_Service_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"platform\" FROM \"Streaming_Service\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:platform ; rr:objectMap [ rr:column "platform" ] ] .

<#tm_scope_streaming_service_advertisement_1_Advertisement_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\", \"duration\" FROM \"Advertisement\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Advertisement/{id}" ; rr:class :Advertisement ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration ; rr:objectMap [ rr:column "duration" ] ] .

<#tm_scope_streaming_service_advertisement_2_Streaming_Service_Advertisement_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\", \"advertisement_id\" FROM \"Streaming_Service_Advertisement\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Advertisement/{_amb_rowid}" ; rr:class :Streaming_Service_Advertisement ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:advertisement_id ; rr:objectMap [ rr:column "advertisement_id" ] ] .

<#tm_scope_streaming_service_advertisement_3_Streaming_Service_Advertisement_advertisement_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"advertisement_id\" FROM \"Streaming_Service_Advertisement\" WHERE \"advertisement_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Advertisement/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAdvertisement ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Advertisement/{advertisement_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_service_advertisement_4_Streaming_Service_Advertisement_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\" FROM \"Streaming_Service_Advertisement\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Advertisement/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_service_id}" ; rr:termType rr:IRI ] ] .

