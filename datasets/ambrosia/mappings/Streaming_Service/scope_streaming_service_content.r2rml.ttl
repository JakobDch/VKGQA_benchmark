@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_service_content_0_Streaming_Service_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"subscription_fee\" FROM \"Streaming_Service\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subscription_fee ; rr:objectMap [ rr:column "subscription_fee" ] ] .

<#tm_scope_streaming_service_content_1_Content_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"content_id\", \"type\", \"description\", \"price\" FROM \"Content\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Content/{content_id}" ; rr:class :Content ] ;
  rr:predicateObjectMap [ rr:predicate p:content_id ; rr:objectMap [ rr:column "content_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_streaming_service_content_2_Streaming_Service_Content_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_service_id\", \"content_id\" FROM \"Streaming_Service_Content\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Content/{streaming_service_id}/{content_id}" ; rr:class :Streaming_Service_Content ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content_id ; rr:objectMap [ rr:column "content_id" ] ] .

<#tm_scope_streaming_service_content_3_Streaming_Service_Content_content_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_service_id\", \"content_id\" FROM \"Streaming_Service_Content\" WHERE \"content_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Content/{streaming_service_id}/{content_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasContent ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Content/{content_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_service_content_4_Streaming_Service_Content_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_service_id\", \"content_id\" FROM \"Streaming_Service_Content\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Content/{streaming_service_id}/{content_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_service_id}" ; rr:termType rr:IRI ] ] .

