<#tm_scope_streaming_service_monetization_model_0_Monetization_Model_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"model_name\" FROM \"Monetization_Model\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Monetization_Model/{id}" ; rr:class :Monetization_Model ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:model_name ; rr:objectMap [ rr:column "model_name" ] ] .

