@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_service_platform_0_Platform_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Platform\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Platforms/{id}" ; rr:class :Platforms ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_streaming_service_platform_1_Streaming_Service_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"service_name\", \"description\" FROM \"Streaming_Service\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_name ; rr:objectMap [ rr:column "service_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_streaming_service_platform_2_Streaming_Service_Platform_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"streaming_id\", \"platform_id\" FROM \"Streaming_Service_Platform\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Platform/{id}" ; rr:class :Streaming_Service_Platform ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_id ; rr:objectMap [ rr:column "streaming_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:platform_id ; rr:objectMap [ rr:column "platform_id" ] ] .

<#tm_scope_streaming_service_platform_3_Streaming_Service_Platform_platform_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"platform_id\" FROM \"Streaming_Service_Platform\" WHERE \"platform_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Platform/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPlatforms ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Platforms/{platform_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_service_platform_4_Streaming_Service_Platform_streaming_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"streaming_id\" FROM \"Streaming_Service_Platform\" WHERE \"streaming_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Platform/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_id}" ; rr:termType rr:IRI ] ] .

