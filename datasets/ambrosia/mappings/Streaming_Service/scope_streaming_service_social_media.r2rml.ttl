@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_service_social_media_0_Streaming_Service_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"service_name\", \"service_url\" FROM \"Streaming_Service\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_name ; rr:objectMap [ rr:column "service_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_url ; rr:objectMap [ rr:column "service_url" ] ] .

<#tm_scope_streaming_service_social_media_1_Social_Media_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"social_media_id\", \"type\" FROM \"Social_Media\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Social_Media/{social_media_id}" ; rr:class :Social_Media ] ;
  rr:predicateObjectMap [ rr:predicate p:social_media_id ; rr:objectMap [ rr:column "social_media_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] .

<#tm_scope_streaming_service_social_media_2_Streaming_Service_Social_Media_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\", \"social_media_id\" FROM \"Streaming_Service_Social_Media\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Social_Media/{_amb_rowid}" ; rr:class :Streaming_Service_Social_Media ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:social_media_id ; rr:objectMap [ rr:column "social_media_id" ] ] .

<#tm_scope_streaming_service_social_media_3_Streaming_Service_Social_Media_social_media_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"social_media_id\" FROM \"Streaming_Service_Social_Media\" WHERE \"social_media_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Social_Media/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSocial_Media ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Social_Media/{social_media_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_service_social_media_4_Streaming_Service_Social_Media_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\" FROM \"Streaming_Service_Social_Media\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
