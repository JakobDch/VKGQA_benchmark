@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_service_user_interface_0_Streaming_Service_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"price\" FROM \"Streaming_Service\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_streaming_service_user_interface_1_User_Interface_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"interface_type\" FROM \"User_Interface\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/User_Interface/{id}" ; rr:class :User_Interface ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:interface_type ; rr:objectMap [ rr:column "interface_type" ] ] .

<#tm_scope_streaming_service_user_interface_2_Streaming_Service_User_Interface_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\", \"user_interface_id\" FROM \"Streaming_Service_User_Interface\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_User_Interface/{_amb_rowid}" ; rr:class :Streaming_Service_User_Interface ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:user_interface_id ; rr:objectMap [ rr:column "user_interface_id" ] ] .

<#tm_scope_streaming_service_user_interface_3_Streaming_Service_User_Interface_user_interface_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"user_interface_id\" FROM \"Streaming_Service_User_Interface\" WHERE \"user_interface_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_User_Interface/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUser_Interface ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/User_Interface/{user_interface_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_service_user_interface_4_Streaming_Service_User_Interface_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\" FROM \"Streaming_Service_User_Interface\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_User_Interface/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_service_id}" ; rr:termType rr:IRI ] ] .

