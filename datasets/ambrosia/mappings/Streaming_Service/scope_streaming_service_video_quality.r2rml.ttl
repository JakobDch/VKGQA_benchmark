@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_service_video_quality_0_Streaming_Service_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"price\" FROM \"Streaming_Service\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:price ; rr:objectMap [ rr:column "price" ] ] .

<#tm_scope_streaming_service_video_quality_1_Video_Quality_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"quality\" FROM \"Video_Quality\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Video_Quality/{id}" ; rr:class :Video_Quality ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:quality ; rr:objectMap [ rr:column "quality" ] ] .

<#tm_scope_streaming_service_video_quality_2_Streaming_Service_Video_Quality_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_service_id\", \"video_quality_id\" FROM \"Streaming_Service_Video_Quality\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Video_Quality/{streaming_service_id}/{video_quality_id}" ; rr:class :Streaming_Service_Video_Quality ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:video_quality_id ; rr:objectMap [ rr:column "video_quality_id" ] ] .

<#tm_scope_streaming_service_video_quality_3_Streaming_Service_Video_Quality_video_quality_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_service_id\", \"video_quality_id\" FROM \"Streaming_Service_Video_Quality\" WHERE \"video_quality_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Video_Quality/{streaming_service_id}/{video_quality_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVideo_Quality ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Video_Quality/{video_quality_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_service_video_quality_4_Streaming_Service_Video_Quality_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_service_id\", \"video_quality_id\" FROM \"Streaming_Service_Video_Quality\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Service_Video_Quality/{streaming_service_id}/{video_quality_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_service_id}" ; rr:termType rr:IRI ] ] .

