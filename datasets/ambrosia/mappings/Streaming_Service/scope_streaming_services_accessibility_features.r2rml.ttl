@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_services_accessibility_features_0_Accessibility_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"featureName\" FROM \"Accessibility_Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Accessibility_Features/{id}" ; rr:class :Accessibility_Features ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:featureName ; rr:objectMap [ rr:column "featureName" ] ] .

<#tm_scope_streaming_services_accessibility_features_1_Streaming_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"serviceName\", \"basePrice\" FROM \"Streaming_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:serviceName ; rr:objectMap [ rr:column "serviceName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:basePrice ; rr:objectMap [ rr:column "basePrice" ] ] .

<#tm_scope_streaming_services_accessibility_features_2_Streaming_Services_Accessibility_Features_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"streamingServiceId\", \"accessibilityFeatureId\" FROM \"Streaming_Services_Accessibility_Features\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Accessibility_Features/{id}" ; rr:class :Streaming_Services_Accessibility_Features ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:streamingServiceId ; rr:objectMap [ rr:column "streamingServiceId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:accessibilityFeatureId ; rr:objectMap [ rr:column "accessibilityFeatureId" ] ] .

<#tm_scope_streaming_services_accessibility_features_3_Streaming_Services_Accessibility_Features_accessibilityFeatureId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"accessibilityFeatureId\" FROM \"Streaming_Services_Accessibility_Features\" WHERE \"accessibilityFeatureId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Accessibility_Features/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAccessibility_Features ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Accessibility_Features/{accessibilityFeatureId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_services_accessibility_features_4_Streaming_Services_Accessibility_Features_streamingServiceId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"streamingServiceId\" FROM \"Streaming_Services_Accessibility_Features\" WHERE \"streamingServiceId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Accessibility_Features/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streamingServiceId}" ; rr:termType rr:IRI ] ] .

