@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_services_audio_formats_0_Audio_Formats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"format_name\", \"description\" FROM \"Audio_Formats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Audio_Formats/{id}" ; rr:class :Audio_Formats ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:format_name ; rr:objectMap [ rr:column "format_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_streaming_services_audio_formats_1_Streaming_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"service_name\", \"subscription_price\", \"number_of_users\" FROM \"Streaming_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_name ; rr:objectMap [ rr:column "service_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subscription_price ; rr:objectMap [ rr:column "subscription_price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:number_of_users ; rr:objectMap [ rr:column "number_of_users" ] ] .

<#tm_scope_streaming_services_audio_formats_2_Streaming_Services_Audio_Formats_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\", \"audio_format_id\" FROM \"Streaming_Services_Audio_Formats\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Audio_Formats/{_amb_rowid}" ; rr:class :Streaming_Services_Audio_Formats ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:audio_format_id ; rr:objectMap [ rr:column "audio_format_id" ] ] .

<#tm_scope_streaming_services_audio_formats_3_Streaming_Services_Audio_Formats_audio_format_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"audio_format_id\" FROM \"Streaming_Services_Audio_Formats\" WHERE \"audio_format_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Audio_Formats/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAudio_Formats ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Audio_Formats/{audio_format_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_services_audio_formats_4_Streaming_Services_Audio_Formats_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\" FROM \"Streaming_Services_Audio_Formats\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Audio_Formats/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_service_id}" ; rr:termType rr:IRI ] ] .

