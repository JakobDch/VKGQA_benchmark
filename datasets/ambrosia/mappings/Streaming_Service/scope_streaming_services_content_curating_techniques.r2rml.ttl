@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_services_content_curating_techniques_0_Content_Curating_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"technique\" FROM \"Content_Curating_Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Content_Curating_Techniques/{id}" ; rr:class :Content_Curating_Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:technique ; rr:objectMap [ rr:column "technique" ] ] .

<#tm_scope_streaming_services_content_curating_techniques_1_Streaming_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"service_id\", \"name\", \"genre\" FROM \"Streaming_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{service_id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:service_id ; rr:objectMap [ rr:column "service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] .

<#tm_scope_streaming_services_content_curating_techniques_2_Users_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"user_id\", \"username\", \"password\" FROM \"Users\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Users/{user_id}" ; rr:class :Users ] ;
  rr:predicateObjectMap [ rr:predicate p:user_id ; rr:objectMap [ rr:column "user_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:username ; rr:objectMap [ rr:column "username" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:password ; rr:objectMap [ rr:column "password" ] ] .

<#tm_scope_streaming_services_content_curating_techniques_3_Views_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"view_id\", \"user_id\", \"streamed_service_id\", \"viewed_date\" FROM \"Views\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Views/{view_id}" ; rr:class :Views ] ;
  rr:predicateObjectMap [ rr:predicate p:view_id ; rr:objectMap [ rr:column "view_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:user_id ; rr:objectMap [ rr:column "user_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:streamed_service_id ; rr:objectMap [ rr:column "streamed_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:viewed_date ; rr:objectMap [ rr:column "viewed_date" ] ] .

<#tm_scope_streaming_services_content_curating_techniques_4_Views_streamed_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"view_id\", \"streamed_service_id\" FROM \"Views\" WHERE \"streamed_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Views/{view_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streamed_service_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_services_content_curating_techniques_5_Views_user_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"view_id\", \"user_id\" FROM \"Views\" WHERE \"user_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Views/{view_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUsers ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Users/{user_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_services_content_curating_techniques_6_Streaming_Services_Content_Curating_Techniques_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_services_content_curating_technique_id\", \"streaming_service_id\", \"content_curating_technique_id\" FROM \"Streaming_Services_Content_Curating_Techniques\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Content_Curating_Techniques/{streaming_services_content_curating_technique_id}" ; rr:class :Streaming_Services_Content_Curating_Techniques ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_services_content_curating_technique_id ; rr:objectMap [ rr:column "streaming_services_content_curating_technique_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
