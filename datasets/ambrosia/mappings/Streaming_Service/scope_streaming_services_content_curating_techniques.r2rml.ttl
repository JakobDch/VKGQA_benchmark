  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_services_content_curating_technique_id\", \"streaming_service_id\" FROM \"Streaming_Services_Content_Curating_Techniques\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Content_Curating_Techniques/{streaming_services_content_curating_technique_id}" ] ;
