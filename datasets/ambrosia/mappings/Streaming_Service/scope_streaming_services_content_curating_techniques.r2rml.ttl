<#tm_scope_streaming_services_content_curating_techniques_7_Streaming_Services_Content_Curating_Techniques_content_curating_technique_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_services_content_curating_technique_id\", \"content_curating_technique_id\" FROM \"Streaming_Services_Content_Curating_Techniques\" WHERE \"content_curating_technique_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Content_Curating_Techniques/{streaming_services_content_curating_technique_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasContent_Curating_Techniques ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Content_Curating_Techniques/{content_curating_technique_id}" ; rr:termType rr:IRI ] ] .

