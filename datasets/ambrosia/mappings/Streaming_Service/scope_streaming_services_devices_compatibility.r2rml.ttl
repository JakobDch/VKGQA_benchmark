  rr:predicateObjectMap [ rr:predicate p:serviceName ; rr:objectMap [ rr:column "serviceName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subscriptionPrice ; rr:objectMap [ rr:column "subscriptionPrice" ] ] .

