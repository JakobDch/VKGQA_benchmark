@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_services_devices_compatibility_0_Devices_Compatibility_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"deviceName\", \"isActive\" FROM \"Devices_Compatibility\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Devices_Compatibility/{id}" ; rr:class :Devices_Compatibility ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:deviceName ; rr:objectMap [ rr:column "deviceName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:isActive ; rr:objectMap [ rr:column "isActive" ] ] .

