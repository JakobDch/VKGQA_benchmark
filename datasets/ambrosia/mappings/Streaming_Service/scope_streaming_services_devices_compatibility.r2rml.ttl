<#tm_scope_streaming_services_devices_compatibility_5_UserSubscriptions_subscriptionPlanId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"subscriptionPlanId\" FROM \"UserSubscriptions\" WHERE \"subscriptionPlanId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/UserSubscriptions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubscription_Plan ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Subscription_Plan/{subscriptionPlanId}" ; rr:termType rr:IRI ] ] .

