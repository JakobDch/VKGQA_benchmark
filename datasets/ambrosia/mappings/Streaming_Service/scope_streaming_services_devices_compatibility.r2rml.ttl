<#tm_scope_streaming_services_devices_compatibility_4_UserSubscriptions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"userId\", \"streamingServiceId\", \"subscriptionPlanId\" FROM \"UserSubscriptions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/UserSubscriptions/{_amb_rowid}" ; rr:class :UserSubscriptions ] ;
  rr:predicateObjectMap [ rr:predicate p:userId ; rr:objectMap [ rr:column "userId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:streamingServiceId ; rr:objectMap [ rr:column "streamingServiceId" ] ] ;
