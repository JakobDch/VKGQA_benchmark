@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_services_genres_0_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\" FROM \"Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Genres/{id}" ; rr:class :Genres ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_streaming_services_genres_1_Streaming_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"service_name\", \"release_date\" FROM \"Streaming_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_name ; rr:objectMap [ rr:column "service_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] .

<#tm_scope_streaming_services_genres_2_Streaming_Services_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_services_id\", \"genres_id\" FROM \"Streaming_Services_Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Genres/{streaming_services_id}/{genres_id}" ; rr:class :Streaming_Services_Genres ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_services_id ; rr:objectMap [ rr:column "streaming_services_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genres_id ; rr:objectMap [ rr:column "genres_id" ] ] .

<#tm_scope_streaming_services_genres_3_Streaming_Services_Genres_genres_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_services_id\", \"genres_id\" FROM \"Streaming_Services_Genres\" WHERE \"genres_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Genres/{streaming_services_id}/{genres_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenres ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Genres/{genres_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_services_genres_4_Streaming_Services_Genres_streaming_services_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_services_id\", \"genres_id\" FROM \"Streaming_Services_Genres\" WHERE \"streaming_services_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Genres/{streaming_services_id}/{genres_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_services_id}" ; rr:termType rr:IRI ] ] .

