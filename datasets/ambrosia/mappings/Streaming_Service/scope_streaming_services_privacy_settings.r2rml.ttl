@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_services_privacy_settings_0_Streaming_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"service_name\", \"subscription_price\" FROM \"Streaming_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_name ; rr:objectMap [ rr:column "service_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subscription_price ; rr:objectMap [ rr:column "subscription_price" ] ] .

<#tm_scope_streaming_services_privacy_settings_1_Privacy_Settings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"setting_id\", \"setting_value\" FROM \"Privacy_Settings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Privacy_Settings/{setting_id}" ; rr:class :Privacy_Settings ] ;
  rr:predicateObjectMap [ rr:predicate p:setting_id ; rr:objectMap [ rr:column "setting_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:setting_value ; rr:objectMap [ rr:column "setting_value" ] ] .

<#tm_scope_streaming_services_privacy_settings_2_Streaming_Services_Privacy_Settings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\", \"privacy_settings_id\" FROM \"Streaming_Services_Privacy_Settings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Privacy_Settings/{_amb_rowid}" ; rr:class :Streaming_Services_Privacy_Settings ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:privacy_settings_id ; rr:objectMap [ rr:column "privacy_settings_id" ] ] .

<#tm_scope_streaming_services_privacy_settings_3_Streaming_Services_Privacy_Settings_privacy_settings_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"privacy_settings_id\" FROM \"Streaming_Services_Privacy_Settings\" WHERE \"privacy_settings_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Privacy_Settings/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPrivacy_Settings ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Privacy_Settings/{privacy_settings_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_services_privacy_settings_4_Streaming_Services_Privacy_Settings_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\" FROM \"Streaming_Services_Privacy_Settings\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Privacy_Settings/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_service_id}" ; rr:termType rr:IRI ] ] .

