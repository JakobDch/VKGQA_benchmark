@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_services_social_media_integrations_0_Streaming_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"service_name\", \"subscription_fee\" FROM \"Streaming_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_name ; rr:objectMap [ rr:column "service_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subscription_fee ; rr:objectMap [ rr:column "subscription_fee" ] ] .

<#tm_scope_streaming_services_social_media_integrations_1_Social_Media_Integrations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"integration_type\", \"description\" FROM \"Social_Media_Integrations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Social_Media_Integrations/{id}" ; rr:class :Social_Media_Integrations ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:integration_type ; rr:objectMap [ rr:column "integration_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_streaming_services_social_media_integrations_2_Streaming_Services_Social_Media_Integrations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\", \"social_media_integration_id\" FROM \"Streaming_Services_Social_Media_Integrations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Social_Media_Integrations/{_amb_rowid}" ; rr:class :Streaming_Services_Social_Media_Integrations ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:social_media_integration_id ; rr:objectMap [ rr:column "social_media_integration_id" ] ] .

<#tm_scope_streaming_services_social_media_integrations_3_Streaming_Services_Social_Media_Integrations_social_media_integration_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"social_media_integration_id\" FROM \"Streaming_Services_Social_Media_Integrations\" WHERE \"social_media_integration_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Social_Media_Integrations/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSocial_Media_Integrations ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Social_Media_Integrations/{social_media_integration_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_services_social_media_integrations_4_Streaming_Services_Social_Media_Integrations_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\" FROM \"Streaming_Services_Social_Media_Integrations\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Social_Media_Integrations/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_service_id}" ; rr:termType rr:IRI ] ] .

