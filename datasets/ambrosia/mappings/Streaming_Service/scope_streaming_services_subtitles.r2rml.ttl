@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_services_subtitles_0_Streaming_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"url\" FROM \"Streaming_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:url ; rr:objectMap [ rr:column "url" ] ] .

<#tm_scope_streaming_services_subtitles_1_Subtitles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"language\", \"default_subtitle\" FROM \"Subtitles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Subtitles/{id}" ; rr:class :Subtitles ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:language ; rr:objectMap [ rr:column "language" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:default_subtitle ; rr:objectMap [ rr:column "default_subtitle" ] ] .

<#tm_scope_streaming_services_subtitles_2_Streaming_Services_Subtitles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\", \"subtitle_id\" FROM \"Streaming_Services_Subtitles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Subtitles/{_amb_rowid}" ; rr:class :Streaming_Services_Subtitles ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subtitle_id ; rr:objectMap [ rr:column "subtitle_id" ] ] .

<#tm_scope_streaming_services_subtitles_3_Streaming_Services_Subtitles_subtitle_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"subtitle_id\" FROM \"Streaming_Services_Subtitles\" WHERE \"subtitle_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Subtitles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubtitles ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Subtitles/{subtitle_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_services_subtitles_4_Streaming_Services_Subtitles_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\" FROM \"Streaming_Services_Subtitles\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Subtitles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_service_id}" ; rr:termType rr:IRI ] ] .

