@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_services_third_party_apps_0_Streaming_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"description\" FROM \"Streaming_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_streaming_services_third_party_apps_1_Third_Party_Apps_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"app_id\", \"app_name\", \"is_active\" FROM \"Third_Party_Apps\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Third_Party_Apps/{app_id}" ; rr:class :Third_Party_Apps ] ;
  rr:predicateObjectMap [ rr:predicate p:app_id ; rr:objectMap [ rr:column "app_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:app_name ; rr:objectMap [ rr:column "app_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:is_active ; rr:objectMap [ rr:column "is_active" ] ] .

<#tm_scope_streaming_services_third_party_apps_2_Streaming_Services_Third_Party_Apps_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_service_id\", \"third_party_app_id\" FROM \"Streaming_Services_Third_Party_Apps\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Third_Party_Apps/{streaming_service_id}/{third_party_app_id}" ; rr:class :Streaming_Services_Third_Party_Apps ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:third_party_app_id ; rr:objectMap [ rr:column "third_party_app_id" ] ] .

<#tm_scope_streaming_services_third_party_apps_3_Streaming_Services_Third_Party_Apps_third_party_app_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_service_id\", \"third_party_app_id\" FROM \"Streaming_Services_Third_Party_Apps\" WHERE \"third_party_app_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Third_Party_Apps/{streaming_service_id}/{third_party_app_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasThird_Party_Apps ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Third_Party_Apps/{third_party_app_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_services_third_party_apps_4_Streaming_Services_Third_Party_Apps_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_service_id\", \"third_party_app_id\" FROM \"Streaming_Services_Third_Party_Apps\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Third_Party_Apps/{streaming_service_id}/{third_party_app_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_service_id}" ; rr:termType rr:IRI ] ] .

