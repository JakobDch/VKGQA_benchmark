@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streaming_services_video_players_0_Streaming_Services_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"service_name\", \"description\" FROM \"Streaming_Services\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{id}" ; rr:class :Streaming_Services ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:service_name ; rr:objectMap [ rr:column "service_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_streaming_services_video_players_1_Video_Players_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"player_type\", \"version\" FROM \"Video_Players\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Video_Players/{id}" ; rr:class :Video_Players ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:player_type ; rr:objectMap [ rr:column "player_type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:version ; rr:objectMap [ rr:column "version" ] ] .

<#tm_scope_streaming_services_video_players_2_Streaming_Services_Video_Players_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\", \"video_player_id\" FROM \"Streaming_Services_Video_Players\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Video_Players/{_amb_rowid}" ; rr:class :Streaming_Services_Video_Players ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_service_id ; rr:objectMap [ rr:column "streaming_service_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:video_player_id ; rr:objectMap [ rr:column "video_player_id" ] ] .

<#tm_scope_streaming_services_video_players_3_Streaming_Services_Video_Players_video_player_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"video_player_id\" FROM \"Streaming_Services_Video_Players\" WHERE \"video_player_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Video_Players/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasVideo_Players ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Video_Players/{video_player_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streaming_services_video_players_4_Streaming_Services_Video_Players_streaming_service_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_service_id\" FROM \"Streaming_Services_Video_Players\" WHERE \"streaming_service_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services_Video_Players/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreaming_Services ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streaming_Services/{streaming_service_id}" ; rr:termType rr:IRI ] ] .

