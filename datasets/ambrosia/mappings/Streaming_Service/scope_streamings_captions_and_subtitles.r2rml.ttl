@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streamings_captions_and_subtitles_0_Streamings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"streaming_id\", \"title\", \"duration\" FROM \"Streamings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streamings/{streaming_id}" ; rr:class :Streamings ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_id ; rr:objectMap [ rr:column "streaming_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration ; rr:objectMap [ rr:column "duration" ] ] .

<#tm_scope_streamings_captions_and_subtitles_1_Captions_and_subtitles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"caption_id\", \"type\", \"language\" FROM \"Captions_and_subtitles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Captions_and_subtitles/{caption_id}" ; rr:class :Captions_and_subtitles ] ;
  rr:predicateObjectMap [ rr:predicate p:caption_id ; rr:objectMap [ rr:column "caption_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:language ; rr:objectMap [ rr:column "language" ] ] .

<#tm_scope_streamings_captions_and_subtitles_2_Streamings_captions_and_subtitles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streamings_id\", \"captions_and_subtitles_id\" FROM \"Streamings_captions_and_subtitles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streamings_captions_and_subtitles/{_amb_rowid}" ; rr:class :Streamings_captions_and_subtitles ] ;
  rr:predicateObjectMap [ rr:predicate p:streamings_id ; rr:objectMap [ rr:column "streamings_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:captions_and_subtitles_id ; rr:objectMap [ rr:column "captions_and_subtitles_id" ] ] .

<#tm_scope_streamings_captions_and_subtitles_3_Streamings_captions_and_subtitles_captions_and_subtitles_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"captions_and_subtitles_id\" FROM \"Streamings_captions_and_subtitles\" WHERE \"captions_and_subtitles_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streamings_captions_and_subtitles/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCaptions_and_subtitles ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Captions_and_subtitles/{captions_and_subtitles_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streamings_captions_and_subtitles_4_Streamings_captions_and_subtitles_streamings_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streamings_id\" FROM \"Streamings_captions_and_subtitles\" WHERE \"streamings_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streamings_captions_and_subtitles/{_amb_rowid}" ] ;
