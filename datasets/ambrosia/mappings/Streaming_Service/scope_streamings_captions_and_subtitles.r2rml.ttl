<#tm_scope_streamings_captions_and_subtitles_8_User_Payments_payment_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"payment_id\" FROM \"User_Payments\" WHERE \"payment_id\" IS NOT NULL""" ] ;
