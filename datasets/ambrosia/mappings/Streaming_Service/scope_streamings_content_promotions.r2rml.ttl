@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streamings_content_promotions_0_Streamings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_date\" FROM \"Streamings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streamings/{id}" ; rr:class :Streamings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] .

<#tm_scope_streamings_content_promotions_1_Content_Promotions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type\", \"description\" FROM \"Content_Promotions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Content_Promotions/{id}" ; rr:class :Content_Promotions ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_streamings_content_promotions_2_Streamings_Content_Promotions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_id\", \"content_promotion_type_id\" FROM \"Streamings_Content_Promotions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streamings_Content_Promotions/{_amb_rowid}" ; rr:class :Streamings_Content_Promotions ] ;
  rr:predicateObjectMap [ rr:predicate p:streaming_id ; rr:objectMap [ rr:column "streaming_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content_promotion_type_id ; rr:objectMap [ rr:column "content_promotion_type_id" ] ] .

<#tm_scope_streamings_content_promotions_3_Streamings_Content_Promotions_content_promotion_type_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"content_promotion_type_id\" FROM \"Streamings_Content_Promotions\" WHERE \"content_promotion_type_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streamings_Content_Promotions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasContent_Promotions ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Content_Promotions/{content_promotion_type_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streamings_content_promotions_4_Streamings_Content_Promotions_streaming_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"streaming_id\" FROM \"Streamings_Content_Promotions\" WHERE \"streaming_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streamings_Content_Promotions/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreamings ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Streamings/{streaming_id}" ; rr:termType rr:IRI ] ] .

