@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_streamings_payments_0_Users_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"username\", \"email\" FROM \"Users\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Users/{id}" ; rr:class :Users ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:username ; rr:objectMap [ rr:column "username" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] .

<#tm_scope_streamings_payments_1_Genres_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"genre_id\", \"name\" FROM \"Genres\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Genres/{genre_id}" ; rr:class :Genres ] ;
  rr:predicateObjectMap [ rr:predicate p:genre_id ; rr:objectMap [ rr:column "genre_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] .

<#tm_scope_streamings_payments_2_Movies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"title\", \"release_year\", \"genre_id\" FROM \"Movies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Movies/{movie_id}" ; rr:class :Movies ] ;
  rr:predicateObjectMap [ rr:predicate p:movie_id ; rr:objectMap [ rr:column "movie_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_year ; rr:objectMap [ rr:column "release_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre_id ; rr:objectMap [ rr:column "genre_id" ] ] .

<#tm_scope_streamings_payments_3_Movies_genre_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"movie_id\", \"genre_id\" FROM \"Movies\" WHERE \"genre_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Movies/{movie_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGenres ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Genres/{genre_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_streamings_payments_4_Subscriptions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"subscription_id\", \"user_id\", \"start_date\", \"end_date\", \"status\" FROM \"Subscriptions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Subscriptions/{subscription_id}" ; rr:class :Subscriptions ] ;
  rr:predicateObjectMap [ rr:predicate p:subscription_id ; rr:objectMap [ rr:column "subscription_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:user_id ; rr:objectMap [ rr:column "user_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:status ; rr:objectMap [ rr:column "status" ] ] .

<#tm_scope_streamings_payments_5_Subscriptions_user_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"subscription_id\", \"user_id\" FROM \"Subscriptions\" WHERE \"user_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Subscriptions/{subscription_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUsers ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Users/{user_id}" ; rr:termType rr:IRI ] ] .

