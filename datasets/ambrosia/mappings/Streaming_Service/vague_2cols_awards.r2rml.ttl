  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Release_Date\", \"Runtime\", \"Genre\" FROM \"Movie\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Movie/{id}" ; rr:class :Movie ] ;
