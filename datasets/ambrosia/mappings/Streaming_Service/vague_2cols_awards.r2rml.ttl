@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_awards_0_Award_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Award_Name\", \"Winning_Category\", \"Film\", \"Year\", \"Presenter\" FROM \"Award\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Award/{id}" ; rr:class :Award ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Award_Name ; rr:objectMap [ rr:column "Award_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Winning_Category ; rr:objectMap [ rr:column "Winning_Category" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Film ; rr:objectMap [ rr:column "Film" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Presenter ; rr:objectMap [ rr:column "Presenter" ] ] .

