<#tm_vague_2cols_awards_5_Viewership_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Movie_ID\", \"Total_Views\", \"Peak_Concurrent_Streams\", \"Platform\" FROM \"Viewership\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Viewership/{id}" ; rr:class :Viewership ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Movie_ID ; rr:objectMap [ rr:column "Movie_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Total_Views ; rr:objectMap [ rr:column "Total_Views" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Peak_Concurrent_Streams ; rr:objectMap [ rr:column "Peak_Concurrent_Streams" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Platform ; rr:objectMap [ rr:column "Platform" ] ] .

<#tm_vague_2cols_awards_6_Viewership_Movie_ID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Movie_ID\" FROM \"Viewership\" WHERE \"Movie_ID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Viewership/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMovie ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Movie/{Movie_ID}" ; rr:termType rr:IRI ] ] .

