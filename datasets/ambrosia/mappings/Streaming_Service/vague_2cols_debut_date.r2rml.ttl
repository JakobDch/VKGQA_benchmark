@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_debut_date_0_Podcast_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Debut_Day\", \"Debut_Year\", \"Title\", \"Hosts\", \"Duration\" FROM \"Podcast\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Podcast/{id}" ; rr:class :Podcast ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Debut_Day ; rr:objectMap [ rr:column "Debut_Day" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Debut_Year ; rr:objectMap [ rr:column "Debut_Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Hosts ; rr:objectMap [ rr:column "Hosts" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Duration ; rr:objectMap [ rr:column "Duration" ] ] .

<#tm_vague_2cols_debut_date_1_Episode_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Podcast_id\", \"Episode_Number\", \"Release_Date\", \"Length\" FROM \"Episode\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Episode/{id}" ; rr:class :Episode ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Podcast_id ; rr:objectMap [ rr:column "Podcast_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Episode_Number ; rr:objectMap [ rr:column "Episode_Number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Release_Date ; rr:objectMap [ rr:column "Release_Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Length ; rr:objectMap [ rr:column "Length" ] ] .

<#tm_vague_2cols_debut_date_2_Episode_Podcast_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Podcast_id\" FROM \"Episode\" WHERE \"Podcast_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Episode/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPodcast ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Podcast/{Podcast_id}" ; rr:termType rr:IRI ] ] .

