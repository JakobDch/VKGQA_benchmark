@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_filming_location_0_Users_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"user_id\", \"username\", \"email\", \"password\", \"city\", \"country\", \"created_at\" FROM \"Users\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Users/{user_id}" ; rr:class :Users ] ;
  rr:predicateObjectMap [ rr:predicate p:user_id ; rr:objectMap [ rr:column "user_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:username ; rr:objectMap [ rr:column "username" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:password ; rr:objectMap [ rr:column "password" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:city ; rr:objectMap [ rr:column "city" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:country ; rr:objectMap [ rr:column "country" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:created_at ; rr:objectMap [ rr:column "created_at" ] ] .

<#tm_vague_2cols_filming_location_1_Subscriptions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"subscription_id\", \"user_id\", \"plan\", \"start_date\", \"end_date\" FROM \"Subscriptions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Subscriptions/{subscription_id}" ; rr:class :Subscriptions ] ;
  rr:predicateObjectMap [ rr:predicate p:subscription_id ; rr:objectMap [ rr:column "subscription_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:user_id ; rr:objectMap [ rr:column "user_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:plan ; rr:objectMap [ rr:column "plan" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] .

<#tm_vague_2cols_filming_location_2_Subscriptions_user_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"subscription_id\", \"user_id\" FROM \"Subscriptions\" WHERE \"user_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Subscriptions/{subscription_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUsers ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Users/{user_id}" ; rr:termType rr:IRI ] ] .

