@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_number_of_seasons_0_TV_Shows_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"Title\", \"Released_Seasons\", \"Planned_Seasons\", \"Series\", \"GenreID\", \"PlatformID\", \"RatingID\" FROM \"TV_Shows\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/TV_Shows/{id}" ; rr:class :TV_Shows ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Released_Seasons ; rr:objectMap [ rr:column "Released_Seasons" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Planned_Seasons ; rr:objectMap [ rr:column "Planned_Seasons" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Series ; rr:objectMap [ rr:column "Series" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GenreID ; rr:objectMap [ rr:column "GenreID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:PlatformID ; rr:objectMap [ rr:column "PlatformID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RatingID ; rr:objectMap [ rr:column "RatingID" ] ] .

<#tm_vague_2cols_number_of_seasons_1_TV_Shows_RatingID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"RatingID\" FROM \"TV_Shows\" WHERE \"RatingID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/TV_Shows/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRatings ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Ratings/{RatingID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_number_of_seasons_2_TV_Shows_PlatformID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"PlatformID\" FROM \"TV_Shows\" WHERE \"PlatformID\" IS NOT NULL""" ] ;
