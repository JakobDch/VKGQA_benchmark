<#tm_vague_2cols_premiere_date_4_Reviews_contentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"contentId\" FROM \"Reviews\" WHERE \"contentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Reviews/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasContent ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Content/{contentId}" ; rr:termType rr:IRI ] ] .

