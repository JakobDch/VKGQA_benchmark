<#tm_vague_2cols_premiere_date_3_Reviews_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"userId\", \"contentId\", \"rating\", \"reviewText\" FROM \"Reviews\"""" ] ;
