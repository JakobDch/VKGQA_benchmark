  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration ; rr:objectMap [ rr:column "duration" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:category ; rr:objectMap [ rr:column "category" ] ] .

<#tm_vague_2cols_recording_location_3_Customer_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"first_name\", \"last_name\", \"email\", \"password\", \"subscription_plan_id\" FROM \"Customer\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Customer/{customer_id}" ; rr:class :Customer ] ;
  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:password ; rr:objectMap [ rr:column "password" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:subscription_plan_id ; rr:objectMap [ rr:column "subscription_plan_id" ] ] .

<#tm_vague_2cols_recording_location_4_Customer_subscription_plan_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"customer_id\", \"subscription_plan_id\" FROM \"Customer\" WHERE \"subscription_plan_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Customer/{customer_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasSubscription_Plan ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Subscription_Plan/{subscription_plan_id}" ; rr:termType rr:IRI ] ] .

