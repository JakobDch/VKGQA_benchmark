  rr:predicateObjectMap [ rr:predicate p:customer_id ; rr:objectMap [ rr:column "customer_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:content_id ; rr:objectMap [ rr:column "content_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:play_date ; rr:objectMap [ rr:column "play_date" ] ] .

<#tm_vague_2cols_recording_location_6_PlayHistory_content_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"history_id\", \"content_id\" FROM \"PlayHistory\" WHERE \"content_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/PlayHistory/{history_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasContentLibrary ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/ContentLibrary/{content_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_recording_location_7_PlayHistory_customer_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"history_id\", \"customer_id\" FROM \"PlayHistory\" WHERE \"customer_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/PlayHistory/{history_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCustomer ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Customer/{customer_id}" ; rr:termType rr:IRI ] ] .

