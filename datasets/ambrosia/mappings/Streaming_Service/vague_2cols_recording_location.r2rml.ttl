@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_recording_location_0_Studio_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"studio_name\", \"address\", \"podcast\", \"genre\", \"rating\" FROM \"Studio\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Studio/{id}" ; rr:class :Studio ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:studio_name ; rr:objectMap [ rr:column "studio_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:podcast ; rr:objectMap [ rr:column "podcast" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:rating ; rr:objectMap [ rr:column "rating" ] ] .

<#tm_vague_2cols_recording_location_1_SubscriptionPlan_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"plan_id\", \"plan_name\", \"monthly_price\", \"annual_price\", \"features\" FROM \"SubscriptionPlan\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Subscription_Plan/{plan_id}" ; rr:class :Subscription_Plan ] ;
  rr:predicateObjectMap [ rr:predicate p:plan_id ; rr:objectMap [ rr:column "plan_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:plan_name ; rr:objectMap [ rr:column "plan_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:monthly_price ; rr:objectMap [ rr:column "monthly_price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:annual_price ; rr:objectMap [ rr:column "annual_price" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:features ; rr:objectMap [ rr:column "features" ] ] .

<#tm_vague_2cols_recording_location_2_ContentLibrary_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"content_id\", \"title\", \"description\", \"duration\", \"release_date\", \"category\" FROM \"ContentLibrary\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/ContentLibrary/{content_id}" ; rr:class :ContentLibrary ] ;
  rr:predicateObjectMap [ rr:predicate p:content_id ; rr:objectMap [ rr:column "content_id" ] ] ;
