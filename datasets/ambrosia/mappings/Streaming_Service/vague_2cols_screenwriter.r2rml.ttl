@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_screenwriter_0_Subscribers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"subscriber_id\", \"username\", \"email\", \"password\" FROM \"Subscribers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Subscribers/{subscriber_id}" ; rr:class :Subscribers ] ;
  rr:predicateObjectMap [ rr:predicate p:subscriber_id ; rr:objectMap [ rr:column "subscriber_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:username ; rr:objectMap [ rr:column "username" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "email" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:password ; rr:objectMap [ rr:column "password" ] ] .

