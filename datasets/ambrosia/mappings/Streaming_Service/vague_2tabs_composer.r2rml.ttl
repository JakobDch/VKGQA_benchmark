  rr:predicateObjectMap [ rr:predicate p:genre ; rr:objectMap [ rr:column "genre" ] ] .

<#tm_vague_2tabs_composer_2_Soundtrack_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"title\", \"release_date\", \"band_id\", \"musician_id\" FROM \"Soundtrack\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Soundtrack/{id}" ; rr:class :Soundtrack ] ;
