  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:release_date ; rr:objectMap [ rr:column "release_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:band_id ; rr:objectMap [ rr:column "band_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:musician_id ; rr:objectMap [ rr:column "musician_id" ] ] .

<#tm_vague_2tabs_composer_3_Soundtrack_musician_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"musician_id\" FROM \"Soundtrack\" WHERE \"musician_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Soundtrack/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasMusician ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Musician/{musician_id}" ; rr:termType rr:IRI ] ] .

