<#tm_vague_2tabs_debut_date_8_Podcast_Genre_podcast_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"pod_genre_id\", \"podcast_id\" FROM \"Podcast_Genre\" WHERE \"podcast_id\" IS NOT NULL""" ] ;
