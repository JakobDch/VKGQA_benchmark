@prefix : <http://ambrosia.example.org/streamingservice#> .
@prefix p: <http://ambrosia.example.org/streamingservice/prop#> .
@prefix ex: <http://ambrosia.example.org/streamingservice/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_debut_date_0_Debut_Day_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"day\", \"month\" FROM \"Debut_Day\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Debut_Date/{id}" ; rr:class :Debut_Date ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:day ; rr:objectMap [ rr:column "day" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:month ; rr:objectMap [ rr:column "month" ] ] .

<#tm_vague_2tabs_debut_date_1_Debut_Year_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"year\" FROM \"Debut_Year\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Debut_Year/{id}" ; rr:class :Debut_Year ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:year ; rr:objectMap [ rr:column "year" ] ] .

<#tm_vague_2tabs_debut_date_2_Podcast_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"podcast_name\", \"debut_day_id\", \"debut_year_id\" FROM \"Podcast\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Podcast/{id}" ; rr:class :Podcast ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:podcast_name ; rr:objectMap [ rr:column "podcast_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:debut_day_id ; rr:objectMap [ rr:column "debut_day_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:debut_year_id ; rr:objectMap [ rr:column "debut_year_id" ] ] .

<#tm_vague_2tabs_debut_date_3_Podcast_debut_year_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"debut_year_id\" FROM \"Podcast\" WHERE \"debut_year_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Podcast/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDebut_Year ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Debut_Year/{debut_year_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_debut_date_4_Podcast_debut_day_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"debut_day_id\" FROM \"Podcast\" WHERE \"debut_day_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Podcast/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDebut_Date ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Debut_Date/{debut_day_id}" ; rr:termType rr:IRI ] ] .

