  rr:logicalTable [ rr:sqlQuery """SELECT \"podcast_id\", \"address_id\" FROM \"Podcast\" WHERE \"address_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Podcast/{podcast_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAddress ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Address/{address_id}" ; rr:termType rr:IRI ] ] .

