<#tm_vague_2tabs_recording_location_0_Studio_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"studio_id\", \"name\", \"founded_year\" FROM \"Studio\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Studio/{studio_id}" ; rr:class :Studio ] ;
  rr:predicateObjectMap [ rr:predicate p:studio_id ; rr:objectMap [ rr:column "studio_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:founded_year ; rr:objectMap [ rr:column "founded_year" ] ] .

