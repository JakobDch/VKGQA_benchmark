  rr:predicateObjectMap [ rr:predicate p:location_id ; rr:objectMap [ rr:column "location_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:era_id ; rr:objectMap [ rr:column "era_id" ] ] .

<#tm_vague_2tabs_setting_3_Story_era_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"era_id\" FROM \"Story\" WHERE \"era_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Story/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEra ; rr:objectMap [ rr:template "http://ambrosia.example.org/streamingservice/id/Era/{era_id}" ; rr:termType rr:IRI ] ] .

