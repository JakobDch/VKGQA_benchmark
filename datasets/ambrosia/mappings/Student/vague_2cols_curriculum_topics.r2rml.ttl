@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_curriculum_topics_0_Courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CourseID\", \"Core_Concepts\", \"Advanced_Topics\", \"CourseName\", \"TeachersName\" FROM \"Courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Courses/{CourseID}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseID ; rr:objectMap [ rr:column "CourseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Core_Concepts ; rr:objectMap [ rr:column "Core_Concepts" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Advanced_Topics ; rr:objectMap [ rr:column "Advanced_Topics" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseName ; rr:objectMap [ rr:column "CourseName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TeachersName ; rr:objectMap [ rr:column "TeachersName" ] ] .

<#tm_vague_2cols_curriculum_topics_1_Enrollment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\", \"CourseID\" FROM \"Enrollment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{EnrollmentID}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentID ; rr:objectMap [ rr:column "EnrollmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseID ; rr:objectMap [ rr:column "CourseID" ] ] .

<#tm_vague_2cols_curriculum_topics_2_Enrollment_CourseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"CourseID\" FROM \"Enrollment\" WHERE \"CourseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourses ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Courses/{CourseID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_curriculum_topics_3_Enrollment_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\" FROM \"Enrollment\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_curriculum_topics_4_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"FirstName\", \"LastName\", \"DateOfBirth\", \"Address\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{StudentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DateOfBirth ; rr:objectMap [ rr:column "DateOfBirth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] .

<#tm_vague_2cols_curriculum_topics_5_Grades_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GradeID\", \"EnrollmentID\", \"Grade\", \"Comments\" FROM \"Grades\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Grades/{GradeID}" ; rr:class :Grades ] ;
  rr:predicateObjectMap [ rr:predicate p:GradeID ; rr:objectMap [ rr:column "GradeID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentID ; rr:objectMap [ rr:column "EnrollmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Grade ; rr:objectMap [ rr:column "Grade" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Comments ; rr:objectMap [ rr:column "Comments" ] ] .

<#tm_vague_2cols_curriculum_topics_6_Grades_EnrollmentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"GradeID\", \"EnrollmentID\" FROM \"Grades\" WHERE \"EnrollmentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Grades/{GradeID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEnrollments ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{EnrollmentID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_curriculum_topics_7_Attendance_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AttendenceID\", \"EnrollmentID\", \"NumberOfDaysPresent\", \"TotalNumberOfClasses\", \"ExcusedAbsences\", \"UnexcusedAbsences\" FROM \"Attendance\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Attendance/{AttendenceID}" ; rr:class :Attendance ] ;
  rr:predicateObjectMap [ rr:predicate p:AttendenceID ; rr:objectMap [ rr:column "AttendenceID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentID ; rr:objectMap [ rr:column "EnrollmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumberOfDaysPresent ; rr:objectMap [ rr:column "NumberOfDaysPresent" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TotalNumberOfClasses ; rr:objectMap [ rr:column "TotalNumberOfClasses" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ExcusedAbsences ; rr:objectMap [ rr:column "ExcusedAbsences" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:UnexcusedAbsences ; rr:objectMap [ rr:column "UnexcusedAbsences" ] ] .

<#tm_vague_2cols_curriculum_topics_8_Attendance_EnrollmentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AttendenceID\", \"EnrollmentID\" FROM \"Attendance\" WHERE \"EnrollmentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Attendance/{AttendenceID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEnrollments ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{EnrollmentID}" ; rr:termType rr:IRI ] ] .

