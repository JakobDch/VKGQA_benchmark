  rr:predicateObjectMap [ rr:predicate p:classId ; rr:objectMap [ rr:column "classId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dateAttended ; rr:objectMap [ rr:column "dateAttended" ] ] ;
