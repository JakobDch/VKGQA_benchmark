  rr:predicateObjectMap [ rr:predicate p:studentId ; rr:objectMap [ rr:column "studentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:physicalMilestones ; rr:objectMap [ rr:column "physicalMilestones" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cognitiveMilestones ; rr:objectMap [ rr:column "cognitiveMilestones" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:childAge ; rr:objectMap [ rr:column "childAge" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:otherDetails ; rr:objectMap [ rr:column "otherDetails" ] ] .

<#tm_vague_2cols_developmental_milestones_6_MilestoneRecords_studentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"recordId\", \"studentId\" FROM \"MilestoneRecords\" WHERE \"studentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/MilestoneRecords/{recordId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{studentId}" ; rr:termType rr:IRI ] ] .

