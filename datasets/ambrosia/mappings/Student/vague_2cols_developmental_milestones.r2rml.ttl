<#tm_vague_2cols_developmental_milestones_9_Attendance_studentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"attendanceId\", \"studentId\" FROM \"Attendance\" WHERE \"studentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Attendance/{attendanceId}" ] ;
