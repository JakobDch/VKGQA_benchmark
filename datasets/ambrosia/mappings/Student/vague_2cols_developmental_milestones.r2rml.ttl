@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_developmental_milestones_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"dateOfBirth\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:dateOfBirth ; rr:objectMap [ rr:column "dateOfBirth" ] ] .

<#tm_vague_2cols_developmental_milestones_1_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"classID\", \"className\", \"teacherName\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Classes/{classID}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:classID ; rr:objectMap [ rr:column "classID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:className ; rr:objectMap [ rr:column "className" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:teacherName ; rr:objectMap [ rr:column "teacherName" ] ] .

<#tm_vague_2cols_developmental_milestones_2_Enrollments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollmentId\", \"studentId\", \"classId\" FROM \"Enrollments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{enrollmentId}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:enrollmentId ; rr:objectMap [ rr:column "enrollmentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:studentId ; rr:objectMap [ rr:column "studentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:classId ; rr:objectMap [ rr:column "classId" ] ] .

<#tm_vague_2cols_developmental_milestones_3_Enrollments_classId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollmentId\", \"classId\" FROM \"Enrollments\" WHERE \"classId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{enrollmentId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClasses ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Classes/{classId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_developmental_milestones_4_Enrollments_studentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollmentId\", \"studentId\" FROM \"Enrollments\" WHERE \"studentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{enrollmentId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{studentId}" ; rr:termType rr:IRI ] ] .

