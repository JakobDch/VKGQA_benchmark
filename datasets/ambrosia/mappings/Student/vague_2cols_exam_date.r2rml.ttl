@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_exam_date_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"FirstName\", \"LastName\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{StudentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] .

<#tm_vague_2cols_exam_date_1_Addresses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AddressID\", \"StreetAddress\", \"City\", \"State\", \"ZipCode\", \"StudentID\" FROM \"Addresses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Addresses/{AddressID}" ; rr:class :Addresses ] ;
  rr:predicateObjectMap [ rr:predicate p:AddressID ; rr:objectMap [ rr:column "AddressID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StreetAddress ; rr:objectMap [ rr:column "StreetAddress" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:City ; rr:objectMap [ rr:column "City" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:State ; rr:objectMap [ rr:column "State" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ZipCode ; rr:objectMap [ rr:column "ZipCode" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] .

<#tm_vague_2cols_exam_date_2_Addresses_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AddressID\", \"StudentID\" FROM \"Addresses\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Addresses/{AddressID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

