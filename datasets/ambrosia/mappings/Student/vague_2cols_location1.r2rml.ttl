@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_location1_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"First_name\", \"Last_name\", \"Date_of_birth\", \"Email\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{ID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:First_name ; rr:objectMap [ rr:column "First_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Last_name ; rr:objectMap [ rr:column "Last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date_of_birth ; rr:objectMap [ rr:column "Date_of_birth" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

<#tm_vague_2cols_location1_1_Departments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Department_ID\", \"Name\", \"Location\" FROM \"Departments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Departments/{Department_ID}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:Department_ID ; rr:objectMap [ rr:column "Department_ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "Location" ] ] .

<#tm_vague_2cols_location1_2_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Room_number\", \"Building_name\", \"Capacity\", \"Lectures\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Rooms/{Room_number}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:Room_number ; rr:objectMap [ rr:column "Room_number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Building_name ; rr:objectMap [ rr:column "Building_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Lectures ; rr:objectMap [ rr:column "Lectures" ] ] .

<#tm_vague_2cols_location1_3_Enrollments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Student_id\", \"Course_id\", \"Semester_year\", \"Grade\" FROM \"Enrollments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{_amb_rowid}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:Student_id ; rr:objectMap [ rr:column "Student_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Course_id ; rr:objectMap [ rr:column "Course_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Semester_year ; rr:objectMap [ rr:column "Semester_year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Grade ; rr:objectMap [ rr:column "Grade" ] ] .

<#tm_vague_2cols_location1_4_Enrollments_Course_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Course_id\" FROM \"Enrollments\" WHERE \"Course_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourses ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Courses/{Course_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location1_5_Enrollments_Student_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"Student_id\" FROM \"Enrollments\" WHERE \"Student_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{Student_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location1_6_Teachers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Teacher_Id\", \"First_name\", \"Last_name\", \"Hire_date\", \"Office_room_number\" FROM \"Teachers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Teachers/{Teacher_Id}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:Teacher_Id ; rr:objectMap [ rr:column "Teacher_Id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:First_name ; rr:objectMap [ rr:column "First_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Last_name ; rr:objectMap [ rr:column "Last_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Hire_date ; rr:objectMap [ rr:column "Hire_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Office_room_number ; rr:objectMap [ rr:column "Office_room_number" ] ] .

<#tm_vague_2cols_location1_7_Teachers_Office_room_number_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Teacher_Id\", \"Office_room_number\" FROM \"Teachers\" WHERE \"Office_room_number\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Teachers/{Teacher_Id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRooms ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Rooms/{Office_room_number}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location1_8_Courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Course_id\", \"Title\", \"Description\", \"Credits\", \"Teacher_id\" FROM \"Courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Courses/{Course_id}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:Course_id ; rr:objectMap [ rr:column "Course_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Title ; rr:objectMap [ rr:column "Title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Credits ; rr:objectMap [ rr:column "Credits" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Teacher_id ; rr:objectMap [ rr:column "Teacher_id" ] ] .

<#tm_vague_2cols_location1_9_Courses_Teacher_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Course_id\", \"Teacher_id\" FROM \"Courses\" WHERE \"Teacher_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Courses/{Course_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTeachers ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Teachers/{Teacher_id}" ; rr:termType rr:IRI ] ] .

