@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_location2_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StudentID\", \"FirstName\", \"LastName\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{StudentID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] .

<#tm_vague_2cols_location2_1_Departments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DepartmentID\", \"DepartmentName\" FROM \"Departments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Departments/{DepartmentID}" ; rr:class :Departments ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartmentID ; rr:objectMap [ rr:column "DepartmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DepartmentName ; rr:objectMap [ rr:column "DepartmentName" ] ] .

<#tm_vague_2cols_location2_2_Enrollments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"CourseID\", \"StudentID\" FROM \"Enrollments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{EnrollmentID}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:EnrollmentID ; rr:objectMap [ rr:column "EnrollmentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseID ; rr:objectMap [ rr:column "CourseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] .

<#tm_vague_2cols_location2_3_Enrollments_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"StudentID\" FROM \"Enrollments\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location2_4_Enrollments_CourseID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EnrollmentID\", \"CourseID\" FROM \"Enrollments\" WHERE \"CourseID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{EnrollmentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCourses ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Courses/{CourseID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location2_5_Courses_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CourseID\", \"CourseTitle\", \"RoomNumber\", \"Building\", \"StartTime\", \"EndTime\" FROM \"Courses\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Courses/{CourseID}" ; rr:class :Courses ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseID ; rr:objectMap [ rr:column "CourseID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseTitle ; rr:objectMap [ rr:column "CourseTitle" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomNumber ; rr:objectMap [ rr:column "RoomNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Building ; rr:objectMap [ rr:column "Building" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartTime ; rr:objectMap [ rr:column "StartTime" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndTime ; rr:objectMap [ rr:column "EndTime" ] ] .

<#tm_vague_2cols_location2_6_Buildings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"BuildingID\", \"Name\", \"Address\" FROM \"Buildings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Buildings/{BuildingID}" ; rr:class :Buildings ] ;
  rr:predicateObjectMap [ rr:predicate p:BuildingID ; rr:objectMap [ rr:column "BuildingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Address ; rr:objectMap [ rr:column "Address" ] ] .

<#tm_vague_2cols_location2_7_Rooms_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoomID\", \"BuildingID\", \"Capacity\" FROM \"Rooms\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Rooms/{RoomID}" ; rr:class :Rooms ] ;
  rr:predicateObjectMap [ rr:predicate p:RoomID ; rr:objectMap [ rr:column "RoomID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BuildingID ; rr:objectMap [ rr:column "BuildingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Capacity ; rr:objectMap [ rr:column "Capacity" ] ] .

<#tm_vague_2cols_location2_8_Rooms_BuildingID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RoomID\", \"BuildingID\" FROM \"Rooms\" WHERE \"BuildingID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Rooms/{RoomID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBuildings ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Buildings/{BuildingID}" ; rr:termType rr:IRI ] ] .

