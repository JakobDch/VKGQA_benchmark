  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Relationship ; rr:objectMap [ rr:column "Relationship" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HomePhone ; rr:objectMap [ rr:column "HomePhone" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:WorkPhone ; rr:objectMap [ rr:column "WorkPhone" ] ] ;
