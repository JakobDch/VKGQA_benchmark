<#tm_vague_2cols_teaching_subjects_7_EmergencyContacts_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ContactID\", \"GuardianID\", \"Name\", \"Relationship\", \"PhoneNumber\" FROM \"EmergencyContacts\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/EmergencyContacts/{ContactID}" ; rr:class :EmergencyContacts ] ;
  rr:predicateObjectMap [ rr:predicate p:ContactID ; rr:objectMap [ rr:column "ContactID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GuardianID ; rr:objectMap [ rr:column "GuardianID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Relationship ; rr:objectMap [ rr:column "Relationship" ] ] ;
