<#tm_vague_2cols_teaching_subjects_8_EmergencyContacts_GuardianID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ContactID\", \"GuardianID\" FROM \"EmergencyContacts\" WHERE \"GuardianID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/EmergencyContacts/{ContactID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGuardians ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Guardians/{GuardianID}" ; rr:termType rr:IRI ] ] .

