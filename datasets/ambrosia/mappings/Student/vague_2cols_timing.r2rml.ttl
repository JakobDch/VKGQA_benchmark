<#tm_vague_2cols_timing_7_Submissions_assignment_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"submission_id\", \"assignment_id\" FROM \"Submissions\" WHERE \"assignment_id\" IS NOT NULL""" ] ;
