@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_version_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FirstName\", \"LastName\", \"Email\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{ID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:email ; rr:objectMap [ rr:column "Email" ] ] .

<#tm_vague_2cols_version_1_Instructors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"FirstName\", \"LastName\", \"Department\" FROM \"Instructors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Instructors/{ID}" ; rr:class :Instructors ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FirstName ; rr:objectMap [ rr:column "FirstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LastName ; rr:objectMap [ rr:column "LastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Department ; rr:objectMap [ rr:column "Department" ] ] .

<#tm_vague_2cols_version_2_Enrollments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RegistrationID\", \"StudentID\", \"CourseCode\", \"Grade\" FROM \"Enrollments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{RegistrationID}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:RegistrationID ; rr:objectMap [ rr:column "RegistrationID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StudentID ; rr:objectMap [ rr:column "StudentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseCode ; rr:objectMap [ rr:column "CourseCode" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Grade ; rr:objectMap [ rr:column "Grade" ] ] .

<#tm_vague_2cols_version_3_Enrollments_StudentID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"RegistrationID\", \"StudentID\" FROM \"Enrollments\" WHERE \"StudentID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{RegistrationID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{StudentID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_version_4_TextbookEditions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"EditionNumber\", \"YearPublished\", \"Publisher\", \"ISBN\", \"Textbooks\" FROM \"TextbookEditions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/TextbookEditions/{EditionNumber}" ; rr:class :TextbookEditions ] ;
  rr:predicateObjectMap [ rr:predicate p:EditionNumber ; rr:objectMap [ rr:column "EditionNumber" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:YearPublished ; rr:objectMap [ rr:column "YearPublished" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Publisher ; rr:objectMap [ rr:column "Publisher" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:ISBN ; rr:objectMap [ rr:column "ISBN" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Textbooks ; rr:objectMap [ rr:column "Textbooks" ] ] .

<#tm_vague_2cols_version_5_CourseOfferings_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OfferingID\", \"CourseCode\", \"Semester\", \"Year\", \"InstructorID\" FROM \"CourseOfferings\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/CourseOfferings/{OfferingID}" ; rr:class :CourseOfferings ] ;
  rr:predicateObjectMap [ rr:predicate p:OfferingID ; rr:objectMap [ rr:column "OfferingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseCode ; rr:objectMap [ rr:column "CourseCode" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Semester ; rr:objectMap [ rr:column "Semester" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Year ; rr:objectMap [ rr:column "Year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:InstructorID ; rr:objectMap [ rr:column "InstructorID" ] ] .

<#tm_vague_2cols_version_6_CourseOfferings_InstructorID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"OfferingID\", \"InstructorID\" FROM \"CourseOfferings\" WHERE \"InstructorID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/CourseOfferings/{OfferingID}" ] ;
