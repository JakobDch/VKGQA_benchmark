<#tm_vague_2cols_version_7_BookCopies_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CopyID\", \"CourseOfferingID\", \"TextbookEditionID\", \"Quantity\" FROM \"BookCopies\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/BookCopies/{CopyID}" ; rr:class :BookCopies ] ;
  rr:predicateObjectMap [ rr:predicate p:CopyID ; rr:objectMap [ rr:column "CopyID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:CourseOfferingID ; rr:objectMap [ rr:column "CourseOfferingID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:TextbookEditionID ; rr:objectMap [ rr:column "TextbookEditionID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Quantity ; rr:objectMap [ rr:column "Quantity" ] ] .

<#tm_vague_2cols_version_8_BookCopies_TextbookEditionID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CopyID\", \"TextbookEditionID\" FROM \"BookCopies\" WHERE \"TextbookEditionID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/BookCopies/{CopyID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTextbookEditions ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/TextbookEditions/{TextbookEditionID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_version_9_BookCopies_CourseOfferingID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"CopyID\", \"CourseOfferingID\" FROM \"BookCopies\" WHERE \"CourseOfferingID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/BookCopies/{CopyID}" ] ;
