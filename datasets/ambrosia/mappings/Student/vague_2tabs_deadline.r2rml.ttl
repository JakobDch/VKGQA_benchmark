@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_deadline_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"first_name\", \"last_name\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:first_name ; rr:objectMap [ rr:column "first_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:last_name ; rr:objectMap [ rr:column "last_name" ] ] .

<#tm_vague_2tabs_deadline_1_Classes_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"class_id\", \"course_title\", \"instructor\" FROM \"Classes\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Classes/{class_id}" ; rr:class :Classes ] ;
  rr:predicateObjectMap [ rr:predicate p:class_id ; rr:objectMap [ rr:column "class_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:course_title ; rr:objectMap [ rr:column "course_title" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:instructor ; rr:objectMap [ rr:column "instructor" ] ] .

<#tm_vague_2tabs_deadline_2_Date_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"date_id\", \"year\", \"month\", \"day\" FROM \"Date\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Date/{date_id}" ; rr:class :Date ] ;
  rr:predicateObjectMap [ rr:predicate p:date_id ; rr:objectMap [ rr:column "date_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:year ; rr:objectMap [ rr:column "year" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:month ; rr:objectMap [ rr:column "month" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:day ; rr:objectMap [ rr:column "day" ] ] .

<#tm_vague_2tabs_deadline_3_Time_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"time_id\", \"hour\", \"minute\", \"second\" FROM \"Time\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Time/{time_id}" ; rr:class :Time ] ;
  rr:predicateObjectMap [ rr:predicate p:time_id ; rr:objectMap [ rr:column "time_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:hour ; rr:objectMap [ rr:column "hour" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:minute ; rr:objectMap [ rr:column "minute" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:second ; rr:objectMap [ rr:column "second" ] ] .

<#tm_vague_2tabs_deadline_4_Enrollment_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"student_id\", \"class_id\" FROM \"Enrollment\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{enrollment_id}" ; rr:class :Enrollments ] ;
  rr:predicateObjectMap [ rr:predicate p:enrollment_id ; rr:objectMap [ rr:column "enrollment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:student_id ; rr:objectMap [ rr:column "student_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:class_id ; rr:objectMap [ rr:column "class_id" ] ] .

<#tm_vague_2tabs_deadline_5_Enrollment_class_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"class_id\" FROM \"Enrollment\" WHERE \"class_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{enrollment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasClasses ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Classes/{class_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_deadline_6_Enrollment_student_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"enrollment_id\", \"student_id\" FROM \"Enrollment\" WHERE \"student_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Enrollments/{enrollment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{student_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_deadline_7_Assignments_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignment_id\", \"due_date\", \"due_time\", \"description\" FROM \"Assignments\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Assignments/{assignment_id}" ; rr:class :Assignments ] ;
