  rr:predicateObjectMap [ rr:predicate p:due_date ; rr:objectMap [ rr:column "due_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:due_time ; rr:objectMap [ rr:column "due_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2tabs_deadline_8_Assignments_due_time_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignment_id\", \"due_time\" FROM \"Assignments\" WHERE \"due_time\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Assignments/{assignment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTime ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Time/{due_time}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_deadline_9_Assignments_due_date_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"assignment_id\", \"due_date\" FROM \"Assignments\" WHERE \"due_date\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Assignments/{assignment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDate ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Date/{due_date}" ; rr:termType rr:IRI ] ] .

