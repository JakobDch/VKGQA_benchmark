@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_developmental_milestones_0_Children_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"age\" FROM \"Children\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Children/{id}" ; rr:class :Children ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:age ; rr:objectMap [ rr:column "age" ] ] .

<#tm_vague_2tabs_developmental_milestones_1_Physical_Milestones_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"milestone_name\", \"description\" FROM \"Physical_Milestones\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Physical_Milestones/{id}" ; rr:class :Physical_Milestones ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:milestone_name ; rr:objectMap [ rr:column "milestone_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2tabs_developmental_milestones_2_Cognitive_Milestones_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"milestone_name\", \"description\" FROM \"Cognitive_Milestones\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Cognitive_Milestones/{id}" ; rr:class :Cognitive_Milestones ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:milestone_name ; rr:objectMap [ rr:column "milestone_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2tabs_developmental_milestones_3_Child_Age_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"child_id\", \"physical_milestone_id\", \"cognitive_milestone_id\" FROM \"Child_Age\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Child_Age/{_amb_rowid}" ; rr:class :Child_Age ] ;
  rr:predicateObjectMap [ rr:predicate p:child_id ; rr:objectMap [ rr:column "child_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:physical_milestone_id ; rr:objectMap [ rr:column "physical_milestone_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:cognitive_milestone_id ; rr:objectMap [ rr:column "cognitive_milestone_id" ] ] .

<#tm_vague_2tabs_developmental_milestones_4_Child_Age_cognitive_milestone_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"cognitive_milestone_id\" FROM \"Child_Age\" WHERE \"cognitive_milestone_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Child_Age/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasCognitive_Milestones ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Cognitive_Milestones/{cognitive_milestone_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_developmental_milestones_5_Child_Age_physical_milestone_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"physical_milestone_id\" FROM \"Child_Age\" WHERE \"physical_milestone_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Child_Age/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPhysical_Milestones ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Physical_Milestones/{physical_milestone_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_developmental_milestones_6_Child_Age_child_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"_amb_rowid\", \"child_id\" FROM \"Child_Age\" WHERE \"child_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Child_Age/{_amb_rowid}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasChildren ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Children/{child_id}" ; rr:termType rr:IRI ] ] .

