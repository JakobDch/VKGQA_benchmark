@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_location_0_Building_Name_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"address\" FROM \"Building_Name\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Buildings/{id}" ; rr:class :Buildings ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:address ; rr:objectMap [ rr:column "address" ] ] .

<#tm_vague_2tabs_location_1_University_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"university_name\", \"website\" FROM \"University\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Universities/{id}" ; rr:class :Universities ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:university_name ; rr:objectMap [ rr:column "university_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:website ; rr:objectMap [ rr:column "website" ] ] .

<#tm_vague_2tabs_location_2_Libraries_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"library_name\", \"building_id\", \"university_id\" FROM \"Libraries\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Libraries/{id}" ; rr:class :Libraries ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:library_name ; rr:objectMap [ rr:column "library_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:building_id ; rr:objectMap [ rr:column "building_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:university_id ; rr:objectMap [ rr:column "university_id" ] ] .

<#tm_vague_2tabs_location_3_Libraries_university_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"university_id\" FROM \"Libraries\" WHERE \"university_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Libraries/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUniversities ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Universities/{university_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_location_4_Libraries_building_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"building_id\" FROM \"Libraries\" WHERE \"building_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Libraries/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasBuildings ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Buildings/{building_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_location_5_Students_base> a rr:TriplesMap ;
