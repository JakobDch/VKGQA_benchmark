<#tm_vague_2tabs_location_8_Classrooms_building_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"building_id\" FROM \"Classrooms\" WHERE \"building_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Classrooms/{id}" ] ;
