@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_passing_requirements_0_Students_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\", \"birthDate\" FROM \"Students\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{id}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:birthDate ; rr:objectMap [ rr:column "birthDate" ] ] .

<#tm_vague_2tabs_passing_requirements_1_Minimum_Scores_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"score\" FROM \"Minimum_Scores\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Passing_Requirements/{id}" ; rr:class :Passing_Requirements ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:score ; rr:objectMap [ rr:column "score" ] ] .

<#tm_vague_2tabs_passing_requirements_2_Percentage_Requirements_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"percentage\" FROM \"Percentage_Requirements\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Percentage_Requirements/{id}" ; rr:class :Percentage_Requirements ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:percentage ; rr:objectMap [ rr:column "percentage" ] ] .

<#tm_vague_2tabs_passing_requirements_3_Exams_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"studentId\", \"examDate\", \"minScoreId\", \"percentReqId\" FROM \"Exams\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Exams/{id}" ; rr:class :Exams ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:studentId ; rr:objectMap [ rr:column "studentId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:examDate ; rr:objectMap [ rr:column "examDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:minScoreId ; rr:objectMap [ rr:column "minScoreId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:percentReqId ; rr:objectMap [ rr:column "percentReqId" ] ] .

<#tm_vague_2tabs_passing_requirements_4_Exams_percentReqId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"percentReqId\" FROM \"Exams\" WHERE \"percentReqId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Exams/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPercentage_Requirements ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Percentage_Requirements/{percentReqId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_passing_requirements_5_Exams_minScoreId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"minScoreId\" FROM \"Exams\" WHERE \"minScoreId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Exams/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasPassing_Requirements ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Passing_Requirements/{minScoreId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_passing_requirements_6_Exams_studentId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"studentId\" FROM \"Exams\" WHERE \"studentId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Exams/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStudents ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{studentId}" ; rr:termType rr:IRI ] ] .

