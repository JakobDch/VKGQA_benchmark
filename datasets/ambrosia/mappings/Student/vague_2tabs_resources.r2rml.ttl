@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_resources_0_OnlineResources_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"resourceId\", \"url\", \"title\" FROM \"OnlineResources\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/OnlineResources/{resourceId}" ; rr:class :OnlineResources ] ;
  rr:predicateObjectMap [ rr:predicate p:resourceId ; rr:objectMap [ rr:column "resourceId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:url ; rr:objectMap [ rr:column "url" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:title ; rr:objectMap [ rr:column "title" ] ] .

<#tm_vague_2tabs_resources_1_TestPreparations_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"preparationId\", \"topic\", \"resourcesId\", \"servicesId\" FROM \"TestPreparations\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/TestPreparations/{preparationId}" ; rr:class :TestPreparations ] ;
  rr:predicateObjectMap [ rr:predicate p:preparationId ; rr:objectMap [ rr:column "preparationId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:topic ; rr:objectMap [ rr:column "topic" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:resourcesId ; rr:objectMap [ rr:column "resourcesId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:servicesId ; rr:objectMap [ rr:column "servicesId" ] ] .

<#tm_vague_2tabs_resources_2_TestPreparations_servicesId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"preparationId\", \"servicesId\" FROM \"TestPreparations\" WHERE \"servicesId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/TestPreparations/{preparationId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTutoringServices ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/TutoringServices/{servicesId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_resources_3_TestPreparations_resourcesId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"preparationId\", \"resourcesId\" FROM \"TestPreparations\" WHERE \"resourcesId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/TestPreparations/{preparationId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasOnlineResources ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/OnlineResources/{resourcesId}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_resources_4_TutoringServices_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"serviceId\", \"tutorId\", \"date\", \"duration\" FROM \"TutoringServices\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/TutoringServices/{serviceId}" ; rr:class :TutoringServices ] ;
  rr:predicateObjectMap [ rr:predicate p:serviceId ; rr:objectMap [ rr:column "serviceId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:tutorId ; rr:objectMap [ rr:column "tutorId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:duration ; rr:objectMap [ rr:column "duration" ] ] .

<#tm_vague_2tabs_resources_5_Tutors_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"firstName\", \"lastName\" FROM \"Tutors\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Tutors/{id}" ; rr:class :Tutors ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:firstName ; rr:objectMap [ rr:column "firstName" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:lastName ; rr:objectMap [ rr:column "lastName" ] ] .

