<#tm_vague_2tabs_studies_3_Faculty_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"faculty_name\", \"department_id\" FROM \"Faculty\"""" ] ;
