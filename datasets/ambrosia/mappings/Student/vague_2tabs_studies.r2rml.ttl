<#tm_vague_2tabs_studies_4_Faculty_department_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"department_id\" FROM \"Faculty\" WHERE \"department_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Faculty/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasDepartments ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Departments/{department_id}" ; rr:termType rr:IRI ] ] .

