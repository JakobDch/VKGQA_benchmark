@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_teaching_subjects_0_Academic_Discipline_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"DisciplineID\", \"Name\", \"Description\" FROM \"Academic_Discipline\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Academic_Discipline/{DisciplineID}" ; rr:class :Academic_Discipline ] ;
  rr:predicateObjectMap [ rr:predicate p:DisciplineID ; rr:objectMap [ rr:column "DisciplineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Description ; rr:objectMap [ rr:column "Description" ] ] .

<#tm_vague_2tabs_teaching_subjects_1_Grade_Level_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"LevelID\", \"Name\", \"MinAge\", \"MaxAge\" FROM \"Grade_Level\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Grade_Level/{LevelID}" ; rr:class :Grade_Level ] ;
  rr:predicateObjectMap [ rr:predicate p:LevelID ; rr:objectMap [ rr:column "LevelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MinAge ; rr:objectMap [ rr:column "MinAge" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MaxAge ; rr:objectMap [ rr:column "MaxAge" ] ] .

<#tm_vague_2tabs_teaching_subjects_2_Student_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"BirthDate\", \"GradeLevelID\", \"DisciplineID\", \"fullname\" FROM \"Student\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{ID}" ; rr:class :Students ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:BirthDate ; rr:objectMap [ rr:column "BirthDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GradeLevelID ; rr:objectMap [ rr:column "GradeLevelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DisciplineID ; rr:objectMap [ rr:column "DisciplineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "fullname" ] ] .

<#tm_vague_2tabs_teaching_subjects_3_Student_DisciplineID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"DisciplineID\" FROM \"Student\" WHERE \"DisciplineID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAcademic_Discipline ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Academic_Discipline/{DisciplineID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_teaching_subjects_4_Student_GradeLevelID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"GradeLevelID\" FROM \"Student\" WHERE \"GradeLevelID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Students/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGrade_Level ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Grade_Level/{GradeLevelID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_teaching_subjects_5_Teacher_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"HireDate\", \"GradeLevelID\", \"DisciplineID\", \"fullname\" FROM \"Teacher\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Teachers/{ID}" ; rr:class :Teachers ] ;
  rr:predicateObjectMap [ rr:predicate p:ID ; rr:objectMap [ rr:column "ID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:HireDate ; rr:objectMap [ rr:column "HireDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:GradeLevelID ; rr:objectMap [ rr:column "GradeLevelID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:DisciplineID ; rr:objectMap [ rr:column "DisciplineID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "fullname" ] ] .

<#tm_vague_2tabs_teaching_subjects_6_Teacher_DisciplineID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"DisciplineID\" FROM \"Teacher\" WHERE \"DisciplineID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Teachers/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasAcademic_Discipline ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Academic_Discipline/{DisciplineID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_teaching_subjects_7_Teacher_GradeLevelID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ID\", \"GradeLevelID\" FROM \"Teacher\" WHERE \"GradeLevelID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Teachers/{ID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasGrade_Level ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Grade_Level/{GradeLevelID}" ; rr:termType rr:IRI ] ] .

