@prefix : <http://ambrosia.example.org/student#> .
@prefix p: <http://ambrosia.example.org/student/prop#> .
@prefix ex: <http://ambrosia.example.org/student/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2tabs_topic_0_Industry_Sector_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"description\" FROM \"Industry_Sector\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Industry_Sector/{id}" ; rr:class :Industry_Sector ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_vague_2tabs_topic_1_Project_Name_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"project_name\", \"start_date\", \"end_date\" FROM \"Project_Name\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Project_Name/{id}" ; rr:class :Project_Name ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:project_name ; rr:objectMap [ rr:column "project_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_date ; rr:objectMap [ rr:column "start_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_date ; rr:objectMap [ rr:column "end_date" ] ] .

<#tm_vague_2tabs_topic_2_Internship_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"student_id\", \"industry_sector_id\", \"project_id\" FROM \"Internship\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Internship/{id}" ; rr:class :Internship ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:student_id ; rr:objectMap [ rr:column "student_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:industry_sector_id ; rr:objectMap [ rr:column "industry_sector_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:project_id ; rr:objectMap [ rr:column "project_id" ] ] .

<#tm_vague_2tabs_topic_3_Internship_project_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"project_id\" FROM \"Internship\" WHERE \"project_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Internship/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasProject_Name ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Project_Name/{project_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2tabs_topic_4_Internship_industry_sector_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"industry_sector_id\" FROM \"Internship\" WHERE \"industry_sector_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/student/id/Internship/{id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasIndustry_Sector ; rr:objectMap [ rr:template "http://ambrosia.example.org/student/id/Industry_Sector/{industry_sector_id}" ; rr:termType rr:IRI ] ] .

