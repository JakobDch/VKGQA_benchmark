@prefix : <http://ambrosia.example.org/traffic#> .
@prefix p: <http://ambrosia.example.org/traffic/prop#> .
@prefix ex: <http://ambrosia.example.org/traffic/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_education_program_target_audiences_0_Education_Program_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"description\" FROM \"Education_Program\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Education_Program/{id}" ; rr:class :Education_Program ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:description ; rr:objectMap [ rr:column "description" ] ] .

<#tm_scope_education_program_target_audiences_1_Target_Audiences_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"audience_name\" FROM \"Target_Audiences\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Target_Audiences/{id}" ; rr:class :Target_Audiences ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "audience_name" ] ] .

<#tm_scope_education_program_target_audiences_2_Education_Program_Target_Audiences_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"education_program_id\", \"target_audience_id\" FROM \"Education_Program_Target_Audiences\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Education_Program_Target_Audiences/{education_program_id}/{target_audience_id}" ; rr:class :Education_Program_Target_Audiences ] .

<#tm_scope_education_program_target_audiences_3_Education_Program_Target_Audiences_target_audience_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"education_program_id\", \"target_audience_id\" FROM \"Education_Program_Target_Audiences\" WHERE \"target_audience_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Education_Program_Target_Audiences/{education_program_id}/{target_audience_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTarget_Audiences ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Target_Audiences/{target_audience_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_education_program_target_audiences_4_Education_Program_Target_Audiences_education_program_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"education_program_id\", \"target_audience_id\" FROM \"Education_Program_Target_Audiences\" WHERE \"education_program_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Education_Program_Target_Audiences/{education_program_id}/{target_audience_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasEducation_Program ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Education_Program/{education_program_id}" ; rr:termType rr:IRI ] ] .

