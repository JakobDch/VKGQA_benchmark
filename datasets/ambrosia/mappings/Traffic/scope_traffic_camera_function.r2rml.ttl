@prefix : <http://ambrosia.example.org/traffic#> .
@prefix p: <http://ambrosia.example.org/traffic/prop#> .
@prefix ex: <http://ambrosia.example.org/traffic/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_traffic_camera_function_0_Traffic_Camera_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"location\" FROM \"Traffic_Camera\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Camera/{id}" ; rr:class :Traffic_Camera ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_traffic_camera_function_1_Function_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"functionName\" FROM \"Function\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Function/{id}" ; rr:class :Function ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "functionName" ] ] .

<#tm_scope_traffic_camera_function_2_Traffic_Camera_Function_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cameraId\", \"functionId\" FROM \"Traffic_Camera_Function\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Camera_Function/{functionId}/{cameraId}" ; rr:class :Traffic_Camera_Function ] .

<#tm_scope_traffic_camera_function_3_Traffic_Camera_Function_functionId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"functionId\", \"cameraId\" FROM \"Traffic_Camera_Function\" WHERE \"functionId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Camera_Function/{functionId}/{cameraId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFunction ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Function/{functionId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_traffic_camera_function_4_Traffic_Camera_Function_cameraId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"functionId\", \"cameraId\" FROM \"Traffic_Camera_Function\" WHERE \"cameraId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Camera_Function/{functionId}/{cameraId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTraffic_Camera ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Camera/{cameraId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_traffic_camera_function_5_Road_Condition_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"roadId\", \"condition\" FROM \"Road_Condition\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Road_Condition/{id}" ; rr:class :Road_Condition ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:roadId ; rr:objectMap [ rr:column "roadId" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:condition ; rr:objectMap [ rr:column "condition" ] ] .

<#tm_scope_traffic_camera_function_6_Camera_Road_Link_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"cameraId\", \"roadId\" FROM \"Camera_Road_Link\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Camera_Road_Link/{roadId}/{cameraId}" ; rr:class :Camera_Road_Link ] .

<#tm_scope_traffic_camera_function_7_Camera_Road_Link_roadId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"roadId\", \"cameraId\" FROM \"Camera_Road_Link\" WHERE \"roadId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Camera_Road_Link/{roadId}/{cameraId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasRoad_Condition ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Road_Condition/{roadId}" ; rr:termType rr:IRI ] ] .

<#tm_scope_traffic_camera_function_8_Camera_Road_Link_cameraId_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"roadId\", \"cameraId\" FROM \"Camera_Road_Link\" WHERE \"cameraId\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Camera_Road_Link/{roadId}/{cameraId}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTraffic_Camera ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Camera/{cameraId}" ; rr:termType rr:IRI ] ] .

