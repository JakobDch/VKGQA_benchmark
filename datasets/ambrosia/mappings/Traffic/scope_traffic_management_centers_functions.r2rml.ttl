@prefix : <http://ambrosia.example.org/traffic#> .
@prefix p: <http://ambrosia.example.org/traffic/prop#> .
@prefix ex: <http://ambrosia.example.org/traffic/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_traffic_management_centers_functions_0_Functions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"functionName\" FROM \"Functions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Function/{id}" ; rr:class :Function ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "functionName" ] ] .

<#tm_scope_traffic_management_centers_functions_1_Traffic_Management_Centers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"centerID\", \"name\", \"location\" FROM \"Traffic_Management_Centers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Management_Centers/{centerID}" ; rr:class :Traffic_Management_Centers ] ;
  rr:predicateObjectMap [ rr:predicate p:centerID ; rr:objectMap [ rr:column "centerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:location ; rr:objectMap [ rr:column "location" ] ] .

<#tm_scope_traffic_management_centers_functions_2_Traffic_Management_Centers_Functions_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TMC_id\", \"Function_id\" FROM \"Traffic_Management_Centers_Functions\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Management_Centers_Functions/{Function_id}/{TMC_id}" ; rr:class :Traffic_Management_Centers_Functions ] .

<#tm_scope_traffic_management_centers_functions_3_Traffic_Management_Centers_Functions_Function_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Function_id\", \"TMC_id\" FROM \"Traffic_Management_Centers_Functions\" WHERE \"Function_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Management_Centers_Functions/{Function_id}/{TMC_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasFunction ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Function/{Function_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_traffic_management_centers_functions_4_Traffic_Management_Centers_Functions_TMC_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"Function_id\", \"TMC_id\" FROM \"Traffic_Management_Centers_Functions\" WHERE \"TMC_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Management_Centers_Functions/{Function_id}/{TMC_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTraffic_Management_Centers ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Management_Centers/{TMC_id}" ; rr:termType rr:IRI ] ] .

