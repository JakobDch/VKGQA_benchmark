@prefix : <http://ambrosia.example.org/traffic#> .
@prefix p: <http://ambrosia.example.org/traffic/prop#> .
@prefix ex: <http://ambrosia.example.org/traffic/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_scope_traffic_simulators_applications_0_Applications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"application_name\" FROM \"Applications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Applications/{application_id}" ; rr:class :Applications ] ;
  rr:predicateObjectMap [ rr:predicate p:application_id ; rr:objectMap [ rr:column "application_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "application_name" ] ] .

<#tm_scope_traffic_simulators_applications_1_Traffic_Simulators_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"simulator_id\", \"simulator_name\", \"simulator_version\" FROM \"Traffic_Simulators\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Simulators/{simulator_id}" ; rr:class :Traffic_Simulators ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "simulator_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:version ; rr:objectMap [ rr:column "simulator_version" ] ] .

<#tm_scope_traffic_simulators_applications_2_Traffic_Simulators_simulator_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"simulator_id\" FROM \"Traffic_Simulators\" WHERE \"simulator_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Simulators/{simulator_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTraffic_Simulators_Applications ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Simulators_Applications/{simulator_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_traffic_simulators_applications_3_Traffic_Simulators_Applications_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"traffic_simulator_id\", \"application_id\" FROM \"Traffic_Simulators_Applications\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Simulators_Applications/{application_id}/{traffic_simulator_id}" ; rr:class :Traffic_Simulators_Applications ] .

<#tm_scope_traffic_simulators_applications_4_Traffic_Simulators_Applications_application_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"traffic_simulator_id\" FROM \"Traffic_Simulators_Applications\" WHERE \"application_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Simulators_Applications/{application_id}/{traffic_simulator_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasApplications ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Applications/{application_id}" ; rr:termType rr:IRI ] ] .

<#tm_scope_traffic_simulators_applications_5_Traffic_Simulators_Applications_traffic_simulator_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"application_id\", \"traffic_simulator_id\" FROM \"Traffic_Simulators_Applications\" WHERE \"traffic_simulator_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Simulators_Applications/{application_id}/{traffic_simulator_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasTraffic_Simulators ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Traffic_Simulators/{traffic_simulator_id}" ; rr:termType rr:IRI ] ] .

