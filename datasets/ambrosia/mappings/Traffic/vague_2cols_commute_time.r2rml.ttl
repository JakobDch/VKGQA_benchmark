@prefix : <http://ambrosia.example.org/traffic#> .
@prefix p: <http://ambrosia.example.org/traffic/prop#> .
@prefix ex: <http://ambrosia.example.org/traffic/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_commute_time_0_Neighborhood_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"name\", \"population\", \"mean_commute_time\", \"median_commute_time\" FROM \"Neighborhood\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Neighborhood/{id}" ; rr:class :Neighborhood ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:population ; rr:objectMap [ rr:column "population" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:meanCommuteTime ; rr:objectMap [ rr:column "mean_commute_time" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:medianCommuteTime ; rr:objectMap [ rr:column "median_commute_time" ] ] .

<#tm_vague_2cols_commute_time_1_VehicleType_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"id\", \"type_name\", \"count_passing\" FROM \"VehicleType\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/VehicleType/{id}" ; rr:class :VehicleType ] ;
  rr:predicateObjectMap [ rr:predicate p:id ; rr:objectMap [ rr:column "id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:name ; rr:objectMap [ rr:column "type_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:count_passing ; rr:objectMap [ rr:column "count_passing" ] ] .

<#tm_vague_2cols_commute_time_2_DailyTrafficVolume_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"date\", \"neighborhood_id\", \"total_traffic\" FROM \"DailyTrafficVolume\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/DailyTrafficVolume/{neighborhood_id}" ; rr:class :DailyTrafficVolume ] ;
  rr:predicateObjectMap [ rr:predicate p:date ; rr:objectMap [ rr:column "date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:total_traffic ; rr:objectMap [ rr:column "total_traffic" ] ] .

<#tm_vague_2cols_commute_time_3_DailyTrafficVolume_neighborhood_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"neighborhood_id\" FROM \"DailyTrafficVolume\" WHERE \"neighborhood_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/DailyTrafficVolume/{neighborhood_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNeighborhood ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Neighborhood/{neighborhood_id}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_commute_time_4_Accidents_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"accident_date\", \"neighborhood_id\", \"num_accident\" FROM \"Accidents\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Accidents/{neighborhood_id}" ; rr:class :Accidents ] ;
  rr:predicateObjectMap [ rr:predicate p:accident_date ; rr:objectMap [ rr:column "accident_date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:num_accident ; rr:objectMap [ rr:column "num_accident" ] ] .

<#tm_vague_2cols_commute_time_5_Accidents_neighborhood_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"neighborhood_id\" FROM \"Accidents\" WHERE \"neighborhood_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Accidents/{neighborhood_id}" ] ;
