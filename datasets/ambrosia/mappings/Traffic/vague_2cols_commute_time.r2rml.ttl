<#tm_vague_2cols_commute_time_8_SpeedLimits_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"road_segment_id\", \"street_name\", \"neighborhood_id\", \"start_point\", \"end_point\", \"max_limit\", \"min_limit\" FROM \"SpeedLimits\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/SpeedLimits/{road_segment_id}" ; rr:class :SpeedLimits ] ;
  rr:predicateObjectMap [ rr:predicate p:road_segment_id ; rr:objectMap [ rr:column "road_segment_id" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:street_name ; rr:objectMap [ rr:column "street_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:start_point ; rr:objectMap [ rr:column "start_point" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:end_point ; rr:objectMap [ rr:column "end_point" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:max_limit ; rr:objectMap [ rr:column "max_limit" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:min_limit ; rr:objectMap [ rr:column "min_limit" ] ] .

<#tm_vague_2cols_commute_time_9_SpeedLimits_neighborhood_id_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"road_segment_id\", \"neighborhood_id\" FROM \"SpeedLimits\" WHERE \"neighborhood_id\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/SpeedLimits/{road_segment_id}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasNeighborhood ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Neighborhood/{neighborhood_id}" ; rr:termType rr:IRI ] ] .

