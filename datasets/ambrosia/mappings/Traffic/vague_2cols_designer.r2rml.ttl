@prefix : <http://ambrosia.example.org/traffic#> .
@prefix p: <http://ambrosia.example.org/traffic/prop#> .
@prefix ex: <http://ambrosia.example.org/traffic/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_designer_0_CivilEngineers_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"ProjectID\", \"Intersection\", \"Civil_Engineer\", \"Engineering_Firm\", \"StartDate\", \"EndDate\", \"Budget\" FROM \"CivilEngineers\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/CivilEngineers/{ProjectID}" ; rr:class :CivilEngineers ] ;
  rr:predicateObjectMap [ rr:predicate p:ProjectID ; rr:objectMap [ rr:column "ProjectID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Intersection ; rr:objectMap [ rr:column "Intersection" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Civil_Engineer ; rr:objectMap [ rr:column "Civil_Engineer" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Engineering_Firm ; rr:objectMap [ rr:column "Engineering_Firm" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:StartDate ; rr:objectMap [ rr:column "StartDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:EndDate ; rr:objectMap [ rr:column "EndDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Budget ; rr:objectMap [ rr:column "Budget" ] ] .

