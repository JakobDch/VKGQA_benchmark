@prefix : <http://ambrosia.example.org/traffic#> .
@prefix p: <http://ambrosia.example.org/traffic/prop#> .
@prefix ex: <http://ambrosia.example.org/traffic/id/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_vague_2cols_location_0_Streets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"StreetID\", \"Street_Name\", \"Block_Number\", \"Bus_Stop\", \"NumLanes\", \"MaxSpeed\" FROM \"Streets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Streets/{StreetID}" ; rr:class :Streets ] ;
  rr:predicateObjectMap [ rr:predicate p:StreetID ; rr:objectMap [ rr:column "StreetID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Street_Name ; rr:objectMap [ rr:column "Street_Name" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Block_Number ; rr:objectMap [ rr:column "Block_Number" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Bus_Stop ; rr:objectMap [ rr:column "Bus_Stop" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:NumLanes ; rr:objectMap [ rr:column "NumLanes" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:MaxSpeed ; rr:objectMap [ rr:column "MaxSpeed" ] ] .

<#tm_vague_2cols_location_1_Accidents_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccidentID\", \"Date\", \"LocationID\", \"Severity\" FROM \"Accidents\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Accidents/{AccidentID}" ; rr:class :Accidents ] ;
  rr:predicateObjectMap [ rr:predicate p:AccidentID ; rr:objectMap [ rr:column "AccidentID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:Date ; rr:objectMap [ rr:column "Date" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:severity ; rr:objectMap [ rr:column "Severity" ] ] .

<#tm_vague_2cols_location_2_Accidents_LocationID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"AccidentID\", \"LocationID\" FROM \"Accidents\" WHERE \"LocationID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Accidents/{AccidentID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreets ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Streets/{LocationID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_3_Vehicles_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"VehicleID\", \"Type\", \"LicensePlate\", \"OwnerID\" FROM \"Vehicles\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Vehicles/{VehicleID}" ; rr:class :Vehicles ] ;
  rr:predicateObjectMap [ rr:predicate p:VehicleID ; rr:objectMap [ rr:column "VehicleID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:type ; rr:objectMap [ rr:column "Type" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:LicensePlate ; rr:objectMap [ rr:column "LicensePlate" ] ] .

<#tm_vague_2cols_location_4_Vehicles_OwnerID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"VehicleID\", \"OwnerID\" FROM \"Vehicles\" WHERE \"OwnerID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Vehicles/{VehicleID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasUsers ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Users/{OwnerID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_5_Users_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"UserID\", \"FirstName\", \"LastName\", \"Email\", \"PhoneNumber\" FROM \"Users\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/Users/{UserID}" ; rr:class :Users ] ;
