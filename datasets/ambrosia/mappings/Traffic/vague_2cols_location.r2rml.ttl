  rr:logicalTable [ rr:sqlQuery """SELECT \"WorkID\", \"StartDate\", \"EndDate\", \"StreetID\", \"WorkType\" FROM \"RoadWorks\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/RoadWorks/{WorkID}" ; rr:class :RoadWorks ] ;
