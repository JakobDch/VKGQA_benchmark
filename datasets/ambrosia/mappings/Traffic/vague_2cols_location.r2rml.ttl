<#tm_vague_2cols_location_7_RoadWorks_StreetID_fk> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"WorkID\", \"StreetID\" FROM \"RoadWorks\" WHERE \"StreetID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/RoadWorks/{WorkID}" ] ;
  rr:predicateObjectMap [ rr:predicate p:hasStreets ; rr:objectMap [ rr:template "http://ambrosia.example.org/traffic/id/Streets/{StreetID}" ; rr:termType rr:IRI ] ] .

<#tm_vague_2cols_location_8_SpeedingTickets_base> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT \"TicketID\", \"IssueDate\", \"OffenderVehicleID\", \"FineAmount\" FROM \"SpeedingTickets\"""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/SpeedingTickets/{TicketID}" ; rr:class :SpeedingTickets ] ;
  rr:predicateObjectMap [ rr:predicate p:TicketID ; rr:objectMap [ rr:column "TicketID" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:IssueDate ; rr:objectMap [ rr:column "IssueDate" ] ] ;
  rr:predicateObjectMap [ rr:predicate p:FineAmount ; rr:objectMap [ rr:column "FineAmount" ] ] .

