  rr:logicalTable [ rr:sqlQuery """SELECT \"TicketID\", \"OffenderVehicleID\" FROM \"SpeedingTickets\" WHERE \"OffenderVehicleID\" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "http://ambrosia.example.org/traffic/id/SpeedingTickets/{TicketID}" ] ;
