@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix cwe: <http://w3id.org/sepses/vocab/ref/cwe#> .

<#tm_table1_cwe> a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "table1" ] ;
  rr:subjectMap [ rr:template "https://w3id.org/ambiguity/noise/cwe_secutable/resource/CWE/table1/{cwe_id}" ; rr:class cwe:CWE ] ;
  rr:predicateObjectMap [ rr:predicate rdfs:label ; rr:objectMap [ rr:column "name" ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:abstraction ; rr:objectMap [ rr:column "weakness_abstraction" ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:status ; rr:objectMap [ rr:column "status" ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:extendedDescription ; rr:objectMap [ rr:column "extended_description" ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:weaknessOrdinality ; rr:objectMap [ rr:column "weakness_ordinalities" ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:backgroundDetail ; rr:objectMap [ rr:column "background_details" ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:likelihoodOfExploit ; rr:objectMap [ rr:column "likelihood_of_exploit" ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:hasRelatedWeakness ; rr:objectMap [ rr:template "https://w3id.org/ambiguity/noise/cwe_secutable/resource/RelatedWeakness/table1/{row_id}/c6" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:hasApplicablePlatform ; rr:objectMap [ rr:template "https://w3id.org/ambiguity/noise/cwe_secutable/resource/ApplicablePlatform/table1/{row_id}/c8" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:hasModeOfIntroduction ; rr:objectMap [ rr:template "https://w3id.org/ambiguity/noise/cwe_secutable/resource/ModeOfIntroduction/table1/{row_id}/c11" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:hasCommonConsequence ; rr:objectMap [ rr:template "https://w3id.org/ambiguity/noise/cwe_secutable/resource/CommonConsequence/table1/{row_id}/c14" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:hasDetectionMethod ; rr:objectMap [ rr:template "https://w3id.org/ambiguity/noise/cwe_secutable/resource/DetectionMethod/table1/{row_id}/c15" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate cwe:hasPotentialMitigation ; rr:objectMap [ rr:template "https://w3id.org/ambiguity/noise/cwe_secutable/resource/PotentialMitigation/table1/{row_id}/c16" ; rr:termType rr:IRI ] ] .

<#tm_table1_RelatedWeakness_c6> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT row_id, "related_weaknesses" FROM "table1" WHERE "related_weaknesses" IS NOT NULL""" ] ;
  rr:subjectMap [ rr:template "https://w3id.org/ambiguity/noise/cwe_secutable/resource/RelatedWeakness/table1/{row_id}/c6" ; rr:class cwe:RelatedWeakness ] ;
  rr:predicateObjectMap [ rr:predicate rdfs:label ; rr:objectMap [ rr:column "related_weaknesses" ] ] .

<#tm_table1_ApplicablePlatform_c8> a rr:TriplesMap ;
