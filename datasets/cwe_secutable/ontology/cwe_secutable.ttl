    rdfs:range xsd:string .

:modeOfIntroductionPhase a owl:DatatypeProperty ;
    rdfs:label "modeOfIntroductionPhase" ;
    rdfs:domain :ModeOfIntroduction ;
    rdfs:range xsd:string .

:modificationComment a owl:DatatypeProperty ;
    rdfs:label "modificationComment" ;
    rdfs:domain :ModificationHistory ;
    rdfs:range xsd:string .

:modificationDate a owl:DatatypeProperty ;
    rdfs:label "modificationDate" ;
    rdfs:domain :ModificationHistory ;
    rdfs:range xsd:string .

