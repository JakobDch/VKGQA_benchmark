<http://w3id.org/sepses/vocab/ref/capec#CAPEC> a owl:Class ;
    rdfs:label "CAPEC" ;
    rdfs:subClassOf owl:Thing .

:SubmissionHistory a owl:Class ;
    rdfs:label "SubmissionHistory" ;
    rdfs:subClassOf owl:Thing .

