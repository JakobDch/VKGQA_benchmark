@prefix : <http://w3id.org/sepses/vocab/ref/cwe#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dc:creator a owl:AnnotationProperty .

dc:description a owl:AnnotationProperty .

dc:rights a owl:AnnotationProperty .

dc:title a owl:AnnotationProperty .

vann:preferredNamespacePrefix a owl:AnnotationProperty .

<http://w3id.org/sepses/vocab/ref/cwe> a owl:Ontology ;
    dc:creator "Andreas Ekelhart",
        "Elmar Kiesling",
        "Fajar J. Ekaputra",
        "Kabul Kurniawan" ;
    dc:description """An ontology to represent CWE 
This ontology is developed based on the CWE resources extracted from MITRE CWE (https://cwe.mitre.org/) """@en ;
    dc:rights "http://creativecommons.org/licenses/by/4.0/" ;
    dc:title "CWE Ontology" ;
    vann:preferredNamespacePrefix "cwe" ;
    owl:versionIRI <https://w3id.org/sepses/vocab/ref/cwe/2.0.0> .

:abstraction a owl:DatatypeProperty ;
    rdfs:label "abstraction" ;
    rdfs:domain :CWE ;
    rdfs:range xsd:string .

:applicablePlatformLanguage a owl:DatatypeProperty ;
    rdfs:label "applicablePlatformLanguage" ;
    rdfs:domain :ApplicablePlatform ;
    rdfs:range xsd:string .

:applicablePlatformParadigm a owl:DatatypeProperty ;
    rdfs:label "applicablePlatformParadigm" ;
    rdfs:domain :ApplicablePlatform ;
    rdfs:range xsd:string .

:applicablePlatformTechnology a owl:DatatypeProperty ;
    rdfs:label "applicablePlatformTechnology" ;
    rdfs:domain :ApplicablePlatform ;
    rdfs:range xsd:string .

:backgroundDetail a owl:DatatypeProperty ;
    rdfs:label "backgroundDetail" ;
    rdfs:domain :CWE ;
    rdfs:range xsd:string .

:consequenceImpact a owl:DatatypeProperty ;
    rdfs:label "consequenceImpact" ;
    rdfs:domain :CommonConsequence ;
    rdfs:range xsd:string .

:consequenceNote a owl:DatatypeProperty ;
    rdfs:label "consequenceNote" ;
    rdfs:domain :CommonConsequence ;
    rdfs:range xsd:string .

:consequenceScope a owl:DatatypeProperty ;
    rdfs:label "consequenceScope" ;
    rdfs:domain :CommonConsequence ;
    rdfs:range xsd:string .

:detectionDescription a owl:DatatypeProperty ;
    rdfs:label "detectionDescription" ;
    rdfs:domain :DetectionMethod ;
    rdfs:range xsd:string .

:detectionEffectiveness a owl:DatatypeProperty ;
    rdfs:label "detectionEffectiveness" ;
    rdfs:domain :DetectionMethod ;
    rdfs:range xsd:string .

:detectionEffectivenessNote a owl:DatatypeProperty ;
    rdfs:label "detectionEffectiveness" ;
    rdfs:domain :DetectionMethod ;
    rdfs:range xsd:string .

:detectionMethod a owl:DatatypeProperty ;
    rdfs:label "detectionMethod" ;
    rdfs:domain :DetectionMethod ;
    rdfs:range xsd:string .

:extendedDescription a owl:DatatypeProperty ;
    rdfs:label "extendedDescription" ;
    rdfs:domain :CWE ;
    rdfs:range xsd:string .

:hasApplicablePlatform a owl:ObjectProperty ;
    rdfs:label "hasApplicablePlatform" ;
    rdfs:domain :CWE ;
    rdfs:range :ApplicablePlatform .

:hasCAPEC a owl:ObjectProperty ;
    rdfs:label "hasCAPEC" ;
    rdfs:domain :CWE ;
    rdfs:range <http://w3id.org/sepses/vocab/ref/capec#CAPEC> .

:hasCommonConsequence a owl:ObjectProperty ;
    rdfs:label "hasCommonConsequence" ;
    rdfs:domain :CWE ;
    rdfs:range :CommonConsequence ;
    owl:inverseOf :isCommonConsequenceOf .

:hasDetectionMethod a owl:ObjectProperty ;
    rdfs:label "hasDetectionMethod" ;
    rdfs:domain :CWE ;
    rdfs:range :DetectionMethod ;
    owl:inverseOf :isDetectionMethodOf .

:hasModeOfIntroduction a owl:ObjectProperty ;
    rdfs:label "hasModeOfIntroduction" ;
    rdfs:domain :CWE ;
    rdfs:range :ModeOfIntroduction ;
    owl:inverseOf :isModeOfIntroductionOf .

:hasModificationHistory a owl:ObjectProperty ;
    rdfs:label "hasModificationHistory" ;
    rdfs:domain :CWE ;
    rdfs:range :ModificationHistory .

:hasPotentialMitigation a owl:ObjectProperty ;
    rdfs:label "hasPotentialMitigation" ;
    rdfs:domain :CWE ;
    rdfs:range :PotentialMitigation ;
    owl:inverseOf :isPotentialMitigationOf .

:hasReference a owl:ObjectProperty ;
    rdfs:label "hasReference" ;
    rdfs:domain :CWE ;
    rdfs:range :Reference .

:hasRelatedWeakness a owl:ObjectProperty ;
    rdfs:label "hasRelatedWeakness" ;
    rdfs:domain :CWE ;
    rdfs:range :RelatedWeakness ;
    owl:inverseOf :isRelatedWeaknessOf .

:hasSubmissionHistory a owl:ObjectProperty ;
    rdfs:label "hasSubmissionHistory" ;
    rdfs:domain :CWE ;
    rdfs:range :SubmissionHistory .

:isModificationHistoryOf a owl:ObjectProperty ;
