@prefix : <http://example.org/eicu#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_eicu_0_eicu_patient> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT DISTINCT UNIQUEPID FROM PATIENT""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#patient/{UNIQUEPID}" ; rr:class :Patient ] ;
  rr:predicateObjectMap [ rr:predicate :uniquePid ; rr:objectMap [ rr:column "UNIQUEPID" ; rr:datatype xsd:string ] ] .

<#tm_eicu_1_eicu_hospitalstay> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT DISTINCT PATIENTHEALTHSYSTEMSTAYID, UNIQUEPID FROM PATIENT""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#hospitalstay/{PATIENTHEALTHSYSTEMSTAYID}" ; rr:class :HospitalStay ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/eicu#patient/{UNIQUEPID}" ; rr:termType rr:IRI ] ] .

<#tm_eicu_2_eicu_icustay> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT PATIENTUNITSTAYID, PATIENTHEALTHSYSTEMSTAYID, GENDER, AGE, ETHNICITY, HOSPITALID, WARDID, ADMISSIONHEIGHT, ADMISSIONWEIGHT, DISCHARGEWEIGHT, HOSPITALADMITTIME, HOSPITALADMITSOURCE, UNITADMITTIME, UNITDISCHARGETIME, HOSPITALDISCHARGETIME, HOSPITALDISCHARGESTATUS FROM PATIENT""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#icustay/{PATIENTUNITSTAYID}" ; rr:class :IcuStay ] ;
  rr:predicateObjectMap [ rr:predicate :ofHospitalStay ; rr:objectMap [ rr:template "http://example.org/eicu#hospitalstay/{PATIENTHEALTHSYSTEMSTAYID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :gender ; rr:objectMap [ rr:column "GENDER" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :age ; rr:objectMap [ rr:column "AGE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :ethnicity ; rr:objectMap [ rr:column "ETHNICITY" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :hospitalId ; rr:objectMap [ rr:column "HOSPITALID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :wardId ; rr:objectMap [ rr:column "WARDID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :admissionHeight ; rr:objectMap [ rr:column "ADMISSIONHEIGHT" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :admissionWeight ; rr:objectMap [ rr:column "ADMISSIONWEIGHT" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :dischargeWeight ; rr:objectMap [ rr:column "DISCHARGEWEIGHT" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :hospitalAdmitTime ; rr:objectMap [ rr:column "HOSPITALADMITTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :hospitalAdmitSource ; rr:objectMap [ rr:column "HOSPITALADMITSOURCE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :unitAdmitTime ; rr:objectMap [ rr:column "UNITADMITTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :unitDischargeTime ; rr:objectMap [ rr:column "UNITDISCHARGETIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :hospitalDischargeTime ; rr:objectMap [ rr:column "HOSPITALDISCHARGETIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :hospitalDischargeStatus ; rr:objectMap [ rr:column "HOSPITALDISCHARGESTATUS" ; rr:datatype xsd:string ] ] .

<#tm_eicu_3_eicu_lab> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT LABID, PATIENTUNITSTAYID, LABNAME, LABRESULT, LABRESULTTIME FROM LAB""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#lab/{LABID}" ; rr:class :LabEvent ] ;
  rr:predicateObjectMap [ rr:predicate :duringIcuStay ; rr:objectMap [ rr:template "http://example.org/eicu#icustay/{PATIENTUNITSTAYID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :labName ; rr:objectMap [ rr:column "LABNAME" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :labResult ; rr:objectMap [ rr:column "LABRESULT" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :labResultTime ; rr:objectMap [ rr:column "LABRESULTTIME" ; rr:datatype xsd:dateTime ] ] .

<#tm_eicu_4_eicu_vital> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT VITALPERIODICID, PATIENTUNITSTAYID, TEMPERATURE, SAO2, HEARTRATE, RESPIRATION, SYSTEMICSYSTOLIC, SYSTEMICDIASTOLIC, SYSTEMICMEAN, OBSERVATIONTIME FROM VITALPERIODIC""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#vital/{VITALPERIODICID}" ; rr:class :VitalSign ] ;
  rr:predicateObjectMap [ rr:predicate :duringIcuStay ; rr:objectMap [ rr:template "http://example.org/eicu#icustay/{PATIENTUNITSTAYID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :temperature ; rr:objectMap [ rr:column "TEMPERATURE" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :sao2 ; rr:objectMap [ rr:column "SAO2" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :heartRate ; rr:objectMap [ rr:column "HEARTRATE" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :respiration ; rr:objectMap [ rr:column "RESPIRATION" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :systolicBp ; rr:objectMap [ rr:column "SYSTEMICSYSTOLIC" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :diastolicBp ; rr:objectMap [ rr:column "SYSTEMICDIASTOLIC" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :meanBp ; rr:objectMap [ rr:column "SYSTEMICMEAN" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :observationTime ; rr:objectMap [ rr:column "OBSERVATIONTIME" ; rr:datatype xsd:dateTime ] ] .

<#tm_eicu_5_eicu_medication> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT MEDICATIONID, PATIENTUNITSTAYID, DRUGNAME, DOSAGE, ROUTEADMIN, DRUGSTARTTIME, DRUGSTOPTIME FROM MEDICATION""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#medication/{MEDICATIONID}" ; rr:class :Medication ] ;
  rr:predicateObjectMap [ rr:predicate :duringIcuStay ; rr:objectMap [ rr:template "http://example.org/eicu#icustay/{PATIENTUNITSTAYID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :drug ; rr:objectMap [ rr:column "DRUGNAME" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :dosage ; rr:objectMap [ rr:column "DOSAGE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :route ; rr:objectMap [ rr:column "ROUTEADMIN" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :drugStartTime ; rr:objectMap [ rr:column "DRUGSTARTTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :drugStopTime ; rr:objectMap [ rr:column "DRUGSTOPTIME" ; rr:datatype xsd:dateTime ] ] .

<#tm_eicu_6_eicu_diagnosis> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT DIAGNOSISID, PATIENTUNITSTAYID, DIAGNOSISNAME, ICD9CODE, DIAGNOSISTIME FROM DIAGNOSIS""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#diagnosis/{DIAGNOSISID}" ; rr:class :Diagnosis ] ;
