<#tm_eicu_9_eicu_intakeoutput> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT INTAKEOUTPUTID, PATIENTUNITSTAYID, CELLPATH, CELLLABEL, CELLVALUENUMERIC, INTAKEOUTPUTTIME FROM INTAKEOUTPUT""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#intakeoutput/{INTAKEOUTPUTID}" ; rr:class :IntakeOutput ] ;
