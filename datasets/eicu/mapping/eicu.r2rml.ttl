  rr:predicateObjectMap [ rr:predicate :cellPath ; rr:objectMap [ rr:column "CELLPATH" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :cellLabel ; rr:objectMap [ rr:column "CELLLABEL" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :cellValue ; rr:objectMap [ rr:column "CELLVALUENUMERIC" ; rr:datatype xsd:double ] ] ;
