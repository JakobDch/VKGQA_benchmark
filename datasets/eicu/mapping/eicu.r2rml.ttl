  rr:predicateObjectMap [ rr:predicate :diagnosisName ; rr:objectMap [ rr:column "DIAGNOSISNAME" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :icd9Code ; rr:objectMap [ rr:column "ICD9CODE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :diagnosisTime ; rr:objectMap [ rr:column "DIAGNOSISTIME" ; rr:datatype xsd:dateTime ] ] .

<#tm_eicu_7_eicu_treatment> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT TREATMENTID, PATIENTUNITSTAYID, TREATMENTNAME, TREATMENTTIME FROM TREATMENT""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#treatment/{TREATMENTID}" ; rr:class :Treatment ] ;
  rr:predicateObjectMap [ rr:predicate :duringIcuStay ; rr:objectMap [ rr:template "http://example.org/eicu#icustay/{PATIENTUNITSTAYID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :treatmentName ; rr:objectMap [ rr:column "TREATMENTNAME" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :treatmentTime ; rr:objectMap [ rr:column "TREATMENTTIME" ; rr:datatype xsd:dateTime ] ] .

<#tm_eicu_8_eicu_allergy> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT ALLERGYID, PATIENTUNITSTAYID, DRUGNAME, ALLERGYNAME, ALLERGYTIME FROM ALLERGY""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#allergy/{ALLERGYID}" ; rr:class :Allergy ] ;
