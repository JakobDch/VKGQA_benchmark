<#tm_eicu_10_eicu_microlab> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT MICROLABID, PATIENTUNITSTAYID, CULTURESITE, ORGANISM, CULTURETAKENTIME FROM MICROLAB""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#microlab/{MICROLABID}" ; rr:class :MicroLab ] ;
  rr:predicateObjectMap [ rr:predicate :duringIcuStay ; rr:objectMap [ rr:template "http://example.org/eicu#icustay/{PATIENTUNITSTAYID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :cultureSite ; rr:objectMap [ rr:column "CULTURESITE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :organism ; rr:objectMap [ rr:column "ORGANISM" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :cultureTakenTime ; rr:objectMap [ rr:column "CULTURETAKENTIME" ; rr:datatype xsd:dateTime ] ] .

<#tm_eicu_11_eicu_cost> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT COSTID, UNIQUEPID, PATIENTHEALTHSYSTEMSTAYID, EVENTTYPE, EVENTID, CHARGETIME, COST FROM COST""" ] ;
  rr:subjectMap [ rr:template "http://example.org/eicu#cost/{COSTID}" ; rr:class :CostEvent ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/eicu#patient/{UNIQUEPID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :ofHospitalStay ; rr:objectMap [ rr:template "http://example.org/eicu#hospitalstay/{PATIENTHEALTHSYSTEMSTAYID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :eventType ; rr:objectMap [ rr:column "EVENTTYPE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :billedEventId ; rr:objectMap [ rr:column "EVENTID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :chargeTime ; rr:objectMap [ rr:column "CHARGETIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :cost ; rr:objectMap [ rr:column "COST" ; rr:datatype xsd:double ] ] .

