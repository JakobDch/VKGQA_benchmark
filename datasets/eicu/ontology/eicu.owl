<?xml version="1.0" encoding="utf-8"?>
<!--
  eICU domain ontology (hand-modelled, not bootstrapped).
  Rationale: see ../MODELING.md. Column semantics from eicu.mit.edu (eICU-CRD docs),
  curated in ../glossary/columns.csv.
-->
<rdf:RDF
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
  xmlns="http://example.org/eicu#">

  <owl:Ontology rdf:about="http://example.org/eicu">
    <rdfs:label>eICU critical-care ontology</rdfs:label>
    <rdfs:comment>A domain ontology over the eICU Collaborative Research Database: patients, their hospital and ICU stays, and the labs, vital signs, medications, diagnoses, treatments and other events recorded during ICU care.</rdfs:comment>
  </owl:Ontology>

  <!-- Classes -->
  <owl:Class rdf:about="http://example.org/eicu#Patient">
    <rdfs:label>Patient</rdfs:label>
    <rdfs:comment>An individual patient, identified across all of their hospital and ICU stays.</rdfs:comment>
  </owl:Class>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#uniquePid">
    <rdfs:domain rdf:resource="http://example.org/eicu#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>unique patient id</rdfs:label>
    <rdfs:comment>The eICU uniquepid identifier of the patient.</rdfs:comment>
  </owl:DatatypeProperty>
  <owl:Class rdf:about="http://example.org/eicu#HospitalStay">
    <rdfs:label>Hospital stay</rdfs:label>
    <rdfs:comment>A hospital admission of a patient, which may contain one or more ICU stays.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/eicu#IcuStay">
    <rdfs:label>ICU stay</rdfs:label>
    <rdfs:comment>A single stay in an intensive care unit; the central unit of care in eICU.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/eicu#LabEvent">
    <rdfs:label>Laboratory event</rdfs:label>
    <rdfs:comment>A laboratory test measurement during an ICU stay.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/eicu#VitalSign">
    <rdfs:label>Vital sign</rdfs:label>
    <rdfs:comment>A periodic bedside vital-sign observation (5-minute median) during an ICU stay.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/eicu#Medication">
    <rdfs:label>Medication</rdfs:label>
    <rdfs:comment>An active medication order during an ICU stay.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/eicu#Diagnosis">
    <rdfs:label>Diagnosis</rdfs:label>
    <rdfs:comment>A diagnosis recorded during an ICU stay, with its ICD-9 code.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/eicu#Treatment">
    <rdfs:label>Treatment</rdfs:label>
    <rdfs:comment>A treatment administered during an ICU stay.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/eicu#Allergy">
    <rdfs:label>Allergy</rdfs:label>
    <rdfs:comment>An allergy recorded for a patient during an ICU stay.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/eicu#IntakeOutput">
    <rdfs:label>Intake/output</rdfs:label>
    <rdfs:comment>A fluid intake or output entry recorded during an ICU stay.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/eicu#MicroLab">
    <rdfs:label>Microbiology culture</rdfs:label>
    <rdfs:comment>A microbiology culture and its identified organism during an ICU stay.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://example.org/eicu#CostEvent">
    <rdfs:label>Cost event</rdfs:label>
    <rdfs:comment>A billed cost charged for an event during a hospital stay.</rdfs:comment>
  </owl:Class>

  <!-- Object properties -->
  <owl:ObjectProperty rdf:about="http://example.org/eicu#ofPatient">
    <rdfs:label>of patient</rdfs:label>
    <rdfs:comment>Relates a hospital stay (or cost) to the patient it concerns.</rdfs:comment>
    <rdfs:range rdf:resource="http://example.org/eicu#Patient"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/eicu#ofHospitalStay">
    <rdfs:label>of hospital stay</rdfs:label>
    <rdfs:comment>Relates an ICU stay (or cost) to the hospital stay it belongs to.</rdfs:comment>
    <rdfs:range rdf:resource="http://example.org/eicu#HospitalStay"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://example.org/eicu#duringIcuStay">
    <rdfs:label>during ICU stay</rdfs:label>
    <rdfs:comment>Relates a clinical event to the ICU stay during which it occurred.</rdfs:comment>
    <rdfs:range rdf:resource="http://example.org/eicu#IcuStay"/>
  </owl:ObjectProperty>

  <!-- IcuStay / patient datatype properties -->
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#gender"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>gender</rdfs:label><rdfs:comment>Reported gender of the patient.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#age"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>age</rdfs:label><rdfs:comment>Patient's age in years ('>89' for patients over 89).</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#ethnicity"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>ethnicity</rdfs:label><rdfs:comment>Ethnic background of the patient.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#hospitalId"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>hospital id</rdfs:label><rdfs:comment>Identifier of the hospital facility.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#wardId"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>ward id</rdfs:label><rdfs:comment>Identifier of the ward unit.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#admissionHeight"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/><rdfs:label>admission height</rdfs:label><rdfs:comment>Patient height in cm at admission.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#admissionWeight"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/><rdfs:label>admission weight</rdfs:label><rdfs:comment>Patient weight in kg upon ICU entry.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#dischargeWeight"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/><rdfs:label>discharge weight</rdfs:label><rdfs:comment>Patient weight in kg upon ICU discharge.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#hospitalAdmitTime"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>hospital admit time</rdfs:label><rdfs:comment>Time of admission to the hospital.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#hospitalAdmitSource"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>hospital admit source</rdfs:label><rdfs:comment>Origin location prior to hospital admission.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#unitAdmitTime"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>unit admit time</rdfs:label><rdfs:comment>Time of admission to the ICU unit.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#unitDischargeTime"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>unit discharge time</rdfs:label><rdfs:comment>Time of discharge from the ICU unit.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#hospitalDischargeTime"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>hospital discharge time</rdfs:label><rdfs:comment>Time of discharge from the hospital.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#hospitalDischargeStatus"><rdfs:domain rdf:resource="http://example.org/eicu#IcuStay"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>hospital discharge status</rdfs:label><rdfs:comment>Vital status of the patient at hospital discharge (Alive/Expired).</rdfs:comment></owl:DatatypeProperty>

  <!-- LabEvent -->
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#labName"><rdfs:domain rdf:resource="http://example.org/eicu#LabEvent"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>lab name</rdfs:label><rdfs:comment>Name of the laboratory test.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#labResult"><rdfs:domain rdf:resource="http://example.org/eicu#LabEvent"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/><rdfs:label>lab result</rdfs:label><rdfs:comment>Numeric value of the laboratory measurement.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#labResultTime"><rdfs:domain rdf:resource="http://example.org/eicu#LabEvent"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>lab result time</rdfs:label><rdfs:comment>Time at which the lab value was drawn.</rdfs:comment></owl:DatatypeProperty>

  <!-- VitalSign -->
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#temperature"><rdfs:domain rdf:resource="http://example.org/eicu#VitalSign"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/><rdfs:label>temperature</rdfs:label><rdfs:comment>Temperature in Celsius.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#sao2"><rdfs:domain rdf:resource="http://example.org/eicu#VitalSign"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>SaO2</rdfs:label><rdfs:comment>Oxygen saturation percentage.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#heartRate"><rdfs:domain rdf:resource="http://example.org/eicu#VitalSign"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>heart rate</rdfs:label><rdfs:comment>Heart rate in beats per minute.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#respiration"><rdfs:domain rdf:resource="http://example.org/eicu#VitalSign"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>respiration</rdfs:label><rdfs:comment>Respiratory rate in breaths per minute.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#systolicBp"><rdfs:domain rdf:resource="http://example.org/eicu#VitalSign"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>systolic blood pressure</rdfs:label><rdfs:comment>Systemic systolic blood pressure.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#diastolicBp"><rdfs:domain rdf:resource="http://example.org/eicu#VitalSign"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>diastolic blood pressure</rdfs:label><rdfs:comment>Systemic diastolic blood pressure.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#meanBp"><rdfs:domain rdf:resource="http://example.org/eicu#VitalSign"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>mean blood pressure</rdfs:label><rdfs:comment>Systemic mean blood pressure.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#observationTime"><rdfs:domain rdf:resource="http://example.org/eicu#VitalSign"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>observation time</rdfs:label><rdfs:comment>Time at which the vital signs were observed.</rdfs:comment></owl:DatatypeProperty>

  <!-- Medication -->
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#drug"><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>drug</rdfs:label><rdfs:comment>Name of the drug (medication order or allergy).</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#dosage"><rdfs:domain rdf:resource="http://example.org/eicu#Medication"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>dosage</rdfs:label><rdfs:comment>Dosage of the drug.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#route"><rdfs:domain rdf:resource="http://example.org/eicu#Medication"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>route</rdfs:label><rdfs:comment>Route of administration of the drug.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#drugStartTime"><rdfs:domain rdf:resource="http://example.org/eicu#Medication"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>drug start time</rdfs:label><rdfs:comment>Time the drug order was started.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#drugStopTime"><rdfs:domain rdf:resource="http://example.org/eicu#Medication"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>drug stop time</rdfs:label><rdfs:comment>Time the drug order was stopped.</rdfs:comment></owl:DatatypeProperty>

  <!-- Diagnosis -->
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#diagnosisName"><rdfs:domain rdf:resource="http://example.org/eicu#Diagnosis"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>diagnosis name</rdfs:label><rdfs:comment>Name/path of the diagnosis.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#icd9Code"><rdfs:domain rdf:resource="http://example.org/eicu#Diagnosis"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>ICD-9 code</rdfs:label><rdfs:comment>ICD-9 code for the diagnosis.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#diagnosisTime"><rdfs:domain rdf:resource="http://example.org/eicu#Diagnosis"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>diagnosis time</rdfs:label><rdfs:comment>Time at which the diagnosis was recorded.</rdfs:comment></owl:DatatypeProperty>

  <!-- Treatment -->
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#treatmentName"><rdfs:domain rdf:resource="http://example.org/eicu#Treatment"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>treatment name</rdfs:label><rdfs:comment>Name/path of the treatment.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#treatmentTime"><rdfs:domain rdf:resource="http://example.org/eicu#Treatment"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>treatment time</rdfs:label><rdfs:comment>Time at which the treatment was recorded.</rdfs:comment></owl:DatatypeProperty>

  <!-- Allergy -->
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#allergyName"><rdfs:domain rdf:resource="http://example.org/eicu#Allergy"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>allergy name</rdfs:label><rdfs:comment>Name of the allergy.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#allergyTime"><rdfs:domain rdf:resource="http://example.org/eicu#Allergy"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>allergy time</rdfs:label><rdfs:comment>Time the allergy was recorded.</rdfs:comment></owl:DatatypeProperty>

  <!-- IntakeOutput -->
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#cellLabel"><rdfs:domain rdf:resource="http://example.org/eicu#IntakeOutput"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>cell label</rdfs:label><rdfs:comment>Label of the intake/output entry.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#cellPath"><rdfs:domain rdf:resource="http://example.org/eicu#IntakeOutput"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>cell path</rdfs:label><rdfs:comment>Root path of the intake/output info.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#cellValue"><rdfs:domain rdf:resource="http://example.org/eicu#IntakeOutput"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/><rdfs:label>cell value</rdfs:label><rdfs:comment>Numeric value of the intake/output entry.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#intakeOutputTime"><rdfs:domain rdf:resource="http://example.org/eicu#IntakeOutput"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>intake/output time</rdfs:label><rdfs:comment>Time of the intake/output entry.</rdfs:comment></owl:DatatypeProperty>

  <!-- MicroLab -->
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#cultureSite"><rdfs:domain rdf:resource="http://example.org/eicu#MicroLab"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>culture site</rdfs:label><rdfs:comment>Site from which the culture was taken.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#organism"><rdfs:domain rdf:resource="http://example.org/eicu#MicroLab"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>organism</rdfs:label><rdfs:comment>Organism identified in the culture.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#cultureTakenTime"><rdfs:domain rdf:resource="http://example.org/eicu#MicroLab"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>culture taken time</rdfs:label><rdfs:comment>Time the culture was taken.</rdfs:comment></owl:DatatypeProperty>

  <!-- CostEvent -->
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#eventType"><rdfs:domain rdf:resource="http://example.org/eicu#CostEvent"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>event type</rdfs:label><rdfs:comment>Type of the billed event.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#cost"><rdfs:domain rdf:resource="http://example.org/eicu#CostEvent"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/><rdfs:label>cost</rdfs:label><rdfs:comment>Monetary cost charged for the event.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#chargeTime"><rdfs:domain rdf:resource="http://example.org/eicu#CostEvent"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/><rdfs:label>charge time</rdfs:label><rdfs:comment>Time at which the cost was charged.</rdfs:comment></owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://example.org/eicu#billedEventId"><rdfs:domain rdf:resource="http://example.org/eicu#CostEvent"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>billed event id</rdfs:label><rdfs:comment>Row identifier of the billed event in its source table.</rdfs:comment></owl:DatatypeProperty>

</rdf:RDF>
