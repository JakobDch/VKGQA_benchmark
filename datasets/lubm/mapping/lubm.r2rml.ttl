@prefix : <http://example.org/voc#> .
@prefix ex: <http://example.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_lubm_0_uni1_student> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni1\".\"student\"""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni1/student/{s_id}" ; rr:class :Student ] ;
  rr:predicateObjectMap [ rr:predicate foaf:firstName ; rr:objectMap [ rr:column "first_name" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate foaf:lastName ; rr:objectMap [ rr:column "last_name" ; rr:datatype xsd:string ] ] .

<#tm_lubm_1_uni1_academic> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni1\".\"academic\"""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni1/academic/{a_id}" ] ;
  rr:predicateObjectMap [ rr:predicate foaf:firstName ; rr:objectMap [ rr:column "first_name" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate foaf:lastName ; rr:objectMap [ rr:column "last_name" ; rr:datatype xsd:string ] ] .

<#tm_lubm_2_uni1_fullProfessor> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni1\".\"academic\" WHERE \"position\" = 1""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni1/academic/{a_id}" ; rr:class :FullProfessor ] .

<#tm_lubm_3_uni1_AssociateProfessor> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni1\".\"academic\" WHERE \"position\" = 2""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni1/academic/{a_id}" ; rr:class :AssociateProfessor ] .

<#tm_lubm_4_uni1_PostDoc> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni1\".\"academic\" WHERE \"position\" = 9""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni1/academic/{a_id}" ; rr:class :PostDoc ] .

<#tm_lubm_5_uni1_externalTeacher> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni1\".\"academic\" WHERE \"position\" = 8""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni1/academic/{a_id}" ; rr:class :ExternalTeacher ] .

<#tm_lubm_6_uni1_teaching> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni1\".\"teaching\"""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni1/academic/{a_id}" ] ;
  rr:predicateObjectMap [ rr:predicate :teaches ; rr:objectMap [ rr:template "http://example.org/uni1/course/{c_id}" ; rr:termType rr:IRI ] ] .

<#tm_lubm_7_uni1_course> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni1\".\"course\"""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni1/course/{c_id}" ; rr:class :Course ] ;
  rr:predicateObjectMap [ rr:predicate :title ; rr:objectMap [ rr:column "title" ] ] .

<#tm_lubm_8_uni2_person> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni2\".\"person\"""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni2/person/{pid}" ] ;
  rr:predicateObjectMap [ rr:predicate foaf:firstName ; rr:objectMap [ rr:column "fname" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate foaf:lastName ; rr:objectMap [ rr:column "lname" ; rr:datatype xsd:string ] ] .

<#tm_lubm_9_uni2_undergraduate> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni2\".\"person\" WHERE \"status\" = 1""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni2/person/{pid}" ; rr:class :UndergraduateStudent ] .

<#tm_lubm_10_uni2_graduate> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni2\".\"person\" WHERE \"status\" = 2""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni2/person/{pid}" ; rr:class :GraduateStudent ] .

<#tm_lubm_11_uni2_associate_prof> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni2\".\"person\" WHERE \"status\" = 8""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni2/person/{pid}" ; rr:class :AssociateProfessor ] .

<#tm_lubm_12_uni2_course> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni2\".\"course\"""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni2/course/{cid}" ; rr:class :Course ] ;
  rr:predicateObjectMap [ rr:predicate :title ; rr:objectMap [ rr:column "topic" ; rr:datatype xsd:string ] ] .

<#tm_lubm_13_uni2_lecturer> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni2\".\"course\"""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni2/person/{lecturer}" ] ;
  rr:predicateObjectMap [ rr:predicate :givesLecture ; rr:objectMap [ rr:template "http://example.org/uni2/course/{cid}" ; rr:termType rr:IRI ] ] .

<#tm_lubm_14_uni2_lab_teacher> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT * FROM \"uni2\".\"course\"""" ] ;
  rr:subjectMap [ rr:template "http://example.org/uni2/person/{lab_teacher}" ] ;
  rr:predicateObjectMap [ rr:predicate :givesLab ; rr:objectMap [ rr:template "http://example.org/uni2/course/{cid}" ; rr:termType rr:IRI ] ] .

