@prefix : <http://example.org/mimic#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .

<#tm_mimic_0_mimic_patient> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT SUBJECT_ID, GENDER, DOB, DOD FROM PATIENTS""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:class :Patient ] ;
  rr:predicateObjectMap [ rr:predicate :gender ; rr:objectMap [ rr:column "GENDER" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :dateOfBirth ; rr:objectMap [ rr:column "DOB" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :dateOfDeath ; rr:objectMap [ rr:column "DOD" ; rr:datatype xsd:dateTime ] ] .

<#tm_mimic_1_mimic_admission> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT SUBJECT_ID, HADM_ID, ADMITTIME, DISCHTIME, ADMISSION_TYPE, ADMISSION_LOCATION, DISCHARGE_LOCATION, INSURANCE, LANGUAGE, MARITAL_STATUS, ETHNICITY, AGE, EXTRACT(EPOCH FROM (TIMESTAMP '2105-12-31 23:59:00' - ADMITTIME))/86400.0 AS DAYS_SINCE, EXTRACT(EPOCH FROM (DISCHTIME - ADMITTIME))/86400.0 AS LOS_DAYS FROM ADMISSIONS""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:class :Admission ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :admissionTime ; rr:objectMap [ rr:column "ADMITTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :dischargeTime ; rr:objectMap [ rr:column "DISCHTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :admissionType ; rr:objectMap [ rr:column "ADMISSION_TYPE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :admissionLocation ; rr:objectMap [ rr:column "ADMISSION_LOCATION" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :dischargeLocation ; rr:objectMap [ rr:column "DISCHARGE_LOCATION" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :insurance ; rr:objectMap [ rr:column "INSURANCE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :language ; rr:objectMap [ rr:column "LANGUAGE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :maritalStatus ; rr:objectMap [ rr:column "MARITAL_STATUS" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :ethnicity ; rr:objectMap [ rr:column "ETHNICITY" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :age ; rr:objectMap [ rr:column "AGE" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :daysSinceAdmission ; rr:objectMap [ rr:column "DAYS_SINCE" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :lengthOfStayDays ; rr:objectMap [ rr:column "LOS_DAYS" ; rr:datatype xsd:double ] ] .

<#tm_mimic_2_mimic_icustay> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT SUBJECT_ID, HADM_ID, ICUSTAY_ID, FIRST_CAREUNIT, LAST_CAREUNIT, FIRST_WARDID, LAST_WARDID, INTIME, OUTTIME, EXTRACT(EPOCH FROM (TIMESTAMP '2105-12-31 23:59:00' - INTIME))/86400.0 AS DAYS_SINCE, EXTRACT(EPOCH FROM (OUTTIME - INTIME))/86400.0 AS LOS_DAYS FROM ICUSTAYS""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#icustay/{ICUSTAY_ID}" ; rr:class :IcuStay ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :firstCareUnit ; rr:objectMap [ rr:column "FIRST_CAREUNIT" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :lastCareUnit ; rr:objectMap [ rr:column "LAST_CAREUNIT" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :firstWardId ; rr:objectMap [ rr:column "FIRST_WARDID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :lastWardId ; rr:objectMap [ rr:column "LAST_WARDID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :icuInTime ; rr:objectMap [ rr:column "INTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :icuOutTime ; rr:objectMap [ rr:column "OUTTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :daysSinceIcuIn ; rr:objectMap [ rr:column "DAYS_SINCE" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :icuLengthOfStayDays ; rr:objectMap [ rr:column "LOS_DAYS" ; rr:datatype xsd:double ] ] .

<#tm_mimic_3_mimic_transfer> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT ROW_ID, SUBJECT_ID, HADM_ID, ICUSTAY_ID, EVENTTYPE, CAREUNIT, WARDID, INTIME, OUTTIME, EXTRACT(EPOCH FROM (TIMESTAMP '2105-12-31 23:59:00' - INTIME))/86400.0 AS DAYS_SINCE FROM TRANSFERS""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#transfer/{ROW_ID}" ; rr:class :Transfer ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringIcuStay ; rr:objectMap [ rr:template "http://example.org/mimic#icustay/{ICUSTAY_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :eventType ; rr:objectMap [ rr:column "EVENTTYPE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :careUnit ; rr:objectMap [ rr:column "CAREUNIT" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :wardId ; rr:objectMap [ rr:column "WARDID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :transferInTime ; rr:objectMap [ rr:column "INTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :transferOutTime ; rr:objectMap [ rr:column "OUTTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :daysSinceTransferIn ; rr:objectMap [ rr:column "DAYS_SINCE" ; rr:datatype xsd:double ] ] .

<#tm_mimic_4_mimic_chartevent> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT c.ROW_ID, c.SUBJECT_ID, c.HADM_ID, c.ICUSTAY_ID, c.ITEMID, d.LABEL, c.CHARTTIME, c.VALUENUM, c.VALUEUOM FROM CHARTEVENTS c JOIN D_ITEMS d ON c.ITEMID = d.ITEMID""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#chartevent/{ROW_ID}" ; rr:class :ChartEvent ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringIcuStay ; rr:objectMap [ rr:template "http://example.org/mimic#icustay/{ICUSTAY_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :measurementLabel ; rr:objectMap [ rr:column "LABEL" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :measurementItemId ; rr:objectMap [ rr:column "ITEMID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :chartTime ; rr:objectMap [ rr:column "CHARTTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :valueNumeric ; rr:objectMap [ rr:column "VALUENUM" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :valueUnit ; rr:objectMap [ rr:column "VALUEUOM" ; rr:datatype xsd:string ] ] .

<#tm_mimic_5_mimic_labevent> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT l.ROW_ID, l.SUBJECT_ID, l.HADM_ID, l.ITEMID, d.LABEL, l.CHARTTIME, EXTRACT(EPOCH FROM (TIMESTAMP '2105-12-31 23:59:00' - l.CHARTTIME))/86400.0 AS DAYS_SINCE, l.VALUENUM, l.VALUEUOM FROM LABEVENTS l JOIN D_LABITEMS d ON l.ITEMID = d.ITEMID""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#labevent/{ROW_ID}" ; rr:class :LabEvent ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :measurementLabel ; rr:objectMap [ rr:column "LABEL" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :measurementItemId ; rr:objectMap [ rr:column "ITEMID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :chartTime ; rr:objectMap [ rr:column "CHARTTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :daysSinceChart ; rr:objectMap [ rr:column "DAYS_SINCE" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :valueNumeric ; rr:objectMap [ rr:column "VALUENUM" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :valueUnit ; rr:objectMap [ rr:column "VALUEUOM" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :billedRowId ; rr:objectMap [ rr:column "ROW_ID" ; rr:datatype xsd:integer ] ] .

<#tm_mimic_6_mimic_inputevent> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT i.ROW_ID, i.SUBJECT_ID, i.HADM_ID, i.ICUSTAY_ID, i.ITEMID, d.LABEL, i.CHARTTIME, EXTRACT(EPOCH FROM (TIMESTAMP '2105-12-31 23:59:00' - i.CHARTTIME))/86400.0 AS DAYS_SINCE, i.AMOUNT FROM INPUTEVENTS_CV i JOIN D_ITEMS d ON i.ITEMID = d.ITEMID""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#inputevent/{ROW_ID}" ; rr:class :InputEvent ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringIcuStay ; rr:objectMap [ rr:template "http://example.org/mimic#icustay/{ICUSTAY_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :measurementLabel ; rr:objectMap [ rr:column "LABEL" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :measurementItemId ; rr:objectMap [ rr:column "ITEMID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :chartTime ; rr:objectMap [ rr:column "CHARTTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :daysSinceChart ; rr:objectMap [ rr:column "DAYS_SINCE" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :amount ; rr:objectMap [ rr:column "AMOUNT" ; rr:datatype xsd:double ] ] .

<#tm_mimic_7_mimic_outputevent> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT o.ROW_ID, o.SUBJECT_ID, o.HADM_ID, o.ICUSTAY_ID, o.ITEMID, d.LABEL, o.CHARTTIME, o.VALUE FROM OUTPUTEVENTS o JOIN D_ITEMS d ON o.ITEMID = d.ITEMID""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#outputevent/{ROW_ID}" ; rr:class :OutputEvent ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringIcuStay ; rr:objectMap [ rr:template "http://example.org/mimic#icustay/{ICUSTAY_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :measurementLabel ; rr:objectMap [ rr:column "LABEL" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :measurementItemId ; rr:objectMap [ rr:column "ITEMID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :chartTime ; rr:objectMap [ rr:column "CHARTTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :outputValue ; rr:objectMap [ rr:column "VALUE" ; rr:datatype xsd:double ] ] .

<#tm_mimic_8_mimic_microbiologyevent> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT ROW_ID, SUBJECT_ID, HADM_ID, CHARTTIME, SPEC_TYPE_DESC, ORG_NAME FROM MICROBIOLOGYEVENTS""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#microbiologyevent/{ROW_ID}" ; rr:class :MicrobiologyEvent ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :chartTime ; rr:objectMap [ rr:column "CHARTTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :specimenType ; rr:objectMap [ rr:column "SPEC_TYPE_DESC" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :organismName ; rr:objectMap [ rr:column "ORG_NAME" ; rr:datatype xsd:string ] ] .

<#tm_mimic_9_mimic_diagnosis> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT x.ROW_ID, x.SUBJECT_ID, x.HADM_ID, x.ICD9_CODE, d.SHORT_TITLE, d.LONG_TITLE, x.CHARTTIME, EXTRACT(EPOCH FROM (TIMESTAMP '2105-12-31 23:59:00' - x.CHARTTIME))/86400.0 AS DAYS_SINCE FROM DIAGNOSES_ICD x JOIN D_ICD_DIAGNOSES d ON x.ICD9_CODE = d.ICD9_CODE""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#diagnosis/{ROW_ID}" ; rr:class :Diagnosis ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :icd9Code ; rr:objectMap [ rr:column "ICD9_CODE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :shortTitle ; rr:objectMap [ rr:column "SHORT_TITLE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :longTitle ; rr:objectMap [ rr:column "LONG_TITLE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :recordedTime ; rr:objectMap [ rr:column "CHARTTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :daysSinceChart ; rr:objectMap [ rr:column "DAYS_SINCE" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :billedRowId ; rr:objectMap [ rr:column "ROW_ID" ; rr:datatype xsd:integer ] ] .

<#tm_mimic_10_mimic_procedure> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT x.ROW_ID, x.SUBJECT_ID, x.HADM_ID, x.ICD9_CODE, d.SHORT_TITLE, d.LONG_TITLE, x.CHARTTIME FROM PROCEDURES_ICD x JOIN D_ICD_PROCEDURES d ON x.ICD9_CODE = d.ICD9_CODE""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#procedure/{ROW_ID}" ; rr:class :Procedure ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :icd9Code ; rr:objectMap [ rr:column "ICD9_CODE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :shortTitle ; rr:objectMap [ rr:column "SHORT_TITLE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :longTitle ; rr:objectMap [ rr:column "LONG_TITLE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :recordedTime ; rr:objectMap [ rr:column "CHARTTIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :billedRowId ; rr:objectMap [ rr:column "ROW_ID" ; rr:datatype xsd:integer ] ] .

<#tm_mimic_11_mimic_prescription> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT ROW_ID, SUBJECT_ID, HADM_ID, DRUG, DOSE_VAL_RX, DOSE_UNIT_RX, ROUTE, STARTDATE, ENDDATE, EXTRACT(EPOCH FROM (TIMESTAMP '2105-12-31 23:59:00' - STARTDATE))/86400.0 AS DAYS_SINCE FROM PRESCRIPTIONS""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#prescription/{ROW_ID}" ; rr:class :Prescription ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :drug ; rr:objectMap [ rr:column "DRUG" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :doseValue ; rr:objectMap [ rr:column "DOSE_VAL_RX" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :doseUnit ; rr:objectMap [ rr:column "DOSE_UNIT_RX" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :route ; rr:objectMap [ rr:column "ROUTE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :startDate ; rr:objectMap [ rr:column "STARTDATE" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :endDate ; rr:objectMap [ rr:column "ENDDATE" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :daysSinceStart ; rr:objectMap [ rr:column "DAYS_SINCE" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate :billedRowId ; rr:objectMap [ rr:column "ROW_ID" ; rr:datatype xsd:integer ] ] .

<#tm_mimic_12_mimic_costevent> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT ROW_ID, SUBJECT_ID, HADM_ID, EVENT_TYPE, EVENT_ID, CHARGETIME, COST FROM COST""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#costevent/{ROW_ID}" ; rr:class :CostEvent ] ;
  rr:predicateObjectMap [ rr:predicate :ofPatient ; rr:objectMap [ rr:template "http://example.org/mimic#patient/{SUBJECT_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :duringAdmission ; rr:objectMap [ rr:template "http://example.org/mimic#admission/{HADM_ID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate :eventType ; rr:objectMap [ rr:column "EVENT_TYPE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :billedEventId ; rr:objectMap [ rr:column "EVENT_ID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate :chargeTime ; rr:objectMap [ rr:column "CHARGETIME" ; rr:datatype xsd:dateTime ] ] ;
  rr:predicateObjectMap [ rr:predicate :cost ; rr:objectMap [ rr:column "COST" ; rr:datatype xsd:double ] ] .

<#tm_mimic_13_mimic_drugrank> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT g.DRUG, dense_rank() OVER (ORDER BY g.cnt DESC) AS RNK FROM ( SELECT DRUG, COUNT(*) cnt FROM prescriptions GROUP BY DRUG ) g""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#drugrank/{DRUG}" ; rr:class :DrugRank ] ;
  rr:predicateObjectMap [ rr:predicate :rankedDrug ; rr:objectMap [ rr:column "DRUG" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :frequencyRank ; rr:objectMap [ rr:column "RNK" ; rr:datatype xsd:integer ] ] .

<#tm_mimic_14_mimic_diagnosisrank> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT g.ICD9_CODE, d.SHORT_TITLE, dense_rank() OVER (ORDER BY g.cnt DESC) AS RNK FROM ( SELECT ICD9_CODE, COUNT(*) cnt FROM diagnoses_icd GROUP BY ICD9_CODE ) g JOIN d_icd_diagnoses d ON g.ICD9_CODE = d.ICD9_CODE""" ] ;
  rr:subjectMap [ rr:template "http://example.org/mimic#diagnosisrank/{ICD9_CODE}" ; rr:class :DiagnosisCodeRank ] ;
  rr:predicateObjectMap [ rr:predicate :rankedShortTitle ; rr:objectMap [ rr:column "SHORT_TITLE" ; rr:datatype xsd:string ] ] ;
  rr:predicateObjectMap [ rr:predicate :frequencyRank ; rr:objectMap [ rr:column "RNK" ; rr:datatype xsd:integer ] ] .

