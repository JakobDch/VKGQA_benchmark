<#tm_mimic_17_mimic_microrank> a rr:TriplesMap ;
  rr:logicalTable [ rr:sqlQuery """SELECT g.SPEC_TYPE_DESC, dense_rank() OVER (ORDER BY g.cnt DESC) AS RNK FROM ( SELECT SPEC_TYPE_DESC, COUNT(*) cnt FROM microbiologyevents GROUP BY SPEC_TYPE_DESC ) g""" ] ;
