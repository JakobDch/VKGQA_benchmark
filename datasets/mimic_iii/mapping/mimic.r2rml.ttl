  rr:logicalTable [ rr:sqlQuery """SELECT g.ICD9_CODE, d.SHORT_TITLE, dense_rank() OVER (ORDER BY g.cnt DESC) AS RNK FROM ( SELECT ICD9_CODE, COUNT(*) cnt FROM procedures_icd GROUP BY ICD9_CODE ) g JOIN d_icd_procedures d ON g.ICD9_CODE = d.ICD9_CODE""" ] ;
