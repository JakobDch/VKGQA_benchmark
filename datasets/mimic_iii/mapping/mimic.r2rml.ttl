  rr:logicalTable [ rr:sqlQuery """SELECT g.ITEMID, d.LABEL, dense_rank() OVER (ORDER BY g.cnt DESC) AS RNK FROM ( SELECT ITEMID, COUNT(*) cnt FROM labevents GROUP BY ITEMID ) g JOIN d_labitems d ON g.ITEMID = d.ITEMID""" ] ;
